[42.69358, "i", "cat > /app/parallel_linear.py << 'EOF'\nimport torch\nimport torch.nn as nn\nimport torch.distributed as dist\n\nclass ColumnParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        \n        # Get distributed info\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n        \n        # out_features should be divisible by world_size\n        out_features_per_rank = out_features // world_size\n        \n        # Split master_weight along out_features dimension\n        # master_weight shape: (out_features, in_features)\n        weight_shard = master_weight[rank * out_features_per_rank:(rank + 1) * out_features_per_rank, :]\n        self.register_buffer('weight', weight_shard)\n        \n        # Initialize bias - sharded in same way as output dimension\n        if self.use_bias:\n            bias_shard = torch.zeros(out_features_per_rank, device=master_weight.device, dtype=master_weight.dtype)\n            self.register_buffer('bias', bias_shard)\n        else:\n            self.bias = None\n    \n    def forward(self, x):\n        # x shape: (batch, in_features)\n        # weight shape: (out_features_per_rank, in_features)\n        # output shape: (batch, out_features_per_rank)\n        out = torch.nn.functional.linear(x, self.weight, self.bias)\n        return out\n\n\nclass RowParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        \n        # Get distributed info\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n        \n        # in_features should be divisible by world_size\n        in_features_per_rank = in_features // world_size\n        \n        # Split master_weight along in_features dimension\n        # master_weight shape: (out_features, in_features)\n        weight_shard = master_weight[:, rank * in_features_per_rank:(rank + 1) * in_features_per_rank]\n        self.register_buffer('weight', weight_shard)\n        \n        # Initialize bias - full on each rank\n        if self.use_bias:\n            bias_full = torch.zeros(out_features, device=master_weight.device, dtype=master_weight.dtype)\n            self.register_buffer('bias', bias_full)\n        else:\n            self.bias = None\n    \n    def forward(self, x):\n        # x shape: (batch, in_features_per_rank) - already scattered input\n        # weight shape: (out_features, in_features_per_rank)\n        # output shape: (batch, out_features)\n        out = torch.nn.functional.linear(x, self.weight, self.bias)\n        # Sum partial outputs across all ranks\n        dist.all_reduce(out, op=dist.ReduceOp.SUM)\n        return out\nEOF\n"]
