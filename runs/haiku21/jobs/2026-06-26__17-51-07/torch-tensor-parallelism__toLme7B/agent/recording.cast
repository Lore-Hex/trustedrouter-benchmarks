[43.315807, "o", "import torch\r\nimport torch.nn as nn\r\nimport torch.distributed as dist\r\n\r\nclass ColumnParallelLinear(nn.Module):\r\n    def __init__(self, in_features, out_features, bias, master_weight):\r\n        super().__init__()\r\n        self.in_features = in_features\r\n        self.out_features = out_features\r\n        self.use_bias = bias\r\n        \r\n        # Get distributed info\r\n        world_size = dist.get_world_size()\r\n        rank = dist.get_rank()\r\n        \r\n        # out_features should be divisible by world_size\r\n        out_features_per_rank = out_features // world_size\r\n        \r\n        # Split master_weight along out_features dimension\r\n        # master_weight shape: (out_features, in_features)\r\n"]
[43.316709, "o", "\u001b[?2004h"]
