Sending keys: ['cat > /app/compress.py << \'EOF\'\n#!/usr/bin/env python3\nimport sys\n\nclass ArithmeticEncoder:\n    def __init__(self):\n        self.range = 1\n        self.fraction = 0\n        self.radix = 255\n        self.output_bytes = []\n        self.cc = {}  # context -> [count0, count1]\n        \n    def get_context_counts(self, ctx):\n        if ctx not in self.cc:\n            self.cc[ctx] = [0, 0]\n        return self.cc[ctx]\n    \n    def put_bit(self, bit, ctx):\n        counts = self.get_context_counts(ctx)\n        split = self.range * (-~counts[0]) // (counts[0] + counts[1] + 2)\n        \n        if bit:\n            self.fraction += split\n            self.range -= split\n            counts[1] += 1\n        else:\n            self.range = split\n            counts[0] += 1\n        \n        while self.range < self.radix:\n            self.range *= self.radix\n            self.fraction *= self.radix\n            byte_val = (self.fraction // (self.range // self.radix)) + 1\n            if byte_val > 255:\n                byte_val = 255\n            self.output_bytes.append(byte_val)\n            self.fraction = self.fraction % (self.range // self.radix)\n    \n    def put_integer(self, value, bits, ctx):\n        subtract_it = 1 << bits\n        value += subtract_it\n        \n        ctx *= 99\n        tmp = bits\n        while True:\n            has_more = 1 if value >= (1 << (tmp + 1)) else 0\n            self.put_bit(has_more, tmp + ctx)\n            if not has_more:\n                break\n            tmp += 1\n        \n        tmp -= 1\n        for i in range(tmp):\n            bit = (value >> (tmp - 1 - i)) & 1\n            self.put_bit(bit, ctx)\n    \n    def get_output(self):\n        return bytes(self.output_bytes)\n\nwith open(\'/app/data.txt\', \'rb\') as f:\n    data = f.read()\n\nencoder = ArithmeticEncoder()\nencoder.put_integer(len(data), 9, 0)\n\nfor byte_val in data:\n    encoder.put_bit(0, 1)\n    if byte_val < 128:\n        encoder.put_bit(0, 8)\n        encoder.put_integer(byte_val, 4, 9)\n    else:\n        encoder.put_bit(1, 8)\n        encoder.put_integer(256 - byte_val, 4, 9)\n\noutput = encoder.get_output()\nwith open(\'/app/data.comp\', \'wb\') as f:\n    f.write(output)\n\nprint(f"Compressed {len(data)} bytes to {len(output)} bytes")\nEOF\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
