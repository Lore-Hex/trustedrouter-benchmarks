es // world_size\n        \n        # Split master_weight along in_features dimension\n        # master_weight shape: (out_features, in_features)\n        weight_shard = master_weight[:, rank * in_features_per_rank:(rank + 1) * in_features_per_rank]\n        self.register_buffer('weight', weight_shard)\n        \n        # Initialize bias - full on each rank\n        if self.use_bias:\n            bias_full = torch.zeros(out_features, device=master_weight.device, dtype=master_weight.dtype)\n            self.register_buffer('bias', bias_full)\n        else:\n            self.bias = None\n    \n    def forward(self, x):\n        # x shape: (batch, in_features_per_rank) - already scattered input\n        # weight shape: (out_features, in_features_per_rank)\n        # output shape: (batch, out_features)\n        out = torch.nn.functional.linear(x, self.weight, self.bias)\n        # Sum partial outputs across all ranks\n        dist.all_reduce(out, op=dist.ReduceOp.SUM)\n        return out\nEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
