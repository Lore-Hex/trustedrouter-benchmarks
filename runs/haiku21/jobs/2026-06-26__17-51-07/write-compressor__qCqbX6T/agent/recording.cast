[263.687522, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         counts[1]++;\r\n\u001b[?2004l\r"]
[263.687536, "o", "\u001b[?2004h"]
[263.6876, "o", ">     } else {"]
[263.687726, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[263.68774, "o", "        high = split;"]
[263.687857, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         counts[0]++;"]
[263.687893, "o", "\r\n"]
[263.687931, "o", "\u001b[?2004l\r"]
[263.688006, "o", "\u001b[?2004h"]
[263.688063, "o", ">     }\r\n"]
[263.688107, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[263.68976, "o", "    \r\n"]
[263.68979, "o", "\u001b[?2004l\r\u001b[?2004h>     while (high - low < radix) {\r\n\u001b[?2004l\r\u001b[?2004h>         high = high * radix;\r\n\u001b[?2004l\r\u001b[?2004h>         low = low * radix;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void put_integer(int value, int bits, int ctx) {\r\n\u001b[?2004l\r\u001b[?2004h>     int subtract_it = 1 << bits;\r\n\u001b[?2004l\r\u001b[?2004h>     value += subtract_it;\r\n\u001b[?2004l\r\u001b[?2004h>     ctx *= 99;\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     int tmp = bits;\r\n\u001b[?2004l\r\u001b[?2004h>     while (value >= (1 << (tmp + 1))) {\r\n\u001b[?2004l\r\u001b[?2004h>         put_bit(1, tmp + ctx);\r\n\u001b[?2004l\r\u001b[?2004h>         tmp++;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     put_bit(0, tmp + ctx);\r\n\u001b[?2004l\r\u001b[?2004h>     tmp--;\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < tmp; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         int bit = (value >> (tmp - 1 - i)) & 1;\r\n\u001b[?2004l\r\u001b[?2004h>         put_bit(bit, ctx);\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> void flush_output() {\r\n\u001b[?2004l\r\u001b[?2004h>     while (high > 1 || low > 0) {\r\n\u001b[?2004l\r\u001b[?2004h>         int byte = (low / (1LL << 32)) % 256;\r\n\u001b[?2004l\r\u001b[?2004h>         putchar(byte + 1);\r\n\u001b[?2004l\r\u001b[?2004h>         low = (low % (1LL << 32)) * radix;\r\n\u001b[?2004l\r\u001b[?2004h>         high = (high % (1LL << 32)) * radix;\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> int main() {\r\n\u001b[?2004l\r\u001b[?2004h>     char buf[10000];\r\n\u001b[?2004l\r\u001b[?2004h>     int len = fread(buf, 1, 10000, stdin);\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     put_integer(len, 9, 0);\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for (int i = 0; i < len; i++) {\r\n\u001b[?2004l\r\u001b[?2004h>         unsigned char c = buf[i];\r\n\u001b[?2004l\r\u001b[?2004h>         put_bit(0, 1);\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if (c < 128) {\r\n\u001b[?2004l\r\u001b[?2004h>             put_bit(0, 8);\r\n\u001b[?2004l\r\u001b[?2004h>             put_integer(c, 4, 9);\r\n\u001b[?2004l\r\u001b[?2004h>         } else {\r\n\u001b[?2004l\r\u001b[?2004h>             put_bit(1, 8);\r\n\u001b[?2004l\r\u001b[?2004h>             put_integer(256 - c, 4, 9);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     flush_output();\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
