[263.684627, "i", "cat > /app/comp.c << 'EOF'\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n\nint radix = 255;\nlong low = 0, high = 1;\nlong pending_bits = 0;\nint cc[1000000];\n\nvoid put_bit(int bit, int ctx) {\n    int *counts = cc + ctx * 2;\n    long range = high - low;\n    long split = low + range * (-~counts[0]) / (counts[0] + counts[1] + 2);\n    \n    if (bit) {\n        low = split;\n        counts[1]++;\n    } else {\n        high = split;\n        counts[0]++;\n    }\n    \n    while (high - low < radix) {\n        high = high * radix;\n        low = low * radix;\n    }\n}\n\nvoid put_integer(int value, int bits, int ctx) {\n    int subtract_it = 1 << bits;\n    value += subtract_it;\n    ctx *= 99;\n    \n    int tmp = bits;\n    while (value >= (1 << (tmp + 1))) {\n        put_bit(1, tmp + ctx);\n        tmp++;\n    }\n    put_bit(0, tmp + ctx);\n    tmp--;\n    \n    for (int i = 0; i < tmp; i++) {\n        int bit = (value >> (tmp - 1 - i)) & 1;\n        put_bit(bit, ctx);\n    }\n}\n\nvoid flush_output() {\n    while (high > 1 || low > 0) {\n        int byte = (low / (1LL << 32)) % 256;\n        putchar(byte + 1);\n        low = (low % (1LL << 32)) * radix;\n        high = (high % (1LL << 32)) * radix;\n    }\n}\n\nint main() {\n    char buf[10000];\n    int len = fread(buf, 1, 10000, stdin);\n    \n    put_integer(len, 9, 0);\n    \n    for (int i = 0; i < len; i++) {\n        unsigned char c = buf[i];\n        put_bit(0, 1);\n        \n        if (c < 128) {\n            put_bit(0, 8);\n            put_integer(c, 4, 9);\n        } else {\n            put_bit(1, 8);\n            put_integer(256 - c, 4, 9);\n        }\n    }\n    \n    flush_output();\n    return 0;\n}\nEOF\n"]
