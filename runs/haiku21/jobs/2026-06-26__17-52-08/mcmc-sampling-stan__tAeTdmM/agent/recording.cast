[607.254673, "i", "cat > /app/analysis.R << 'EOF'\nlibrary(rstan)\n\nset.seed(1)\n\ndata_df <- read.csv('/app/data.csv')\ny <- data_df$y\nn <- data_df$n\nN <- length(y)\n\nstan_data <- list(\n  N = N,\n  y = y,\n  n = n\n)\n\nfit <- stan(\n  file = '/app/hierarchical_model.stan',\n  data = stan_data,\n  chains = 4,\n  iter = 100000,\n  seed = 1,\n  verbose = FALSE\n)\n\nsamples <- extract(fit)\nalpha_samples <- samples$alpha\nbeta_samples <- samples$beta\n\nalpha_mean <- mean(alpha_samples)\nbeta_mean <- mean(beta_samples)\n\nwrite.table(alpha_mean, file = '/app/posterior_alpha_mean.txt', row.names = FALSE, col.names = FALSE)\nwrite.table(beta_mean, file = '/app/posterior_beta_mean.txt', row.names = FALSE, col.names = FALSE)\n\ncat('Posterior mean of alpha:', alpha_mean, '\\n')\ncat('Posterior mean of beta:', beta_mean, '\\n')\nEOF\n"]
