[606.920432, "i", "cat > /app/hierarchical_model.stan << 'EOF'\ndata {\n  int<lower=0> N;\n  array[N] int<lower=0> y;\n  array[N] int<lower=1> n;\n}\n\nparameters {\n  real<lower=0> alpha;\n  real<lower=0> beta;\n  array[N] real<lower=0, upper=1> theta;\n}\n\nmodel {\n  // Prior for alpha and beta: proportional to (alpha + beta)^(-5/2)\n  target += -2.5 * log(alpha + beta);\n\n  // Likelihood\n  for (i in 1:N) {\n    theta[i] ~ beta(alpha, beta);\n    y[i] ~ binomial(n[i], theta[i]);\n  }\n}\nEOF\n"]
[606.921226, "o", "cat > /app/hierarchical_model.stan << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h"]
