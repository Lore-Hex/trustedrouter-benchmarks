[606.923905, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>   target += -2.5 * log(alpha + beta);\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>   // Likelihood\r\n\u001b[?2004l\r\u001b[?2004h>   for (i in 1:N) {\r\n\u001b[?2004l\r\u001b[?2004h>     theta[i] ~ beta(alpha, beta);\r\n\u001b[?2004l\r\u001b[?2004h>     y[i] ~ binomial(n[i], theta[i]);\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
