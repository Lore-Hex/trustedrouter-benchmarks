Sending keys: ['cat > /app/parallel_linear.py << \'EOF\'\nimport torch\nimport torch.nn as nn\nfrom torch.distributed import get_world_size, get_rank\nimport torch.distributed\n\n\nclass ColumnParallelLinear(nn.Module):\n    """Column-parallel linear layer.\n    \n    Splits the weight matrix by rows (output dimension).\n    Each rank computes a subset of output features.\n    Outputs from all ranks are concatenated via all_gather.\n    """\n    \n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        \n        # Get distributed training info\n        self.world_size = get_world_size()\n        self.rank = get_rank()\n        \n        # Each rank gets a portion of output features\n        assert out_features % self.world_size == 0\n        self.out_features_local = out_features // self.world_size\n        \n        # Split weight matrix along output dimension (rows)\n        # master_weight shape: (out_features, in_features)\n        start_idx = self.rank * self.out_features_local\n        end_idx = start_idx + self.out_features_local\n        weight_local = master_weight[start_idx:end_idx, :].clone().detach()\n        \n        self.weight = nn.Parameter(weight_local)\n        \n        # Bias is sharded along output dimension (same as output)\n        if bias:\n            bias_local = torch.zeros(self.out_features_local, dtype=master_weight.dtype, device=master_weight.device)\n            self.bias = nn.Parameter(bias_local)\n        else:\n            self.register_parameter(\'bias\', None)\n    \n    def forward(self, x):\n        """Forward pass for column-parallel linear layer.\n        \n        Args:\n            x: input tensor of shape (batch_size, in_features)\n        \n        Returns:\n            output tensor of shape (batch_size, out_features)\n        """\n        # Compute local output\n        y_local = torch.nn.functional.linear(x, self.weight, self.bias)\n        # y_local shape: (batch_size, out_features_local)\n        \n        # All-gather to concatenate outputs from all ranks\n        if self.world_size > 1:\n            # Gather outputs from all ranks\n            y_list = [torch.empty_like(y_local) for _ in range(self.world_size)]\n            torch.distributed.all_gather(y_list, y_local)\n            # Concatenate along feature dimension\n            y = torch.cat(y_list, dim=-1)\n        else:\n            y = y_local\n        \n        return y\n\n\nclass RowParallelLinear(nn.Module):\n    """Row-parallel linear layer.\n    \n    Splits the weight matrix by columns (input dimension).\n    Each rank receives a scattered slice of the input.\n    Partial outputs are summed via all_reduce.\n    """\n    \n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        \n        # Get distributed training info\n        self.world_size = get_world_size()\n        self.rank = get_rank()\n        \n        # Each rank gets a portion of input features\n        assert in_features % self.world_size == 0\n        self.in_features_local = in_features // self.world_size\n        \n        # Split weight matrix along input dimension (columns)\n        # master_weight shape: (out_features, in_features)\n        start_idx = self.rank * self.in_features_local\n        end_idx = start_idx + self.in_features_local\n        weight_local = master_weight[:, start_idx:end_idx].clone().detach()\n        \n        self.weight = nn.Parameter(weight_local)\n        \n        # Bias is full on each rank (not sharded)\n        if bias:\n            bias_full = torch.zeros(out_features, dtype=master_weight.dtype, device=master_weight.device)\n            self.bias = nn.Parameter(bias_full)\n        else:\n            self.register_parameter(\'bias\', None)\n    \n    def forward(self, x):\n        """Forward pass for row-parallel linear layer.\n        \n        Args:\n            x: scattered input tensor of shape (batch_size, in_features_local)\n        \n        Returns:\n            output tensor of shape (batch_size, out_features)\n        """\n        # Compute partial output using local input and weight\n        y_partial = torch.nn.functional.linear(x, self.weight, None)\n        # y_partial shape: (batch_size, out_features)\n        \n        # All-reduce to sum partial outputs from all ranks\n        if self.world_size > 1:\n            torch.distributed.all_reduce(y_partial)\n        \n        # Add bias (same on all ranks)\n        if self.bias is not None:\n            y_partial = y_partial + self.bias\n        \n        return y_partial\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
