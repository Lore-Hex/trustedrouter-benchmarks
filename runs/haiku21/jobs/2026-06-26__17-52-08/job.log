rintf(f, "%d %d %d\\n", r, g, b);\n        }\n    }\n    \n    fclose(f);\n    printf("Rendering complete\\n");\n    printf("Wrote image to image.ppm\\n");\n    printf("Done.\\n");\n    return 0;\n}\nSPHERECODE\n'] min_timeout_sec: 0.2 max_timeout_sec: 180.0
