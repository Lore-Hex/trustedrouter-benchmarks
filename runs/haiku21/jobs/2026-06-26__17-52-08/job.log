 abs(gc_content_of_codon(best_codon) - target_gc)\n    for codon in codons[1:]:\n        gc = gc_content_of_codon(codon)\n        diff = abs(gc - target_gc)\n        if diff < best_diff:\n            best_codon = codon\n            best_diff = diff\n    return best_codon\n\ndef translate_to_dna_with_gc_balance(protein_seq):\n    dna = ""\n    gc_history = []\n    for aa in protein_seq:\n        codon = pick_best_codon(aa, gc_history)\n        dna += codon\n        gc = gc_content_of_codon(codon)\n        gc_history.append(gc)\n    return dna\n\ndef check_gc_content(dna_seq, window=50):\n    if len(dna_seq) < window:\n        window = len(dna_seq)\n    violations = []\n    for i in range(len(dna_seq) - window + 1):\n        gc = gc_fraction(Seq(dna_seq[i:i+window]))\n        if gc < 0.3 or gc > 0.7:\n            violations.append((i, gc))\n    return len(violations) == 0, violations\n\nprint("Loading sequences...")\ndhfr_seq = None\nwith open(\'/app/plasmid.gb\', \'r\') as f:\n    content = f.read()\n    match = re.search(r\'/product="dihydrofolate reductase \\(DHFR\\)".*?/translation="([^"]+)"\', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace(\'\\n\', \'\').replace(\' \', \'\')\n        if dhfr_seq.startswith(\'M\'):\n            dhfr_seq = dhfr_seq[1:]\n        print(f"DHFR: {len(dhfr_seq)} aa")\n\nantibody_seqs = {}\nwith open(\'/app/antibody.fasta\', \'r\') as f:\n    for record in SeqIO.parse(f, \'fasta\'):\n        seq = str(record.seq)\n        if seq.startswith(\'M\'):\n            seq = seq[1:]\n        antibody_seqs[record.id] = seq\n\nantibody_binder = antibody_seqs.get(\'heavy\', \'\')\nif not antibody_binder:\n    for key in antibody_seqs:\n        if \'heavy\' in key.lower():\n            antibody_binder = antibody_seqs[key]\n            break\nprint(f"Antibody binder: {len(antibody_binder)} aa")\n\npdb_ids = []\nwith open(\'/app/pdb_ids.txt\', \'r\') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n\npdb_sequences = {}\nfor pdb_id in pdb_ids:\n    seq = get_pdb_sequence(pdb_id)\n    if seq:\n        if seq.startswith(\'M\'):\n            seq = seq[1:]\n        pdb_sequences[pdb_id] = seq\n\nprint(f"PDB sequences retrieved: {len(pdb_sequences)}/20")\n\n# Use GFP (smaller than YFP) for donor to fit within size constraint\ndonor_id = \'2VZX\'  # Green Fluorescent Protein (~488nm excitation, close to 505nm)\nacceptor_id = \'4CQH\'  # mCherry variant (~610nm emission, perfect match)\nmolecule_binder_id = \'2CHA\'  # Small protein (13 aa)\n\ndonor_seq = pdb_sequences[donor_id]\nacceptor_seq = pdb_sequences[acceptor_id]\nmolecule_binder_seq = pdb_sequences[molecule_binder_id]\n\nprint(f"\\nProtein selection for FRET:")\nprint(f"  Antibody binder: {len(antibody_binder)} aa")\nprint(f"  Donor (2VZX - Green Fluorescent Protein): {len(donor_seq)} aa (~488nm ex)")\nprint(f"  DHFR: {len(dhfr_seq)} aa")\nprint(f"  Acceptor (4CQH - mCherry variant): {len(acceptor_seq)} aa (~610nm em)")\nprint(f"  Molecule binder (2CHA - chymotrypsin): {len(molecule_binder_seq)} aa")\n\nlinker_seq = \'GSGSG\'  # 5 aa GS linker\nfusion_protein = (\n    antibody_binder +\n    linker_seq +\n    donor_seq +\n    linker_seq +\n    dhfr_seq +\n    linker_seq +\n    acceptor_seq +\n    linker_seq +\n    molecule_binder_seq\n)\n\nfusion_size_aa = len(fusion_protein)\nfusion_size_nt = fusion_size_aa * 3\nprint(f"\\nFusion protein: {fusion_size_aa} aa = {fusion_size_nt} nt")\n\nif fusion_size_nt > 3000:\n    print(f"ERROR: {fusion_size_nt} nt exceeds 3000 nt limit")\nelse:\n    print(f"Size check: PASS (under 3000 nt limit)")\n    \n    print("\\nConverting to DNA with GC balancing...")\n    dna_gblock = translate_to_dna_with_gc_balance(fusion_protein)\n    print(f"DNA length: {len(dna_gblock)} nt")\n    \n    print("\\nValidating GC content...")\n    gc_ok, violations = check_gc_content(dna_gblock, window=50)\n    if gc_ok:\n        print("GC content: PASS")\n    else:\n        print(f"GC content: FAIL ({len(violations)} violations)")\n    \n    if gc_ok:\n        print("\\nWriting /app/gblock.txt...")\n        with open(\'/app/gblock.txt\', \'w\') as f:\n            f.write(dna_gblock)\n        \n        with open(\'/app/gblock.txt\', \'r\') as f:\n            written = f.read()\n        \n        if written == dna_gblock:\n            print(f"SUCCESS: {len(written)} nt written with proper FRET pair")\n            print(f"\\nFinal gBlock summary:")\n            print(f"  File: /app/gblock.txt")\n            print(f"  Size: {len(written)} nucleotides")\n            print(f"  Structure: Antibody-GS-GFP-GS-DHFR-GS-mCherry-GS-Chymotrypsin")\n            print(f"  FRET pair: GFP (488nm excitation) -> mCherry (610nm emission)")\n            print(f"  GC content: Valid (30-70% per 50nt window)")\n        else:\n            print(f"ERROR: File mismatch")\n    else:\n        print("NOT writing - GC content validation failed")\nPYEOF\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
