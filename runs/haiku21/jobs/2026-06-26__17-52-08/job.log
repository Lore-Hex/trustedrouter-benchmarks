Sending keys: ['cat > /app/pipeline_parallel.py << \'EOF\'\nimport torch\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\ndef train_step_pipeline_afab(model, inputs, targets, device, dtype):\n    """\n    Pipeline parallel training with all-forward-all-backward (AFAB) scheduling.\n    \n    Args:\n        model: LlamaForCausalLM instance\n        inputs: list of microbatches of input IDs (each a tensor)\n        targets: list of corresponding microbatches of target IDs\n        device: torch device\n        dtype: torch dtype\n    """\n    rank = dist.get_rank()\n    world_size = dist.get_world_size()\n    num_microbatches = len(inputs)\n    \n    # ===== MODEL LAYER PARTITIONING =====\n    # Get all transformer layers and distribute them across ranks\n    all_layers = list(model.model.layers)\n    num_total_layers = len(all_layers)\n    \n    # Calculate balanced layer distribution\n    layers_per_rank = num_total_layers // world_size\n    remainder_layers = num_total_layers % world_size\n    \n    # Determine which layers this rank is responsible for\n    layer_start_idx = 0\n    for r in range(rank):\n        layer_start_idx += layers_per_rank + (1 if r < remainder_layers else 0)\n    \n    num_layers_this_rank = layers_per_rank + (1 if rank < remainder_layers else 0)\n    layer_end_idx = layer_start_idx + num_layers_this_rank\n    \n    my_layers = all_layers[layer_start_idx:layer_end_idx]\n    \n    # Move assigned layers to the specified device and dtype\n    for layer in my_layers:\n        layer.to(device=device, dtype=dtype)\n    \n    # Move rank-specific model components to device\n    if rank == 0:\n        model.model.embed_tokens.to(device=device, dtype=dtype)\n    \n    if rank == world_size - 1:\n        model.model.norm.to(device=device, dtype=dtype)\n        model.lm_head.to(device=device, dtype=dtype)\n    \n    # ===== FORWARD PASS: AFAB - ALL FORWARD =====\n    # Store inputs to this rank (for gradient computation in backward)\n    rank_inputs = {}\n    total_loss = None\n    \n    for mb_idx in range(num_microbatches):\n        # Get input IDs and target IDs, move to device\n        input_ids = inputs[mb_idx].to(device=device, dtype=torch.long)\n        target_ids = targets[mb_idx].to(device=device, dtype=torch.long)\n        \n        # Get hidden state for this stage\n        if rank == 0:\n            # First rank: embed the input tokens\n            hidden_state = model.model.embed_tokens(input_ids)\n            hidden_state = hidden_state.to(dtype=dtype)\n        else:\n            # Other ranks: receive hidden states from previous rank\n            hidden_state = torch.zeros(\n                input_ids.shape[0],\n                input_ids.shape[1],\n                model.config.hidden_size,\n                device=device,\n                dtype=dtype,\n                requires_grad=True\n            )\n            dist.recv(hidden_state, src=rank - 1)\n        \n        # Save input to this rank for backward pass\n        rank_inputs[mb_idx] = hidden_state\n        \n        # Forward pass through assigned layers\n        for layer in my_layers:\n            layer_output = layer(hidden_state, attention_mask=None)\n            hidden_state = layer_output[0]\n        \n        # Send or finalize\n        if rank < world_size - 1:\n            # Send hidden state to next rank (detached to avoid circular grad computation)\n            dist.send(hidden_state.detach().clone(), dst=rank + 1)\n        else:\n            # Last rank: compute loss\n            # Apply final layer norm and LM head\n            normalized_hidden = model.model.norm(hidden_state)\n            logits = model.lm_head(normalized_hidden)\n            \n            # Compute cross-entropy loss, scaled by number of microbatches\n            microbatch_loss = F.cross_entropy(\n                logits.view(-1, model.config.vocab_size),\n                target_ids.view(-1),\n                reduction=\'sum\'\n            ) / num_microbatches\n            \n            # Accumulate loss\n            if total_loss is None:\n                total_loss = microbatch_loss\n            else:\n                total_loss = total_loss + microbatch_loss\n    \n    # ===== BACKWARD PASS: AFAB - ALL BACKWARD =====\n    if rank == world_size - 1:\n        # Last rank: start backward from accumulated loss\n        total_loss.backward()\n    else:\n        # Non-last ranks: receive gradients from next rank and backprop\n        for mb_idx in range(num_microbatches):\n            # Receive gradient from next rank\n            gradient = torch.zeros_like(rank_inputs[mb_idx])\n            dist.recv(gradient, src=rank + 1)\n            \n            # Backward through this microbatch\n            # retain_graph=True for all but the last microbatch to allow multiple backward calls\n            rank_inputs[mb_idx].backward(\n                gradient,\n                retain_graph=(mb_idx < num_microbatches - 1)\n            )\n        \n        # Send gradients to previous rank (if not first rank)\n        if rank > 0:\n            for mb_idx in range(num_microbatches):\n                # The gradient w.r.t. the received hidden state is in rank_inputs[mb_idx].grad\n                input_gradient = rank_inputs[mb_idx].grad\n                dist.send(input_gradient.clone(), dst=rank - 1)\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
