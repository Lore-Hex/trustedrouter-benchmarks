  \'S\': [\'TCT\', \'TCC\', \'TCA\', \'TCG\', \'AGT\', \'AGC\'],\n        \'Y\': [\'TAT\', \'TAC\'], \'C\': [\'TGT\', \'TGC\'],\n        \'P\': [\'CCT\', \'CCC\', \'CCA\', \'CCG\'],\n        \'H\': [\'CAT\', \'CAC\'], \'Q\': [\'CAA\', \'CAG\'],\n        \'N\': [\'AAT\', \'AAC\'], \'K\': [\'AAA\', \'AAG\'],\n        \'T\': [\'ACT\', \'ACC\', \'ACA\', \'ACG\'],\n        \'R\': [\'CGT\', \'CGC\', \'CGA\', \'CGG\', \'AGA\', \'AGG\'],\n        \'A\': [\'GCT\', \'GCC\', \'GCA\', \'GCG\'],\n        \'G\': [\'GGT\', \'GGC\', \'GGA\', \'GGG\'],\n        \'V\': [\'GTT\', \'GTC\', \'GTA\', \'GTG\'],\n        \'D\': [\'GAT\', \'GAC\'], \'E\': [\'GAA\', \'GAG\'],\n        \'I\': [\'ATT\', \'ATC\', \'ATA\']\n    }\n    if aa in codon_table:\n        codons = codon_table[aa]\n        if len(codons) == 1:\n            return codons[0]\n        # Prefer codons that keep GC content balanced\n        avg_gc = sum(gc_history[-10:]) / max(len(gc_history[-10:]), 1) if gc_history else 0.5\n        best = codons[0]\n        best_diff = abs(sum(1 for c in best if c in \'GC\')/3.0 - avg_gc)\n        for codon in codons[1:]:\n            gc_codon = sum(1 for c in codon if c in \'GC\') / 3.0\n            diff = abs(gc_codon - avg_gc)\n            if diff < best_diff:\n                best = codon\n                best_diff = diff\n        return best\n    return None\n\ndef translate_protein_to_dna(protein_seq):\n    """Translate protein to DNA with GC balancing"""\n    dna = ""\n    gc_history = []\n    for aa in protein_seq:\n        codon = codon_for_aa(aa, gc_history)\n        if codon:\n            dna += codon\n            gc = sum(1 for c in codon if c in \'GC\') / 3.0\n            gc_history.append(gc)\n    return dna\n\ndef check_gc_content(dna_seq, window=50):\n    """Check GC content in sliding windows"""\n    if len(dna_seq) < window:\n        window = len(dna_seq)\n    for i in range(len(dna_seq) - window + 1):\n        gc = gc_fraction(Seq(dna_seq[i:i+window]))\n        if gc < 0