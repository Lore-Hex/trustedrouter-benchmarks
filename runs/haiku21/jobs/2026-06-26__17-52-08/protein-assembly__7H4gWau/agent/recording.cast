[361.95051, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             linker += random.choice('GS')  # G has 2x GC-contributing codons\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             linker += random.choice('GS')\r\n\u001b[?2004l\r\u001b[?2004h>     return linker\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def codon_for_aa(aa, gc_history=[]):\r\n\u001b[?2004l\r\u001b[?2004h>     codon_table = {\r\n\u001b[?2004l\r\u001b[?2004h>         'M': ['ATG'], 'W': ['TGG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'F': ['TTT', 'TTC'], 'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\r\n\u001b[?2004l\r\u001b[?2004h>         'Y': ['TAT', 'TAC'], 'C': ['TGT', 'TGC'],\r\n\u001b[?2004l\r\u001b[?2004h>         'P': ['CCT', 'CCC', 'CCA', 'CCG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'H': ['CAT', 'CAC'], 'Q': ['CAA', 'CAG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'N': ['AAT', 'AAC'], 'K': ['AAA', 'AAG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'T': ['ACT', 'ACC', 'ACA', 'ACG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'A"]
[361.950538, "o", "': ['GCT', 'GCC', 'GCA', 'GCG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'G': ['GGT', 'GGC', 'GGA', 'GGG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'V': ['GTT', 'GTC', 'GTA', 'GTG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'D': ['GAT', 'GAC'], 'E': ['GAA', 'GAG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'I': ['ATT', 'ATC', 'ATA']\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     if aa in codon_table:\r\n\u001b[?2004l\r\u001b[?2004h>         codons = codon_table[aa]\r\n\u001b[?2004l\r\u001b[?2004h>         if len(codons) == 1:\r\n\u001b[?2004l\r\u001b[?2004h>             return codons[0]\r\n\u001b[?2004l\r\u001b[?2004h>         # Prefer codons that keep GC content balanced\r\n\u001b[?2004l\r\u001b[?2004h>         avg_gc = sum(gc_history[-10:]) / max(len(gc_history[-10:]), 1) if gc_history else 0.5\r\n\u001b[?2004l\r\u001b[?2004h>         best = codons[0]\r\n\u001b[?2004l\r\u001b[?2004h>         best_diff = abs(sum(1 for c in best if c in 'GC')/3.0 - avg_gc)\r\n\u001b[?2004l\r\u001b[?2004h"]
