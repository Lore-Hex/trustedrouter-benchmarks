[444.766509, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> # Select proteins\r\n\u001b[?2004l\r\u001b[?2004h> molecule_binder_id = sorted_by_size[0][0]  # Smallest\r\n\u001b[?2004l\r\u001b[?2004h> donor_id = sorted_by_size[3][0]  # 4th smallest\r\n\u001b[?2004l\r\u001b[?2004h> acceptor_id = sorted_by_size[5][0]  # 6th smallest\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> donor_seq = pdb_sequences[donor_id]\r\n\u001b[?2004l\r\u001b[?2004h> acceptor_seq = pdb_sequences[acceptor_id]\r\n\u001b[?2004l\r\u001b[?2004h> molecule_binder_seq = pdb_sequences[molecule_binder_id]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"\\nProtein selection:\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"  Antibody binder: {len(antibody_binder)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"  Donor ({donor_id}): {len(donor_seq)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"  DHFR: {len(dhfr_seq)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"  Acceptor ({acceptor_id}): {len(acceptor_seq)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> print(f\"  Molecule binder ({molecule_binder_id}): {len(molecule_binder_seq)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Build fusion with 5 aa GS linkers\r\n\u001b[?2004l\r\u001b[?2004h> l"]
