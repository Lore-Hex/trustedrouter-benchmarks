[317.655799, "o", "    \"\"\"Translate protein to DNA codons with GC content control\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.655846, "o", "    codon_table = {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.65587, "o", "        'M': ['ATG'], 'W': ['TGG'],\r\n\u001b[?2004l\r"]
[317.65588, "o", "\u001b[?2004h> "]
[317.655969, "o", "        'F': ['TTT', 'TTC'], 'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656018, "o", "        'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656069, "o", "        'Y': ['TAT', 'TAC'], 'C': ['TGT', 'TGC'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656131, "o", "        'P': ['CCT', 'CCC', 'CCA', 'CCG'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656156, "o", "        'H': ['CAT', 'CAC'], 'Q': ['CAA', 'CAG'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656311, "o", "        'N': ['AAT', 'AAC'], 'K': ['AAA', 'AAG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'T': ['ACT', 'ACC', 'ACA', 'ACG'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656326, "o", "        'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],"]
[317.656331, "o", "\r\n"]
[317.656343, "o", "\u001b[?2004l\r"]
[317.656377, "o", "\u001b[?2004h> "]
[317.656419, "o", "        'A': ['GCT', 'GCC', 'GCA', 'GCG'],\r\n"]
[317.656426, "o", "\u001b[?2004l\r"]
[317.656449, "o", "\u001b[?2004h"]
[317.656456, "o", "> "]
[317.656514, "o", "        'G': ['GGT', 'GGC', 'GGA', 'GGG'],\r\n\u001b[?2004l\r"]
[317.656533, "o", "\u001b[?2004h> "]
[317.656645, "o", "        'V': ['GTT', 'GTC', 'GTA', 'GTG'],\r\n\u001b[?2004l\r\u001b[?2004h>         'D': ['GAT', 'GAC'], 'E': ['GAA', 'GAG'],\r\n\u001b[?2004l\r"]
[317.656671, "o", "\u001b[?2004h"]
[317.656679, "o", "> "]
[317.656736, "o", "        'I': ['ATT', 'ATC', 'ATA']\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656756, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656783, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.656802, "o", "    dna_seq = \"\"\r\n"]
[317.656821, "o", "\u001b[?2004l\r"]
[317.657556, "o", "\u001b[?2004h>     for aa in protein_seq:\r\n\u001b[?2004l\r\u001b[?2004h>         if aa in codon_table:\r\n\u001b[?2004l\r\u001b[?2004h>             codons = codon_table[aa]\r\n\u001b[?2004l\r\u001b[?2004h>             # Pick codon with best GC content for current window\r\n\u001b[?2004l\r\u001b[?2004h>             best_codon = codons[0]\r\n\u001b[?2004l\r\u001b[?2004h>             if len(codons) > 1:\r\n\u001b[?2004l\r\u001b[?2004h>                 for codon in codons:\r\n\u001b[?2004l\r\u001b[?2004h>                     gc = sum(1 for c in codon if c in 'GC') / 3.0\r\n\u001b[?2004l\r\u001b[?2004h>                     gc_best = sum(1 for c in best_codon if c in 'GC') / 3.0\r\n\u001b[?2004l\r\u001b[?2004h>                     if abs(gc - 0.5) < abs(gc_best - 0.5):\r\n\u001b[?2004l\r\u001b[?2004h>                         best_codon = codon\r\n\u001b[?2004l\r\u001b[?2004h>             dna_seq += best_codon\r\n\u001b[?2004l\r\u001b[?2004h>     return dna_seq.upper()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check_gc_content(dna_seq, window=50):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Check if GC content is within range for all windows\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.657573, "o", "    for i in range(len(dna_seq) - window + 1):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.657639, "o", "        window_seq = dna_seq[i:i+window]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.657663, "o", "        gc = gc_fraction(Seq(window_seq))\r\n\u001b[?2004l\r"]
[317.657693, "o", "\u001b[?2004h> "]
[317.657743, "o", "        if gc < 0.3 or gc > 0.7:\r\n\u001b[?2004l\r"]
[317.657784, "o", "\u001b[?2004h>             return False, i, gc\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.657834, "o", "    return True, -1, -1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[317.657872, "o", "> # Parse files\r\n\u001b[?2004l\r\u001b[?2004h> "]
