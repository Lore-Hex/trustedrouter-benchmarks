[361.955322, "o", "        print(\"GC content OK (30-70% per 50nt window)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.95536, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.955419, "o", "        print(f\"GC content violation at position {pos}: {gc_val*100:.1f}%\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[361.955426, "o", "\u001b[?2004h"]
[361.955473, "o", ">     # Write output\r\n\u001b[?2004l\r\u001b[?2004h"]
[361.95548, "o", "> "]
[361.955521, "o", "    with open('/app/gblock.txt', 'w') as f:\r\n\u001b[?2004l\r"]
[361.955542, "o", "\u001b[?2004h> "]
[361.95555, "o", "        f.write(dna_gblock)\r\n\u001b[?2004l\r"]
[361.955595, "o", "\u001b[?2004h> "]
[361.955605, "o", "    print(f\"\\nWritten to /app/gblock.txt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
