[603.824255, "i", "python3 << 'PYEOF'\nimport re\nfrom Bio import SeqIO\nfrom Bio.SeqUtils import gc_fraction\nfrom Bio.Seq import Seq\nimport requests\n\ndef get_pdb_sequence(pdb_id):\n    try:\n        url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n        resp = requests.get(url, timeout=5)\n        if resp.status_code == 200:\n            data = resp.json()\n            if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\n                return data['entity_poly']['pdbx_seq_one_letter_code']\n    except:\n        pass\n    return None\n\ndef get_codons_for_aa(aa):\n    codon_table = {\n        'M': ['ATG'], 'W': ['TGG'],\n        'F': ['TTT', 'TTC'],\n        'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\n        'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\n        'Y': ['TAT', 'TAC'],\n        'C': ['TGT', 'TGC'],\n        'P': ['CCT', 'CCC', 'CCA', 'CCG'],\n        'H': ['CAT', 'CAC'],\n        'Q': ['CAA', 'CAG'],\n        'N': ['AAT', 'AAC'],\n        'K': ['AAA', 'AAG'],\n        'T': ['ACT'"]
[603.824415, "i", ", 'ACC', 'ACA', 'ACG'],\n        'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\n        'A': ['GCT', 'GCC', 'GCA', 'GCG'],\n        'G': ['GGT', 'GGC', 'GGA', 'GGG'],\n        'V': ['GTT', 'GTC', 'GTA', 'GTG'],\n        'D': ['GAT', 'GAC'],\n        'E': ['GAA', 'GAG'],\n        'I': ['ATT', 'ATC', 'ATA']\n    }\n    return codon_table.get(aa, ['NNN'])\n\ndef gc_content_of_codon(codon):\n    return sum(1 for c in codon if c in 'GC') / 3.0\n\ndef pick_best_codon(aa, recent_gc_values):\n    codons = get_codons_for_aa(aa)\n    if len(codons) == 1:\n        return codons[0]\n    target_gc = 0.5\n    if recent_gc_values:\n        target_gc = sum(recent_gc_values[-20:]) / len(recent_gc_values[-20:])\n    best_codon = codons[0]\n    best_diff = abs(gc_content_of_codon(best_codon) - target_gc)\n    for codon in codons[1:]:\n        gc = gc_content_of_codon(codon)\n        diff = abs(gc - target_gc)\n        if diff < best_diff:\n            best_codon = codon\n            best_diff = diff\n    return best_codon\n\ndef translate_to_dna_with_gc_b"]
[603.824424, "o", "python3 << 'PYEOF'\r\n\u001b[?2004l\r"]
[603.824427, "i", "alance(protein_seq):\n    dna = \"\"\n    gc_history = []\n    for aa in protein_seq:\n        codon = pick_best_codon(aa, gc_history)\n        dna += codon\n        gc = gc_content_of_codon(codon)\n        gc_history.append(gc)\n    return dna\n\ndef check_gc_content(dna_seq, window=50):\n    if len(dna_seq) < window:\n        window = len(dna_seq)\n    violations = []\n    for i in range(len(dna_seq) - window + 1):\n        gc = gc_fraction(Seq(dna_seq[i:i+window]))\n        if gc < 0.3 or gc > 0.7:\n            violations.append((i, gc))\n    return len(violations) == 0, violations\n\nprint(\"Loading sequences...\")\ndhfr_seq = None\nwith open('/app/plasmid.gb', 'r') as f:\n    content = f.read()\n    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\n        if dhfr_seq.startswith('M'):\n            dhfr_seq = dhfr_seq[1:]\n        print(f\"DHFR: {len(dhfr_seq)} aa\")\n\nantibody_seqs = {}\nwith ope"]
[603.825497, "o", "\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> from Bio import SeqIO\r\n\u001b[?2004l\r\u001b[?2004h> from Bio.SeqUtils import gc_fraction\r\n\u001b[?2004l\r\u001b[?2004h> from Bio.Seq import Seq\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_pdb_sequence(pdb_id):\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\r\n\u001b[?2004l\r\u001b[?2004h>         resp = requests.get(url, timeout=5)\r\n\u001b[?2004l\r\u001b[?2004h>         if resp.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             data = resp.json()\r\n\u001b[?2004l\r\u001b[?2004h>             if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\r\n\u001b[?2004l\r\u001b[?2004h>                 return data['entity_poly']['pdbx_seq_one_letter_code']\r\n\u001b[?2004l\r\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r\u001b[?2004h>     return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_codons_for_aa(aa):\r\n\u001b[?2004l\r\u001b[?2004h>     codon_table = {\r\n\u001b[?2004l\r\u001b[?2004h>         'M': ['ATG'], 'W"]
[603.825584, "i", "n('/app/antibody.fasta', 'r') as f:\n    for record in SeqIO.parse(f, 'fasta'):\n        seq = str(record.seq)\n        if seq.startswith('M'):\n            seq = seq[1:]\n        antibody_seqs[record.id] = seq\n\nantibody_binder = antibody_seqs.get('heavy', '')\nif not antibody_binder:\n    for key in antibody_seqs:\n        if 'heavy' in key.lower():\n            antibody_binder = antibody_seqs[key]\n            break\nprint(f\"Antibody binder: {len(antibody_binder)} aa\")\n\npdb_ids = []\nwith open('/app/pdb_ids.txt', 'r') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n\npdb_sequences = {}\nfor pdb_id in pdb_ids:\n    seq = get_pdb_sequence(pdb_id)\n    if seq:\n        if seq.startswith('M'):\n            seq = seq[1:]\n        pdb_sequences[pdb_id] = seq\n\nprint(f\"PDB sequences retrieved: {len(pdb_sequences)}/20\")\n\n# Use GFP (smaller than YFP) for donor to fit within size constraint\ndonor_id = '2VZX'  # Green Fluorescent Protein (~488nm excitation, close to 505nm)\nacceptor_id = '4CQH'  # mCherry variant (~610nm "]
