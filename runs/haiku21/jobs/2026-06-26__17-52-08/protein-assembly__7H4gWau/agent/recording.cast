[361.948508, "o", "import random\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_pdb_sequence(pdb_id):\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\r\n\u001b[?2004l\r\u001b[?2004h>         resp = requests.get(url, timeout=5)\r\n\u001b[?2004l\r\u001b[?2004h>         if resp.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             data = resp.json()\r\n\u001b[?2004l\r\u001b[?2004h>             if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\r\n\u001b[?2004l\r\u001b[?2004h>                 return data['entity_poly']['pdbx_seq_one_letter_code']\r\n\u001b[?2004l\r\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r\u001b[?2004h>     return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def query_fpbase():\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         url = \"https://www.fpbase.org/api/v1/proteins/\"\r\n\u001b[?2004l\r\u001b[?2004h>         resp = requests.get(url, timeout=10)\r\n\u001b[?2004l\r\u001b[?2004h>         if resp.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             return resp.json()"]
[361.948512, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r\u001b[?2004h>     return []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def find_best_match(target_ex, target_em, tolerance=20):\r\n\u001b[?2004l\r\u001b[?2004h>     proteins = query_fpbase()\r\n\u001b[?2004l\r\u001b[?2004h>     best = None\r\n\u001b[?2004l\r\u001b[?2004h>     best_dist = float('inf')\r\n\u001b[?2004l\r\u001b[?2004h>     for p in proteins:\r\n\u001b[?2004l\r\u001b[?2004h>         if isinstance(p, dict):\r\n\u001b[?2004l\r\u001b[?2004h>             ex = p.get('ex_max')\r\n\u001b[?2004l\r\u001b[?2004h>             em = p.get('em_max')\r\n\u001b[?2004l\r\u001b[?2004h>             name = p.get('name', '')\r\n\u001b[?2004l\r\u001b[?2004h>             if ex and em:\r\n\u001b[?2004l\r\u001b[?2004h>                 dist = abs(ex - target_ex) + abs(em - target_em)\r\n\u001b[?2004l\r\u001b[?2004h>                 if dist < best_dist:\r\n\u001b[?2004l\r\u001b[?2004h>                     best_dist = dist\r\n\u001b[?2004l\r\u001b[?2004h> "]
