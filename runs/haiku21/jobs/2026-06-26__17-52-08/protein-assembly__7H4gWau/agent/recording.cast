[603.827503, "o", ">     return best_codon\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def translate_to_dna_with_gc_balance(protein_seq):\r\n\u001b[?2004l\r\u001b[?2004h>     dna = \"\"\r\n\u001b[?2004l\r\u001b[?2004h>     gc_history = []\r\n\u001b[?2004l\r\u001b[?2004h>     for aa in protein_seq:\r\n\u001b[?2004l\r\u001b[?2004h>         codon = pick_best_codon(aa, gc_history)\r\n\u001b[?2004l\r\u001b[?2004h>         dna += codon\r\n\u001b[?2004l\r\u001b[?2004h>         gc = gc_content_of_codon(codon)\r\n\u001b[?2004l\r\u001b[?2004h>         gc_history.append(gc)\r\n\u001b[?2004l\r\u001b[?2004h>     return dna\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check_gc_content(dna_seq, window=50):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[603.828504, "o", "    if len(dna_seq) < window:\r\n\u001b[?2004l\r\u001b[?2004h>         window = len(dna_seq)\r\n\u001b[?2004l\r\u001b[?2004h>     violations = []\r\n\u001b[?2004l\r\u001b[?2004h>     for i in range(len(dna_seq) - window + 1):\r\n\u001b[?2004l\r\u001b[?2004h>         gc = gc_fraction(Seq(dna_seq[i:i+window]))\r\n\u001b[?2004l\r\u001b[?2004h>         if gc < 0.3 or gc > 0.7:\r\n\u001b[?2004l\r\u001b[?2004h>             violations.append((i, gc))\r\n\u001b[?2004l\r\u001b[?2004h>     return len(violations) == 0, violations\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> print(\"Loading sequences...\")\r\n\u001b[?2004l\r\u001b[?2004h> dhfr_seq = None\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/plasmid.gb', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     content = f.read()\r\n\u001b[?2004l\r\u001b[?2004h>     match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\r\n\u001b[?2004l\r\u001b[?2004h>     if match:\r\n\u001b[?2004l\r\u001b[?2004h>         dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\r\n\u001b[?2004l\r\u001b[?2004h>         if dhfr_seq.startswith('M'):\r\n\u001b[?2004l\r\u001b[?2004h>             dhfr_seq = dhfr_seq[1:]\r\n\u001b[?2004l"]
[603.828564, "o", "\r\u001b[?2004h>         print(f\"DHFR: {len(dhfr_seq)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> antibody_seqs = {}\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/antibody.fasta', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     for record in SeqIO.parse(f, 'fasta'):\r\n\u001b[?2004l\r\u001b[?2004h>         seq = str(record.seq)\r\n\u001b[?2004l\r\u001b[?2004h>         if seq.startswith('M'):\r\n\u001b[?2004l\r\u001b[?2004h>             seq = seq[1:]\r\n\u001b[?2004l\r\u001b[?2004h>         antibody_seqs[record.id] = seq\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> antibody_binder = antibody_seqs.get('heavy', '')\r\n\u001b[?2004l\r"]
[603.828595, "o", "\u001b[?2004h> if not antibody_binder:"]
