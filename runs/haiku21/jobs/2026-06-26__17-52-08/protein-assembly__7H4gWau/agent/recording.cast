[361.954491, "o", "# Build fusion protein: antibody - donor - DHFR - acceptor - molecule_binder\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954529, "o", "fusion_protein = antibody_binder\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954574, "o", "linker_length = 10  # Start with 10 aa GS linker\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954618, "o", "linker_seq = 'GSGSGSGSGSGSGSGSGSG'[:linker_length]\r\n\u001b[?2004l\r"]
[361.95464, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954673, "o", "fusion_protein += linker_seq + donor_seq\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954709, "o", "fusion_protein += linker_seq + dhfr_seq\r\n\u001b[?2004l\r"]
[361.954729, "o", "\u001b[?2004h> "]
[361.954757, "o", "fusion_protein += linker_seq + acceptor_seq\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954809, "o", "fusion_protein += linker_seq + molecule_binder_seq\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[361.954852, "o", "\u001b[?2004h> "]
[361.954871, "o", "print(f\"\\nFusion protein: {len(fusion_protein)} aa\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954935, "o", "# Convert to DNA\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.954951, "o", "print(\"Converting to DNA with GC content balancing...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.955003, "o", "dna_gblock = translate_protein_to_dna(fusion_protein)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.955055, "o", "print(f\"DNA gBlock: {len(dna_gblock)} nucleotides\")\r\n\u001b[?2004l\r"]
[361.955076, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
