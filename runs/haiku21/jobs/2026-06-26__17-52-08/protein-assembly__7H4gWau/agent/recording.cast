[317.65297, "i", "cat > /tmp/build_gblock.py << 'ENDSCRIPT'\nimport re\nimport requests\nfrom Bio import SeqIO\nfrom Bio.SeqUtils import gc_fraction\nfrom Bio.Seq import Seq\nimport json\n\ndef get_pdb_sequence(pdb_id):\n    \"\"\"Fetch protein sequence from PDB API\"\"\"\n    try:\n        url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n        resp = requests.get(url, timeout=5)\n        if resp.status_code == 200:\n            data = resp.json()\n            if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\n                return data['entity_poly']['pdbx_seq_one_letter_code']\n    except:\n        pass\n    return None\n\ndef get_fpbase_fluorophores(excitation, emission, tolerance=20):\n    \"\"\"Find fluorescent proteins with matching excitation/emission\"\"\"\n    try:\n        url = \"https://www.fpbase.org/api/v1/proteins/\"\n        resp = requests.get(url, timeout=5)\n        if resp.status_code == 200:\n            proteins = resp.json()\n            matches = []\n            for p in proteins:\n          "]
[317.653165, "i", "      if isinstance(p, dict):\n                    ex = p.get('ex_max', 0)\n                    em = p.get('em_max', 0)\n                    if abs(ex - excitation) <= tolerance and abs(em - emission) <= tolerance:\n                        matches.append(p)\n            return matches\n    except:\n        pass\n    return []\n\ndef translate_to_codons(protein_seq, gc_target_range=(30, 70)):\n    \"\"\"Translate protein to DNA codons with GC content control\"\"\"\n    codon_table = {\n        'M': ['ATG'], 'W': ['TGG'],\n        'F': ['TTT', 'TTC'], 'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\n        'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\n        'Y': ['TAT', 'TAC'], 'C': ['TGT', 'TGC'],\n        'P': ['CCT', 'CCC', 'CCA', 'CCG'],\n        'H': ['CAT', 'CAC'], 'Q': ['CAA', 'CAG'],\n        'N': ['AAT', 'AAC'], 'K': ['AAA', 'AAG'],\n        'T': ['ACT', 'ACC', 'ACA', 'ACG'],\n        'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\n        'A': ['GCT', 'GCC', 'GCA', 'GCG'],\n        'G': ['GGT', 'GGC', 'GGA', 'GGG'],\n   "]
[317.653394, "o", "cat > /tmp/build_gblock.py << 'ENDSCRIPT'"]
[317.653422, "i", "     'V': ['GTT', 'GTC', 'GTA', 'GTG'],\n        'D': ['GAT', 'GAC'], 'E': ['GAA', 'GAG'],\n        'I': ['ATT', 'ATC', 'ATA']\n    }\n    \n    dna_seq = \"\"\n    for aa in protein_seq:\n        if aa in codon_table:\n            codons = codon_table[aa]\n            # Pick codon with best GC content for current window\n            best_codon = codons[0]\n            if len(codons) > 1:\n                for codon in codons:\n                    gc = sum(1 for c in codon if c in 'GC') / 3.0\n                    gc_best = sum(1 for c in best_codon if c in 'GC') / 3.0\n                    if abs(gc - 0.5) < abs(gc_best - 0.5):\n                        best_codon = codon\n            dna_seq += best_codon\n    return dna_seq.upper()\n\ndef check_gc_content(dna_seq, window=50):\n    \"\"\"Check if GC content is within range for all windows\"\"\"\n    for i in range(len(dna_seq) - window + 1):\n        window_seq = dna_seq[i:i+window]\n        gc = gc_fraction(Seq(window_seq))\n        if gc < 0.3 or gc > 0.7:\n            return False, i, gc\n   "]
[317.653523, "o", "\r\n"]
[317.653529, "i", " return True, -1, -1\n\n# Parse files\nprint(\"Parsing input files...\")\ndhfr_seq = None\nwith open('/app/plasmid.gb', 'r') as f:\n    content = f.read()\n    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\n        if dhfr_seq.startswith('M'):\n            dhfr_seq = dhfr_seq[1:]  # Remove N-terminal methionine\n        print(f\"DHFR: {len(dhfr_seq)} aa\")\n\nantibody_seqs = {}\nwith open('/app/antibody.fasta', 'r') as f:\n    for record in SeqIO.parse(f, 'fasta'):\n        seq = str(record.seq)\n        if seq.startswith('M'):\n            seq = seq[1:]\n        antibody_seqs[record.id] = seq\n        print(f\"Antibody {record.id}: {len(seq)} aa\")\n\nantibody_combined = ''.join(antibody_seqs.values())\nprint(f\"Combined antibody: {len(antibody_combined)} aa\")\n\npdb_ids = []\nwith open('/app/pdb_ids.txt', 'r') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n\nprint(f\"\\nQuerying"]
[317.653539, "o", "\u001b[?2004l\r\u001b[?2004h"]
[317.653543, "i", " PDB for {len(pdb_ids)} proteins...\")\npdb_sequences = {}\nfor pdb_id in pdb_ids:\n    seq = get_pdb_sequence(pdb_id)\n    if seq:\n        if seq.startswith('M'):\n            seq = seq[1:]\n        pdb_sequences[pdb_id] = seq\n        print(f\"{pdb_id}: {len(seq)} aa\")\n    else:\n        print(f\"{pdb_id}: Failed to fetch\")\n\nprint(f\"\\nSuccessfully retrieved {len(pdb_sequences)}/{len(pdb_ids)} sequences\")\nprint(f\"DHFR available: {dhfr_seq is not None}\")\nprint(f\"Antibody available: {len(antibody_combined) > 0}\")\nprint(f\"PDB sequences available: {len(pdb_sequences)}\")\nENDSCRIPT\n"]
