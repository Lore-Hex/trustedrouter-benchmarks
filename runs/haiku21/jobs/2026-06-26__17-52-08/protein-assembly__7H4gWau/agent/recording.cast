[317.657997, "o", "    content = f.read()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.658111, "o", "    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[317.658129, "o", "    if match:\r\n\u001b[?2004l\r"]
