[444.760668, "i", "cat > /tmp/build_gblock_v3.py << 'ENDSCRIPT'\nimport re\nfrom Bio import SeqIO\nfrom Bio.SeqUtils import gc_fraction\nfrom Bio.Seq import Seq\nimport requests\n\ndef get_pdb_sequence(pdb_id):\n    try:\n        url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n        resp = requests.get(url, timeout=5)\n        if resp.status_code == 200:\n            data = resp.json()\n            if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\n                return data['entity_poly']['pdbx_seq_one_letter_code']\n    except:\n        pass\n    return None\n\ndef codon_for_aa(aa):\n    # Use codons with balanced GC content\n    codon_table = {\n        'M': 'ATG', 'W': 'TGG',\n        'F': 'TTC', 'L': 'CTG',\n        'S': 'AGC', 'Y': 'TAC', 'C': 'TGC',\n        'P': 'CCG', 'H': 'CAC', 'Q': 'CAG',\n        'N': 'AAC', 'K': 'AAG',\n        'T': 'ACC', 'R': 'AGG',\n        'A': 'GCG', 'G': 'GGC',\n        'V': 'GTG', 'D': 'GAC', 'E': 'GAG',\n        'I': 'ATC'\n    }\n    return codon_table.get(aa, 'NNN"]
[444.762738, "o", "cat > /tmp/build_gblock_v3.py << 'ENDSCRIPT'\r\n\u001b[?2004l\r\u001b[?2004h> import re\r\n\u001b[?2004l\r\u001b[?2004h> from Bio import SeqIO\r\n\u001b[?2004l\r\u001b[?2004h> from Bio.SeqUtils import gc_fraction\r\n\u001b[?2004l\r\u001b[?2004h> from Bio.Seq import Seq\r\n\u001b[?2004l\r\u001b[?2004h> import requests\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def get_pdb_sequence(pdb_id):\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\r\n\u001b[?2004l\r\u001b[?2004h>         resp = requests.get(url, timeout=5)\r\n\u001b[?2004l\r\u001b[?2004h>         if resp.status_code == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             data = resp.json()\r\n\u001b[?2004l\r\u001b[?2004h>             if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\r\n\u001b[?2004l\r\u001b[?2004h>                 return data['entity_poly']['pdbx_seq_one_letter_code']\r\n\u001b[?2004l\r\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r\u001b[?2004h>     return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def codon_for_aa(aa):\r\n\u001b[?2004l\r\u001b[?2004h>     # Use codo"]
[444.762754, "i", "')\n\ndef translate_to_dna(protein_seq):\n    return ''.join(codon_for_aa(aa) for aa in protein_seq)\n\ndef check_gc_content(dna_seq, window=50):\n    if len(dna_seq) < window:\n        return True, -1, -1\n    for i in range(len(dna_seq) - window + 1):\n        gc = gc_fraction(Seq(dna_seq[i:i+window]))\n        if gc < 0.3 or gc > 0.7:\n            return False, i, gc\n    return True, -1, -1\n\nprint(\"Loading sequences...\")\ndhfr_seq = None\nwith open('/app/plasmid.gb', 'r') as f:\n    content = f.read()\n    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\n        if dhfr_seq.startswith('M'):\n            dhfr_seq = dhfr_seq[1:]\n        print(f\"DHFR: {len(dhfr_seq)} aa\")\n\nantibody_seqs = {}\nwith open('/app/antibody.fasta', 'r') as f:\n    for record in SeqIO.parse(f, 'fasta'):\n        seq = str(record.seq)\n        if seq.startswith('M'):\n            seq = seq[1:]\n        antibody_se"]
[444.762807, "o", "ns with balanced GC content\r\n\u001b[?2004l\r\u001b[?2004h>     codon_table = {\r\n\u001b[?2004l\r\u001b[?2004h>         'M': 'ATG', 'W': 'TGG',\r\n\u001b[?2004l\r\u001b[?2004h>         'F': 'TTC', 'L': 'CTG',\r\n\u001b[?2004l\r\u001b[?2004h>         'S': 'AGC', 'Y': 'TAC', 'C': 'TGC',\r\n\u001b[?2004l\r\u001b[?2004h>         'P': 'CCG', 'H': 'CAC', 'Q': 'CAG',\r\n\u001b[?2004l\r\u001b[?2004h>         'N': 'AAC', 'K': 'AAG',\r\n\u001b[?2004l\r\u001b[?2004h>         'T': 'ACC', 'R': 'AGG',\r\n\u001b[?2004l\r\u001b[?2004h>         'A': 'GCG', 'G': 'GGC',\r\n\u001b[?2004l\r\u001b[?2004h>         'V': 'GTG', 'D': 'GAC', 'E': 'GAG',\r\n\u001b[?2004l\r\u001b[?2004h>         'I': 'ATC'\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     return codon_table.get(aa, 'NNN"]
[444.762816, "i", "qs[record.id] = seq\n        print(f\"Antibody {record.id}: {len(seq)} aa\")\n\n# Use only heavy chain for size constraint\nantibody_binder = antibody_seqs.get('heavy chain', '')\nprint(f\"Using heavy chain: {len(antibody_binder)} aa\")\n\npdb_ids = []\nwith open('/app/pdb_ids.txt', 'r') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n\npdb_sequences = {}\nfor pdb_id in pdb_ids:\n    seq = get_pdb_sequence(pdb_id)\n    if seq:\n        if seq.startswith('M'):\n            seq = seq[1:]\n        pdb_sequences[pdb_id] = seq\n\nprint(f\"\\nPDB sequences retrieved: {len(pdb_sequences)}/20\")\nsorted_by_size = sorted(pdb_sequences.items(), key=lambda x: len(x[1]))\nprint(\"Sizes (smallest first):\")\nfor i, (pid, seq) in enumerate(sorted_by_size[:10]):\n    print(f\"  {i}: {pid}: {len(seq)} aa\")\n\n# Select proteins\nmolecule_binder_id = sorted_by_size[0][0]  # Smallest\ndonor_id = sorted_by_size[3][0]  # 4th smallest\nacceptor_id = sorted_by_size[5][0]  # 6th smallest\n\ndonor_seq = pdb_sequences[donor_id]\nacceptor_seq = pdb_sequence"]
[444.762826, "i", "s[acceptor_id]\nmolecule_binder_seq = pdb_sequences[molecule_binder_id]\n\nprint(f\"\\nProtein selection:\")\nprint(f\"  Antibody binder: {len(antibody_binder)} aa\")\nprint(f\"  Donor ({donor_id}): {len(donor_seq)} aa\")\nprint(f\"  DHFR: {len(dhfr_seq)} aa\")\nprint(f\"  Acceptor ({acceptor_id}): {len(acceptor_seq)} aa\")\nprint(f\"  Molecule binder ({molecule_binder_id}): {len(molecule_binder_seq)} aa\")\n\n# Build fusion with 5 aa GS linkers\nlinker_seq = 'GSGSG'  # 5 aa, GC content 40% (can be varied per requirements)\nfusion_protein = (\n    antibody_binder +\n    linker_seq +\n    donor_seq +\n    linker_seq +\n    dhfr_seq +\n    linker_seq +\n    acceptor_seq +\n    linker_seq +\n    molecule_binder_seq\n)\n\nfusion_size_aa = len(fusion_protein)\nfusion_size_nt = fusion_size_aa * 3\nprint(f\"\\nFusion protein size: {fusion_size_aa} aa = {fusion_size_nt} nt\")\n\nif fusion_size_nt > 3000:\n    print(f\"ERROR: Exceeds 3000 nt limit by {fusion_size_nt - 3000}\")\nelse:\n    print(f\"OK: {3000 - fusion_size_nt} nt available for GC optimization\")\n    \n  "]
[444.762835, "i", "  print(\"\\nConverting to DNA...\")\n    dna_gblock = translate_to_dna(fusion_protein)\n    print(f\"DNA length: {len(dna_gblock)} nt\")\n    \n    print(\"\\nValidating GC content...\")\n    gc_ok, pos, gc_val = check_gc_content(dna_gblock, window=50)\n    if gc_ok:\n        print(\"GC content: PASS (all windows 30-70%)\")\n    else:\n        print(f\"GC content: FAIL at position {pos} ({gc_val*100:.1f}%)\")\n    \n    # Write gblock\n    print(\"\\nWriting /app/gblock.txt...\")\n    with open('/app/gblock.txt', 'w') as f:\n        f.write(dna_gblock)\n    \n    with open('/app/gblock.txt', 'r') as f:\n        written = f.read()\n    \n    if written == dna_gblock:\n        print(f\"SUCCESS: {len(written)} nucleotides written to /app/gblock.txt\")\n    else:\n        print(f\"ERROR: File mismatch\")\nENDSCRIPT\n"]
[444.763374, "o", "')\r\n\u001b[?2004l\r"]
