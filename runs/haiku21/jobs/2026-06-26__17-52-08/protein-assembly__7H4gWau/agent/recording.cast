[30.720073, "i", "cat > /tmp/build_gblock.py << 'ENDSCRIPT'\nimport re\nimport requests\nfrom Bio import SeqIO\nfrom collections import defaultdict\n\n# Parse plasmid.gb to extract DHFR\ndhfr_seq = None\nwith open('/app/plasmid.gb', 'r') as f:\n    content = f.read()\n    # Extract translation from DHFR CDS\n    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\n        print(f\"DHFR sequence found: {len(dhfr_seq)} amino acids\")\n        print(f\"First 50 aa: {dhfr_seq[:50]}\")\n\n# Parse antibody.fasta\nantibody_seqs = {}\nwith open('/app/antibody.fasta', 'r') as f:\n    for record in SeqIO.parse(f, 'fasta'):\n        antibody_seqs[record.id] = str(record.seq)\n        print(f\"Antibody {record.id}: {len(record.seq)} amino acids\")\n\n# Parse pdb_ids.txt\npdb_ids = []\nwith open('/app/pdb_ids.txt', 'r') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n    print(f\"\\nFound {len(pdb_ids)} PDB IDs to "]
[30.720245, "i", "query\")\n\nprint(\"\\nFiles parsed successfully. Ready for API queries.\")\nENDSCRIPT\n"]
