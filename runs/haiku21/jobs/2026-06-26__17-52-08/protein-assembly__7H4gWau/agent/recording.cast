[361.945689, "i", "cat > /tmp/build_gblock_final.py << 'ENDSCRIPT'\nimport re\nimport requests\nfrom Bio import SeqIO\nfrom Bio.SeqUtils import gc_fraction\nfrom Bio.Seq import Seq\nimport random\n\ndef get_pdb_sequence(pdb_id):\n    try:\n        url = f\"https://data.rcsb.org/rest/v1/core/polymer_entity/{pdb_id}/1\"\n        resp = requests.get(url, timeout=5)\n        if resp.status_code == 200:\n            data = resp.json()\n            if 'entity_poly' in data and 'pdbx_seq_one_letter_code' in data['entity_poly']:\n                return data['entity_poly']['pdbx_seq_one_letter_code']\n    except:\n        pass\n    return None\n\ndef query_fpbase():\n    try:\n        url = \"https://www.fpbase.org/api/v1/proteins/\"\n        resp = requests.get(url, timeout=10)\n        if resp.status_code == 200:\n            return resp.json()\n    except:\n        pass\n    return []\n\ndef find_best_match(target_ex, target_em, tolerance=20):\n    proteins = query_fpbase()\n    best = None\n    best_dist = float('inf')\n    for p in proteins:\n        if isinstance(p, di"]
[361.945727, "i", "ct):\n            ex = p.get('ex_max')\n            em = p.get('em_max')\n            name = p.get('name', '')\n            if ex and em:\n                dist = abs(ex - target_ex) + abs(em - target_em)\n                if dist < best_dist:\n                    best_dist = dist\n                    best = (name, ex, em)\n    return best\n\ndef generate_gs_linker(length, target_gc=0.5):\n    \"\"\"Generate a GS linker with target GC content\"\"\"\n    linker = \"\"\n    for _ in range(length):\n        if random.random() < target_gc:\n            linker += random.choice('GS')  # G has 2x GC-contributing codons\n        else:\n            linker += random.choice('GS')\n    return linker\n\ndef codon_for_aa(aa, gc_history=[]):\n    codon_table = {\n        'M': ['ATG'], 'W': ['TGG'],\n        'F': ['TTT', 'TTC'], 'L': ['TTA', 'TTG', 'CTT', 'CTC', 'CTA', 'CTG'],\n        'S': ['TCT', 'TCC', 'TCA', 'TCG', 'AGT', 'AGC'],\n        'Y': ['TAT', 'TAC'], 'C': ['TGT', 'TGC'],\n        'P': ['CCT', 'CCC', 'CCA', 'CCG'],\n        'H': ['CAT', 'CAC'], 'Q': "]
[361.945732, "i", "['CAA', 'CAG'],\n        'N': ['AAT', 'AAC'], 'K': ['AAA', 'AAG'],\n        'T': ['ACT', 'ACC', 'ACA', 'ACG'],\n        'R': ['CGT', 'CGC', 'CGA', 'CGG', 'AGA', 'AGG'],\n        'A': ['GCT', 'GCC', 'GCA', 'GCG'],\n        'G': ['GGT', 'GGC', 'GGA', 'GGG'],\n        'V': ['GTT', 'GTC', 'GTA', 'GTG'],\n        'D': ['GAT', 'GAC'], 'E': ['GAA', 'GAG'],\n        'I': ['ATT', 'ATC', 'ATA']\n    }\n    if aa in codon_table:\n        codons = codon_table[aa]\n        if len(codons) == 1:\n            return codons[0]\n        # Prefer codons that keep GC content balanced\n        avg_gc = sum(gc_history[-10:]) / max(len(gc_history[-10:]), 1) if gc_history else 0.5\n        best = codons[0]\n        best_diff = abs(sum(1 for c in best if c in 'GC')/3.0 - avg_gc)\n        for codon in codons[1:]:\n            gc_codon = sum(1 for c in codon if c in 'GC') / 3.0\n            diff = abs(gc_codon - avg_gc)\n            if diff < best_diff:\n                best = codon\n                best_diff = diff\n        return best\n    return None\n\ndef t"]
[361.945737, "i", "ranslate_protein_to_dna(protein_seq):\n    \"\"\"Translate protein to DNA with GC balancing\"\"\"\n    dna = \"\"\n    gc_history = []\n    for aa in protein_seq:\n        codon = codon_for_aa(aa, gc_history)\n        if codon:\n            dna += codon\n            gc = sum(1 for c in codon if c in 'GC') / 3.0\n            gc_history.append(gc)\n    return dna\n\ndef check_gc_content(dna_seq, window=50):\n    \"\"\"Check GC content in sliding windows\"\"\"\n    if len(dna_seq) < window:\n        window = len(dna_seq)\n    for i in range(len(dna_seq) - window + 1):\n        gc = gc_fraction(Seq(dna_seq[i:i+window]))\n        if gc < 0.3 or gc > 0.7:\n            return False, i, gc\n    return True, -1, -1\n\n# Parse files\nprint(\"Loading sequences...\")\ndhfr_seq = None\nwith open('/app/plasmid.gb', 'r') as f:\n    content = f.read()\n    match = re.search(r'/product=\"dihydrofolate reductase \\(DHFR\\)\".*?/translation=\"([^\"]+)\"', content, re.DOTALL)\n    if match:\n        dhfr_seq = match.group(1).replace('\\n', '').replace(' ', '')\n        if dhfr_seq"]
[361.945848, "i", ".startswith('M'):\n            dhfr_seq = dhfr_seq[1:]\n        print(f\"DHFR: {len(dhfr_seq)} aa\")\n\nantibody_seqs = {}\nwith open('/app/antibody.fasta', 'r') as f:\n    for record in SeqIO.parse(f, 'fasta'):\n        seq = str(record.seq)\n        if seq.startswith('M'):\n            seq = seq[1:]\n        antibody_seqs[record.id] = seq\n\nantibody_binder = ''.join(antibody_seqs.values())\nprint(f\"Antibody binder: {len(antibody_binder)} aa\")\n\npdb_ids = []\nwith open('/app/pdb_ids.txt', 'r') as f:\n    pdb_ids = [line.strip() for line in f if line.strip()]\n\npdb_sequences = {}\nfor pdb_id in pdb_ids:\n    seq = get_pdb_sequence(pdb_id)\n    if seq:\n        if seq.startswith('M'):\n            seq = seq[1:]\n        pdb_sequences[pdb_id] = seq\n\nprint(f\"PDB sequences: {len(pdb_sequences)}/20\")\n\n# Find donor and acceptor\nprint(\"\\nQuerying fpbase for fluorescent proteins...\")\ndonor_info = find_best_match(505, 600)  # Excitation 505nm\nacceptor_info = find_best_match(600, 610)  # Emission 610nm\n\nprint(f\"Best donor candidate: {donor_in"]
[361.945858, "i", "fo}\")\nprint(f\"Best acceptor candidate: {acceptor_info}\")\n\n# For now, use largest/smallest proteins as proxies if fpbase doesn't match\nif not donor_info or not acceptor_info:\n    print(\"Using PDB proteins as donor/acceptor\")\n    sorted_pdb = sorted(pdb_sequences.items(), key=lambda x: len(x[1]))\n    donor_id = sorted_pdb[-2][0]  # Second largest\n    acceptor_id = sorted_pdb[-3][0]  # Third largest\n    molecule_binder_id = sorted_pdb[0][0]  # Smallest\nelse:\n    # Use largest proteins from PDB\n    sorted_pdb = sorted(pdb_sequences.items(), key=lambda x: len(x[1]), reverse=True)\n    donor_id = sorted_pdb[0][0]\n    acceptor_id = sorted_pdb[1][0]\n    molecule_binder_id = sorted_pdb[5][0]\n\ndonor_seq = pdb_sequences[donor_id]\nacceptor_seq = pdb_sequences[acceptor_id]\nmolecule_binder_seq = pdb_sequences[molecule_binder_id]\n\nprint(f\"\\nSelected proteins:\")\nprint(f\"Donor ({donor_id}): {len(donor_seq)} aa\")\nprint(f\"DHFR: {len(dhfr_seq)} aa\")\nprint(f\"Acceptor ({acceptor_id}): {len(acceptor_seq)} aa\")\nprint(f\"Molecule binde"]
[361.945877, "i", "r ({molecule_binder_id}): {len(molecule_binder_seq)} aa\")\nprint(f\"Antibody binder: {len(antibody_binder)} aa\")\n\n# Build fusion protein: antibody - donor - DHFR - acceptor - molecule_binder\nfusion_protein = antibody_binder\nlinker_length = 10  # Start with 10 aa GS linker\nlinker_seq = 'GSGSGSGSGSGSGSGSGSG'[:linker_length]\n\nfusion_protein += linker_seq + donor_seq\nfusion_protein += linker_seq + dhfr_seq\nfusion_protein += linker_seq + acceptor_seq\nfusion_protein += linker_seq + molecule_binder_seq\n\nprint(f\"\\nFusion protein: {len(fusion_protein)} aa\")\n\n# Convert to DNA\nprint(\"Converting to DNA with GC content balancing...\")\ndna_gblock = translate_protein_to_dna(fusion_protein)\nprint(f\"DNA gBlock: {len(dna_gblock)} nucleotides\")\n\nif len(dna_gblock) > 3000:\n    print(f\"ERROR: gBlock too long ({len(dna_gblock)} > 3000)\")\nelse:\n    # Check GC content\n    gc_ok, pos, gc_val = check_gc_content(dna_gblock)\n    if gc_ok:\n        print(\"GC content OK (30-70% per 50nt window)\")\n    else:\n        print(f\"GC content violation"]
