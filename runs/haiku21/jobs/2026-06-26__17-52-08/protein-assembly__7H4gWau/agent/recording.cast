[361.955106, "o", "\u001b[?2004h> "]
[361.955157, "o", "    print(f\"ERROR: gBlock too long ({len(dna_gblock)} > 3000)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[361.955234, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h>     # Check GC content\r\n\u001b[?2004l\r"]
