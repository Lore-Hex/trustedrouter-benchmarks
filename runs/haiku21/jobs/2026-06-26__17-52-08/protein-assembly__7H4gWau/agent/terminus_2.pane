[?2004l[?2004h> def pick_best_codon(aa, recent_gc_values):
[?2004l[?2004h>     codons = get_codons_for_aa(aa)
[?2004l[?2004h>     if len(codons) == 1:
[?2004l[?2004h>         return codons[0]
[?2004l[?2004h>     target_gc = 0.5
[?2004l[?2004h>     if recent_gc_values:
[?2004l[?2004h>         target_gc = sum(recent_gc_values[-20:]) / len(recent_gc_values[-20:])
[?2004l[?2004h>     best_codon = codons[0]
