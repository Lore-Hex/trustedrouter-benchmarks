[232.258389, "i", "python3 -c \"from feal import create_random_keys, encrypt, key; create_random_keys(); from attack import attack; result = attack(encrypt); print('Recovered key[5]:', hex(result)); print('Actual key[5]:', hex(key[5])); print('Match:', result == key[5])\"\n"]
[232.259678, "o", "python3 -c \"from feal import create_random_keys, encrypt, key; create_random_keys(); from attack import attack; result = attack(encrypt); print('Recovered key[5]:', hex(result)); print('Actual key[5]:', hex(key[5])); print('Match:', result == key[5])\"\r\n"]
