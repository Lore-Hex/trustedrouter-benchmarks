[214.818552, "o", "    test_plaintexts = [\r\n\u001b[?2004l\r\u001b[?2004h>         0x0000000000000000,\r\n\u001b[?2004l\r\u001b[?2004h>         0x0000000000000001, \r\n\u001b[?2004l\r\u001b[?2004h>         0x8000000000000000,\r\n\u001b[?2004l\r\u001b[?2004h>         0x0100000000000000,\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Encrypt with the real (unknown) key[5] via encrypt_fn\r\n\u001b[?2004l\r\u001b[?2004h>     observed_ciphers = []\r\n\u001b[?2004l\r\u001b[?2004h>     for pt in test_plaintexts:\r\n\u001b[?2004l\r\u001b[?2004h>         observed_ciphers.append(encrypt_fn(pt))\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Save the original key[5]\r\n\u001b[?2004l\r\u001b[?2004h>     original_key5 = feal.key[5]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         # Brute force all possible key[5] values\r\n\u001b[?2004l\r\u001b[?2004h>         for seed in range(65536):\r\n\u001b[?2004l\r\u001b[?2004h>             candidate_key5 = (seed * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h>             feal.key[5] = candidate_key5\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             #"]
[214.818563, "o", " Test if this key[5] produces the observed ciphertexts\r\n\u001b[?2004l\r\u001b[?2004h>             matches = True\r\n\u001b[?2004l\r\u001b[?2004h>             for pt, observed_ct in zip(test_plaintexts, observed_ciphers):\r\n\u001b[?2004l\r\u001b[?2004h>                 if feal.encrypt(pt) != observed_ct:\r\n\u001b[?2004l\r\u001b[?2004h>                     matches = False\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if matches:\r\n\u001b[?2004l\r\u001b[?2004h>                 return candidate_key5\r\n\u001b[?2004l\r\u001b[?2004h>     finally:\r\n\u001b[?2004l\r\u001b[?2004h>         # Restore original key[5]\r\n\u001b[?2004l\r\u001b[?2004h>         feal.key[5] = original_key5\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Should not reach here if attack successful\r\n\u001b[?2004l\r\u001b[?2004h>     return (0 * 1234567) & 0xFFFFFFFF\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
