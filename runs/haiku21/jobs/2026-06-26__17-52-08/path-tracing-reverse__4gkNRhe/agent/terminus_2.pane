[?2004l[?2004h> import struct
[?2004l[?2004h> import subprocess
[?2004l[?2004h> 
[?2004l[?2004h> result = subprocess.run(['readelf', '-x', '.rodata', '/app/mystery'], capture_output=True, text=True)
[?2004l[?2004h> lines = result.stdout.split('\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Looking for floating-point constants in .rodata:')
[?2004l[?2004h> for line in lines:
[?2004l[?2004h>     if '0x' in line and any(c in '0123456789abcdef' for c in line):
[?2004l[?2004h>         # Try to extract hex values
[?2004l[?2004h>         parts = line.split()
[?2004l[?2004h>         try:
[?2004l[?2004h>             for i in range(1, len(parts)):
[?2004l[?2004h>                 if len(parts[i]) == 8:  # 4-byte float
