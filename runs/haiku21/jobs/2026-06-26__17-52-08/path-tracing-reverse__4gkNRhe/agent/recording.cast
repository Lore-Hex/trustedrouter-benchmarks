[565.348737, "i", "python3 << 'MANUAL_ANALYZE'\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 1600:  # First 2 rows\n            break\n\nprint('ROW 0 (y=0, v=-1):')\nfor x in [0, 50, 100, 150, 200, 250, 300, 350, 400, 450, 500, 550, 600, 650, 700, 750, 799]:\n    u = (x - 400) / 400.0\n    rsq = u*u + 1.0\n    r, g, b = pixels[x]\n    print(f'x={x:3d} u={u:7.3f} r²={rsq:6.3f}: ({r:3d},{g:3d},{b:3d})')\nMANUAL_ANALYZE\n"]
