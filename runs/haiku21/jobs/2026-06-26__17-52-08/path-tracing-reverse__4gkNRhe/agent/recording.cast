[842.196054, "o", "                double w = sqrt(1.0 - rsq);\r\n\u001b[?2004l\r\u001b[?2004h>                 double len = sqrt(u*u + v*v + w*w);"]
[842.197285, "o", "\r\n\u001b[?2004l\r"]
[842.19731, "o", "\u001b[?2004h>                 double nx = u / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 double ny = v / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 double nz = w / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 double lx = 0.7071067811865476;\r\n\u001b[?2004l\r\u001b[?2004h>                 double ly = 0.7071067811865476;\r\n\u001b[?2004l\r\u001b[?2004h>                 double diff = nx*lx + ny*ly;\r\n\u001b[?2004l\r\u001b[?2004h>                 if (diff < 0) diff = 0;\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)round(120.0 + 35.0*diff + 5.0*rsq);\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)round(175.0 + 20.0*diff + 10.0*u);\r\n\u001b[?2004l\r\u001b[?2004h>             } else {\r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)round(146.0 + 13.0*u*u);\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)round(190.0 + 7.0*u*u);\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (r < 0) r = 0; if (r > 255) r = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             if (g < 0) g = 0; if (g > 255) g = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             fprintf(f, \"%d %d %d\\n\", r, g, b);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Rendering complete\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Wrote image to image.ppm\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Done.\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> ROUNDED\r\n\u001b[?2004l\r"]
