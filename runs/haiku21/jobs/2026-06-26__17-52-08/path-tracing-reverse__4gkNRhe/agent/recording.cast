[629.323304, "o", "\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for (int y = 0; y < 600; y++) {\r\n\u001b[?2004l\r\u001b[?2004h>         for (int x = 0; x < 800; x++) {\r\n\u001b[?2004l\r\u001b[?2004h>             float u = (x - 400.0f) / 400.0f;\r\n\u001b[?2004l\r\u001b[?2004h>             float v = (y - 300.0f) / 300.0f;\r\n\u001b[?2004l\r\u001b[?2004h>             float rsq = u*u + v*v;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             int r, g, b = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (rsq <= 1.0f) {\r\n\u001b[?2004l\r\u001b[?2004h>                 float w = sqrtf(1.0f - rsq);\r\n\u001b[?2004l\r\u001b[?2004h>                 float len = sqrtf(rsq + w*w);\r\n\u001b[?2004l\r\u001b[?2004h>                 float nx = u / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 float ny = v / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 float nz = w / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 float light_dist = sqrtf(2.0f);\r\n\u001b[?2004l\r\u001b[?2004h>                 float diff = (nx + ny) / light_dist;\r\n\u001b[?2004l\r\u001b[?2004h>                 if (diff < 0) diff = 0;\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)(150.0f + 10.0f * diff - 5.0f*u*u);\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)(190.0f + 8.0f * diff + 5.0f*u);\r\n\u001b[?2004l\r\u001b[?2004h>             } else {\r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)(150.0f - 5.0f*u*u - 20.0f*(rsq-1.0f));\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)(155.0f + 50.0f*u - 10.0f*(rsq-1.0f));\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (r < 0) r = 0; if (r > 255) r = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             if (g < 0) g = 0; if (g > 255) g = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             fprintf(f, \"%d %d %d\\n\", r, g, b);\r\n\u001b[?2004l\r\u001b[?2004h"]
