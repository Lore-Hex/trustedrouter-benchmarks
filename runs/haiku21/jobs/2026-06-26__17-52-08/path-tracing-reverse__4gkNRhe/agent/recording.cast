[319.132345, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for (int y = 0; y < 600; y++) {\r\n\u001b[?2004l\r\u001b[?2004h>         for (int x = 0; x < 800; x++) {\r\n\u001b[?2004l\r\u001b[?2004h>             double dx = (x - 400.0) / 400.0;\r\n\u001b[?2004l\r\u001b[?2004h>             double dy = (y - 300.0) / 300.0;\r\n\u001b[?2004l\r\u001b[?2004h>             double d = sqrt(dx*dx + dy*dy);\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             double t = atan2(dy, dx);\r\n\u001b[?2004l\r\u001b[?2004h>             int r = (int)(159 + 50*sin(t));\r\n\u001b[?2004l\r\u001b[?2004h>             int g = (int)(197 + 40*cos(2*t));\r\n\u001b[?2004l\r\u001b[?2004h>             int b = (int)(255 - 60*d);\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             r = r < 0 ? 0 : (r > 255 ? 255 : r);\r\n\u001b[?2004l\r\u001b[?2004h>             g = g < 0 ? 0 : (g > 255 ? 255 : g);\r\n\u001b[?2004l\r\u001b[?2004h>             b = b < 0 ? 0 : (b > 255 ? 255 : b);\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             fprintf(f, \"%d %d %d\\n\", r, g, b);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Rendering complete\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Wrote image to image.ppm\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Done.\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> ENDCODE\r\n\u001b[?2004l\r"]
