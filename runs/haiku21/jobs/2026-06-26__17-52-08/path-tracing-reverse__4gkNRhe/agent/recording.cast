[315.599421, "i", "python3 << 'ENDPYTHON'\nwith open('image.ppm', 'rb') as f:\n    f.readline()  # P3\n    f.readline()  # 800 600\n    f.readline()  # 255\n    data = f.read()\ncolors = []\nfor i in range(0, min(300, len(data)), 3):\n    if i+2 < len(data):\n        r, g, b = data[i], data[i+1], data[i+2]\n        colors.append((r, g, b))\nprint('First 100 pixels:', colors[:100])\nprint('Unique colors in first 200 pixels:', len(set(colors[:200])))\nENDPYTHON\n"]
[315.599826, "o", "python3 << 'ENDPYTHON'\r\n\u001b[?2004l\r\u001b[?2004h"]
