[695.004735, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             float u = (x - 400.0f) / 400.0f;\r\n\u001b[?2004l\r\u001b[?2004h>             float v = (y - 300.0f) / 300.0f;\r\n\u001b[?2004l\r\u001b[?2004h>             float rsq = u*u + v*v;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             int r, g, b;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (rsq <= 1.0f) {\r\n\u001b[?2004l\r\u001b[?2004h>                 float w = sqrtf(1.0f - rsq);\r\n\u001b[?2004l\r\u001b[?2004h>                 float len = sqrtf(u*u + v*v + w*w);\r\n\u001b[?2004l\r\u001b[?2004h>                 float nx = u / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 float ny = v / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 float nz = w / len;\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 float lx = 0.7071f, ly = 0.7071f, lz = 0.0f;\r\n\u001b[?2004l\r\u001b[?2004h>                 float diff = fmaxf(0.0f, nx*lx + ny*ly + nz*lz);\r\n\u001b[?2004l\r\u001b[?2004h>                 \r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)(100.0f + 50.0f*diff + 8.0f*u*u);\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)(160.0f + 35.0f*diff + 5.0f*u);\r\n\u001b[?2004l\r\u001b[?2004h>                 b = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             } else {\r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)(146.0f + 13.0f*u*u - 3.0f*(rsq-1.0f));\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)(190.0f + 7.0f*u*u - 2.0f*(rsq-1.0f));\r\n\u001b[?2004l\r\u001b[?2004h>                 b = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (r < 0) r = 0; if (r > 255) r = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             if (g < 0) g = 0; if (g > 255) g = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             fprintf(f, \"%d %d %d\\n\", r, g, b);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Rendering complete\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Wrote image to image.ppm\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Done.\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> FINALCODE\r\n\u001b[?2004l\r"]
