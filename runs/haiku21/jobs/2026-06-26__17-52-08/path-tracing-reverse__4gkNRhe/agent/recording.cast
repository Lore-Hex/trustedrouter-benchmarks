[628.334934, "i", "python3 << 'FIND_EXACT'\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 800:\n            break\n\nrow0 = pixels\n\n# Analyze if values follow simple formulas\nprint('Checking for formula patterns in row 0:')\nfor x in [0, 100, 200, 300, 400, 500, 600, 700, 799]:\n    r, g, b = row0[x]\n    u = (x - 400) / 400.0\n    u2 = u * u\n    print(f'x={x:3d} u={u:6.2f} u²={u2:6.4f}: R={r:3d} G={g:3d} B={b:3d}')\n\nprint('\\nLooking for R formula:')\nr_vals = [row0[x][0] for x in [0, 50, 100, 150, 200, 250, 300, 350, 400]]\nprint('R values (x=0 to 400):', r_vals)\nprint('Differences:', [r_vals[i+1] - r_vals[i] for i in range(len(r_vals)-1)])\n\nprint('\\nLooking for G formula:')\ng_vals = [row0[x][1] for x in [0, 50, 100, 150, 200, 250, 300, 350, 400]]\nprint('G values (x=0 to 400):', g_vals)\nprint('Differences:', [g_vals[i+1] - g_vals[i] for i in range(len(g_vals)-1)])\nFIND_EXACT\n"]
