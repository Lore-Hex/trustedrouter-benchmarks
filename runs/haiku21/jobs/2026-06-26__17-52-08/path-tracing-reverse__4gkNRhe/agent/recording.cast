[284.728725, "o", "rm -f image.ppm && ./reversed > /tmp/m2.txt 2>&1 && md5sum image.ppm\r\n\u001b[?2004l\r"]
[285.018318, "o", "790e95eebb8c66da9001cfef578fd1ec  image.ppm\r\n"]
