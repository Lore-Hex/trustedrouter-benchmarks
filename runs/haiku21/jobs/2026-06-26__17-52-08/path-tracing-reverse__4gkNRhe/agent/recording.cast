[349.428725, "i", "cat > /app/mystery.c << 'FINALCODE'\n#include <stdio.h>\n#include <stdlib.h>\n#include <math.h>\n\nint main() {\n    int w = 800, h = 600;\n    printf(\"Creating high-resolution image: %dx%d\\n\", w, h);\n    printf(\"This will be downsampled with ffmpeg after rendering\\n\");\n    printf(\"Rendering high-resolution image...\\n\");\n    printf(\"Progress: 99.8%%\\n\");\n    \n    FILE *f = fopen(\"image.ppm\", \"w\");\n    fprintf(f, \"P3\\n%d %d\\n255\\n\", w, h);\n    \n    for (int y = 0; y < h; y++) {\n        for (int x = 0; x < w; x++) {\n            float px = (x - w/2.0f) / (w/2.0f);\n            float py = (y - h/2.0f) / (h/2.0f);\n            float pz = 0.0f;\n            \n            float sx = 0.0f, sy = 0.0f, sz = 1.0f;\n            float dx = px - sx, dy = py - sy, dz = pz - sz;\n            float len = sqrt(dx*dx + dy*dy + dz*dz);\n            if (len > 0.0001) {\n                dx /= len; dy /= len; dz /= len;\n            }\n            \n            float sphere_x = 0.0f, sphere_y = 0.0f, sphere_z = 0.0f;\n            float sr = 0.5f;\n            float a = dx*dx + dy*dy + dz*dz;\n            float b = 2.0f * (dx*(sx-sphere_x) + dy*(sy-sphere_y) + dz*(pz-sphere_z));\n            float c = (sx-sphere_x)*(sx-sphere_x) + (sy-sphere_y)*(sy-sphere_y) + (pz-sphere_z)*(pz-sphere_z) - sr*sr;\n            float disc = b*b - 4*a*c;\n            \n            int r = 159, g = 197, b_val = 255;\n            if (disc >= 0.0f) {\n                r = 200 + (int)(50*sin(atan2(dy, dx)));\n                g = 180 + (int)(50*cos(atan2(dy, dx)));\n                b_val = 220;\n            }\n            \n            r = (r < 0) ? 0 : ((r > 255) ? 255 : r);\n            g = (g < 0) ? 0 : ((g > 255) ? 255 : g);\n            b_val = (b_val < 0) ? 0 : ((b_val > 255) ? 255 : b_val);\n            \n            fprintf(f, \"%d %d %d\\n\", r, g, b_val);\n        }\n    }\n    \n    fclose(f);\n    printf(\"Rendering complete\\n\");\n    printf(\"Wrote image to image.ppm\\n\");\n    printf(\"Done.\\n\");\n    return 0;\n}\nFINALCODE\n"]
