[901.651479, "i", "python3 << 'EXTRACT_INTERIOR'\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 4000:\n            break\n\nprint('Interior sphere pixels at various y:')\nfor y in [100, 200]:\n    for x in [300, 400, 500]:\n        idx = y*800 + x\n        if idx < len(pixels):\n            r, g, b = pixels[idx]\n            u = (x - 400) / 400.0\n            v = (y - 300) / 300.0\n            rsq = u*u + v*v\n            print(f'y={y} x={x} rsq={rsq:.4f}: R={r} G={g}')\nEXTRACT_INTERIOR\n"]
