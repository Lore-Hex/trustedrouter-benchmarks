[603.050171, "i", "python3 << 'EXTRACT_ALL'\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 810:  # First row plus one pixel\n            break\n\nprint('First row (y=0) sample pixels:')\nfor x in range(0, 801, 50):\n    if x < len(pixels):\n        r, g, b = pixels[x]\n        u = (x - 400) / 400.0\n        v = -1.0\n        rsq = u*u + v*v\n        print(f'x={x:3d} u={u:7.4f} rsq={rsq:7.4f}: RGB=({r:3d},{g:3d},{b:3d})')\n\nif len(pixels) > 800:\n    print('\\nFirst pixel of row 1 (y=1):')\n    r, g, b = pixels[800]\n    print(f'  RGB=({r},{g},{b})')\nEXTRACT_ALL\n"]
