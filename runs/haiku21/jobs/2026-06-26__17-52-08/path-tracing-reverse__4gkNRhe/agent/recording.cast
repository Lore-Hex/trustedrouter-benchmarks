[382.431568, "i", "python3 << 'ENDPYTHON'\nimport struct\nwith open('image.ppm', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = {}\n    y = 0\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            x = len(pixels) - y*800 if y*800 <= len(pixels) else 0\n            if y*800 <= len(pixels) < (y+1)*800:\n                pixels[len(pixels)] = tuple(map(int, parts))\n            if len(pixels) >= 1000:\n                break\nfor i in [0, 100, 200, 400, 500, 600, 700, 799, 800, 801, 900]:\n    if i in pixels:\n        print(f'Pixel {i:4d}: {pixels[i]}')\nENDPYTHON\n"]
[382.432234, "o", "python3 << 'ENDPYTHON'\r\n\u001b[?2004l\r"]
