[494.451222, "i", "python3 << 'ENDPYTHON'\nimport struct\n# Extract floating point constants from readelf output\nwith open('image.ppm', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 50:\n            break\n\nprint('First row analysis (y=0):')\nfor i in range(0, min(50, len(pixels)), 10):\n    print(f'  x={i:3d}: {pixels[i]}')\n\n# Analyze the pattern\nif len(pixels) >= 20:\n    print('\\nColor gradients:')\n    for i in range(0, 20, 5):\n        r0, g0, b0 = pixels[i]\n        r1, g1, b1 = pixels[i+5] if i+5 < len(pixels) else pixels[i]\n        print(f'  Pixels {i}-{i+5}: R {r0}->{r1}, G {g0}->{g1}, B {b0}->{b1}')\nENDPYTHON\n"]
[494.452108, "o", "python3 << 'ENDPYTHON'\r\n\u001b[?2004l\r"]
