[537.413977, "i", "python3 << 'ANALYZEROW'\nimport numpy as np\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    pixels = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            pixels.append(tuple(map(int, parts)))\n        if len(pixels) >= 800:\n            break\n\nprint('All R values for y=0:')\nr_vals = [p[0] for p in pixels]\nprint('Min R:', min(r_vals), 'Max R:', max(r_vals))\nprint('R values at x indices: 0, 100, 200, 300, 400, 500, 600, 700, 799:')\nfor x in [0, 100, 200, 300, 400, 500, 600, 700, 799]:\n    print(f'  R[{x}]={r_vals[x]}')\n\nprint('\\nAll G values for y=0:')\ng_vals = [p[1] for p in pixels]\nprint('Min G:', min(g_vals), 'Max G:', max(g_vals))\nprint('G values at x indices: 0, 100, 200, 300, 400, 500, 600, 700, 799:')\nfor x in [0, 100, 200, 300, 400, 500, 600, 700, 799]:\n    print(f'  G[{x}]={g_vals[x]}')\n\nprint('\\nAll B values for y=0:')\nb_vals = [p[2] for p in pixels]\nprint('Unique B values:', set(b_vals))\nANALYZEROW\n"]
