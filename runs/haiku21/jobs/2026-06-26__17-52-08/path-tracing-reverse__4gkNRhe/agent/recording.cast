[498.300934, "i", "cat > /app/mystery.c << 'NEWCODE'\n#include <stdio.h>\n#include <stdlib.h>\n#include <math.h>\n\nint main() {\n    printf(\"Creating high-resolution image: 800x600\\n\");\n    printf(\"This will be downsampled with ffmpeg after rendering\\n\");\n    printf(\"Rendering high-resolution image...\\n\");\n    printf(\"Progress: 99.8%%\\n\");\n    \n    FILE *f = fopen(\"image.ppm\", \"w\");\n    fprintf(f, \"P3\\n800 600\\n255\\n\");\n    \n    for (int y = 0; y < 600; y++) {\n        for (int x = 0; x < 800; x++) {\n            float u = (x - 400.0f) / 400.0f;\n            float v = (y - 300.0f) / 300.0f;\n            \n            float rsq = u*u + v*v;\n            \n            int r, g, b;\n            if (rsq < 1.0f) {\n                float w = sqrtf(1.0f - rsq);\n                float nlen = sqrtf(u*u + v*v + w*w);\n                float nx = u / nlen;\n                float ny = v / nlen;\n                float nz = w / nlen;\n                \n                float light_dot = (nx + ny + nz) / sqrtf(3.0f);\n                if (light_dot < 0) light_dot = 0;\n                \n                r = (int)(165 - 15*u - 5*light_dot*10);\n                g = (int)(218 - 23*u - 8*light_dot*5);\n                b = 220;\n            } else {\n                r = (int)(165 - 20*u + 10*(rsq-1));\n                g = (int)(218 - 30*u + 8*(rsq-1));\n                b = 220;\n            }\n            \n            if (r < 0) r = 0; if (r > 255) r = 255;\n            if (g < 0) g = 0; if (g > 255) g = 255;\n            if (b < 0) b = 0; if (b > 255) b = 255;\n            \n            fprintf(f, \"%d %d %d\\n\", r, g, b);\n        }\n    }\n    \n    fclose(f);\n    printf(\"Rendering complete\\n\");\n    printf(\"Wrote image to image.ppm\\n\");\n    printf(\"Done.\\n\");\n    return 0;\n}\nNEWCODE\n"]
