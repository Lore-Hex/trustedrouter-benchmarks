[536.623891, "i", "python3 << 'SOLVE'\nimport numpy as np\n# Read original at y=0\nwith open('/app/image.ppm.orig', 'r') as f:\n    f.readline(); f.readline(); f.readline()\n    orig_row0 = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            orig_row0.append(tuple(map(int, parts)))\n        if len(orig_row0) >= 800:\n            break\n\nprint('Sample pixels from y=0:')\nfor x in [0, 100, 200, 300, 400, 500, 600, 700, 799]:\n    if x < len(orig_row0):\n        u = (x - 400.0) / 400.0\n        r, g, b = orig_row0[x]\n        print(f'  x={x:3d} u={u:7.3f}: R={r:3d} G={g:3d} B={b:3d}')\n\n# Fit R = a + b*u^2\ndata_x = np.array([0, 100, 200, 400, 600, 700, 799])\ndata_u = (data_x - 400.0) / 400.0\ndata_r = np.array([orig_row0[x][0] for x in data_x])\n\n# Fit polynomial\ncoeffs_r = np.polyfit(data_u, data_r, 2)\nprint(f'\\nR channel fit: R = {coeffs_r[0]:.2f}*u^2 + {coeffs_r[1]:.2f}*u + {coeffs_r[2]:.2f}')\n\ndata_g = np.array([orig_row0[x][1] for x in data_x])\ncoeffs_g = np.polyfit(data_u, data_g, 2)\nprint(f'G channel fit: G = {coeffs_g[0]:.2f}*u^2 + {coeffs_g[1]:.2f}*u + {coeffs_g[2]:.2f}')\nSOLVE\n"]
[536.62487, "o", "python3 << 'SOLVE'\r\n\u001b[?2004l\r\u001b[?2004h"]
