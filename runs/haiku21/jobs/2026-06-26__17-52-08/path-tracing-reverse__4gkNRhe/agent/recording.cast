[346.978423, "i", "python3 << 'ENDPYTHON'\nwith open('image.ppm', 'r') as f:\n    f.readline()  # P3\n    f.readline()  # 800 600\n    f.readline()  # 255\n    colors = []\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) == 3:\n            colors.append((int(parts[0]), int(parts[1]), int(parts[2])))\n        if len(colors) >= 3200:  # First 100 rows\n            break\nprint('First 20 pixels:', colors[:20])\nprint('Last 20 of first 100:', colors[80:100])\nprint('Pixel at (0,0):', colors[0])\nprint('Pixel at (100,0):', colors[100])\nprint('Pixel at (400,0):', colors[400])\nprint('Total unique colors in sample:', len(set(colors[:1600])))\nENDPYTHON\n"]
