[498.306602, "o", "\u001b[?2004l\r\u001b[?2004h>                 g = (int)(218 - 23*u - 8*light_dot*5);\r\n\u001b[?2004l\r\u001b[?2004h>                 b = 220;\r\n\u001b[?2004l\r\u001b[?2004h>             } else {\r\n\u001b[?2004l\r\u001b[?2004h>                 r = (int)(165 - 20*u + 10*(rsq-1));\r\n\u001b[?2004l\r\u001b[?2004h>                 g = (int)(218 - 30*u + 8*(rsq-1));\r\n\u001b[?2004l\r\u001b[?2004h>                 b = 220;\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             if (r < 0) r = 0; if (r > 255) r = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             if (g < 0) g = 0; if (g > 255) g = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             if (b < 0) b = 0; if (b > 255) b = 255;\r\n\u001b[?2004l\r\u001b[?2004h>             \r\n\u001b[?2004l\r\u001b[?2004h>             fprintf(f, \"%d %d %d\\n\", r, g, b);\r\n\u001b[?2004l\r\u001b[?2004h>         }\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     fclose(f);\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Rendering complete\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Wrote image to image.ppm\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     printf(\"Done.\\n\");\r\n\u001b[?2004l\r\u001b[?2004h>     return 0;\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> NEWCODE\r\n\u001b[?2004l\r"]
