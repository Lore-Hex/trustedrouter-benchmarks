[497.369468, "o", "First 10 pixels of row 0: [(159, 197, 255), (159, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255)]\r\nPixels 100-110: [(155, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255), (154, 195, 255)]\r\nPixels 400-410: [(146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255), (146, 190, 255)]\r\nPixels 790-800 (end of row 0): [(158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (159, 197, 255), (159, 197, 255)]\r\nPixels 800-810 (start of row 1): [(159, 197, 255), (159, 197, 255), (159, 197, 255), (159, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255), (158, 197, 255)]\r\n\r\nB channel values from first row:\r\nB values at x=[0,100,200,...,700]: [255, 255, 255, 255, 255, 255, 255, 255]\r\n"]
