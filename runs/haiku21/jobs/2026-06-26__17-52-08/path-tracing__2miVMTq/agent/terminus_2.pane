[?2004l[?2004h>         data.append((row, r, g, b))
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> rows = np.array([x[0] for x in data])
[?2004l[?2004h> r_vals = np.array([x[1] for x in data])
[?2004l[?2004h> g_vals = np.array([x[2] for x in data])
[?2004l[?2004h> coef_r = np.polyfit(rows, r_vals, 4)
[?2004l[?2004h> coef_g = np.polyfit(rows, g_vals, 4)
