[?2004l[?2004h> print('G coef:',coef_g)
[?2004l[?2004h> err_r = np.polyval(coef_r, rows) - r_vals
[?2004l[?2004h> err_g = np.polyval(coef_g, rows) - g_vals
[?2004l[?2004h> print(f'R RMSE: {np.sqrt(np.mean(err_r**2)):.4f}')
