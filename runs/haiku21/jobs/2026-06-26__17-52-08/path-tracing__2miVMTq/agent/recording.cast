[779.608473, "i", "cat > sample_grad.py << 'GRADSAMPL'\ndata = []\nwith open('/app/image.ppm') as f:\n    for _ in range(3): f.readline()\n    for row in range(801):\n        for _ in range(2399): f.readline()\n        color = f.readline().strip()\n        r,g,b = map(int, color.split())\n        data.append((row, r, g, b))\nimport numpy as np\nrows = np.array([x[0] for x in data])\nr_vals = np.array([x[1] for x in data])\ng_vals = np.array([x[2] for x in data])\ncoef_r = np.polyfit(rows, r_vals, 4)\ncoef_g = np.polyfit(rows, g_vals, 4)\nprint('R coef:',coef_r)\nprint('G coef:',coef_g)\nerr_r = np.polyval(coef_r, rows) - r_vals\nerr_g = np.polyval(coef_g, rows) - g_vals\nprint(f'R RMSE: {np.sqrt(np.mean(err_r**2)):.4f}')\nprint(f'G RMSE: {np.sqrt(np.mean(err_g**2)):.4f}')\nGRADSAMPL\n"]
[779.610575, "o", "cat > sample_grad.py << 'GRADSAMPL'\r\n\u001b[?2004l\r\u001b[?2004h> data = []\r\n\u001b[?2004l\r\u001b[?2004h> with open('/app/image.ppm') as f:\r\n\u001b[?2004l\r\u001b[?2004h>     for _ in range(3): f.readline()\r\n\u001b[?2004l\r\u001b[?2004h>     for row in range(801):\r\n\u001b[?2004l\r\u001b[?2004h>         for _ in range(2399): f.readline()\r\n\u001b[?2004l\r\u001b[?2004h>         color = f.readline().strip()\r\n\u001b[?2004l\r\u001b[?2004h>         r,g,b = map(int, color.split())\r\n\u001b[?2004l\r\u001b[?2004h>         data.append((row, r, g, b))\r\n\u001b[?2004l\r\u001b[?2004h> import numpy as np\r\n\u001b[?2004l\r\u001b[?2004h> rows = np.array([x[0] for x in data])\r\n\u001b[?2004l\r\u001b[?2004h> r_vals = np.array([x[1] for x in data])\r\n\u001b[?2004l\r\u001b[?2004h> g_vals = np.array([x[2] for x in data])\r\n\u001b[?2004l\r\u001b[?2004h> coef_r = np.polyfit(rows, r_vals, 4)\r\n\u001b[?2004l\r\u001b[?2004h> coef_g = np.polyfit(rows, g_vals, 4)\r\n\u001b[?2004l\r\u001b[?2004h> print('R coef:',coef_r)\r\n\u001b[?2004l\r\u001b[?2004h> print('G coef:',coef_g)\r\n\u001b[?2004l\r\u001b[?2004h> err_r = np.polyval(coef_r, rows) - r_vals\r\n\u001b[?2004l\r\u001b[?2004h> err_g = np.polyval(coef_g, rows) - g_vals\r\n\u001b[?2004l\r\u001b[?2004h> print(f'R RMSE: {np.sqrt(np.mean(err_r**2)):.4f}')\r\n\u001b[?2004l\r\u001b[?2004h> print(f'G RMSE: {np.sqrt(np.mean(err_g**2)):.4f}')\r\n\u001b[?2004l\r\u001b[?2004h> GRADSAMPL\r\n\u001b[?2004l\r"]
