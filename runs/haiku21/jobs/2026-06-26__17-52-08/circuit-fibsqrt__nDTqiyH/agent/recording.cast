[688.869259, "o", "        lt_kp1[k] = cmp_lt if cmp_lt is not None else None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869318, "o", "    # Compute k_match[k] = ge_k[k] AND lt_kp1[k]"]
[688.869323, "o", "\r\n"]
[688.869358, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[688.869394, "o", "    k_match = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869419, "o", "    for k in range(100):\r\n\u001b[?2004l\r"]
[688.869448, "o", "\u001b[?2004h>         ksq = k * k"]
[688.869473, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[688.869517, "o", ">         if ksq >= (1 << 32):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869543, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869573, "o", "        km = sig\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869616, "o", "        if lt_kp1[k] is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869731, "o", "            f.write(f\"out{km}=out{ge_k[k]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.8698, "o", "            f.write(f\"out{km}=out{ge_k[k]} & out{lt_kp1[k]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>         sig += 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.869838, "o", "        k_match[k] = km\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[688.869869, "o", "\u001b[?2004h> "]
[688.869941, "o", "    # Output: multiplex fib values\r\n\u001b[?2004l\r\u001b[?2004h>     for b in range(32):\r\n\u001b[?2004l\r\u001b[?2004h>         result = sig\r\n\u001b[?2004l\r"]
[688.869969, "o", "\u001b[?2004h> "]
[688.870017, "o", "        f.write(f\"out{sig}=0\\n\")\r\n\u001b[?2004l\r"]
[688.870034, "o", "\u001b[?2004h"]
[688.87004, "o", "> "]
[688.870076, "o", "        sig += 1\r\n\u001b[?2004l\r"]
[688.870138, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.870172, "o", "        for k in range(100):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.870177, "o", "            ksq = k * k\r\n\u001b[?2004l\r\u001b[?2004h"]
[688.870222, "o", ">             if ksq >= (1 << 32):\r\n"]
[688.870259, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[688.870302, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[688.870314, "o", "\u001b[?2004h> "]
[688.870351, "o", "            and_sig = sig\r\n\u001b[?2004l\r\u001b[?2004h"]
[688.870355, "o", "> "]
[688.870456, "o", "            f.write(f\"out{and_sig}=out{k_match[k]} & out{fib_sigs[k][b]}\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.870499, "o", "            sig += 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.870507, "o", "            or_sig = sig\r\n\u001b[?2004l\r"]
[688.87051, "o", "\u001b[?2004h"]
[688.87054, "o", "> "]
[688.870602, "o", "            f.write(f\"out{or_sig}=out{result} | out{and_sig}\\n\")\r\n"]
[688.870644, "o", "\u001b[?2004l\r\u001b[?2004h"]
[688.870651, "o", ">             sig += 1"]
[688.870662, "o", "\r\n"]
[688.870686, "o", "\u001b[?2004l\r"]
[688.870727, "o", "\u001b[?2004h"]
[688.870735, "o", ">             result = or_sig\r\n\u001b[?2004l\r\u001b[?2004h"]
[688.870816, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> print(f\"Total signals: {sig}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[688.870854, "o", "OPTIMIZED\r\n\u001b[?2004l\r"]
[688.953453, "o", "Total signals: 22296\r\n"]
[688.957704, "o", "\u001b[?2004hroot@b91058a2fe67:/app# "]
