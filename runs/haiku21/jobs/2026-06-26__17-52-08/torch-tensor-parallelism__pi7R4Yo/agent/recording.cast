[96.955392, "o", "import torch\r\nimport torch.nn as nn\r\nfrom torch.distributed import get_world_size, get_rank\r\nimport torch.distributed\r\n\r\n\r\nclass ColumnParallelLinear(nn.Module):\r\n    \"\"\"Column-parallel linear layer.\r\n    \r\n    Splits the weight matrix by rows (output dimension).\r\n    Each rank computes a subset of output features.\r\n    Outputs from all ranks are concatenated via all_gather.\r\n    \"\"\"\r\n    \r\n    def __init__(self, in_features, out_features, bias, master_weight):\r\n        super().__init__()\r\n        self.in_features = in_features\r\n        self.out_features = out_features\r\n        self.use_bias = bias\r\n        \r\n"]
[96.956418, "o", "\u001b[?2004hroot@fc5c75e9ab67:/app# "]
