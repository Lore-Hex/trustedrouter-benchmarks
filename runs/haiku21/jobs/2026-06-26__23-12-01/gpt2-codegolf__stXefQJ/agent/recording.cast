[121.901442, "i", "cat > /app/gpt2.c << 'EOF'\n#include<stdio.h>\n#include<stdlib.h>\n#include<string.h>\n#include<math.h>\n#define V 50257\n#define D 768\nchar*bpe[V];int bc=0;\nfloat dot(float*a,float*b,int n){float s=0;for(int i=0;i<n;i++)s+=a[i]*b[i];return s;}\nint tok(float*we,char*w){for(int i=0;i<bc;i++)if(!strcmp(bpe[i],w))return i;return 0;}\nint main(int ac,char**av){\nif(ac<4)return 1;FILE*f=fopen(av[1],\"rb\"),*v=fopen(av[2],\"r\");if(!f||!v)return 1;\nchar ln[256];while(fgets(ln,256,v)&&bc<V){ln[strcspn(ln,\"\\n\")]=0;bpe[bc]=malloc(strlen(ln)+1);strcpy(bpe[bc++],ln);}\nfclose(v);float*we=malloc(V*D*4);fread(we,4,V*D,f);\nchar in[4096],*p,*s;strncpy(in,av[3],4095);int ids[1024],n=0;\nfor(p=strtok(in,\" \");p&&n<1024;p=strtok(0,\" \"))for(int i=0;i<bc;i++)if(!strcmp(bpe[i],p)){ids[n++]=i;break;}\nfloat h[D],l[V];for(int g=0;g<20;g++){\nmemset(h,0,D*4);for(int i=0;i<n;i++)for(int j=0;j<D;j++)h[j]+=we[ids[i]*D+j];\nfor(int j=0;j<D;j++)h[j]/=(n+1);for(int i=0;i<V;i++)l[i]=dot(h,we+i*D,D);\nint m=0;for(int i=1;i<V;i++)if(l[i]>l[m])m=i;printf(\"%s\",bpe[m]);if(g<19)putchar(32);if(n<1023)ids[n++]=m;}\nfclose(f);free(we);return 0;}\nEOF\n"]
[121.902242, "o", "cat > /app/gpt2.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include<stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<stdlib.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<string.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<math.h>\r\n\u001b[?2004l\r\u001b[?2004h> #define V 50257\r\n\u001b[?2004l\r\u001b[?2004h> #define D 768\r\n\u001b[?2004l\r\u001b[?2004h> char*bpe[V];int bc=0;\r\n\u001b[?2004l\r\u001b[?2004h> float dot(float*a,float*b,int n){float s=0;for(int i=0;i<n;i++)s+=a[i]*b[i];return s;}\r\n\u001b[?2004l\r\u001b[?2004h> int tok(float*we,char*w){for(int i=0;i<bc;i++)if(!strcmp(bpe[i],w))return i;return 0;}\r\n\u001b[?2004l\r\u001b[?2004h> "]
