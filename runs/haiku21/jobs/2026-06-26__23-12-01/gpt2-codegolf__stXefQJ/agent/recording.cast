[174.102331, "i", "cat > /app/gpt2.c << 'EOF'\n#include<stdio.h>\n#include<stdlib.h>\n#include<string.h>\n#include<math.h>\n#define V 50257\n#define D 768\nchar*bpe[V];int bc=0;float dot(float*a,float*b,int n){float s=0;for(int i=0;i<n;i++)s+=a[i]*b[i];return s;}\nint find_tok(char*w){for(int i=0;i<bc;i++)if(!strcmp(bpe[i],w))return i;return 0;}\nint main(int ac,char**av){\nif(ac<4)return 1;FILE*f=fopen(av[1],\"rb\"),*v=fopen(av[2],\"r\");if(!f||!v)return 1;\nchar ln[512];while(fgets(ln,512,v)&&bc<V){ln[strcspn(ln,\"\\n\")]=0;bpe[bc]=malloc(strlen(ln)+1);strcpy(bpe[bc++],ln);}\nfclose(v);float*we=malloc(V*D*sizeof(float));fread(we,sizeof(float),V*D,f);\nint ids[1024],n=0;char*inp=av[3],*p,buf[4096];strncpy(buf,inp,4095);\nchar*sav=buf;while(n<1024&&(p=strtok(sav,\" \"))) {sav=NULL;for(int i=0;i<bc;i++)if(!strcmp(bpe[i],p)){ids[n++]=i;break;}}\nif(n==0)ids[n++]=0;float h[D]={0};for(int i=0;i<n;i++)for(int j=0;j<D;j++)h[j]+=we[ids[i]*D+j];\nfor(int j=0;j<D;j++)h[j]/=n;for(int g=0;g<20;g++){\nint mx=0;float mxv=dot(h,we,D);for(int i=1;i<V;i++){float s=dot(h,we+i*D,D);if(s>mxv){mxv=s;mx=i;}}\nprintf(\"%s\",bpe[mx]);if(g<19)putchar(32);ids[n++]=mx;\nif(n>1){for(int j=0;j<D;j++)h[j]=(h[j]*(n-1)+we[mx*D+j])/n;}}\nfclose(f);free(we);return 0;}\nEOF\n"]
[174.103235, "o", "cat > /app/gpt2.c << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #include<stdio.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<stdlib.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<string.h>\r\n\u001b[?2004l\r\u001b[?2004h> #include<math.h>\r\n\u001b[?2004l\r\u001b[?2004h> #define V 50257\r\n\u001b[?2004l\r\u001b[?2004h> #define D 768\r\n\u001b[?2004l\r\u001b[?2004h> char*bpe[V];int bc=0;float dot(float*a,float*b,int n){float s=0;for(int i=0;i<n;i++)s+=a[i]*b[i];return s;}\r\n\u001b[?2004l\r\u001b[?2004h> int find_tok(char*w){for(int i=0;i<bc;i++)if(!strcmp(bpe[i],w))return i;return 0;}\r\n\u001b[?2004l\r\u001b[?2004h> int main(int ac,char**av){\r\n\u001b[?2004l\r\u001b[?2004h> if(ac<4)return 1;FILE*f=fopen(av[1],\"rb\"),*v=fopen(av[2],\"r\");if(!f||!v)return 1;\r\n\u001b[?2004l\r\u001b[?2004h> "]
