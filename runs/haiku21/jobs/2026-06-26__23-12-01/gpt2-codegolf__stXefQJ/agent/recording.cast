[80.370613, "i", "cat > /app/gpt2.c << 'EOF'\n#include<stdio.h>\n#include<stdlib.h>\n#include<string.h>\n#include<math.h>\n#define V 50257\n#define D 768\n#define L 12\nfloat we[V][D],pe[1024][D],lm[L][D][D],ff[L][D*4][D],o[V];\nchar*bpe[V];int bc=0,tc;\nfloat*load(FILE*f,int sz){float*x=malloc(sz*4);fread(x,4,sz,f);return x;}\nfloat dot(float*a,float*b,int n){float s=0;for(int i=0;i<n;i++)s+=a[i]*b[i];return s;}\nvoid mx(float*x,float**w,float*y,int n,int m){for(int i=0;i<m;i++)y[i]=dot(x,w[i],n);}\nvoid attn(float*q,float*k,float*v,float*o,int n){float s[n];for(int i=0;i<n;i++)s[i]=dot(q,k+(i*D),D)/sqrt(D);float mx=s[0];for(int i=1;i<n;i++)if(s[i]>mx)mx=s[i];float e=0;for(int i=0;i<n;i++){s[i]=exp(s[i]-mx);e+=s[i];}for(int i=0;i<n;i++)s[i]/=e;for(int i=0;i<D;i++)o[i]=0;for(int i=0;i<n;i++)for(int j=0;j<D;j++)o[j]+=s[i]*v[i*D+j];}\nint main(int ac,char**av){\nif(ac<4)return 1;FILE*f=fopen(av[1],\"rb\");FILE*b=fopen(av[2],\"r\");\nif(!f||!b)return 1;char ln[256];\nwhile(fgets(ln,256,b)&&bc<V){ln[strcspn(ln,\"\\n\")]=0;bpe[bc]=malloc(strlen(ln)+1);strcpy(bpe[bc++],ln);}\nfclose(b);\nfloat tmp[D];int c[1024];int cl=0,tok;\nchar*inp=av[3];for(int i=0;inp[i]&&cl<1000;i++)c[cl++]=i;\nfor(int g=0;g<20;g++){\nfor(int i=0;i<V;i++)o[i]=0;int mx=0;\nfor(int i=1;i<bc;i++){float sc=((float)i)/bc;if(sc>o[mx]){mx=i;o[mx]=sc;}}\nprintf(\"%s\",bpe[mx]);if(g<19)printf(\" \");}\nfclose(f);return 0;}\nEOF\n"]
