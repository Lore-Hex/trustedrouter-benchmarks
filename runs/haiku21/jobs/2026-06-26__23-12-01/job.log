Sending keys: ['cat > /app/run.py << \'EOF\'\nimport asyncio\nfrom typing import Callable, Awaitable\n\n\nasync def run_tasks(tasks: list[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:\n    """\n    Run tasks concurrently with a maximum concurrency limit.\n    \n    Ensures that cleanup code (finally blocks) in tasks still runs even\n    if the function is interrupted via KeyboardInterrupt.\n    \n    Args:\n        tasks: List of callables that return awaitables (async functions/coroutines)\n        max_concurrent: Maximum number of tasks to run concurrently\n    \n    Raises:\n        KeyboardInterrupt: If interrupted, after all tasks have completed their cleanup\n    """\n    semaphore = asyncio.Semaphore(max_concurrent)\n    task_objects = []\n    \n    async def run_with_semaphore(task: Callable[[], Awaitable[None]]) -> None:\n        """Run a task with semaphore-based concurrency control."""\n        async with semaphore:\n            await task()\n    \n    try:\n        # Create and schedule all tasks upfront\n        # They will be rate-limited by the semaphore\n        task_objects = [\n            asyncio.create_task(run_with_semaphore(task)) for task in tasks\n        ]\n        \n        # Wait for all tasks to complete\n        # return_exceptions=True ensures exceptions don\'t stop the wait\n        await asyncio.gather(*task_objects, return_exceptions=True)\n    \n    except KeyboardInterrupt:\n        # On interrupt, cancel all pending tasks\n        # This will cause CancelledError in the tasks, triggering any finally blocks\n        for task_obj in task_objects:\n            if not task_obj.done():\n                task_obj.cancel()\n        \n        # Wait for all tasks to finish (cleanup code will run)\n        await asyncio.gather(*task_objects, return_exceptions=True)\n        \n        # Re-raise the interrupt after cleanup\n        raise\nEOF'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
