[27.745579, "i", "python3 -c \"\nimport asyncio\nfrom run import run_tasks\n\nresults = []\n\nasync def make_task(i):\n    async def task():\n        try:\n            await asyncio.sleep(0.05)\n            results.append(i)\n        finally:\n            results.append(f'cleanup_{i}')\n    return task\n\nasync def main():\n    tasks = [await make_task(i) for i in range(6)]\n    await run_tasks(tasks, max_concurrent=2)\n    print('results:', results)\n    # Verify max 2 ran concurrently by checking order\n    print('TEST PASSED' if len(results) == 12 else 'TEST FAILED')\n\nasyncio.run(main())\n\"\n"]
