[?2004h> import asyncio
[?2004l[?2004h> from typing import Callable, Awaitable
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> async def run_tasks(
[?2004l[?2004h>     tasks: list[Callable[[], Awaitable[None]]],
[?2004l[?2004h>     max_concurrent: int,
[?2004l[?2004h> ) -> None:
[?2004l[?2004h>     """Run async tasks with a maximum concurrency limit.
[?2004l[?2004h> 
[?2004l[?2004h>     Ensures cleanup code (finally blocks) in tasks still runs
[?2004l[?2004h>     even when cancelled via keyboard interrupt.
[?2004l[?2004h>     """
[?2004l[?2004h>     semaphore = asyncio.Semaphore(max_concurrent)
[?2004l[?2004h> 
[?2004l[?2004h>     async def run_with_semaphore(task: Callable[[], Awaitable[None]]) -> None:
[?2004l[?2004h>         async with semaphore:
[?2004l[?2004h>             await task()
[?2004l[?2004h> 
[?2004l[?2004h>     running_tasks = [
[?2004l[?2004h>         asyncio.create_task(run_with_semaphore(task)) for task in tasks
[?2004l[?2004h>     ]
[?2004l[?2004h> 
[?2004l[?2004h>     try:
[?2004l[?2004h>         await asyncio.gather(*running_tasks)
[?2004l[?2004h>     except (asyncio.CancelledError, KeyboardInterrupt):
[?2004l[?2004h>         # Cancel all tasks that haven't finished yet
[?2004l[?2004h>         for t in running_tasks:
[?2004l[?2004h>             if not t.done():
[?2004l[?2004h>                 t.cancel()
[?2004l[?2004h>         # Wait for all tasks to finish, including their cleanup (finally blocks)
[?2004l[?2004h>         await asyncio.gather(*running_tasks, return_exceptions=True)
[?2004l[?2004h>         raise
