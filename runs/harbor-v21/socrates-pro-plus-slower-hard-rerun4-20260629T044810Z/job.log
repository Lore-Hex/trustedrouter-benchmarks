Sending keys: ['cat > /app/crop_extract.py << \'EOF\'\nimport os\nimport subprocess\nimport re\nimport tempfile\nfrom PIL import Image\n\n# Focus on frames from /app/frames (1fps)\nframes = sorted([f for f in os.listdir(\'/app/frames\') if f.endswith(\'.png\')])\nprint(f"Processing {len(frames)} frames...")\n\n# First frame to get image dimensions\nsample = Image.open(os.path.join(\'/app/frames\', frames[0]))\nw, h = sample.size\nprint(f"Image size: {w}x{h}")\n\n# Crop bottom portion (command prompt area) - bottom 20% of image\ncrop_top = int(h * 0.75)\n\nprev_text = ""\nfor i, frame in enumerate(frames):\n    frame_path = os.path.join(\'/app/frames\', frame)\n    img = Image.open(frame_path)\n    \n    # Crop bottom portion\n    cropped = img.crop((0, crop_top, w, h))\n    \n    # Save to temp and OCR\n    with tempfile.NamedTemporaryFile(suffix=\'.png\', delete=False) as tmp:\n        tmp_path = tmp.name\n        cropped.save(tmp_path)\n    \n    result = subprocess.run([\'tesseract\', tmp_path, \'stdout\'], \n                         capture_output=True, text=True, timeout=10)\n    os.unlink(tmp_path)\n    \n    text = result.stdout.strip()\n    if text != prev_text:  # Only print when text changes\n        print(f"\\n=== Frame {i+1} ===")\n        print(text)\n        prev_text = text\n\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
