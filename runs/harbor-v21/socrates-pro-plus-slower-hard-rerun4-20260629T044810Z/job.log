Sending keys: ['cat << \'PYEOF\' > /app/discover_dag.py\nimport pandas as pd\nimport numpy as np\nfrom scipy import stats\nfrom itertools import combinations\n\n# Load data\ndf = pd.read_csv(\'/app/bn_sample_10k.csv\')\nnodes = list(df.columns)\nn = len(df)\nprint(f"Nodes: {nodes}")\nprint(f"N samples: {n}")\nprint(f"\\nCorrelation matrix:")\nprint(df.corr().round(3))\n\n# PC Algorithm - Phase 1: Learn skeleton via conditional independence tests\n# Using partial correlation test at alpha=0.01\nalpha = 0.01\n\ndef partial_corr_test(df, x, y, z_list, n):\n    """Test if x and y are conditionally independent given z_list using Fisher\'s z transform."""\n    if len(z_list) == 0:\n        r = df[x].corr(df[y])\n    else:\n        # Compute partial correlation using regression residuals\n        from sklearn.linear_model import LinearRegression\n        Z = df[list(z_list)].values\n        \n        reg_x = LinearRegression().fit(Z, df[x].values)\n        resid_x = df[x].values - reg_x.predict(Z)\n        \n        reg_y = LinearRegression().fit(Z, df[y].values)\n        resid_y = df[y].values - reg_y.predict(Z)\n        \n        r = np.corrcoef(resid_x, resid_y)[0, 1]\n    \n    if abs(r) >= 1.0:\n        return False, 0.0  # Not independent\n    \n    # Fisher\'s z transform\n    z = 0.5 * np.log((1 + r) / (1 - r))\n    se = 1.0 / np.sqrt(n - len(z_list) - 3)\n    z_stat = abs(z) / se\n    p_value = 2 * (1 - stats.norm.cdf(z_stat))\n    \n    return p_value > alpha, p_value\n\n# Initialize complete undirected graph\nedges = set()\nfor i, j in combinations(range(len(nodes)), 2):\n    edges.add((i, j))\n\nprint(f"\\nInitial edges: {len(edges)}")\n\n# PC Phase 1: Remove edges based on conditional independence\nsep_set = {}  # Separating sets\nfor level in range(len(nodes) - 1):\n    print(f"\\nLevel {level} conditioning sets:")\n    edges_to_remove = []\n    for (i, j) in list(edges):\n        neighbors_i = {k for k in range(len(nodes)) if (min(i,k), max(i,k)) in edges and k != j}\n        neighbors_j = {k for k in range(len(nodes)) if (min(j,k), max(j,k)) in edges and k != i}\n        possible_z = neighbors_i | neighbors_j\n        \n        for z_subset in combinations(possible_z, level):\n            indep, p_val = partial_corr_test(df, nodes[i], nodes[j], [nodes[k] for k in z_subset], n)\n            if indep:\n                edges_to_remove.append((i, j))\n                sep_set[(i, j)] = set(z_subset)\n                sep_set[(j, i)] = set(z_subset)\n                print(f"  {nodes[i]} _||_ {nodes[j]} | {[nodes[k] for k in z_subset]} (p={p_val:.4f})")\n                break\n    \n    for e in edges_to_remove:\n        edges.discard(e)\n    \n    print(f"  Remaining edges: {len(edges)}")\n\nprint(f"\\nSkeleton edges: {len(edges)}")\nfor i, j in sorted(edges):\n    print(f"  {nodes[i]} -- {nodes[j]}")\n\n# PC Phase 2: Orient v-structures\noriented = set()\nfor (i, j) in edges:\n    neighbors_i = {k for k in range(len(nodes)) if (min(i,k), max(i,k)) in edges and k != j}\n    for k in neighbors_i:\n        if (min(j,k), max(j,k)) not in edges:\n            # k and j are not adjacent, i is a collider: k -> i <- j\n            oriented.add((k, i))\n            oriented.add((j, i))\n            print(f"\\nV-structure: {nodes[k]} -> {nodes[i]} <- {nodes[j]}")\n\nprint(f"\\nOriented edges from v-structures: {len(oriented)}")\nfor i, j in sorted(oriented):\n    print(f"  {nodes[i]} -> {nodes[j]}")\n\n# Apply rules: U has no parents\nprint("\\nApplying rules:")\nu_idx = nodes.index(\'U\')\nfinal_edges = []  # list of (parent, child) tuples\n\n# First, handle v-structure orientations\noriented_set = set()\nfor i, j in oriented:\n    if i != u_idx:  # Don\'t add edges into U\n        oriented_set.add((i, j))\n        final_edges.append((nodes[i], nodes[j]))\n\n# For remaining skeleton edges not yet oriented\nfor (i, j) in edges:\n    if (i, j) in oriented or (j, i) in oriented:\n        continue\n    \n    # Check if one is U\n    if i == u_idx:\n        # U -> j (U has no parents)\n        final_edges.append((nodes[i], nodes[j]))\n        print(f"  {nodes[i]} -> {nodes[j]} (U has no parents)")\n    elif j == u_idx:\n        # U -> i (U has no parents)\n        final_edges.append((nodes[j], nodes[i]})\n        print(f"  {nodes[j]} -> {nodes[i]} (U has no parents)")\n    else:\n        # Alphabetical: earlier letter is child\n        if nodes[i] < nodes[j]:\n            # nodes[i] is child: j -> i\n            final_edges.append((nodes[j], nodes[i]))\n            print(f"  {nodes[j]} -> {nodes[i]} (alphabetical: {nodes[i]} is child)")\n        else:\n            # nodes[j] is child: i -> j\n            final_edges.append((nodes[i], nodes[j]))\n            print(f"  {nodes[i]} -> {nodes[j]} (alphabetical: {nodes[j]} is child)")\n\n# Remove duplicates\nfinal_edges = list(set(final_edges))\nprint(f"\\nFinal DAG edges ({len(final_edges)}):")\nfor p, c in sorted(final_edges):\n    print(f"  {p} -> {c}")\n\n# Save DAG\ndag_df = pd.DataFrame(final_edges, columns=[\'from\', \'to\'])\ndag_df = dag_df[[\'to\', \'from\']]  # Reorder to match format: to,from\ndag_df.to_csv(\'/app/learned_dag.csv\', index=False)\nprint("\\nSaved learned_dag.csv")\nprint(dag_df.to_string(index=False))\n\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
