Sending keys: ['cat > /app/clean_extract.py << \'EOF\'\nimport os\nimport subprocess\nimport re\nimport tempfile\nfrom PIL import Image, ImageOps, ImageEnhance\n\nframes = sorted([f for f in os.listdir(\'/app/frames2\') if f.endswith(\'.png\')])\nprint(f"Total frames: {len(frames)}")\n\ndef preprocess_and_ocr(frame_path):\n    try:\n        img = Image.open(frame_path)\n        img_gray = img.convert(\'L\')\n        # Enhance contrast\n        enhancer = ImageEnhance.Contrast(img_gray)\n        img_enhanced = enhancer.enhance(2.0)\n        # Invert\n        img_inverted = ImageOps.invert(img_enhanced)\n        # Save to temp file\n        with tempfile.NamedTemporaryFile(suffix=\'.png\', delete=False) as tmpfile:\n            tmp_path = tmpfile.name\n            img_inverted.save(tmp_path)\n        result = subprocess.run([\'tesseract\', tmp_path, \'stdout\'], \n                             capture_output=True, text=True, timeout=10)\n        os.unlink(tmp_path)\n        return result.stdout\n    except Exception as e:\n        return ""\n\n# Process all frames and collect data\nframe_data = []\nfor i, frame in enumerate(frames):\n    frame_path = os.path.join(\'/app/frames2\', frame)\n    text = preprocess_and_ocr(frame_path)\n    \n    # Extract moves counter\n    moves_match = re.search(r\'Moves?[:\\s]+(\\d+)\', text)\n    moves = int(moves_match.group(1)) if moves_match else -1\n    \n    # Extract command (last line with >)\n    command = ""\n    lines = text.split(\'\\n\')\n    for line in reversed(lines):\n        if \'>\' in line:\n            parts = line.split(\'>\', 1)\n            if len(parts) > 1 and parts[1].strip():\n                command = parts[1].strip().lower()\n                break\n    \n    frame_data.append((i, moves, command, text))\n\n# Find actual commands by tracking moves changes\ncommands = []\nprev_moves = -1\nseen_commands = set()\n\nfor idx, moves, command, text in frame_data:\n    if moves > prev_moves and command:\n        # Clean up common OCR artifacts\n        cmd = command.rstrip(\'.\')  # Remove trailing dots\n        cmd = cmd.rstrip(\'_\')     # Remove trailing underscores\n        cmd = re.sub(r\'\\s+\', \' \', cmd)  # Normalize spaces\n        \n        # Skip obvious garbage\n        if len(cmd) > 1 and not re.match(r\'^[a-z]{1}$\', cmd):\n            # Only add if it\'s a new command (not duplicate of previous)\n            if not commands or commands[-1] != cmd:\n                commands.append(cmd)\n        prev_moves = moves\n\n# Write to solution.txt\nwith open(\'/app/solution.txt\', \'w\') as f:\n    for i, cmd in enumerate(commands, 1):\n        f.write(cmd + \'\\n\')\n        print(f"{i}. {cmd}")\n\nprint(f"\\nTotal commands: {len(commands)}")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
