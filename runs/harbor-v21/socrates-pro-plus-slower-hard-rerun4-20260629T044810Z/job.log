Sending keys: ['cat > /app/train5.py << \'PYEOF\'\nimport pandas as pd\nimport fasttext\nimport os\nimport re\nimport numpy as np\n\ndef clean_text(text):\n    text = str(text).lower()\n    text = text.replace(\'\\n\', \' \').replace(\'\\r\', \' \')\n    text = re.sub(r\'[^a-z0-9\\s]\', \' \', text)\n    text = re.sub(r\'\\s+\', \' \', text).strip()\n    return text\n\nprint(\'Loading data...\')\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\n# Use a 200K subset for faster autotune trials\nnp.random.seed(42)\nsubset_idx = np.random.choice(len(train_df), 200000, replace=False)\nsubset_df = train_df.iloc[subset_idx]\n\nprint(f\'Subset size: {len(subset_df)}\')\n\nprint(\'Writing subset train...\')\nwith open(\'/app/train_subset.txt\', \'w\') as f:\n    for _, row in subset_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Writing full train...\')\nwith open(\'/app/train_full.txt\', \'w\') as f:\n    for _, row in train_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Writing test...\')\nwith open(\'/app/test.txt\', \'w\') as f:\n    for _, row in test_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\n# Autotune on subset - no size constraint, 10 minutes\nprint(\'\\nRunning autotune (10 min, no size constraint)...\')\nmodel = fasttext.train_supervised(\n    input=\'/app/train_subset.txt\',\n    autotuneValidationFile=\'/app/test.txt\',\n    autotuneDuration=600,\n    thread=4,\n    verbose=2\n)\n\nprint(\'\\nEvaluating autotune model on test...\')\nn, p, r = model.test(\'/app/test.txt\')\nprint(f\'Subset autotune - Precision: {p:.4f}\')\n\n# Save autotune model temporarily to get model size\nmodel.save_model(\'/tmp/autotune_temp.bin\')\nprint(f\'Autotune model size: {os.path.getsize("/tmp/autotune_temp.bin")/(1024*1024):.1f} MB\')\n\n# Read the best hyperparameters from the autotune model\n# The autotune model stores best params, let\'s try to extract them\n# by reading the model args from the binary\nimport subprocess\nresult = subprocess.run([\'./fasttext\', \'autotune\', \'printargs\', \'/tmp/autotune_temp.bin\'], \n                       capture_output=True, text=True) if os.path.exists(\'./fasttext\') else None\n\nprint(\'\\nRetraining on full data with similar high-performing params...\')\n# Try manually with params that typically work well for this task\nmodel = fasttext.train_supervised(\n    input=\'/app/train_full.txt\',\n    lr=0.5,\n    epoch=50,\n    wordNgrams=2,\n    dim=150,\n    loss=\'softmax\',\n    bucket=2000000,\n    minCount=2,\n    thread=4,\n    verbose=2\n)\n\nprint(\'\\nEvaluating on test...\')\nn, p, r = model.test(\'/app/test.txt\')\nprint(f\'Full data model - Precision: {p:.4f}\')\n\nmodel.save_model(\'/app/model_full.bin\')\nsize_mb = os.path.getsize(\'/app/model_full.bin\') / (1024*1024)\nprint(f\'Full model size: {size_mb:.1f} MB\')\n\nif size_mb > 150:\n    print(\'\\nQuantizing...\')\n    model.quantize(input=\'/app/train_full.txt\', retrain=True, epoch=10, lr=0.25, thread=4, dsub=2, qnorm=True)\n    model.save_model(\'/app/model.bin\')\n    size_mb = os.path.getsize(\'/app/model.bin\') / (1024*1024)\n    n, p, r = model.test(\'/app/test.txt\')\n    print(f\'Quantized - Size: {size_mb:.1f} MB, Precision: {p:.4f}\')\nelse:\n    os.rename(\'/app/model_full.bin\', \'/app/model.bin\')\n    print(f\'Saved as /app/model.bin ({size_mb:.1f} MB)\')\n\nprint(\'\\nDone!\')\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
