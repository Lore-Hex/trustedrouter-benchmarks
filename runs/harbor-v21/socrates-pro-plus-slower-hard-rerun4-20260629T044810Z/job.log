Sending keys: ["cat > /app/train.py << 'PYEOF'\nimport pandas as pd\nimport fasttext\nimport os\nimport re\n\ndef clean_text(text):\n    # Remove newlines and collapse whitespace for fasttext format\n    text = str(text)\n    text = text.replace('\\n', ' ').replace('\\r', ' ')\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text\n\nprint('Loading train data...')\ntrain_df = pd.read_parquet('data/train-00000-of-00001.parquet')\nprint(f'Train shape: {train_df.shape}')\n\nprint('Loading test data...')\ntest_df = pd.read_parquet('data/test-00000-of-00001.parquet')\nprint(f'Test shape: {test_df.shape}')\n\n# Write train file in fasttext format\nprint('Writing train.txt...')\nwith open('/app/train.txt', 'w') as f:\n    for _, row in train_df.iterrows():\n        label = row['label']\n        text = clean_text(row['text'])\n        f.write(f'__label__{label} {text}\\n')\n\n# Write test file in fasttext format\nprint('Writing test.txt...')\nwith open('/app/test.txt', 'w') as f:\n    for _, row in test_df.iterrows():\n        label = row['label']\n        text = clean_text(row['text'])\n        f.write(f'__label__{label} {text}\\n')\n\nprint('Training model...')\nmodel = fasttext.train_supervised(\n    input='/app/train.txt',\n    lr=0.5,\n    epoch=25,\n    wordNgrams=2,\n    dim=50,\n    loss='softmax',\n    bucket=1000000,\n    minCount=2,\n    thread=4,\n    verbose=2\n)\n\nprint('\\nEvaluating on test set...')\nn_samples, precision, recall = model.test('/app/test.txt')\nprint(f'Test samples: {n_samples}')\nprint(f'Precision: {precision:.4f}')\nprint(f'Recall: {recall:.4f}')\n\n# Save unquantized first\nmodel.save_model('/app/model_unquant.bin')\nsize_mb = os.path.getsize('/app/model_unquant.bin') / (1024*1024)\nprint(f'Unquantized model size: {size_mb:.1f} MB')\n\nif size_mb > 150:\n    print('Model too large, quantizing...')\n    model.quantize(input='/app/train.txt', retrain=True, epoch=5, lr=0.25, thread=4)\n    model.save_model('/app/model.bin')\n    size_mb = os.path.getsize('/app/model.bin') / (1024*1024)\n    print(f'Quantized model size: {size_mb:.1f} MB')\n    \n    print('\\nRe-evaluating quantized model...')\n    n_samples, precision, recall = model.test('/app/test.txt')\n    print(f'Test samples: {n_samples}')\n    print(f'Precision: {precision:.4f}')\n    print(f'Recall: {recall:.4f}')\nelse:\n    os.rename('/app/model_unquant.bin', '/app/model.bin')\n    print(f'Model saved as /app/model.bin ({size_mb:.1f} MB)')\n\nprint('Done!')\nPYEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
