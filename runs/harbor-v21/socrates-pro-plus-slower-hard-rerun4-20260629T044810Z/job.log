Sending keys: ['cat > /app/train2.py << \'PYEOF\'\nimport pandas as pd\nimport fasttext\nimport os\nimport re\nimport random\n\ndef clean_text(text):\n    text = str(text).lower()\n    text = text.replace(\'\\n\', \' \').replace(\'\\r\', \' \')\n    text = re.sub(r\'[^a-z0-9\\s]\', \' \', text)\n    text = re.sub(r\'\\s+\', \' \', text).strip()\n    return text\n\nprint(\'Loading data...\')\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\n# Split train into train/val for autotune\nrandom.seed(42)\nval_size = 50000\ntrain_subset = train_df.iloc[:-val_size]\nval_df = train_df.iloc[-val_size:]\n\nprint(f\'Train subset: {len(train_subset)}, Val: {len(val_df)}, Test: {len(test_df)}\')\n\nprint(\'Writing train_subset.txt...\')\nwith open(\'/app/train_subset.txt\', \'w\') as f:\n    for _, row in train_subset.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Writing val.txt...\')\nwith open(\'/app/val.txt\', \'w\') as f:\n    for _, row in val_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Writing full train.txt...\')\nwith open(\'/app/train_full.txt\', \'w\') as f:\n    for _, row in train_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Writing test.txt...\')\nwith open(\'/app/test.txt\', \'w\') as f:\n    for _, row in test_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_text(row["text"])}\\n\')\n\nprint(\'Running autotune...\')\nmodel = fasttext.train_supervised(\n    input=\'/app/train_subset.txt\',\n    autotuneValidationFile=\'/app/val.txt\',\n    autotuneDuration=300,\n    autotuneModelSize=\'100M\',\n    thread=4,\n    verbose=2\n)\n\n# Get autotune results\nprint(\'\\nAutotune best parameters:\')\nprint(model.f.get_args())\n\n# Now retrain on full training data with best params\nargs = model.f.get_args()\nprint(\'\\nRetraining on full data with best params...\')\nmodel = fasttext.train_supervised(\n    input=\'/app/train_full.txt\',\n    lr=args.lr,\n    epoch=args.epoch,\n    wordNgrams=args.wordNgrams,\n    dim=args.dim,\n    loss=args.loss,\n    bucket=args.bucket,\n    minCount=args.minCount,\n    minn=args.minn,\n    maxn=args.maxn,\n    thread=4,\n    verbose=2\n)\n\nprint(\'\\nEvaluating on test set...\')\nn, p, r = model.test(\'/app/test.txt\')\nprint(f\'Unquantized - Samples: {n}, Precision: {p:.4f}, Recall: {r:.4f}\')\n\nmodel.save_model(\'/app/model_unquant2.bin\')\nsize_mb = os.path.getsize(\'/app/model_unquant2.bin\') / (1024*1024)\nprint(f\'Unquantized size: {size_mb:.1f} MB\')\n\n# Quantize\nprint(\'\\nQuantizing...\')\nmodel.quantize(input=\'/app/train_full.txt\', retrain=True, epoch=10, lr=0.5, thread=4, dsub=2, qnorm=True)\nmodel.save_model(\'/app/model.bin\')\nsize_mb = os.path.getsize(\'/app/model.bin\') / (1024*1024)\nprint(f\'Quantized size: {size_mb:.1f} MB\')\n\nn, p, r = model.test(\'/app/test.txt\')\nprint(f\'Quantized - Samples: {n}, Precision: {p:.4f}, Recall: {r:.4f}\')\n\nprint(\'\\nDone!\')\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
