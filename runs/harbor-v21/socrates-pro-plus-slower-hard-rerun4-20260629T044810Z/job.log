Sending keys: ['cat << \'PYEOF\' > /app/discover_dag2.py\nimport pandas as pd\nimport numpy as np\nfrom scipy import stats\nfrom itertools import combinations\nfrom sklearn.linear_model import LinearRegression\n\n# Load data\ndf = pd.read_csv(\'/app/bn_sample_10k.csv\')\nnodes = list(df.columns)\nn = len(df)\nprint(f"Nodes: {nodes}")\n\ndef partial_corr_test(df, x, y, z_list, n):\n    if len(z_list) == 0:\n        r = df[x].corr(df[y])\n    else:\n        Z = df[list(z_list)].values\n        reg_x = LinearRegression().fit(Z, df[x].values)\n        resid_x = df[x].values - reg_x.predict(Z)\n        reg_y = LinearRegression().fit(Z, df[y].values)\n        resid_y = df[y].values - reg_y.predict(Z)\n        r = np.corrcoef(resid_x, resid_y)[0, 1]\n    if abs(r) >= 1.0:\n        return False, 0.0\n    z = 0.5 * np.log((1 + r) / (1 - r))\n    se = 1.0 / np.sqrt(n - len(z_list) - 3)\n    z_stat = abs(z) / se\n    p_value = 2 * (1 - stats.norm.cdf(z_stat))\n    return p_value > 0.01, p_value\n\nalpha = 0.01\n# Initialize complete undirected graph\nedges = set()\nfor i, j in combinations(range(len(nodes)), 2):\n    edges.add((i, j))\n\nsep_set = {}\nfor level in range(len(nodes) - 1):\n    edges_to_remove = []\n    for (i, j) in list(edges):\n        neighbors_i = {k for k in range(len(nodes)) if (min(i,k), max(i,k)) in edges and k != j}\n        neighbors_j = {k for k in range(len(nodes)) if (min(j,k), max(j,k)) in edges and k != i}\n        possible_z = neighbors_i | neighbors_j\n        for z_subset in combinations(possible_z, level):\n            indep, p_val = partial_corr_test(df, nodes[i], nodes[j], [nodes[k] for k in z_subset], n)\n            if indep:\n                edges_to_remove.append((i, j))\n                sep_set[(i, j)] = set(z_subset)\n                sep_set[(j, i)] = set(z_subset)\n                print(f"  {nodes[i]} _||_ {nodes[j]} | {[nodes[k] for k in z_subset]} (p={p_val:.4f})")\n                break\n    for e in edges_to_remove:\n        edges.discard(e)\n\nprint(f"\\nSkeleton edges: {len(edges)}")\nfor i, j in sorted(edges):\n    print(f"  {nodes[i]} -- {nodes[j]}")\n\n# Phase 2: Orient v-structures with separating set check\n# For each triple X -- Z -- Y where X,Y non-adjacent:\n# Orient X -> Z <- Y iff Z NOT in SepSet(X,Y)\nprint("\\nV-structure analysis:")\ndirected = {}  # (parent, child) -> direction. We\'ll track as set of (from, to)\n\nfor z_idx in range(len(nodes)):\n    neighbors_z = [k for k in range(len(nodes)) if (min(z_idx,k), max(z_idx,k)) in edges and k != z_idx]\n    for x_idx, y_idx in combinations(neighbors_z, 2):\n        # Check if x and y are non-adjacent\n        if (min(x_idx, y_idx), max(x_idx, y_idx)) not in edges:\n            # Check if z is NOT in sep_set(x, y)\n            ss = sep_set.get((x_idx, y_idx), set())\n            if z_idx not in ss:\n                # Orient x -> z <- y (v-structure)\n                print(f"  V-structure: {nodes[x_idx]} -> {nodes[z_idx]} <- {nodes[y_idx]} (z={nodes[z_idx]} not in sep set)")\n                directed[(x_idx, z_idx)] = True\n                directed[(y_idx, z_idx)] = True\n            else:\n                print(f"  NO v-structure: {nodes[x_idx]} - {nodes[z_idx]} - {nodes[y_idx]} ({nodes[z_idx]} IS in sep set, orient outward)")\n                # z is in sep set, orient z -> x and z -> y\n                directed[(z_idx, x_idx)] = True\n                directed[(z_idx, y_idx)] = True\n\nprint(f"\\nDirected edges from v-structures: {len(directed)}")\nfor (p, c) in sorted(directed.keys()):\n    print(f"  {nodes[p]} -> {nodes[c]}")\n\n# Now apply remaining rules\n# U has no parents\nu_idx = nodes.index(\'U\')\n\nfinal_edges = set()\n\n# Add all directed edges from v-structure analysis\nfor (p, c) in directed:\n    if c == u_idx:\n        # Skip edges into U (U has no parents) - reverse them\n        print(f"  Reversing {nodes[p]} -> {nodes[c]}: U has no parents, so {nodes[c]} -> {nodes[p]}")\n        final_edges.add((c, p))\n    else:\n        final_edges.add((p, c))\n\n# For undirected edges in skeleton that are not yet oriented\nfor (i, j) in edges:\n    if (i, j) in directed or (j, i) in directed:\n        continue\n    # This edge has not been oriented yet\n    if i == u_idx:\n        final_edges.add((i, j))  # U -> j\n        print(f"  {nodes[i]} -> {nodes[j]} (U has no parents)")\n    elif j == u_idx:\n        final_edges.add((j, i))  # U -> i\n        print(f"  {nodes[j]} -> {nodes[i]} (U has no parents)")\n    else:\n        # Alphabetical: earlier letter is child\n        # "the node labeled with the letter that comes first in the alphabet is the child"\n        if nodes[i] < nodes[j]:\n            # i is child, j is parent: j -> i\n            final_edges.add((j, i))\n            print(f"  {nodes[j]} -> {nodes[i]} ({nodes[i]} comes first alphabetically, so is child)")\n        else:\n            final_edges.add((i, j))\n            print(f"  {nodes[i]} -> {nodes[j]} ({nodes[j]} comes first alphabetically, so is child)")\n\nprint(f"\\nFinal DAG ({len(final_edges)} edges):")\nfor p, c in sorted(final_edges):\n    print(f"  {nodes[p]} -> {nodes[c]}")\n\n# Save DAG in format to,from (meaning from -> to)\ndag_rows = []\nfor p, c in final_edges:\n    dag_rows.append({\'to\': nodes[c], \'from\': nodes[p]})\ndag_df = pd.DataFrame(dag_rows)\ndag_df.to_csv(\'/app/learned_dag.csv\', index=False)\nprint("\\nSaved learned_dag.csv:")\nprint(dag_df.to_string(index=False))\n\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
