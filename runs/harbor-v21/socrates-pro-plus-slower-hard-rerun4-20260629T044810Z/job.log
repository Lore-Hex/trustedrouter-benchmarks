Sending keys: ['cd /app && cat > extract_commands.py << \'EOF\'\nimport os\nimport subprocess\nimport re\n\ndef extract_commands_from_frame(frame_path):\n    """Run OCR on a frame and extract commands."""\n    try:\n        result = subprocess.run([\'tesseract\', frame_path, \'stdout\'], \n                             capture_output=True, text=True, timeout=10)\n        text = result.stdout\n        \n        commands = []\n        lines = text.split(\'\\n\')\n        \n        for line in lines:\n            # Look for lines that contain a \'>\' prompt\n            if \'>\' in line:\n                # Split at the \'>\' and take what\'s after it\n                parts = line.split(\'>\', 1)\n                if len(parts) > 1:\n                    command = parts[1].strip()\n                    # Filter out empty commands and common game text\n                    if command and not any(phrase in command.lower() for phrase in \n                                          [\'copyright\', \'revision\', \'serial number\', \'infocom\']):\n                        commands.append(command)\n        \n        return commands\n    except Exception as e:\n        print(f"Error processing {frame_path}: {e}")\n        return []\n\n# Get all frame files sorted\nframes = sorted([f for f in os.listdir(\'/app/frames\') if f.endswith(\'.png\')])\nprint(f"Processing {len(frames)} frames...")\n\nall_commands = []\nprev_commands = []  # To track previous frame\'s commands to avoid duplicates\n\nfor i, frame in enumerate(frames):\n    frame_path = os.path.join(\'/app/frames\', frame)\n    commands = extract_commands_from_frame(frame_path)\n    \n    # Only add new commands that weren\'t in the previous frame\n    for cmd in commands:\n        if cmd not in prev_commands and cmd not in all_commands:\n            all_commands.append(cmd)\n    \n    prev_commands = commands\n    \n    if i % 20 == 0:\n        print(f"Processed {i+1} frames, found {len(all_commands)} commands")\n\nprint(f"\\nTotal commands found: {len(all_commands)}")\nfor i, cmd in enumerate(all_commands, 1):\n    print(f"{i}. {cmd}")\n\n# Write to solution.txt\nwith open(\'/app/solution.txt\', \'w\') as f:\n    for cmd in all_commands:\n        f.write(cmd + \'\\n\')\n\nprint("\\nCommands written to /app/solution.txt")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
