Sending keys: ['cat > /app/targeted_extract.py << \'EOF\'\nimport os\nimport subprocess\nimport re\n\nframes = sorted([f for f in os.listdir(\'/app/frames\') if f.endswith(\'.png\')])\nprint(f"Processing {len(frames)} frames from /app/frames/ (1fps)...\\n")\n\nresults = []\nprev_moves = -1\n\nfor i, frame in enumerate(frames):\n    frame_path = os.path.join(\'/app/frames\', frame)\n    result = subprocess.run([\'tesseract\', frame_path, \'stdout\'], \n                         capture_output=True, text=True, timeout=10)\n    text = result.stdout\n    \n    # Extract moves\n    moves_match = re.search(r\'Moves?[:\\s]+(\\d+)\', text)\n    moves = int(moves_match.group(1)) if moves_match else -1\n    \n    # Find all lines with > (potential commands)\n    commands_in_frame = []\n    lines = text.split(\'\\n\')\n    for line in lines:\n        if \'>\' in line:\n            parts = line.split(\'>\', 1)\n            if len(parts) > 1:\n                cmd = parts[1].strip()\n                if cmd:\n                    commands_in_frame.append(cmd)\n    \n    # Store if moves changed\n    if moves != prev_moves and moves >= 0:\n        results.append({\n            \'frame\': i+1,\n            \'moves\': moves,\n            \'commands\': commands_in_frame,\n            \'text\': text\n        })\n        prev_moves = moves\n\n# Print summary\nprint(f"Found {len(results)} frames with moves counter changes.\\n")\nfor r in results:\n    cmd_str = \', \'.join(r[\'commands\']) if r[\'commands\'] else \'(empty)\'\n    print(f"Frame {r[\'frame\']:3d} | Moves {r[\'moves\']:3d} | Cmds: {cmd_str}")\n\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
