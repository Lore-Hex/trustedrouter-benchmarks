Sending keys: ['cat > /app/gridsearch.py << \'PYEOF\'\nimport fasttext\nimport os\nimport pandas as pd\nimport re\nimport numpy as np\n\ndef clean_raw(text):\n    text = str(text).replace(\'\\n\', \' \').replace(\'\\r\', \' \')\n    text = re.sub(r\'\\s+\', \' \', text).strip()\n    return text\n\nprint(\'Loading data...\', flush=True)\ntrain_df = pd.read_parquet(\'data/train-00000-of-00001.parquet\')\ntest_df = pd.read_parquet(\'data/test-00000-of-00001.parquet\')\n\n# Create 100K subset for fast grid search\nnp.random.seed(42)\nidx = np.random.choice(len(train_df), 100000, replace=False)\nsub_df = train_df.iloc[idx]\n\nprint(\'Writing subset (100K)...\', flush=True)\nwith open(\'/app/train_sub.txt\', \'w\') as f:\n    for _, row in sub_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_raw(row["text"])}\\n\')\n\nprint(\'Writing raw test...\', flush=True)\nwith open(\'/app/test_raw.txt\', \'w\') as f:\n    for _, row in test_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_raw(row["text"])}\\n\')\n\nprint(\'Writing raw full train...\', flush=True)\nwith open(\'/app/train_raw.txt\', \'w\') as f:\n    for _, row in train_df.iterrows():\n        f.write(f\'__label__{row["label"]} {clean_raw(row["text"])}\\n\')\n\nconfigs = [\n    (\'a\', 0.1, 25, 2, 50, \'softmax\'),\n    (\'b\', 0.5, 25, 2, 50, \'softmax\'),\n    (\'c\', 1.0, 25, 2, 50, \'softmax\'),\n    (\'d\', 0.1, 25, 2, 100, \'softmax\'),\n    (\'e\', 0.5, 25, 2, 100, \'softmax\'),\n    (\'f\', 1.0, 25, 2, 100, \'softmax\'),\n    (\'g\', 0.5, 50, 2, 50, \'softmax\'),\n    (\'h\', 1.0, 50, 2, 50, \'softmax\'),\n    (\'i\', 0.1, 25, 2, 50, \'ova\'),\n    (\'j\', 0.5, 25, 2, 50, \'ova\'),\n    (\'k\', 1.0, 25, 2, 50, \'ova\'),\n    (\'l\', 0.5, 25, 2, 100, \'ova\'),\n    (\'m\', 1.0, 25, 2, 100, \'ova\'),\n]\n\nbest_acc = 0\nbest_cfg = None\nfor name, lr, ep, wn, dm, loss in configs:\n    m = fasttext.train_supervised(\n        input=\'/app/train_sub.txt\', lr=lr, epoch=ep, wordNgrams=wn,\n        dim=dm, loss=loss, bucket=1000000, minCount=1, thread=4, verbose=0\n    )\n    n, p, r = m.test(\'/app/test_raw.txt\')\n    tag = f\'{name}: lr={lr} ep={ep} wn={wn} dm={dm} loss={loss}\'\n    print(f\'{tag} => {p:.4f}\', flush=True)\n    if p > best_acc:\n        best_acc = p\n        best_cfg = (name, lr, ep, wn, dm, loss)\n        print(f\'  NEW BEST!\', flush=True)\n\nprint(f\'\\n=== Best: {best_cfg} acc={best_acc:.4f} ===\', flush=True)\nprint(\'\\nRetraining best on full raw data...\', flush=True)\n_, lr, ep, wn, dm, loss = best_cfg\nm = fasttext.train_supervised(\n    input=\'/app/train_raw.txt\', lr=lr, epoch=ep, wordNgrams=wn,\n    dim=dm, loss=loss, bucket=1000000, minCount=1, thread=4, verbose=2\n)\nn, p, r = m.test(\'/app/test_raw.txt\')\nprint(f\'\\nFull data acc: {p:.4f}\', flush=True)\n\nm.save_model(\'/app/model_best.bin\')\nsz = os.path.getsize(\'/app/model_best.bin\') / (1024*1024)\nprint(f\'Size: {sz:.1f} MB\', flush=True)\n\nif sz > 150:\n    print(\'Quantizing...\', flush=True)\n    m.quantize(input=\'/app/train_raw.txt\', retrain=True, epoch=10, lr=0.25, thread=4, dsub=2, qnorm=True)\n    m.save_model(\'/app/model.bin\')\n    sz2 = os.path.getsize(\'/app/model.bin\') / (1024*1024)\n    n, p, r = m.test(\'/app/test_raw.txt\')\n    print(f\'Quant: sz={sz2:.1f}MB acc={p:.4f}\', flush=True)\nelse:\n    os.rename(\'/app/model_best.bin\', \'/app/model.bin\')\n    print(f\'Saved /app/model.bin ({sz:.1f} MB)\', flush=True)\n\nprint(\'DONE\', flush=True)\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
