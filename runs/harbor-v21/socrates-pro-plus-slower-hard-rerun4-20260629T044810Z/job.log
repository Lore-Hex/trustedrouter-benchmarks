Sending keys: ['cat << \'PYEOF\' > /app/learn_and_intervene.py\nimport pandas as pd\nimport numpy as np\nfrom sklearn.linear_model import LinearRegression\n\nnp.random.seed(42)\n\n# Load data\ndf = pd.read_csv(\'/app/bn_sample_10k.csv\')\nnodes = list(df.columns)\nprint(f"Nodes: {nodes}")\n\n# Define the DAG edges: (parent, child)\n# U -> Y, U -> R, U -> D, U -> M, Y -> D, R -> M\ndag_edges = [\n    (\'U\', \'Y\'),\n    (\'U\', \'R\'),\n    (\'U\', \'D\'),\n    (\'U\', \'M\'),\n    (\'Y\', \'D\'),\n    (\'R\', \'M\'),\n]\n\n# Build parent map\nparents = {n: [] for n in nodes}\nfor p, c in dag_edges:\n    parents[c].append(p)\n\nprint("\\nParent map (original DAG):")\nfor n in nodes:\n    print(f"  {n}: parents = {parents[n]}")\n\n# Fit linear Gaussian model for each node\n# X = intercept + sum(beta_i * parent_i) + noise\nparams = {}  # node -> (intercept, betas, sigma)\nfor n in nodes:\n    pa = parents[n]\n    if len(pa) == 0:\n        # Root node: just fit mean and std\n        mean = df[n].mean()\n        std = df[n].std(ddof=1)\n        params[n] = {\'intercept\': mean, \'betas\': {}, \'sigma\': std}\n        print(f"\\n{n}: mean={mean:.4f}, std={std:.4f}")\n    else:\n        X = df[pa].values\n        y = df[n].values\n        reg = LinearRegression().fit(X, y)\n        resid = y - reg.predict(X)\n        sigma = np.std(resid, ddof=len(pa)+1)\n        betas = dict(zip(pa, reg.coef_))\n        params[n] = {\'intercept\': reg.intercept_, \'betas\': betas, \'sigma\': sigma}\n        print(f"\\n{n}: intercept={reg.intercept_:.4f}, betas={betas}, sigma={sigma:.4f}")\n\n# Now create intervened DAG: do(Y=0)\n# Remove all edges into Y\nprint("\\n" + "="*50)\nprint("Intervention: do(Y=0)")\nprint("="*50)\n\n# Intervened parent map\nint_parents = {n: list(p) for n, p in parents.items()}\n# Remove edges into Y\nint_parents[\'Y\'] = []\n\nprint("\\nIntervened parent map:")\nfor n in nodes:\n    print(f"  {n}: parents = {int_parents[n]}")\n\n# Save intervened DAG\nint_edges = []\nfor n in nodes:\n    for p in int_parents[n]:\n        int_edges.append({\'to\': n, \'from\': p})\nint_dag_df = pd.DataFrame(int_edges)\nint_dag_df.to_csv(\'/app/intervened_dag.csv\', index=False)\nprint("\\nSaved intervened_dag.csv:")\nprint(int_dag_df.to_string(index=False))\n\n# Sample 10k points from intervened BN\n# Need to sample in topological order\n# Topological order: U, Y, R, D, M (U first since it has no parents)\n# With Y intervened to 0, we don\'t sample Y\n\n# Determine topological order\ntopo_order = [\'U\', \'Y\', \'R\', \'D\', \'M\']  # Based on our DAG structure\n\nn_samples = 10000\nsamples = pd.DataFrame(index=range(n_samples), columns=nodes, dtype=float)\n\nprint("\\nSampling 10k points from intervened BN...")\nfor node in topo_order:\n    if node == \'Y\':\n        # Intervention: Y = 0.0\n        samples[node] = 0.0\n        print(f"  {node} = 0.0 (intervened)")\n    else:\n        pa = int_parents[node]\n        p = params[node]\n        if len(pa) == 0:\n            # Root node\n            samples[node] = np.random.normal(p[\'intercept\'], p[\'sigma\'], n_samples)\n            print(f"  {node} ~ N({p[\'intercept\']:.4f}, {p[\'sigma\']:.4f}^2)")\n        else:\n            # Linear combination of parents + noise\n            val = np.full(n_samples, p[\'intercept\'])\n            for parent_name, beta in p[\'betas\'].items():\n                val += beta * samples[parent_name].values\n            val += np.random.normal(0, p[\'sigma\'], n_samples)\n            samples[node] = val\n            print(f"  {node} = {p[\'intercept\']:.4f} + betas*parents + N(0, {p[\'sigma\']:.4f}^2)")\n\n# Save samples\nsamples.to_csv(\'/app/final_bn_sample.csv\', index=False)\nprint(f"\\nSaved final_bn_sample.csv ({len(samples)} rows)")\n\n# Print some statistics\nprint("\\nSample statistics:")\nprint(samples.describe().round(3))\n\n# Compare with original data\nprint("\\nOriginal data statistics:")\nprint(df.describe().round(3))\n\nPYEOF\n'] min_timeou