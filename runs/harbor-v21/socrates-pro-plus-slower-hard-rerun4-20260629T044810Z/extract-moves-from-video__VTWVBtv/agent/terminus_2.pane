[?2004l[?2004h> import os
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import re
[?2004l[?2004h> import tempfile
[?2004l[?2004h> from PIL import Image, ImageOps, ImageEnhance
[?2004l[?2004h> 
[?2004l[?2004h> frames = sorted([f for f in os.listdir('/app/frames2') if f.endswith('.png')])
[?2004l[?2004h> print(f"Total frames: {len(frames)}")
[?2004l[?2004h> 
[?2004l[?2004h> def preprocess_and_ocr(frame_path):
[?2004l[?2004h>     try:
[?2004l[?2004h>         img = Image.open(frame_path)
[?2004l[?2004h>         img_gray = img.convert('L')
[?2004l[?2004h>         # Enhance contrast
[?2004l[?2004h>         enhancer = ImageEnhance.Contrast(img_gray)
[?2004l[?2004h>         img_enhanced = enhancer.enhance(2.0)
[?2004l[?2004h>         # Invert
[?2004l[?2004h>         img_inverted = ImageOps.invert(img_enhanced)
[?2004l[?2004h>         # Save to temp file
[?2004l[?2004h>         with tempfile.NamedTemporaryFile(suffix='.png', delete=False) as tmpfile:
[?2004l[?2004h>             tmp_path = tmpfile.name
[?2004l[?2004h>             img_inverted.save(tmp_path)
[?2004l[?2004h>         result = subprocess.run(['tesseract', tmp_path, 'stdout'], 
[?2004l[?2004h>                              capture_output=True, text=True, timeout=10)
[?2004l[?2004h>         os.unlink(tmp_path)
[?2004l[?2004h>         return result.stdout
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return ""
[?2004l[?2004h> 
[?2004l[?2004h> # Process all frames and collect data
[?2004l[?2004h> frame_data = []
[?2004l[?2004h> for i, frame in enumerate(frames):
[?2004l[?2004h>     frame_path = os.path.join('/app/frames2', frame)
[?2004l[?2004h>     text = preprocess_and_ocr(frame_path)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract moves counter
[?2004l[?2004h>     moves_match = re.search(r'Moves?[:\s]+(\d+)', text)
[?2004l[?2004h>     moves = int(moves_match.group(1)) if moves_match else -1
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract command (last line with >)
[?2004l[?2004h>     command = ""
[?2004l[?2004h>     lines = text.split('\n')
[?2004l[?2004h>     for line in reversed(lines):
[?2004l[?2004h>         if '>' in line:
[?2004l[?2004h>             parts = line.split('>', 1)
[?2004l[?2004h>             if len(parts) > 1 and parts[1].strip():
[?2004l[?2004h>                 command = parts[1].strip().lower()
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     frame_data.append((i, moves, command, text))
[?2004l[?2004h> 
[?2004l[?2004h> # Find actual commands by tracking moves changes
[?2004l[?2004h> commands = []
[?2004l[?2004h> prev_moves = -1
[?2004l[?2004h> seen_commands = set()
[?2004l[?2004h> 
[?2004l[?2004h> for idx, moves, command, text in frame_data:
[?2004l[?2004h>     if moves > prev_moves and command:
[?2004l[?2004h>         # Clean up common OCR artifacts
[?2004l[?2004h>         cmd = command.rstrip('.')  # Remove trailing dots
[?2004l[?2004h>         cmd = cmd.rstrip('_')     # Remove trailing underscores
[?2004l[?2004h>         cmd = re.sub(r'\s+', ' ', cmd)  # Normalize spaces
[?2004l[?2004h>         
[?2004l[?2004h>         # Skip obvious garbage
[?2004l[?2004h>         if len(cmd) > 1 and not re.match(r'^[a-z]{1}$', cmd):
[?2004l[?2004h>             # Only add if it's a new command (not duplicate of previous)
[?2004l[?2004h>             if not commands or commands[-1] != cmd:
[?2004l[?2004h>                 commands.append(cmd)
[?2004l[?2004h>         prev_moves = moves
[?2004l[?2004h> 
[?2004l[?2004h> # Write to solution.txt
[?2004l[?2004h> with open('/app/solution.txt', 'w') as f:
[?2004l[?2004h>     for i, cmd in enumerate(commands, 1):
[?2004l[?2004h>         f.write(cmd + '\n')
[?2004l[?2004h>         print(f"{i}. {cmd}")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nTotal commands: {len(commands)}")
[?2004l[?2004h> EOF
