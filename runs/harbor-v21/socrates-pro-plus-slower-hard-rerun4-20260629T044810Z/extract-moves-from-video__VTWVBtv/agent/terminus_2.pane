[?2004hroot@73095d49d5d2:/app# cat > /app/merge_commands.py << 'EOF'
[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> # Read preprocessed log (commands from 2fps frames)
[?2004l[?2004h> with open('/app/preprocessed_log.txt', 'r') as f:
[?2004l[?2004h>     preprocessed_lines = f.readlines()
[?2004l[?2004h> 
[?2004l[?2004h> # Extract commands from preprocessed log
[?2004l[?2004h> preprocessed_commands = []
[?2004l[?2004h> for line in preprocessed_lines:
[?2004l[?2004h>     match = re.search(r'-> (.+)$', line)
[?2004l[?2004h>     if match:
[?2004l[?2004h>         cmd = match.group(1).strip().lower()
[?2004l[?2004h>         # Clean OCR artifacts
[?2004l[?2004h>         cmd = cmd.rstrip('.')  # Remove trailing dots
[?2004l[?2004h>         cmd = cmd.rstrip('_')  # Remove trailing underscores
[?2004l[?2004h>         cmd = re.sub(r'\s+', ' ', cmd)  # Normalize spaces
[?2004l[?2004h>         preprocessed_commands.append(cmd)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Extracted {len(preprocessed_commands)} commands from preprocessed log.")
[?2004l[?2004h> 
[?2004l[?2004h> # Read crop extraction (lines starting with '>')
[?2004l[?2004h> with open('/app/crop_log.txt', 'r') as f:
[?2004l[?2004h>     crop_lines = f.readlines()
[?2004l[?2004h> 
[?2004l[?2004h> crop_commands = []
[?2004l[?2004h> for line in crop_lines:
[?2004l[?2004h>     line = line.strip()
[?2004l[?2004h>     if line.startswith('>') and line != '>':  # Skip empty prompts
[?2004l[?2004h>         cmd = line[1:].strip().lower()  # Remove '>' and strip
[?2004l[?2004h>         # Clean OCR artifacts
[?2004l[?2004h>         cmd = cmd.rstrip('.')
[?2004l[?2004h>         cmd = cmd.rstrip('_')
[?2004l[?2004h>         cmd = re.sub(r'\s+', ' ', cmd)
[?2004l[?2004h>         if cmd:  # Non-empty after cleaning
[?2004l[?2004h>             crop_commands.append(cmd)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Extracted {len(crop_commands)} commands from crop log.")
[?2004l[?2004h> 
[?2004l[?2004h> # Combine commands, preserving order and removing consecutive duplicates
[?2004l[?2004h> combined = []
[?2004l[?2004h> for cmd in preprocessed_commands + crop_commands:
[?2004l[?2004h>     if not combined or combined[-1] != cmd:
[?2004l[?2004h>         combined.append(cmd)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Combined total: {len(combined)} unique consecutive commands.")
[?2004l[?2004h> 
[?2004l[?2004h> # Write to solution.txt
[?2004l[?2004h> with open('/app/solution.txt', 'w') as f:
[?2004l[?2004h>     for cmd in combined:
[?2004l[?2004h>         f.write(cmd + '\n')
[?2004l[?2004h> 
[?2004l[?2004h> print("Commands written to /app/solution.txt")
[?2004l[?2004h> EOF
