[?2004l[?2004h>     result = subprocess.run(['tesseract', frame_path, 'stdout'], 
[?2004l[?2004h>                          capture_output=True, text=True, timeout=10)
[?2004l[?2004h>     text = result.stdout
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract moves counter
[?2004l[?2004h>     moves_match = re.search(r'Moves?[:\s]+(\d+)', text)
[?2004l[?2004h>     moves = int(moves_match.group(1)) if moves_match else -1
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract command (text after >)
[?2004l[?2004h>     command = ""
[?2004l[?2004h>     lines = text.split('\n')
[?2004l[?2004h>     for line in lines:
[?2004l[?2004h>         if '>' in line:
[?2004l[?2004h>             parts = line.split('>', 1)
[?2004l[?2004h>             if len(parts) > 1 and parts[1].strip():
[?2004l[?2004h>                 cmd = parts[1].strip().lower()
[?2004l[?2004h>                 # Filter out obvious OCR artifacts
[?2004l[?2004h>                 if not any(c * 3 in cmd for c in 'abcdefghijklmnopqrstuvwxyz') and \
[?2004l[?2004h>                    len(cmd) > 1 and not re.search(r'[A-Z]{3,}', cmd):
[?2004l[?2004h>                     command = cmd
[?2004l[?2004h>                     break
[?2004l[?2004h>     
[?2004l[?2004h>     moves_data.append((i+1, moves, command))
[?2004l[?2004h> 
[?2004l[?2004h> # Find frames where moves increase (new command entered)
[?2004l[?2004h> commands = []
[?2004l[?2004h> prev_moves = -1
[?2004l[?2004h> for frame_num, moves, command in moves_data:
[?2004l[?2004h>     if moves > prev_moves and command:
[?2004l[?2004h>         commands.append((frame_num, moves, command))
[?2004l[?2004h>         prev_moves = moves
[?2004l[?2004h> 
[?2004l[?2004h> # Write to solution.txt
[?2004l[?2004h> with open('/app/solution.txt', 'w') as f:
