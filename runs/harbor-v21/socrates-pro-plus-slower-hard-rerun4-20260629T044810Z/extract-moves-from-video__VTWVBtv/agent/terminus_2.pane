[?2004l[?2004h>         text = result.stdout
[?2004l[?2004h>         os.unlink(tmp_path)  # Remove temporary file
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         print(f"Error processing {frame}: {e}")
[?2004l[?2004h>         text = ""
[?2004l[?2004h>     
