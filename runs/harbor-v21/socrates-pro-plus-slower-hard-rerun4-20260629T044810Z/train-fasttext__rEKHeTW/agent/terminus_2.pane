[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import re
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> def clean_raw(text):
[?2004l[?2004h>     text = str(text).replace('\n', ' ').replace('\r', ' ')
[?2004l[?2004h>     text = re.sub(r'\s+', ' ', text).strip()
[?2004l[?2004h>     return text
[?2004l[?2004h> 
[?2004l[?2004h> print('Loading data...', flush=True)
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> 
[?2004l[?2004h> # Create 100K subset for fast grid search
[?2004l[?2004h> np.random.seed(42)
[?2004l[?2004h> idx = np.random.choice(len(train_df), 100000, replace=False)
[?2004l[?2004h> sub_df = train_df.iloc[idx]
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing subset (100K)...', flush=True)
[?2004l[?2004h> with open('/app/train_sub.txt', 'w') as f:
[?2004l[?2004h>     for _, row in sub_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_raw(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing raw test...', flush=True)
[?2004l[?2004h> with open('/app/test_raw.txt', 'w') as f:
[?2004l[?2004h>     for _, row in test_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_raw(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing raw full train...', flush=True)
[?2004l[?2004h> with open('/app/train_raw.txt', 'w') as f:
[?2004l[?2004h>     for _, row in train_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_raw(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> configs = [
[?2004l[?2004h>     ('a', 0.1, 25, 2, 50, 'softmax'),
[?2004l[?2004h>     ('b', 0.5, 25, 2, 50, 'softmax'),
[?2004l[?2004h>     ('c', 1.0, 25, 2, 50, 'softmax'),
[?2004l[?2004h>     ('d', 0.1, 25, 2, 100, 'softmax'),
[?2004l[?2004h>     ('e', 0.5, 25, 2, 100, 'softmax'),
[?2004l[?2004h>     ('f', 1.0, 25, 2, 100, 'softmax'),
[?2004l[?2004h>     ('g', 0.5, 50, 2, 50, 'softmax'),
[?2004l[?2004h>     ('h', 1.0, 50, 2, 50, 'softmax'),
[?2004l[?2004h>     ('i', 0.1, 25, 2, 50, 'ova'),
[?2004l[?2004h>     ('j', 0.5, 25, 2, 50, 'ova'),
[?2004l[?2004h>     ('k', 1.0, 25, 2, 50, 'ova'),
[?2004l[?2004h>     ('l', 0.5, 25, 2, 100, 'ova'),
[?2004l[?2004h>     ('m', 1.0, 25, 2, 100, 'ova'),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> best_acc = 0
[?2004l[?2004h> best_cfg = None
[?2004l[?2004h> for name, lr, ep, wn, dm, loss in configs:
