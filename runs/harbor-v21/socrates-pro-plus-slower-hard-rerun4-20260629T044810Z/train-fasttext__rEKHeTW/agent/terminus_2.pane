[?2004hroot@2e9e26f8e93c:/app# cat > /app/train2.py << 'PYEOF'
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> import re
[?2004l[?2004h> import random
[?2004l[?2004h> 
[?2004l[?2004h> def clean_text(text):
[?2004l[?2004h>     text = str(text).lower()
[?2004l[?2004h>     text = text.replace('\n', ' ').replace('\r', ' ')
[?2004l[?2004h>     text = re.sub(r'[^a-z0-9\s]', ' ', text)
[?2004l[?2004h>     text = re.sub(r'\s+', ' ', text).strip()
[?2004l[?2004h>     return text
[?2004l[?2004h> 
[?2004l[?2004h> print('Loading data...')
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> 
[?2004l[?2004h> # Split train into train/val for autotune
[?2004l[?2004h> random.seed(42)
[?2004l[?2004h> val_size = 50000
[?2004l[?2004h> train_subset = train_df.iloc[:-val_size]
[?2004l[?2004h> val_df = train_df.iloc[-val_size:]
[?2004l[?2004h> 
[?2004l[?2004h> print(f'Train subset: {len(train_subset)}, Val: {len(val_df)}, Test: {len(test_df)}')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing train_subset.txt...')
[?2004l[?2004h> with open('/app/train_subset.txt', 'w') as f:
[?2004l[?2004h>     for _, row in train_subset.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_text(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing val.txt...')
[?2004l[?2004h> with open('/app/val.txt', 'w') as f:
[?2004l[?2004h>     for _, row in val_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_text(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing full train.txt...')
[?2004l[?2004h> with open('/app/train_full.txt', 'w') as f:
[?2004l[?2004h>     for _, row in train_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_text(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Writing test.txt...')
[?2004l[?2004h> with open('/app/test.txt', 'w') as f:
[?2004l[?2004h>     for _, row in test_df.iterrows():
[?2004l[?2004h>         f.write(f'__label__{row["label"]} {clean_text(row["text"])}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Running autotune...')
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='/app/train_subset.txt',
[?2004l[?2004h>     autotuneValidationFile='/app/val.txt',
[?2004l[?2004h>     autotuneDuration=300,
[?2004l[?2004h>     autotuneModelSize='100M',
[?2004l[?2004h>     thread=4,
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Get autotune results
[?2004l[?2004h> print('\nAutotune best parameters:')
[?2004l[?2004h> print(model.f.get_args())
[?2004l[?2004h> 
[?2004l[?2004h> # Now retrain on full training data with best params
[?2004l[?2004h> args = model.f.get_args()
[?2004l[?2004h> print('\nRetraining on full data with best params...')
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='/app/train_full.txt',
[?2004l[?2004h>     lr=args.lr,
[?2004l[?2004h>     epoch=args.epoch,
[?2004l[?2004h>     wordNgrams=args.wordNgrams,
[?2004l[?2004h>     dim=args.dim,
[?2004l[?2004h>     loss=args.loss,
[?2004l[?2004h>     bucket=args.bucket,
[?2004l[?2004h>     minCount=args.minCount,
[?2004l[?2004h>     minn=args.minn,
[?2004l[?2004h>     maxn=args.maxn,
[?2004l[?2004h>     thread=4,
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print('\nEvaluating on test set...')
[?2004l[?2004h> n, p, r = model.test('/app/test.txt')
[?2004l[?2004h> print(f'Unquantized - Samples: {n}, Precision: {p:.4f}, Recall: {r:.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> model.save_model('/app/model_unquant2.bin')
[?2004l[?2004h> size_mb = os.path.getsize('/app/model_unquant2.bin') / (1024*1024)
[?2004l[?2004h> print(f'Unquantized size: {size_mb:.1f} MB')
[?2004l[?2004h> 
[?2004l[?2004h> # Quantize
[?2004l[?2004h> print('\nQuantizing...')
[?2004l[?2004h> model.quantize(input='/app/train_full.txt', retrain=True, epoch=10, lr=0.5, thread=4, dsub=2, qnorm=True)
[?2004l[?2004h> model.save_model('/app/model.bin')
[?2004l[?2004h> size_mb = os.path.getsize('/app/model.bin') / (1024*1024)
[?2004l[?2004h> print(f'Quantized size: {size_mb:.1f} MB')
[?2004l[?2004h> 
[?2004l[?2004h> n, p, r = model.test('/app/test.txt')
[?2004l[?2004h> print(f'Quantized - Samples: {n}, Precision: {p:.4f}, Recall: {r:.4f}')
[?2004l[?2004h> 
