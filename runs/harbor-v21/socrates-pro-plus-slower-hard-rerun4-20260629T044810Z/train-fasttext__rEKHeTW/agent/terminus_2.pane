[?2004hroot@2e9e26f8e93c:/app# cat > /app/train.py << 'PYEOF'
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import fasttext
[?2004l[?2004h> import os
[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> def clean_text(text):
[?2004l[?2004h>     # Remove newlines and collapse whitespace for fasttext format
[?2004l[?2004h>     text = str(text)
[?2004l[?2004h>     text = text.replace('\n', ' ').replace('\r', ' ')
[?2004l[?2004h>     text = re.sub(r'\s+', ' ', text).strip()
[?2004l[?2004h>     return text
[?2004l[?2004h> 
[?2004l[?2004h> print('Loading train data...')
[?2004l[?2004h> train_df = pd.read_parquet('data/train-00000-of-00001.parquet')
[?2004l[?2004h> print(f'Train shape: {train_df.shape}')
[?2004l[?2004h> 
[?2004l[?2004h> print('Loading test data...')
[?2004l[?2004h> test_df = pd.read_parquet('data/test-00000-of-00001.parquet')
[?2004l[?2004h> print(f'Test shape: {test_df.shape}')
[?2004l[?2004h> 
[?2004l[?2004h> # Write train file in fasttext format
[?2004l[?2004h> print('Writing train.txt...')
[?2004l[?2004h> with open('/app/train.txt', 'w') as f:
[?2004l[?2004h>     for _, row in train_df.iterrows():
[?2004l[?2004h>         label = row['label']
[?2004l[?2004h>         text = clean_text(row['text'])
[?2004l[?2004h>         f.write(f'__label__{label} {text}\n')
[?2004l[?2004h> 
[?2004l[?2004h> # Write test file in fasttext format
[?2004l[?2004h> print('Writing test.txt...')
[?2004l[?2004h> with open('/app/test.txt', 'w') as f:
[?2004l[?2004h>     for _, row in test_df.iterrows():
[?2004l[?2004h>         label = row['label']
[?2004l[?2004h>         text = clean_text(row['text'])
[?2004l[?2004h>         f.write(f'__label__{label} {text}\n')
[?2004l[?2004h> 
[?2004l[?2004h> print('Training model...')
[?2004l[?2004h> model = fasttext.train_supervised(
[?2004l[?2004h>     input='/app/train.txt',
[?2004l[?2004h>     lr=0.5,
[?2004l[?2004h>     epoch=25,
[?2004l[?2004h>     wordNgrams=2,
[?2004l[?2004h>     dim=50,
[?2004l[?2004h>     loss='softmax',
[?2004l[?2004h>     bucket=1000000,
[?2004l[?2004h>     minCount=2,
[?2004l[?2004h>     thread=4,
[?2004l[?2004h>     verbose=2
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> print('\nEvaluating on test set...')
[?2004l[?2004h> n_samples, precision, recall = model.test('/app/test.txt')
[?2004l[?2004h> print(f'Test samples: {n_samples}')
[?2004l[?2004h> print(f'Precision: {precision:.4f}')
[?2004l[?2004h> print(f'Recall: {recall:.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Save unquantized first
[?2004l[?2004h> model.save_model('/app/model_unquant.bin')
[?2004l[?2004h> size_mb = os.path.getsize('/app/model_unquant.bin') / (1024*1024)
[?2004l[?2004h> print(f'Unquantized model size: {size_mb:.1f} MB')
[?2004l[?2004h> 
[?2004l[?2004h> if size_mb > 150:
[?2004l[?2004h>     print('Model too large, quantizing...')
[?2004l[?2004h>     model.quantize(input='/app/train.txt', retrain=True, epoch=5, lr=0.25, thread=4)
