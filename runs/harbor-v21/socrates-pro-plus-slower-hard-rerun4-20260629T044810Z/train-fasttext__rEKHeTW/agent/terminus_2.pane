[?2004l[?2004h>     )
[?2004l[?2004h>     n, p, r = m.test('/app/test_raw.txt')
[?2004l[?2004h>     tag = f'{name}: lr={lr} ep={ep} wn={wn} dm={dm} loss={loss}'
