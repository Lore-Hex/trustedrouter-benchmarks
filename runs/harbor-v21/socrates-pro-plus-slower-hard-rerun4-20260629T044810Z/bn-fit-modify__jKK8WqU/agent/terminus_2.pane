[?2004hroot@d4f08a96f82c:/app# cat << 'PYEOF' > /app/learn_and_intervene.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from sklearn.linear_model import LinearRegression
[?2004l[?2004h> 
[?2004l[?2004h> np.random.seed(42)
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> df = pd.read_csv('/app/bn_sample_10k.csv')
[?2004l[?2004h> nodes = list(df.columns)
[?2004l[?2004h> print(f"Nodes: {nodes}")
[?2004l[?2004h> 
[?2004l[?2004h> # Define the DAG edges: (parent, child)
[?2004l[?2004h> # U -> Y, U -> R, U -> D, U -> M, Y -> D, R -> M
[?2004l[?2004h> dag_edges = [
[?2004l[?2004h>     ('U', 'Y'),
[?2004l[?2004h>     ('U', 'R'),
[?2004l[?2004h>     ('U', 'D'),
[?2004l[?2004h>     ('U', 'M'),
[?2004l[?2004h>     ('Y', 'D'),
[?2004l[?2004h>     ('R', 'M'),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> # Build parent map
[?2004l[?2004h> parents = {n: [] for n in nodes}
[?2004l[?2004h> for p, c in dag_edges:
[?2004l[?2004h>     parents[c].append(p)
[?2004l[?2004h> 
[?2004l[?2004h> print("\nParent map (original DAG):")
[?2004l[?2004h> for n in nodes:
[?2004l[?2004h>     print(f"  {n}: parents = {parents[n]}")
[?2004l[?2004h> 
[?2004l[?2004h> # Fit linear Gaussian model for each node
[?2004l[?2004h> # X = intercept + sum(beta_i * parent_i) + noise
[?2004l[?2004h> params = {}  # node -> (intercept, betas, sigma)
[?2004l[?2004h> for n in nodes:
[?2004l[?2004h>     pa = parents[n]
[?2004l[?2004h>     if len(pa) == 0:
[?2004l[?2004h>         # Root node: just fit mean and std
[?2004l[?2004h>         mean = df[n].mean()
[?2004l[?2004h>         std = df[n].std(ddof=1)
[?2004l[?2004h>         params[n] = {'intercept': mean, 'betas': {}, 'sigma': std}
[?2004l[?2004h>         print(f"\n{n}: mean={mean:.4f}, std={std:.4f}")
[?2004l[?2004h>     else:
[?2004l[?2004h>         X = df[pa].values
[?2004l[?2004h>         y = df[n].values
[?2004l[?2004h>         reg = LinearRegression().fit(X, y)
[?2004l[?2004h>         resid = y - reg.predict(X)
[?2004l[?2004h>         sigma = np.std(resid, ddof=len(pa)+1)
[?2004l[?2004h>         betas = dict(zip(pa, reg.coef_))
[?2004l[?2004h>         params[n] = {'intercept': reg.intercept_, 'betas': betas, 'sigma': sigma}
[?2004l[?2004h>         print(f"\n{n}: intercept={reg.intercept_:.4f}, betas={betas}, sigma={sigma:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Now create intervened DAG: do(Y=0)
[?2004l[?2004h> # Remove all edges into Y
[?2004l[?2004h> print("\n" + "="*50)
[?2004l[?2004h> print("Intervention: do(Y=0)")
[?2004l[?2004h> print("="*50)
[?2004l[?2004h> 
[?2004l[?2004h> # Intervened parent map
[?2004l[?2004h> int_parents = {n: list(p) for n, p in parents.items()}
[?2004l[?2004h> # Remove edges into Y
[?2004l[?2004h> int_parents['Y'] = []
[?2004l[?2004h> 
[?2004l[?2004h> print("\nIntervened parent map:")
[?2004l[?2004h> for n in nodes:
[?2004l[?2004h>     print(f"  {n}: parents = {int_parents[n]}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save intervened DAG
[?2004l[?2004h> int_edges = []
[?2004l[?2004h> for n in nodes:
[?2004l[?2004h>     for p in int_parents[n]:
[?2004l[?2004h>         int_edges.append({'to': n, 'from': p})
[?2004l[?2004h> int_dag_df = pd.DataFrame(int_edges)
[?2004l[?2004h> int_dag_df.to_csv('/app/intervened_dag.csv', index=False)
[?2004l[?2004h> print("\nSaved intervened_dag.csv:")
[?2004l[?2004h> print(int_dag_df.to_string(index=False))
[?2004l[?2004h> 
[?2004l[?2004h> # Sample 10k points from intervened BN
[?2004l[?2004h> # Need to sample in topological order
[?2004l[?2004h> # Topological order: U, Y, R, D, M (U first since it has no parents)
[?2004l[?2004h> # With Y intervened to 0, we don't sample Y
[?2004l[?2004h> 
[?2004l[?2004h> # Determine topological order
[?2004l[?2004h> topo_order = ['U', 'Y', 'R', 'D', 'M']  # Based on our DAG structure
[?2004l[?2004h> 
[?2004l[?2004h> n_samples = 10000
[?2004l[?2004h> samples = pd.DataFrame(index=range(n_samples), columns=nodes, dtype=float)
[?2004l[?2004h> 
[?2004l[?2004h> print("\nSampling 10k points from intervened BN...")
[?2004l[?2004h> for node in topo_order:
[?2004l[?2004h>     if node == 'Y':
[?2004l[?2004h>         # Intervention: Y = 0.0
[?2004l[?2004h>         samples[node] = 0.0
[?2004l[?2004h>         print(f"  {node} = 0.0 (intervened)")
[?2004l[?2004h>     else:
[?2004l[?2004h>         pa = int_parents[node]
[?2004l[?2004h>         p = params[node]
[?2004l[?2004h>         if len(pa) == 0:
[?2004l[?2004h>             # Root node
[?2004l[?2004h>             samples[node] = np.random.normal(p['intercept'], p['sigma'], n_samples)
[?2004l[?2004h>             print(f"  {node} ~ N({p['intercept']:.4f}, {p['sigma']:.4f}^2)")
[?2004l[?2004h>         else:
[?2004l[?2004h>             # Linear combination of parents + noise
[?2004l[?2004h>             val = np.full(n_samples, p['intercept'])
[?2004l[?2004h>             for parent_name, beta in p['betas'].items():
[?2004l[?2004h>                 val += beta * samples[parent_name].values
[?2004l[?2004h>             val += np.random.normal(0, p['sigma'], n_samples)
[?2004l[?2004h>             samples[node] = val
[?2004l[?2004h>             print(f"  {node} = {p['intercept']:.4f} + betas*parents + N(0, {p['sigma']:.4f}^2)")
[?2004l[?2004h> 
[?2004l[?2004h> # Save samples
[?2004l[?2004h> samples.to_csv('/app/final_bn_sample.csv', index=False)
[?2004l[?2004h> print(f"\nSaved final_bn_sample.csv ({len(samples)} rows)")
[?2004l[?2004h> 
[?2004l[?2004h> # Print some statistics
[?2004l[?2004h> print("\nSample statistics:")
[?2004l[?2004h> print(samples.describe().round(3))
[?2004l[?2004h> 
[?2004l[?2004h> # Compare with original data
[?2004l[?2004h> print("\nOriginal data statistics:")
[?2004l[?2004h> print(df.describe().round(3))
