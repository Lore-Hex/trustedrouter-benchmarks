[?2004l[?2004h> # Phase 2: Orient v-structures with separating set check
[?2004l[?2004h> # For each triple X -- Z -- Y where X,Y non-adjacent:
[?2004l[?2004h> # Orient X -> Z <- Y iff Z NOT in SepSet(X,Y)
[?2004l[?2004h> print("\nV-structure analysis:")
[?2004l[?2004h> directed = {}  # (parent, child) -> direction. We'll track as set of (from, to)
[?2004l[?2004h> 
[?2004l[?2004h> for z_idx in range(len(nodes)):
