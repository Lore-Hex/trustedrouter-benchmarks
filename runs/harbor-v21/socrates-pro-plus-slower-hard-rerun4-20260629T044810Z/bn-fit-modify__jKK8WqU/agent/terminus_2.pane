[?2004l[?2004h> u_idx = nodes.index('U')
[?2004l[?2004h> 
[?2004l[?2004h> final_edges = set()
[?2004l[?2004h> 
[?2004l[?2004h> # Add all directed edges from v-structure analysis
[?2004l[?2004h> for (p, c) in directed:
[?2004l[?2004h>     if c == u_idx:
[?2004l[?2004h>         # Skip edges into U (U has no parents) - reverse them
[?2004l[?2004h>         print(f"  Reversing {nodes[p]} -> {nodes[c]}: U has no parents, so {nodes[c]} -> {nodes[p]}")
[?2004l[?2004h>         final_edges.add((c, p))
[?2004l[?2004h>     else:
[?2004l[?2004h>         final_edges.add((p, c))
[?2004l[?2004h> 
[?2004l[?2004h> # For undirected edges in skeleton that are not yet oriented
[?2004l[?2004h> for (i, j) in edges:
[?2004l[?2004h>     if (i, j) in directed or (j, i) in directed:
[?2004l[?2004h>         continue
[?2004l[?2004h>     # This edge has not been oriented yet
[?2004l[?2004h>     if i == u_idx:
[?2004l[?2004h>         final_edges.add((i, j))  # U -> j
[?2004l[?2004h>         print(f"  {nodes[i]} -> {nodes[j]} (U has no parents)")
[?2004l[?2004h>     elif j == u_idx:
[?2004l[?2004h>         final_edges.add((j, i))  # U -> i
[?2004l[?2004h>         print(f"  {nodes[j]} -> {nodes[i]} (U has no parents)")
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Alphabetical: earlier letter is child
[?2004l[?2004h>         # "the node labeled with the letter that comes first in the alphabet is the child"
[?2004l[?2004h>         if nodes[i] < nodes[j]:
[?2004l[?2004h>             # i is child, j is parent: j -> i
[?2004l[?2004h>             final_edges.add((j, i))
[?2004l[?2004h>             print(f"  {nodes[j]} -> {nodes[i]} ({nodes[i]} comes first alphabetically, so is child)")
[?2004l[?2004h>         else:
[?2004l[?2004h>             final_edges.add((i, j))
[?2004l[?2004h>             print(f"  {nodes[i]} -> {nodes[j]} ({nodes[j]} comes first alphabetically, so is child)")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nFinal DAG ({len(final_edges)} edges):")
[?2004l[?2004h> for p, c in sorted(final_edges):
[?2004l[?2004h>     print(f"  {nodes[p]} -> {nodes[c]}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save DAG in format to,from (meaning from -> to)
[?2004l[?2004h> dag_rows = []
[?2004l[?2004h> for p, c in final_edges:
[?2004l[?2004h>     dag_rows.append({'to': nodes[c], 'from': nodes[p]})
[?2004l[?2004h> dag_df = pd.DataFrame(dag_rows)
[?2004l[?2004h> dag_df.to_csv('/app/learned_dag.csv', index=False)
[?2004l[?2004h> print("\nSaved learned_dag.csv:")
