[?2004hroot@d4f08a96f82c:/app# cat << 'PYEOF' > /app/discover_dag.py
[?2004l[?2004h> import pandas as pd
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from scipy import stats
[?2004l[?2004h> from itertools import combinations
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> df = pd.read_csv('/app/bn_sample_10k.csv')
[?2004l[?2004h> nodes = list(df.columns)
[?2004l[?2004h> n = len(df)
[?2004l[?2004h> print(f"Nodes: {nodes}")
[?2004l[?2004h> print(f"N samples: {n}")
[?2004l[?2004h> print(f"\nCorrelation matrix:")
[?2004l[?2004h> print(df.corr().round(3))
[?2004l[?2004h> 
[?2004l[?2004h> # PC Algorithm - Phase 1: Learn skeleton via conditional independence tests
[?2004l[?2004h> # Using partial correlation test at alpha=0.01
[?2004l[?2004h> alpha = 0.01
[?2004l[?2004h> 
[?2004l[?2004h> def partial_corr_test(df, x, y, z_list, n):
[?2004l[?2004h>     """Test if x and y are conditionally independent given z_list using Fisher's z transform."""
[?2004l[?2004h>     if len(z_list) == 0:
[?2004l[?2004h>         r = df[x].corr(df[y])
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Compute partial correlation using regression residuals
[?2004l[?2004h>         from sklearn.linear_model import LinearRegression
[?2004l[?2004h>         Z = df[list(z_list)].values
[?2004l[?2004h>         
[?2004l[?2004h>         reg_x = LinearRegression().fit(Z, df[x].values)
[?2004l[?2004h>         resid_x = df[x].values - reg_x.predict(Z)
[?2004l[?2004h>         
[?2004l[?2004h>         reg_y = LinearRegression().fit(Z, df[y].values)
[?2004l[?2004h>         resid_y = df[y].values - reg_y.predict(Z)
[?2004l[?2004h>         
[?2004l[?2004h>         r = np.corrcoef(resid_x, resid_y)[0, 1]
[?2004l[?2004h>     
[?2004l[?2004h>     if abs(r) >= 1.0:
[?2004l[?2004h>         return False, 0.0  # Not independent
[?2004l[?2004h>     
[?2004l[?2004h>     # Fisher's z transform
[?2004l[?2004h>     z = 0.5 * np.log((1 + r) / (1 - r))
[?2004l[?2004h>     se = 1.0 / np.sqrt(n - len(z_list) - 3)
[?2004l[?2004h>     z_stat = abs(z) / se
[?2004l[?2004h>     p_value = 2 * (1 - stats.norm.cdf(z_stat))
[?2004l[?2004h>     
[?2004l[?2004h>     return p_value > alpha, p_value
[?2004l[?2004h> 
[?2004l[?2004h> # Initialize complete undirected graph
[?2004l[?2004h> edges = set()
[?2004l[?2004h> for i, j in combinations(range(len(nodes)), 2):
[?2004l[?2004h>     edges.add((i, j))
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nInitial edges: {len(edges)}")
[?2004l[?2004h> 
[?2004l[?2004h> # PC Phase 1: Remove edges based on conditional independence
[?2004l[?2004h> sep_set = {}  # Separating sets
[?2004l[?2004h> for level in range(len(nodes) - 1):
[?2004l[?2004h>     print(f"\nLevel {level} conditioning sets:")
[?2004l[?2004h>     edges_to_remove = []
[?2004l[?2004h>     for (i, j) in list(edges):
[?2004l[?2004h>         neighbors_i = {k for k in range(len(nodes)) if (min(i,k), max(i,k)) in edges and k != j}
[?2004l[?2004h>         neighbors_j = {k for k in range(len(nodes)) if (min(j,k), max(j,k)) in edges and k != i}
[?2004l[?2004h>         possible_z = neighbors_i | neighbors_j
[?2004l[?2004h>         
[?2004l[?2004h>         for z_subset in combinations(possible_z, level):
[?2004l[?2004h>             indep, p_val = partial_corr_test(df, nodes[i], nodes[j], [nodes[k] for k in z_subset], n)
[?2004l[?2004h>             if indep:
[?2004l[?2004h>                 edges_to_remove.append((i, j))
[?2004l[?2004h>                 sep_set[(i, j)] = set(z_subset)
[?2004l[?2004h>                 sep_set[(j, i)] = set(z_subset)
[?2004l[?2004h>                 print(f"  {nodes[i]} _||_ {nodes[j]} | {[nodes[k] for k in z_subset]} (p={p_val:.4f})")
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     for e in edges_to_remove:
[?2004l[?2004h>         edges.discard(e)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"  Remaining edges: {len(edges)}")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nSkeleton edges: {len(edges)}")
[?2004l[?2004h> for i, j in sorted(edges):
[?2004l[?2004h>     print(f"  {nodes[i]} -- {nodes[j]}")
[?2004l[?2004h> 
[?2004l[?2004h> # PC Phase 2: Orient v-structures
[?2004l[?2004h> oriented = set()
[?2004l[?2004h> for (i, j) in edges:
[?2004l[?2004h>     neighbors_i = {k for k in range(len(nodes)) if (min(i,k), max(i,k)) in edges and k != j}
[?2004l[?2004h>     for k in neighbors_i:
[?2004l[?2004h>         if (min(j,k), max(j,k)) not in edges:
[?2004l[?2004h>             # k and j are not adjacent, i is a collider: k -> i <- j
[?2004l[?2004h>             oriented.add((k, i))
[?2004l[?2004h>             oriented.add((j, i))
[?2004l[?2004h>             print(f"\nV-structure: {nodes[k]} -> {nodes[i]} <- {nodes[j]}")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nOriented edges from v-structures: {len(oriented)}")
[?2004l[?2004h> for i, j in sorted(oriented):
[?2004l[?2004h>     print(f"  {nodes[i]} -> {nodes[j]}")
[?2004l[?2004h> 
[?2004l[?2004h> # Apply rules: U has no parents
[?2004l[?2004h> print("\nApplying rules:")
[?2004l[?2004h> u_idx = nodes.index('U')
[?2004l[?2004h> final_edges = []  # list of (parent, child) tuples
[?2004l[?2004h> 
[?2004l[?2004h> # First, handle v-structure orientations
[?2004l[?2004h> oriented_set = set()
[?2004l[?2004h> for i, j in oriented:
[?2004l[?2004h>     if i != u_idx:  # Don't add edges into U
[?2004l[?2004h>         oriented_set.add((i, j))
[?2004l[?2004h>         final_edges.append((nodes[i], nodes[j]))
[?2004l[?2004h> 
[?2004l[?2004h> # For remaining skeleton edges not yet oriented
[?2004l[?2004h> for (i, j) in edges:
[?2004l[?2004h>     if (i, j) in oriented or (j, i) in oriented:
[?2004l[?2004h>         continue
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if one is U
[?2004l[?2004h>     if i == u_idx:
[?2004l[?2004h>         # U -> j (U has no parents)
[?2004l[?2004h>         final_edges.append((nodes[i], nodes[j]))
[?2004l[?2004h>         print(f"  {nodes[i]} -> {nodes[j]} (U has no parents)")
[?2004l[?2004h>     elif j == u_idx:
[?2004l[?2004h>         # U -> i (U has no parents)
[?2004l[?2004h>         final_edges.append((nodes[j], nodes[i]})
[?2004l[?2004h>         print(f"  {nodes[j]} -> {nodes[i]} (U has no parents)")
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Alphabetical: earlier letter is child
[?2004l[?2004h>         if nodes[i] < nodes[j]:
[?2004l[?2004h>             # nodes[i] is child: j -> i
[?2004l[?2004h>             final_edges.append((nodes[j], nodes[i]))
[?2004l[?2004h>             print(f"  {nodes[j]} -> {nodes[i]} (alphabetical: {nodes[i]} is child)")
[?2004l[?2004h>         else:
[?2004l[?2004h>             # nodes[j] is child: i -> j
[?2004l[?2004h>             final_edges.append((nodes[i], nodes[j]))
[?2004l[?2004h>             print(f"  {nodes[i]} -> {nodes[j]} (alphabetical: {nodes[j]} is child)")
[?2004l[?2004h> 
[?2004l[?2004h> # Remove duplicates
[?2004l[?2004h> final_edges = list(set(final_edges))
[?2004l[?2004h> print(f"\nFinal DAG edges ({len(final_edges)}):")
[?2004l[?2004h> for p, c in sorted(final_edges):
[?2004l[?2004h>     print(f"  {p} -> {c}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save DAG
[?2004l[?2004h> dag_df = pd.DataFrame(final_edges, columns=['from', 'to'])
[?2004l[?2004h> dag_df = dag_df[['to', 'from']]  # Reorder to match format: to,from
[?2004l[?2004h> dag_df.to_csv('/app/learned_dag.csv', index=False)
[?2004l[?2004h> print("\nSaved learned_dag.csv")
[?2004l[?2004h> print(dag_df.to_string(index=False))
