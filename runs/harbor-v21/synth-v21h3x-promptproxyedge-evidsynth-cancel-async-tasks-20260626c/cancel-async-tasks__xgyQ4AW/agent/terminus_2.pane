[?2004l[?2004h>                 await factory()
[?2004l[?2004h>             finally:
[?2004l[?2004h>                 queue.task_done()
[?2004l[?2004h> 
[?2004l[?2004h>     workers = [asyncio.create_task(worker()) for _ in range(worker_count)]
[?2004l[?2004h> 
[?2004l[?2004h>     try:
[?2004l[?2004h>         await asyncio.gather(*workers)
[?2004l[?2004h>     except BaseException:
