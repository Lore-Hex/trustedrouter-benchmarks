[?2004l[?2004h> 
[?2004l[?2004h> async def run_tasks(
[?2004l[?2004h>     tasks: list[Callable[[], Awaitable[None]]],
[?2004l[?2004h>     max_concurrent: int,
[?2004l[?2004h> ) -> None:
[?2004l[?2004h>     """Run async jobs with at most ``max_concurrent`` running concurrently.
[?2004l[?2004h> 
