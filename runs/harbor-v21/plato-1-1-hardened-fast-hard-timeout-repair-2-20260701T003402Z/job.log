ient differences collected: {len(gradient_diffs)}")\n\n# Cluster by direction (cosine similarity)\nprint("\\nClustering gradient differences...")\n\n# Normalize all vectors\ntolerance = 0.95  # Cosine similarity threshold for same direction\n\nrows = []  # List of (sum_of_normalized, count, sum_of_original)\n\nfor i, v in enumerate(gradient_diffs):\n    norm = np.linalg.norm(v)\n    if norm < 1e-10:\n        continue\n    \n    v_normalized = v / norm\n    \n    matched = False\n    for j in range(len(rows)):\n        # Check if parallel (same or opposite direction)\n        cos_sim = abs(np.dot(v_normalized, rows[j][\'direction\']))\n        \n        if cos_sim > tolerance:\n            # Same direction, add to cluster\n            rows[j][\'sum_original\'] += v\n            rows[j][\'count\'] += 1\n            matched = True\n            break\n    \n    if not matched:\n        rows.append({\n            \'direction\': v_normalized,\n            \'sum_original\': v.copy(),\n            \'count\': 1\n        })\n\nprint(f"Found {len(rows)} unique directions")\n\nif len(rows) < 20:\n    print(f"WARNING: Expected 20 rows but found {len(rows)}. Trying with lower tolerance...")\n    # Try with lower tolerance\n    for tol in [0.9, 0.8, 0.7, 0.5]:\n        rows = []\n        for v in gradient_diffs:\n            norm = np.linalg.norm(v)\n            if norm < 1e-10:\n                continue\n            v_normalized = v / norm\n            matched = False\n            for j in range(len(rows)):\n                cos_sim = abs(np.dot(v_normalized, rows[j][\'direction\']))\n                if cos_sim > tol:\n                    rows[j][\'sum_original\'] += v\n                    rows[j][\'count\'] += 1\n                    matched = True\n                    break\n            if not matched:\n                rows.append({\n                    \'direction\': v_normalized,\n                    \'sum_original\': v.copy(),\n                    \'count\': 1\n               