[?2004limport numpy as np
import sys
sys.path.insert(0, "/app")
from forward import forward

def compute_gradient(x, h=1e-7):
    x = np.array(x, dtype=float)
    g = np.zeros(10)
    fx = forward(x)
    for i in range(10):
        xp = x.copy()
        xp[i] += h
        g[i] = (forward(xp) - fx) / h
    return g

np.random.seed(42)
TRANS_THRESH = 1e-5
STEP = 0.02
STEPS_PER_WALK = 500
gradient_diffs = []

for trial in range(200):
    if trial % 20 == 0:
        print("Walk %d, found %d transitions" % (trial, len(gradient_diffs)))
    d = np.random.randn(10)
    d = d / np.linalg.norm(d)
    x_cur = np.zeros(10)
    g_cur = compute_gradient(x_cur)
    for step in range(STEPS_PER_WALK):
        x_next = (step + 1) * STEP * d
        g_next = compute_gradient(x_next)
        diff_norm = np.linalg.norm(g_next - g_cur)
        if diff_norm > TRANS_THRESH:
            lo_t = float(step * STEP)
            hi_t = float((step + 1) * STEP)
            g_lo = g_cur.copy()
            g_hi = g_next.copy()
            for _ in range(60):
                mid_t = (lo_t + hi_t) / 2
                x_mid = mid_t * d
                g_mid = compute_gradient(x_mid)
                if np.linalg.norm(g_mid - g_lo) > TRANS_THRESH:
                    hi_t = mid_t
                    g_hi = g_mid
                else:
                    lo_t = mid_t
                    g_lo = g_mid
            dg = g_hi - g_lo
            if np.linalg.norm(dg) > TRANS_THRESH:
                gradient_diffs.append(dg.copy())
        x_cur = x_next
        g_cur = g_next

print("Total transitions: %d" % len(gradient_diffs))

clusters = []
for v in gradient_diffs:
    norm = np.linalg.norm(v)
    if norm < 1e-10:
        continue
    v_dir = v / norm
    matched = False
    for c in clusters:
        cos_sim = abs(np.dot(v_dir, c[0]))
        if cos_sim > 0.95:
            c[1] += v
            c[2] += 1
            matched = True
            break
    if not matched:
        clusters.append([v_dir, v.copy(), 1])

print("Found %d clusters at tol 0.95" % len(clusters))

for tol in [0.90, 0.85, 0.80, 0.70, 0.50]:
    if len(clusters) >= 20:
        break
    clusters = []
    for v in gradient_diffs:
        norm = np.linalg.norm(v)
        if norm < 1e-10:
            continue
        v_dir = v / norm
        matched = False
        for c in clusters:
            cos_sim = abs(np.dot(v_dir, c[0]))
            if cos_sim > tol:
                c[1] += v
                c[2] += 1
                matched = True
                break
        if not matched:
            clusters.append([v_dir, v.copy(), 1])
    print("Tol %.2f: %d clusters" % (tol, len(clusters)))

clusters.sort(key=lambda c: c[2], reverse=True)

extracted = []
for i in range(min(20, len(clusters))):
    avg = clusters[i][1] / clusters[i][2]
    extracted.append(avg)
    print("Cluster %d: count=%d, norm=%.6f" % (i, clusters[i][2], np.linalg.norm(avg)))

stolen_A1 = np.array(extracted)
print("Stolen A1 shape:", stolen_A1.shape)
np.save("/app/stolen_A1.npy", stolen_A1)
print("Saved to /app/stolen_A1.npy")

import forward as fwd
tA = fwd.A1
for i in range(min(5, len(extracted))):
    v = extracted[i]
    v_n = v / np.linalg.norm(v)
    best_s, best_j = 0, -1
    for j in range(20):
        t = tA[j]
        t_n = t / np.linalg.norm(t)
        s = abs(np.dot(v_n, t_n))
        if s > best_s:
            best_s = s
            best_j = j
    print("Row %d -> True %d, cos_sim=%.6f" % (i, best_j, best_s))
