[?2004limport numpy as np
import sys
sys.path.insert(0, '/app')
from forward import forward

def compute_gradient(x, h=1e-7):
    x = np.array(x, dtype=float)
    g = np.zeros(10)
    fx = forward(x)
    for i in range(10):
        xp = x.copy()
        xp[i] += h
        g[i] = (forward(xp) - fx) / h
    return g

np.random.seed(42)
TRANS_THRESH = 1e-5
STEP = 0.02
STEPS_PER_WALK = 500
gradient_diffs = []
