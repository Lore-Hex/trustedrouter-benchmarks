[?2004l[?2004h>                 grad_change_normalized = grad_change / np.linalg.norm(grad_change)
[?2004l[?2004h>                 crossings.append(grad_change_normalized)
[?2004l[?2004h>     
[?2004l[?2004h>     return crossings
