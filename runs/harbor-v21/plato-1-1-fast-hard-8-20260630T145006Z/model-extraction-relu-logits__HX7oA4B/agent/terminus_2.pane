[?2004l[?2004h>     
[?2004l[?2004h>     # Compute gradients along the line
[?2004l[?2004h>     points = [start + t * direction for t in ts]
[?2004l[?2004h>     grads = [compute_gradient(p) for p in points]
[?2004l[?2004h>     
[?2004l[?2004h>     # Find where gradient changes significantly
[?2004l[?2004h>     for i in range(1, len(grads)):
[?2004l[?2004h>         diff = np.linalg.norm(grads[i] - grads[i-1])
[?2004l[?2004h>         if diff > 1e-4:  # Significant gradient change = ReLU boundary
[?2004l[?2004h>             # Bisect to find more precise crossing point
[?2004l[?2004h>             t_left, t_right = ts[i-1], ts[i]
[?2004l[?2004h>             for _ in range(20):
[?2004l[?2004h>                 t_mid = (t_left + t_right) / 2
[?2004l[?2004h>                 g_mid = compute_gradient(start + t_mid * direction)
