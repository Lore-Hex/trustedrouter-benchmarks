[?2004l[?2004h>         print(f"  Trial {trial}, total {len(directions)}...")
[?2004l[?2004h>     
[?2004l[?2004h>     scale = np.random.choice([0.05, 0.1, 0.5, 1.0, 2.0, 5.0])
[?2004l[?2004h>     start = np.random.randn(10) * scale
[?2004l[?2004h>     direction = np.random.randn(10)
[?2004l[?2004h>     direction /= np.linalg.norm(direction)
[?2004l[?2004h>     
