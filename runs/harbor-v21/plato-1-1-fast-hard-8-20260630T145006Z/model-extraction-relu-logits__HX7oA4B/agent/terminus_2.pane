[?2004l[?2004h>         xp = x.copy(); xp[i] += eps
[?2004l[?2004h>         xm = x.copy(); xm[i] -= eps
[?2004l[?2004h>         grad[i] = (forward(xp) - forward(xm)) / (2*eps)
[?2004l[?2004h>     return grad
