[?2004l[?2004h> # Greedy clustering with cosine similarity threshold
[?2004l[?2004h> threshold = 0.99
[?2004l[?2004h> clusters = []  # list of dict with size and sum
[?2004l[?2004h> 
[?2004l[?2004h> for d in directions:
