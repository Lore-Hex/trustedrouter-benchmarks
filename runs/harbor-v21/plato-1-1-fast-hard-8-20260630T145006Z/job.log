Sending keys: ['cat > /app/steal.py << \'PYEOF\'\nimport numpy as np\nimport sys\nsys.path.insert(0, \'/app\')\nfrom forward import forward\n\ndef compute_gradient(x, eps=1e-5):\n    """Compute gradient using two-sided finite differences for better accuracy."""\n    grad = np.zeros(10)\n    for i in range(10):\n        xp = x.copy(); xp[i] += eps\n        xm = x.copy(); xm[i] -= eps\n        grad[i] = (forward(xp) - forward(xm)) / (2*eps)\n    return grad\n\nnp.random.seed(42)\ndirections = []\n\nprint("Collecting gradient-change directions...")\nfor trial in range(2000):\n    if trial % 200 == 0:\n        print(f"  Trial {trial}, total {len(directions)}...")\n    \n    scale = np.random.choice([0.05, 0.1, 0.5, 1.0, 2.0, 5.0])\n    start = np.random.randn(10) * scale\n    direction = np.random.randn(10)\n    direction /= np.linalg.norm(direction)\n    \n    ts = np.linspace(-20, 20, 800)\n    prev_grad = None\n    \n    for t in ts:\n        p = start + t * direction\n        g = compute_gradient(p)\n        if prev_grad is not None:\n            diff = g - prev_grad\n            nd = np.linalg.norm(diff)\n            if nd > 1e-4:\n                directions.append(diff / nd)\n        prev_grad = g\n\nprint(f"\\nTotal directions collected: {len(directions)}")\n\ndirections = np.array(directions)\n\n# Greedy clustering with cosine similarity threshold\nthreshold = 0.99\nclusters = []  # list of dict with size and sum\n\nfor d in directions:\n    assigned = False\n    for c in clusters:\n        cos = np.dot(d, c[\'mean\'])\n        if abs(cos) > threshold:\n            # Align sign before averaging\n            d_aligned = d * np.sign(cos)\n            c[\'sum\'] += d_aligned\n            c[\'count\'] += 1\n            c[\'mean\'] = c[\'sum\'] / c[\'count\']\n            c[\'mean\'] /= np.linalg.norm(c[\'mean\'])\n            assigned = True\n            break\n    if not assigned:\n        clusters.append({\'sum\': d.copy(), \'count\': 1, \'mean\': d.copy()})\n\ncentroids = [(c[\'mean\'], c[\'count\']) for c in clusters]\n\ncentroids.sort(key=lambda x: -x[1])\n\nprint(f"\\nFound {len(clusters)} clusters. Top sizes:")\nfor i in range(min(30, len(clusters))):\n    print(f"  {i}: {clusters[i][\'count\']}")\n\nA1_extracted = np.array([c[0] for c in centroids[:20]])\n\nnp.save(\'/app/stolen_A1.npy\', A1_extracted)\nprint(f"\\nSaved A1 with shape {A1_extracted.shape}")\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
