[?2004l[?2004h> 
[?2004l[?2004h> cleanup_done = []
[?2004l[?2004h> 
[?2004l[?2004h> async def make_task(name):
[?2004l[?2004h>     async def task():
[?2004l[?2004h>         try:
[?2004l[?2004h>             await asyncio.sleep(0.01)
[?2004l[?2004h>             print(f"  {name} ran")
[?2004l[?2004h>         finally:
[?2004l[?2004h>             cleanup_done.append(name)
[?2004l[?2004h>             print(f"  {name} cleaned up")
[?2004l[?2004h>     return task
[?2004l[?2004h> 
[?2004l[?2004h> async def main():
[?2004l[?2004h>     tasks = []
