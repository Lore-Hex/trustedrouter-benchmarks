[?2004l[?2004h> from __future__ import annotations
[?2004l[?2004h> 
[?2004l[?2004h> import asyncio
[?2004l[?2004h> from typing import Awaitable, Callable
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> async def run_tasks(
[?2004l[?2004h>     tasks: list[Callable[[], Awaitable[None]]],
[?2004l[?2004h>     max_concurrent: int,
[?2004l[?2004h> ) -> None:
[?2004l[?2004h>     """Run async jobs with bounded concurrency.
[?2004l[?2004h> 
[?2004l[?2004h>     Each item in ``tasks`` is a factory returning an awaitable job. At most
[?2004l[?2004h>     ``max_concurrent`` jobs run at one time. Exceptions and cancellation are
[?2004l[?2004h>     collected so every started task gets a chance to run cleanup code before
[?2004l[?2004h>     the first error, if any, is re-raised.
[?2004l[?2004h>     """
[?2004l[?2004h>     if max_concurrent < 1:
[?2004l[?2004h>         raise ValueError("max_concurrent must be >= 1")
[?2004l[?2004h> 
[?2004l[?2004h>     semaphore = asyncio.Semaphore(max_concurrent)
[?2004l[?2004h> 
[?2004l[?2004h>     async def runner(factory: Callable[[], Awaitable[None]]) -> None:
[?2004l[?2004h>         async with semaphore:
[?2004l[?2004h>             await factory()
[?2004l[?2004h> 
[?2004l[?2004h>     results = await asyncio.gather(
[?2004l[?2004h>         *(runner(task) for task in tasks),
[?2004l[?2004h>         return_exceptions=True,
[?2004l[?2004h>     )
[?2004l[?2004h> 
[?2004l[?2004h>     for result in results:
[?2004l[?2004h>         if isinstance(result, BaseException):
[?2004l[?2004h>             raise result
[?2004l[?2004h> PY
