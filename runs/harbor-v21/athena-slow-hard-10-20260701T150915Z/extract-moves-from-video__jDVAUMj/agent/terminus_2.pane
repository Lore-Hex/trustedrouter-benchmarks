[?2004l[?2004h> def parse_frame(text):
[?2004l[?2004h>     lines = text.strip().split('\n')
[?2004l[?2004h>     prompts = []
[?2004l[?2004h>     moves_counter = None
[?2004l[?2004h>     for line in lines:
