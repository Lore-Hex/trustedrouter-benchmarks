[?2004l[?2004h> import os, re, glob
[?2004l[?2004h> 
[?2004l[?2004h> files = sorted(glob.glob('/app/ocr/frame_*.txt'))
[?2004l[?2004h> 
[?2004l[?2004h> def parse_frame(text):
[?2004l[?2004h>     lines = text.strip().split('\n')
[?2004l[?2004h>     prompts = []
[?2004l[?2004h>     moves_counter = None
[?2004l[?2004h>     for line in lines:
[?2004l[?2004h>         m = re.search(r'Moves:\s*(\d+)', line)
[?2004l[?2004h>         if m:
[?2004l[?2004h>             moves_counter = int(m.group(1))
[?2004l[?2004h>         if '>' in line:
[?2004l[?2004h>             idx = line.rindex('>')
[?2004l[?2004h>             cmd = line[idx+1:].strip()
[?2004l[?2004h>             prompts.append(cmd)
[?2004l[?2004h>     return prompts, moves_counter
[?2004l[?2004h> 
[?2004l[?2004h> frame_data = []
[?2004l[?2004h> for f in files:
[?2004l[?2004h>     text = open(f).read()
[?2004l[?2004h>     prompts, counter = parse_frame(text)
[?2004l[?2004h>     frame_data.append({
[?2004l[?2004h>         'file': os.path.basename(f),
[?2004l[?2004h>         'prompts': prompts,
[?2004l[?2004h>         'last': prompts[-1] if prompts else "",
[?2004l[?2004h>         'counter': counter
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> # Strategy: track the last prompt text being typed.
[?2004l[?2004h> # A command is completed when the last prompt text changes to something new
[?2004l[?2004h> # (either empty for a fresh prompt, or a different command).
[?2004l[?2004h> # The completed command is the previous last prompt.
[?2004l[?2004h> moves = []
[?2004l[?2004h> prev_last = frame_data[0]['last']
[?2004l[?2004h> prev_frame = frame_data[0]['file']
[?2004l[?2004h> 
[?2004l[?2004h> for fd in frame_data[1:]:
[?2004l[?2004h>     cur_last = fd['last']
[?2004l[?2004h>     
[?2004l[?2004h>     # If the last prompt changed, the previous was potentially completed
[?2004l[?2004h>     if prev_last and prev_last != cur_last:
[?2004l[?2004h>         # Check if prev_last is a prefix of cur_last (still typing same command)
[?2004l[?2004h>         if not cur_last.startswith(prev_last.rstrip('_').rstrip()):
[?2004l[?2004h>             # Command was completed
[?2004l[?2004h>             moves.append((prev_frame, prev_last))
[?2004l[?2004h>     
[?2004l[?2004h>     prev_last = cur_last
[?2004l[?2004h>     prev_frame = fd['file']
[?2004l[?2004h> 
[?2004l[?2004h> # Last command
[?2004l[?2004h> if prev_last:
[?2004l[?2004h>     moves.append((prev_frame, prev_last))
[?2004l[?2004h> 
[?2004l[?2004h> for i, (frame, move) in enumerate(moves):
[?2004l[?2004h>     print(f"{i+1}: {frame} {move!r}")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nTotal moves: {len(moves)}")
