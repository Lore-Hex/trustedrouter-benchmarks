[?2004l[?2004h>                 prev_completed = True
[?2004l[?2004h>     
[?2004l[?2004h>     # Add all new completed prompts (non-last)
[?2004l[?2004h>     for p in prompts[:-1]:
[?2004l[?2004h>         add_move(p, fd['file'])
