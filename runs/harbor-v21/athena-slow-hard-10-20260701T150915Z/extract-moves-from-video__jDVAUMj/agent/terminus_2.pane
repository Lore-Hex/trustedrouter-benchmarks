[?2004l[?2004h>         if stripped.startswith('>'):
[?2004l[?2004h>             cmd = stripped[1:].strip()
[?2004l[?2004h>             prompts.append(cmd)
[?2004l[?2004h>     return prompts
[?2004l[?2004h> 
