[?2004l[?2004h> 
[?2004l[?2004h> def clean(cmd):
[?2004l[?2004h>     cmd = cmd.strip()
[?2004l[?2004h>     while cmd and cmd[-1] in '._':
[?2004l[?2004h>         cmd = cmd[:-1]
[?2004l[?2004h>     if cmd.startswith('D') and len(cmd) > 1 and cmd[1].islower():
[?2004l[?2004h>         cmd = cmd[1:]
[?2004l[?2004h>     return cmd
[?2004l[?2004h> 
[?2004l[?2004h> def norm(cmd):
[?2004l[?2004h>     return clean(cmd).lower().replace(' ', '').replace(',', ',').strip()
[?2004l[?2004h> 
[?2004l[?2004h> def fuzzy_match(a, b):
[?2004l[?2004h>     a, b = norm(a), norm(b)
[?2004l[?2004h>     if not a or not b:
[?2004l[?2004h>         return a == b
[?2004l[?2004h>     if a == b:
[?2004l[?2004h>         return True
[?2004l[?2004h>     if a.startswith(b) or b.startswith(a):
[?2004l[?2004h>         return True
[?2004l[?2004h>     common = 0
[?2004l[?2004h>     for i in range(min(len(a), len(b))):
[?2004l[?2004h>         if a[i] == b[i]:
[?2004l[?2004h>             common += 1
[?2004l[?2004h>         else:
[?2004l[?2004h>             break
[?2004l[?2004h>     return common >= 3 and common >= min(len(a), len(b)) - 2
