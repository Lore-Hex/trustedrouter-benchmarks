[?2004l[?2004h> prev_counter = frame_data[0]['counter'] or 0
[?2004l[?2004h> 
[?2004l[?2004h> def add_move(cmd, frame):
[?2004l[?2004h>     cmd = clean(cmd)
[?2004l[?2004h>     if not cmd:
[?2004l[?2004h>         return
[?2004l[?2004h>     if moves and fuzzy_match(cmd, moves[-1]):
[?2004l[?2004h>         if len(cmd) > len(moves[-1]):
[?2004l[?2004h>             moves[-1] = cmd
[?2004l[?2004h>     else:
[?2004l[?2004h>         moves.append(cmd)
[?2004l[?2004h> 
[?2004l[?2004h> for fd in frame_data[1:]:
[?2004l[?2004h>     prompts = fd['prompts']
[?2004l[?2004h>     cur_last = fd['last']
[?2004l[?2004h>     cur_counter = fd['counter']
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if prev_last is now completed (appears as non-last in current frame)
[?2004l[?2004h>     prev_completed = False
[?2004l[?2004h>     if prev_last:
[?2004l[?2004h>         for p in prompts[:-1]:
[?2004l[?2004h>             if fuzzy_match(prev_last, p):
[?2004l[?2004h>                 # Use the more complete version
[?2004l[?2004h>                 add_move(p, fd['file'])
[?2004l[?2004h>                 prev_completed = True
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     # If prev_last is not in current frame at all, and counter increased,
[?2004l[?2004h>     # it was completed and scrolled off
[?2004l[?2004h>     if prev_last and not prev_completed and cur_counter and prev_counter and cur_counter > prev_counter:
[?2004l[?2004h>         add_move(prev_last, fd['file'])
[?2004l[?2004h>     
[?2004l[?2004h>     # If prev_last changed and new last is not a prefix extension, prev was completed
[?2004l[?2004h>     if prev_last and cur_last != prev_last:
[?2004l[?2004h>         if not cur_last.startswith(clean(prev_last).rstrip('_')):
[?2004l[?2004h>             if not prev_completed:
