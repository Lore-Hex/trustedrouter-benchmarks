[?2004l[?2004h> 
[?2004l[?2004h> files = sorted(glob.glob('/app/ocr/frame_*.txt'))
[?2004l[?2004h> 
[?2004l[?2004h> def get_prompts(text):
[?2004l[?2004h>     """Get all text after '>' prompt lines (lines starting with '>')."""
