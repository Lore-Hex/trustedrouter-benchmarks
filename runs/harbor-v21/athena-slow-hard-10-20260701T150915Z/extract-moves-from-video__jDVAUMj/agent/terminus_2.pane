[?2004l[?2004h>     if short == long:
[?2004l[?2004h>         return True
[?2004l[?2004h>     # Allow trailing _ in short as wildcard
[?2004l[?2004h>     short_base = short.rstrip('_')
[?2004l[?2004h>     if long.startswith(short_base):
[?2004l[?2004h>         return True
[?2004l[?2004h>     # Check if long starts with most of short
