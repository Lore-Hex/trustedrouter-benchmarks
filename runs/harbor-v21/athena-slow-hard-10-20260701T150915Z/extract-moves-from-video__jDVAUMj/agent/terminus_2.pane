[?2004hroot@5e330e93cc71:/app# python3 << 'PYEOF'
[?2004l[?2004h> import os, re, glob
[?2004l[?2004h> 
[?2004l[?2004h> files = sorted(glob.glob('/app/ocr/frame_*.txt'))
[?2004l[?2004h> 
[?2004l[?2004h> def parse_frame(text):
[?2004l[?2004h>     lines = text.strip().split('\n')
[?2004l[?2004h>     prompts = []
[?2004l[?2004h>     moves_counter = None
[?2004l[?2004h>     for line in lines:
[?2004l[?2004h>         m = re.search(r'Moves:\s*(\d+)', line)
[?2004l[?2004h>         if m:
[?2004l[?2004h>             moves_counter = int(m.group(1))
[?2004l[?2004h>         if '>' in line:
[?2004l[?2004h>             idx = line.rindex('>')
[?2004l[?2004h>             cmd = line[idx+1:].strip()
[?2004l[?2004h>             prompts.append(cmd)
[?2004l[?2004h>     return prompts, moves_counter
[?2004l[?2004h> 
[?2004l[?2004h> frame_data = []
[?2004l[?2004h> for f in files:
[?2004l[?2004h>     text = open(f).read()
[?2004l[?2004h>     prompts, counter = parse_frame(text)
[?2004l[?2004h>     frame_data.append({
[?2004l[?2004h>         'file': os.path.basename(f),
[?2004l[?2004h>         'prompts': prompts,
[?2004l[?2004h>         'counter': counter
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> # Track new completed commands by comparing consecutive frames
[?2004l[?2004h> moves = []
[?2004l[?2004h> prev_all = []
[?2004l[?2004h> 
[?2004l[?2004h> for fd in frame_data:
[?2004l[?2004h>     cur_all = fd['prompts']
[?2004l[?2004h>     
[?2004l[?2004h>     # Find first position where they differ
[?2004l[?2004h>     min_len = min(len(prev_all), len(cur_all))
[?2004l[?2004h>     first_diff = min_len
[?2004l[?2004h>     for i in range(min_len):
[?2004l[?2004h>         if prev_all[i] != cur_all[i]:
[?2004l[?2004h>             first_diff = i
[?2004l[?2004h>             break
[?2004l[?2004h>     
[?2004l[?2004h>     # New completed commands are from first_diff to len(cur_all)-2 (excluding last = being typed)
[?2004l[?2004h>     for i in range(first_diff, len(cur_all) - 1):
[?2004l[?2004h>         cmd = cur_all[i].strip()
[?2004l[?2004h>         if cmd:
[?2004l[?2004h>             moves.append(cmd)
[?2004l[?2004h>     
[?2004l[?2004h>     prev_all = cur_all
[?2004l[?2004h> 
