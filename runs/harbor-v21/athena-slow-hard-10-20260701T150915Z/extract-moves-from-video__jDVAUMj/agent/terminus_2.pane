python3 -c "
import os, re, glob
files = sorted(glob.glob('/app/ocr/frame_*.txt'))
for f in files[:30]:
    text = open(f).read()
    lines = text.strip().split('\n')
    # Find lines with >
    for line in lines:
        if '>' in line:
            print(os.path.basename(f), repr(line))
"
