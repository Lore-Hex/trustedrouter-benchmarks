Sending keys: ["python3 - <<'PY'\np='/app/image.ppm'\ndata=open(p,'rb').read().split()\nw=int(data[1]); h=int(data[2])\niv=[int(v) for v in data[4:]]\ndef px(x,y):\n    i=(y*w+x)*3\n    return iv[i],iv[i+1],iv[i+2]\n# Test Burning Ship with various mappings\n# Burning Ship: z = (|x|+i|y|)^2 + c, z0=0\n# Try mapping: center (1200,900) -> (-0.5, -0.5), scale varies\ndef burning_ship(cx, cy, maxiter):\n    x, y = 0.0, 0.0\n    for i in range(maxiter):\n        if x*x + y*y > 4:\n            return i\n        x, y = x*x - y*y + cx, abs(2*x*y) + cy  # wrong, need |x|+i|y| squared\n    return -1\n\ndef burning_ship2(cx, cy, maxiter):\n    x, y = 0.0, 0.0\n    for i in range(maxiter):\n        if x*x + y*y > 4:\n            return i\n        x2 = x*x - y*y + cx\n        y2 = 2*abs(x)*abs(y) + cy  # burning ship uses |x|, |y|\n        x, y = x2, y2\n    return -1\n\ndef test_mapping(cx0, cy0, scale, maxiter=100, flip_y=False):\n    # Check if interior matches dark red at sampled points\n    matches = 0\n    total = 0\n    for sy in range(800, 1300, 20):\n        for sx in range(900, 1600, 20):\n            cx = cx0 + (sx - 1200) * scale\n            if flip_y:\n                cy = cy0 - (sy - 900) * scale\n            else:\n                cy = cy0 + (sy - 900) * scale\n            interior = burning_ship2(cx, cy, maxiter) == -1\n            r,g,b = px(sx, sy)\n            is_dark_red = (r <= 60 and g <= 15 and b <= 15)\n            if interior == is_dark_red:\n                matches += 1\n            total += 1\n    return matches, total\n\n# Try various mappings\nfor cx0 in [-0.5, -0.4, -0.6]:\n    for cy0 in [-0.5, -0.4, -0.6, -0.3]:\n        for scale in [0.001, 0.0012, 0.0015, 0.002]:\n            for flip in [True, False]:\n                m, t = test_mapping(cx0, cy0, scale, 100, flip)\n                if m > t * 0.7:\n                    print(f'cx0={cx0} cy0={cy0} scale={scale} flip={flip}: {m}/{t} = {m/t:.3f}')\nPY\n"] min_timeout_sec: 5.0 max_timeout_sec: 180.0
