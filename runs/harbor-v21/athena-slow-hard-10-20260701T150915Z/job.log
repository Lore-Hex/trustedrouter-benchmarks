Sending keys: ['python3 << \'PYEOF\'\nimport os, re, glob\n\nfiles = sorted(glob.glob(\'/app/ocr/frame_*.txt\'))\n\n# For each frame, extract all \'>\' prompt texts and the moves counter\ndef parse_frame(text):\n    lines = text.strip().split(\'\\n\')\n    prompts = []\n    moves_counter = None\n    for line in lines:\n        # Look for Moves: N\n        m = re.search(r\'Moves:\\s*(\\d+)\', line)\n        if m:\n            moves_counter = int(m.group(1))\n        if \'>\' in line:\n            idx = line.rindex(\'>\')\n            cmd = line[idx+1:].strip()\n            prompts.append(cmd)\n    return prompts, moves_counter\n\n# Track all prompts and counter across frames\nframe_data = []\nfor f in files:\n    text = open(f).read()\n    prompts, counter = parse_frame(text)\n    frame_data.append({\n        \'file\': os.path.basename(f),\n        \'prompts\': prompts,\n        \'last_prompt\': prompts[-1] if prompts else "",\n        \'all_prompts\': prompts,\n        \'counter\': counter\n    })\n\n# Print frame-by-frame data for first 60 frames\nfor fd in frame_data[:60]:\n    print(f"{fd[\'file\']}: counter={fd[\'counter\']} last={fd[\'last_prompt\']!r} all={fd[\'all_prompts\']}")\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
