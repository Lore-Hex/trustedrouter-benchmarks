r = fd[\'counter\']\n    \n    # Check if prev_last is now completed (appears as non-last in current frame)\n    prev_completed = False\n    if prev_last:\n        for p in prompts[:-1]:\n            if fuzzy_match(prev_last, p):\n                # Use the more complete version\n                add_move(p, fd[\'file\'])\n                prev_completed = True\n                break\n    \n    # If prev_last is not in current frame at all, and counter increased,\n    # it was completed and scrolled off\n    if prev_last and not prev_completed and cur_counter and prev_counter and cur_counter > prev_counter:\n        add_move(prev_last, fd[\'file\'])\n    \n    # If prev_last changed and new last is not a prefix extension, prev was completed\n    if prev_last and cur_last != prev_last:\n        if not cur_last.startswith(clean(prev_last).rstrip(\'_\')):\n            if not prev_completed:\n                add_move(prev_last, fd[\'file\'])\n                prev_completed = True\n    \n    # Add all new completed prompts (non-last)\n    for p in prompts[:-1]:\n        add_move(p, fd[\'file\'])\n    \n    prev_last = cur_last\n    if cur_counter is not None:\n        prev_counter = cur_counter\n\n# Last frame\'s last prompt\nif prev_last:\n    add_move(prev_last, frame_data[-1][\'file\'])\n\nfor i, move in enumerate(moves):\n    print(f"{i+1}: {move!r}")\n\nprint(f"\\nTotal moves: {len(moves)}")\ncounters = [(fd[\'file\'], fd[\'counter\']) for fd in frame_data if fd[\'counter\'] is not None]\nif counters:\n    print(f"Last counter: {counters[-1]}")\nPYEOF\ncat /app/moves_v3.txt\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
