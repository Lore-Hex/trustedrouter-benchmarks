er = fd[\'counter\']\n    \n    overlap = find_overlap(prev_prompts, cur_prompts)\n    \n    # New completed commands: from overlap to len(cur_prompts)-1\n    new_completed = cur_prompts[overlap:len(cur_prompts)-1] if len(cur_prompts) > 1 else []\n    \n    # Also check if prev_prompts[-1] (being typed) is now completed\n    # If it\'s in the overlap but was the last in prev, it\'s now completed\n    if prev_prompts and overlap > 0:\n        prev_last = prev_prompts[-1]\n        # If prev_last was non-empty and it matches something in cur_prompts (not the last), it was completed\n        if prev_last:\n            for i in range(len(cur_prompts)-1):\n                if fuzzy_match(prev_last, cur_prompts[i]):\n                    # It was completed - use the cur version (might be more complete)\n                    cmd = clean(cur_prompts[i])\n                    if cmd and (not moves or norm(cmd) != norm(moves[-1])):\n                        moves.append(cmd)\n                    break\n    \n    for cmd in new_completed:\n        cmd = clean(cmd)\n        if cmd and (not moves or norm(cmd) != norm(moves[-1])):\n            moves.append(cmd)\n    \n    prev_prompts = cur_prompts\n    prev_counter = cur_counter\n\n# Last frame\'s last prompt\nif prev_prompts:\n    cmd = clean(prev_prompts[-1])\n    if cmd and (not moves or norm(cmd) != norm(moves[-1])):\n        moves.append(cmd)\n\nfor i, move in enumerate(moves):\n    print(f"{i+1}: {move!r}")\n\nprint(f"\\nTotal moves: {len(moves)}")\n# Print counter info\ncounters = [(fd[\'file\'], fd[\'counter\']) for fd in frame_data if fd[\'counter\'] is not None]\nif counters:\n    print(f"First counter: {counters[0]}")\n    print(f"Last counter: {counters[-1]}")\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
