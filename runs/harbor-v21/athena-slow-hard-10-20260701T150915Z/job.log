rev=v\nprint('=== vertical checker x=1200 (excluding fractal) ===')\nprev=None\nfor y in range(1175,1800):\n    v=px(1200,y)\n    if v!=prev:\n        print(f'y={y}: {v}')\n        prev=v\nPY\n"] min_timeout_sec: 10.0 max_timeout_sec: 180.0
