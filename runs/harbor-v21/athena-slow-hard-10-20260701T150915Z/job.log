           interior=fn(cx,cy,200)==-1\n                r,g,b=px(sx,sy)\n                is_dark=(r<=60 and g<=15 and b<=15)\n                if interior==is_dark:\n                  matches+=1\n                total+=1\n            frac=matches/total\n            if frac>best[0]:\n              best=(frac,cx0,cy0,scale,flip)\n            if frac>0.75:\n              print(f'{name}: cx0={cx0} cy0={cy0} scale={scale} flip={flip}: {matches}/{total}={frac:.3f}')\n    print(f'{name} best: {best}')\nPY\n"] min_timeout_sec: 10.0 max_timeout_sec: 180.0
