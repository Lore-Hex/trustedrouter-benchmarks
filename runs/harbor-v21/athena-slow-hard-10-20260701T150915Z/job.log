Sending keys: ['cat << \'PYEOF\' > /app/parallel_linear.py\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\nclass _AllGather(torch.autograd.Function):\n    @staticmethod\n    def forward(ctx, x, world_size, rank):\n        ctx.world_size = world_size\n        ctx.rank = rank\n        if world_size == 1:\n            return x.detach().clone()\n        x_contig = x.detach().contiguous()\n        tensor_list = [torch.empty_like(x_contig) for _ in range(world_size)]\n        dist.all_gather(tensor_list, x_contig)\n        return torch.cat(tensor_list, dim=-1)\n\n    @staticmethod\n    def backward(ctx, grad_output):\n        if ctx.world_size == 1:\n            return grad_output, None, None\n        partition_size = grad_output.shape[-1] // ctx.world_size\n        start = ctx.rank * partition_size\n        end = (ctx.rank + 1) * partition_size\n        return grad_output[..., start:end].contiguous(), None, None\n\n\nclass _AllReduce(torch.autograd.Function):\n    @staticmethod\n    def forward(ctx, x):\n        x = x.detach().clone().contiguous()\n        if dist.is_initialized():\n            dist.all_reduce(x, op=dist.ReduceOp.SUM)\n        return x\n\n    @staticmethod\n    def backward(ctx, grad_output):\n        return grad_output\n\n\nclass ColumnParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n        partition_size = out_features // world_size\n        weight_chunk = master_weight[\n            rank * partition_size:(rank + 1) * partition_size, :\n        ].detach().clone().contiguous()\n        self.weight = nn.Parameter(weight_chunk)\n        if bias:\n            self.bias = nn.Parameter(\n                torch.zeros(\n                    partition_size,\n                    dtype=master_weight.dtype,\n                    device=master_weight.device,\n                )\n            )\n        else:\n            self.register_parameter("bias", None)\n        self.in_features = in_features\n        self.out_features = out_features\n\n    def forward(self, x):\n        output = F.linear(x, self.weight, self.bias)\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n        output = _AllGather.apply(output, world_size, rank)\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n        partition_size = in_features // world_size\n        weight_chunk = master_weight[\n            :, rank * partition_size:(rank + 1) * partition_size\n        ].detach().clone().contiguous()\n        self.weight = nn.Parameter(weight_chunk)\n        if bias:\n            self.bias = nn.Parameter(\n                torch.zeros(\n                    out_features,\n                    dtype=master_weight.dtype,\n                    device=master_weight.device,\n                )\n            )\n        else:\n            self.register_parameter("bias", None)\n        self.in_features = in_features\n        self.out_features = out_features\n\n    def forward(self, x):\n        output = F.linear(x, self.weight, None)\n        output = _AllReduce.apply(output)\n        if self.bias is not None:\n            output = output + self.bias\n        return output\nPYEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
