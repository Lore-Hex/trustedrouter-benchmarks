0,10):\n            cx = cx0 + (sx-1200)*scale\n            cy = cy0 + ((sy-900)*scale * (-1 if flip else 1))\n            interior = mandel(cx,cy,100)==-1\n            r,g,b = px(sx,sy)\n            is_dark = (r<=60 and g<=15 and b<=15)\n            if interior==is_dark:\n              matches+=1\n            total+=1\n        if matches > total*0.6:\n          print(f'cx0={cx0} cy0={cy0} scale={scale} flip={flip}: {matches}/{total}={matches/total:.3f}')\nPY\n"] min_timeout_sec: 5.0 max_timeout_sec: 180.0
