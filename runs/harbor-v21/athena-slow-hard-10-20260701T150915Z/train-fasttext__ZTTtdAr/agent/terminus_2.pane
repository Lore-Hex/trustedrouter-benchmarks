[?2004l[?2004h> def clean(t):
[?2004l[?2004h>     if t is None:
[?2004l[?2004h>         return ''
[?2004l[?2004h>     t = html.unescape(str(t))
[?2004l[?2004h>     t = t.replace('\r', ' ').replace('\n', ' ').replace('\t', ' ')
[?2004l[?2004h>     t = re.sub(r'\s+', ' ', t).strip()
[?2004l[?2004h>     t = t.lower()
[?2004l[?2004h>     return t
[?2004l[?2004h> 
[?2004l[?2004h> def write_ft(path, out):
[?2004l[?2004h>     df = pq.read_table(path, columns=['label','text']).to_pandas()
[?2004l[?2004h>     with open(out, 'w', encoding='utf-8') as f:
[?2004l[?2004h>         for label, text in zip(df['label'].tolist(), df['text'].tolist()):
[?2004l[?2004h>             f.write(f'__label__{label} {clean(text)}\n')
