[?2004hroot@6da80db1eb33:/app# python3 - <<'PY'
[?2004l[?2004h> p='/app/image.ppm'
[?2004l[?2004h> data=open(p,'rb').read().split()
[?2004l[?2004h> w=int(data[1]); h=int(data[2])
[?2004l[?2004h> iv=[int(v) for v in data[4:]]
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3
[?2004l[?2004h>     return iv[i],iv[i+1],iv[i+2]
[?2004l[?2004h> # Test Burning Ship with various mappings
[?2004l[?2004h> # Burning Ship: z = (|x|+i|y|)^2 + c, z0=0
[?2004l[?2004h> # Try mapping: center (1200,900) -> (-0.5, -0.5), scale varies
[?2004l[?2004h> def burning_ship(cx, cy, maxiter):
[?2004l[?2004h>     x, y = 0.0, 0.0
[?2004l[?2004h>     for i in range(maxiter):
[?2004l[?2004h>         if x*x + y*y > 4:
[?2004l[?2004h>             return i
[?2004l[?2004h>         x, y = x*x - y*y + cx, abs(2*x*y) + cy  # wrong, need |x|+i|y| squared
[?2004l[?2004h>     return -1
[?2004l[?2004h> 
[?2004l[?2004h> def burning_ship2(cx, cy, maxiter):
[?2004l[?2004h>     x, y = 0.0, 0.0
[?2004l[?2004h>     for i in range(maxiter):
[?2004l[?2004h>         if x*x + y*y > 4:
[?2004l[?2004h>             return i
[?2004l[?2004h>         x2 = x*x - y*y + cx
[?2004l[?2004h>         y2 = 2*abs(x)*abs(y) + cy  # burning ship uses |x|, |y|
[?2004l[?2004h>         x, y = x2, y2
[?2004l[?2004h>     return -1
[?2004l[?2004h> 
[?2004l[?2004h> def test_mapping(cx0, cy0, scale, maxiter=100, flip_y=False):
[?2004l[?2004h>     # Check if interior matches dark red at sampled points
[?2004l[?2004h>     matches = 0
[?2004l[?2004h>     total = 0
[?2004l[?2004h>     for sy in range(800, 1300, 20):
[?2004l[?2004h>         for sx in range(900, 1600, 20):
[?2004l[?2004h>             cx = cx0 + (sx - 1200) * scale
[?2004l[?2004h>             if flip_y:
[?2004l[?2004h>                 cy = cy0 - (sy - 900) * scale
[?2004l[?2004h>             else:
[?2004l[?2004h>                 cy = cy0 + (sy - 900) * scale
[?2004l[?2004h>             interior = burning_ship2(cx, cy, maxiter) == -1
[?2004l[?2004h>             r,g,b = px(sx, sy)
[?2004l[?2004h>             is_dark_red = (r <= 60 and g <= 15 and b <= 15)
[?2004l[?2004h>             if interior == is_dark_red:
[?2004l[?2004h>                 matches += 1
[?2004l[?2004h>             total += 1
[?2004l[?2004h>     return matches, total
[?2004l[?2004h> 
[?2004l[?2004h> # Try various mappings
[?2004l[?2004h> for cx0 in [-0.5, -0.4, -0.6]:
[?2004l[?2004h>     for cy0 in [-0.5, -0.4, -0.6, -0.3]:
[?2004l[?2004h>         for scale in [0.001, 0.0012, 0.0015, 0.002]:
[?2004l[?2004h>             for flip in [True, False]:
[?2004l[?2004h>                 m, t = test_mapping(cx0, cy0, scale, 100, flip)
[?2004l[?2004h>                 if m > t * 0.7:
[?2004l[?2004h>                     print(f'cx0={cx0} cy0={cy0} scale={scale} flip={flip}: {m}/{t} = {m/t:.3f}')
[?2004l[?2004h> PY
