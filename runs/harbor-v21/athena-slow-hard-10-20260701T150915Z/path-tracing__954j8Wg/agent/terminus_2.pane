[?2004l[?2004h>     # Print first 20 transitions and block sizes
[?2004l[?2004h>     print(f'y={y}:')
[?2004l[?2004h>     for i,(x,v) in enumerate(transitions[:20]):
[?2004l[?2004h>         if i+1 < len(transitions):
[?2004l[?2004h>             bw = transitions[i+1][0] - x
[?2004l[?2004h>         else:
[?2004l[?2004h>             bw = w - x
[?2004l[?2004h>         print(f'  x={x} color={v} blockwidth={bw}')
[?2004l[?2004h>     print(f'  total transitions: {len(transitions)}')
[?2004l[?2004h> # Sky gradient: sample at y=0,400,800 and x=0,300,600,900,1200
[?2004l[?2004h> print('=== sky gradient ===')
[?2004l[?2004h> for y in [0,100,200,300,400,500,600,700,800,805,808]:
[?2004l[?2004h>     for x in [0,300,600,900,1200,1500,1800,2100,2399]:
[?2004l[?2004h>         r,g,b = px(x,y)
[?2004l[?2004h>         if b==255:
[?2004l[?2004h>             print(f'y={y} x={x}: ({r},{g},{b})')
[?2004l[?2004h>     print()
[?2004l[?2004h> # Red gradient at x=1200, y=809-856
[?2004l[?2004h> print('=== red gradient x=1200 ===')
[?2004l[?2004h> for y in range(809,857):
[?2004l[?2004h>     print(f'y={y}: {px(1200,y)}')
[?2004l[?2004h> # Test Mandelbrot mapping
[?2004l[?2004h> print('=== testing mandelbrot ===')
[?2004l[?2004h> def mandel(cx,cy,maxiter):
[?2004l[?2004h>     x,y=0.0,0.0
[?2004l[?2004h>     for i in range(maxiter):
[?2004l[?2004h>         if x*x+y*y>4: return i
[?2004l[?2004h>         x,y=x*x-y*y+cx,2*x*y+cy
[?2004l[?2004h>     return -1
[?2004l[?2004h> # Try mapping: pixel(1200,900) -> complex(-0.5,0), scale
[?2004l[?2004h> # Dark red extent: x=1020-1360 (width 340), y=840-1175 (height 335)
[?2004l[?2004h> # Center: (1190, 1007)
[?2004l[?2004h> # Try: center maps to (-0.25, 0), scale = 340/2.5 = 136 px/unit
[?2004l[?2004h> for cx0 in [-0.25,-0.5,-0.3]:
[?2004l[?2004h>   for cy0 in [0,-0.1,0.1]:
[?2004l[?2004h>     for scale in [0.005,0.007,0.01,0.015]:
[?2004l[?2004h>       for flip in [True,False]:
[?2004l[?2004h>         matches=0; total=0
[?2004l[?2004h>         for sy in range(800,1300,10):
[?2004l[?2004h>           for sx in range(1000,1400,10):
[?2004l[?2004h>             cx = cx0 + (sx-1200)*scale
[?2004l[?2004h>             cy = cy0 + ((sy-900)*scale * (-1 if flip else 1))
[?2004l[?2004h>             interior = mandel(cx,cy,100)==-1
[?2004l[?2004h>             r,g,b = px(sx,sy)
[?2004l[?2004h>             is_dark = (r<=60 and g<=15 and b<=15)
[?2004l[?2004h>             if interior==is_dark:
[?2004l[?2004h>               matches+=1
[?2004l[?2004h>             total+=1
[?2004l[?2004h>         if matches > total*0.6:
[?2004l[?2004h>           print(f'cx0={cx0} cy0={cy0} scale={scale} flip={flip}: {matches}/{total}={matches/total:.3f}')
[?2004l[?2004h> PY
[?2004l=== checkerboard transitions ===
