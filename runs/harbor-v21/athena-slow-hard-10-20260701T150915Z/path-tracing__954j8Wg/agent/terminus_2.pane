[?2004l[?2004h> print(f'dark red approx extent: x={minx}-{maxx} y={miny}-{maxy}')
[?2004l[?2004h> print(f'center: ({(minx+maxx)//2}, {(miny+maxy)//2}) size: ({maxx-minx}, {maxy-miny})')
