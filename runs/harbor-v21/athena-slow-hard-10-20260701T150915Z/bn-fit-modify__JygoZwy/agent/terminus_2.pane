[?2004hroot@66c7b0122157:/app# python3 - <<'PY'
[?2004l[?2004h> import csv, math, random
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Read data ----
[?2004l[?2004h> data = []
[?2004l[?2004h> with open('/app/bn_sample_10k.csv') as f:
[?2004l[?2004h>     reader = csv.reader(f)
[?2004l[?2004h>     header = next(reader)
[?2004l[?2004h>     for row in reader:
[?2004l[?2004h>         data.append([float(x) for x in row])
[?2004l[?2004h> 
[?2004l[?2004h> idx = {h: i for i, h in enumerate(header)}
[?2004l[?2004h> n = len(data)
[?2004l[?2004h> 
[?2004l[?2004h> # ---- DAG edges: (to, from) meaning from -> to ----
[?2004l[?2004h> edges = [
[?2004l[?2004h>     ('Y', 'U'),  # U -> Y
[?2004l[?2004h>     ('R', 'U'),  # U -> R
[?2004l[?2004h>     ('D', 'U'),  # U -> D
[?2004l[?2004h>     ('M', 'U'),  # U -> M
[?2004l[?2004h>     ('D', 'Y'),  # Y -> D
[?2004l[?2004h>     ('M', 'R'),  # R -> M
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Save learned_dag.csv ----
[?2004l[?2004h> with open('/app/learned_dag.csv', 'w') as f:
[?2004l[?2004h>     f.write('to,from\n')
[?2004l[?2004h>     for to, frm in edges:
[?2004l[?2004h>         f.write(f'{to},{frm}\n')
[?2004l[?2004h> print('Saved /app/learned_dag.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Build parents map ----
[?2004l[?2004h> parents = {h: [] for h in header}
[?2004l[?2004h> for to, frm in edges:
[?2004l[?2004h>     parents[to].append(frm)
[?2004l[?2004h> 
[?2004l[?2004h> # ---- OLS regression utilities ----
[?2004l[?2004h> def mat_inv(m):
[?2004l[?2004h>     size = len(m)
[?2004l[?2004h>     aug = [row[:] + [1.0 if i == j else 0.0 for j in range(size)] for i, row in enumerate(m)]
[?2004l[?2004h>     for col in range(size):
[?2004l[?2004h>         piv = max(range(col, size), key=lambda r: abs(aug[r][col]))
[?2004l[?2004h>         aug[col], aug[piv] = aug[piv], aug[col]
[?2004l[?2004h>         pv = aug[col][col]
[?2004l[?2004h>         if abs(pv) < 1e-14:
[?2004l[?2004h>             raise ValueError('singular')
[?2004l[?2004h>         for j in range(2 * size):
[?2004l[?2004h>             aug[col][j] /= pv
[?2004l[?2004h>         for r in range(size):
[?2004l[?2004h>             if r != col:
[?2004l[?2004h>                 factor = aug[r][col]
[?2004l[?2004h>                 for j in range(2 * size):
[?2004l[?2004h>                     aug[r][j] -= factor * aug[col][j]
[?2004l[?2004h>     return [row[size:] for row in aug]
[?2004l[?2004h> 
[?2004l[?2004h> def mat_vec(m, v):
[?2004l[?2004h>     return [sum(m[i][j] * v[j] for j in range(len(v))) for i in range(len(m))]
[?2004l[?2004h> 
[?2004l[?2004h> def fit_ols(node, par_nodes):
[?2004l[?2004h>     if not par_nodes:
[?2004l[?2004h>         col = [r[idx[node]] for r in data]
[?2004l[?2004h>         mean = sum(col) / n
[?2004l[?2004h>         var = sum((v - mean) ** 2 for v in col) / n
[?2004l[?2004h>         return {'intercept': mean, 'coefs': {}, 'var': var}
[?2004l[?2004h>     p = len(par_nodes)
[?2004l[?2004h>     XtX = [[0.0] * (p + 1) for _ in range(p + 1)]
[?2004l[?2004h>     Xty = [0.0] * (p + 1)
[?2004l[?2004h>     for r in data:
[?2004l[?2004h>         xrow = [1.0] + [r[idx[x]] for x in par_nodes]
[?2004l[?2004h>         yval = r[idx[node]]
[?2004l[?2004h>         for i in range(p + 1):
[?2004l[?2004h>             Xty[i] += xrow[i] * yval
[?2004l[?2004h>             for j in range(p + 1):
[?2004l[?2004h>                 XtX[i][j] += xrow[i] * xrow[j]
[?2004l[?2004h>     for i in range(p + 1):
[?2004l[?2004h>         for j in range(p + 1):
[?2004l[?2004h>             XtX[i][j] /= n
[?2004l[?2004h>         Xty[i] /= n
[?2004l[?2004h>     inv = mat_inv(XtX)
[?2004l[?2004h>     beta = mat_vec(inv, Xty)
[?2004l[?2004h>     ss = 0.0
[?2004l[?2004h>     for r in data:
[?2004l[?2004h>         pred = beta[0]
[?2004l[?2004h>         for j in range(p):
[?2004l[?2004h>             pred += beta[j + 1] * r[idx[par_nodes[j]]]
[?2004l[?2004h>         ss += (r[idx[node]] - pred) ** 2
[?2004l[?2004h>     var = ss / n
[?2004l[?2004h>     return {
[?2004l[?2004h>         'intercept': beta[0],
[?2004l[?2004h>         'coefs': {par_nodes[j]: beta[j + 1] for j in range(p)},
[?2004l[?2004h>         'var': var
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Fit BN parameters ----
[?2004l[?2004h> params = {}
[?2004l[?2004h> for node in header:
[?2004l[?2004h>     params[node] = fit_ols(node, parents[node])
[?2004l[?2004h>     p = params[node]
[?2004l[?2004h>     print(f"{node}: parents={parents[node]} intercept={p['intercept']:.4f} coefs={p['coefs']} var={p['var']:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Intervened DAG: remove edges into Y ----
[?2004l[?2004h> intervened_edges = [(to, frm) for (to, frm) in edges if to != 'Y']
[?2004l[?2004h> with open('/app/intervened_dag.csv', 'w') as f:
[?2004l[?2004h>     f.write('to,from\n')
[?2004l[?2004h>     for to, frm in intervened_edges:
[?2004l[?2004h>         f.write(f'{to},{frm}\n')
[?2004l[?2004h> print('Saved /app/intervened_dag.csv')
[?2004l[?2004h> 
[?2004l[?2004h> # ---- Sample 10k from intervened BN ----
[?2004l[?2004h> # Intervention: Y = 0.0 with tiny variance (10e-9 = 1e-8)
[?2004l[?2004h> intervene_var = 1e-8
[?2004l[?2004h> intervene_std = math.sqrt(intervene_var)
[?2004l[?2004h> 
[?2004l[?2004h> topo_order = ['U', 'Y', 'R', 'D', 'M']
[?2004l[?2004h> random.seed(42)
[?2004l[?2004h> 
[?2004l[?2004h> samples = []
[?2004l[?2004h> for _ in range(n):
[?2004l[?2004h>     vals = {}
[?2004l[?2004h>     for node in topo_order:
[?2004l[?2004h>         if node == 'Y':
[?2004l[?2004h>             vals[node] = random.gauss(0.0, intervene_std)
[?2004l[?2004h>         else:
[?2004l[?2004h>             p = params[node]
[?2004l[?2004h>             mean = p['intercept']
[?2004l[?2004h>             for parent in parents[node]:
[?2004l[?2004h>                 mean += p['coefs'][parent] * vals[parent]
[?2004l[?2004h>             vals[node] = random.gauss(mean, math.sqrt(p['var']))
[?2004l[?2004h>     samples.append([vals[h] for h in header])
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/final_bn_sample.csv', 'w') as f:
[?2004l[?2004h>     f.write(','.join(f'"{h}"' for h in header) + '\n')
[?2004l[?2004h>     for s in samples:
[?2004l[?2004h>         f.write(','.join(str(v) for v in s) + '\n')
