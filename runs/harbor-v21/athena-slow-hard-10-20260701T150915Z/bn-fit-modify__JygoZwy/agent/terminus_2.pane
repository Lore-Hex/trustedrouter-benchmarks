[?2004l[?2004hroot@66c7b0122157:/app# python3 - <<'PY'
[?2004l[?2004h> import csv, math
[?2004l[?2004h> from itertools import combinations
[?2004l[?2004h> 
[?2004l[?2004h> data=[]
[?2004l[?2004h> with open('/app/bn_sample_10k.csv') as f:
[?2004l[?2004h>     reader=csv.reader(f)
[?2004l[?2004h>     header=next(reader)
[?2004l[?2004h>     for row in reader:
[?2004l[?2004h>         data.append([float(x) for x in row])
[?2004l[?2004h> 
[?2004l[?2004h> n=len(data)
[?2004l[?2004h> k=len(header)
[?2004l[?2004h> idx={h:i for i,h in enumerate(header)}
[?2004l[?2004h> means=[sum(r[i] for r in data)/n for i in range(k)]
[?2004l[?2004h> 
[?2004l[?2004h> # covariance matrix
[?2004l[?2004h> cov=[[0.0]*k for _ in range(k)]
[?2004l[?2004h> for r in data:
[?2004l[?2004h>     for i in range(k):
[?2004l[?2004h>         for j in range(i,k):
[?2004l[?2004h>             cov[i][j]+=(r[i]-means[i])*(r[j]-means[j])
[?2004l[?2004h> for i in range(k):
[?2004l[?2004h>     for j in range(k):
[?2004l[?2004h>         if j<i:
[?2004l[?2004h>             cov[i][j]=cov[j][i]
[?2004l[?2004h>         else:
[?2004l[?2004h>             cov[i][j]/=n
[?2004l[?2004h> 
[?2004l[?2004h> def mat_inv(m):
[?2004l[?2004h>     size=len(m)
[?2004l[?2004h>     aug=[row[:]+[1.0 if i==j else 0.0 for j in range(size)] for i,row in enumerate(m)]
[?2004l[?2004h>     for col in range(size):
[?2004l[?2004h>         piv=max(range(col,size), key=lambda r: abs(aug[r][col]))
[?2004l[?2004h>         aug[col],aug[piv]=aug[piv],aug[col]
[?2004l[?2004h>         pv=aug[col][col]
[?2004l[?2004h>         if abs(pv)<1e-12: raise ValueError('singular')
[?2004l[?2004h>         for j in range(2*size):
[?2004l[?2004h>             aug[col][j]/=pv
[?2004l[?2004h>         for r in range(size):
[?2004l[?2004h>             if r!=col:
[?2004l[?2004h>                 factor=aug[r][col]
[?2004l[?2004h>                 for j in range(2*size):
[?2004l[?2004h>                     aug[r][j]-=factor*aug[col][j]
[?2004l[?2004h>     return [row[size:] for row in aug]
[?2004l[?2004h> 
[?2004l[?2004h> def partial_corr(a,b,cond):
[?2004l[?2004h>     cols=[idx[a],idx[b]]+[idx[c] for c in cond]
[?2004l[?2004h>     sub=[[cov[i][j] for j in cols] for i in cols]
[?2004l[?2004h>     inv=mat_inv(sub)
[?2004l[?2004h>     pa=-inv[0][1]/math.sqrt(inv[0][0]*inv[1][1])
[?2004l[?2004h>     return pa
[?2004l[?2004h> 
[?2004l[?2004h> nodes=['U','Y','R','D','M']
[?2004l[?2004h> print('Pairwise correlations:')
[?2004l[?2004h> for a,b in combinations(nodes,2):
[?2004l[?2004h>     print(f'{a}-{b}: {cov[idx[a]][idx[b]]/math.sqrt(cov[idx[a]][idx[a]]*cov[idx[b]][idx[b]]):.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> print('\nPartial corr given U:')
[?2004l[?2004h> for a,b in combinations(['Y','R','D','M'],2):
[?2004l[?2004h>     print(f'{a}-{b}|U: {partial_corr(a,b,["U"]):.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> print('\nPartial corr given U and each other node:')
[?2004l[?2004h> for a,b in combinations(['Y','R','D','M'],2):
[?2004l[?2004h>     others=[x for x in ['Y','R','D','M'] if x not in (a,b)]
[?2004l[?2004h>     for c in others:
[?2004l[?2004h>         print(f'{a}-{b}|U,{c}: {partial_corr(a,b,["U",c]):.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> print('\nPartial corr given all other nodes (full partial):')
[?2004l[?2004h> for a,b in combinations(nodes,2):
[?2004l[?2004h>     cond=[x for x in nodes if x not in (a,b)]
[?2004l[?2004h>     print(f'{a}-{b}|{" ".join(cond)}: {partial_corr(a,b,cond):.4f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Fisher z-test p-values approx
[?2004l[?2004h> from statistics import NormalDist
[?2004l[?2004h> def z_test(r,n,cond_size):
[?2004l[?2004h>     z=0.5*math.log((1+r+1e-15)/(1-r+1e-15))*math.sqrt(n-cond_size-3)
[?2004l[?2004h>     p=2*(1-NormalDist().cdf(abs(z)))
[?2004l[?2004h>     return p
[?2004l[?2004h> 
[?2004l[?2004h> print('\nFisher z p-values for partial corr given U:')
[?2004l[?2004h> for a,b in combinations(['Y','R','D','M'],2):
[?2004l[?2004h>     r=partial_corr(a,b,['U'])
[?2004l[?2004h>     print(f'{a}-{b}|U: r={r:.4f} p={z_test(r,n,1):.2e}')
[?2004l[?2004h> 
[?2004l[?2004h> print('\nFull partial p-values:')
[?2004l[?2004h> for a,b in combinations(nodes,2):
[?2004l[?2004h>     cond=[x for x in nodes if x not in (a,b)]
[?2004l[?2004h>     r=partial_corr(a,b,cond)
[?2004l[?2004h>     print(f'{a}-{b}|{" ".join(cond)}: r={r:.4f} p={z_test(r,n,len(cond)):.2e}')
