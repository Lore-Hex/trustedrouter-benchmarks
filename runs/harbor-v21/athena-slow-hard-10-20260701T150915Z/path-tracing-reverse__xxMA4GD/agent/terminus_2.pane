[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> int main(){
[?2004l[?2004h>   FILE*f=fopen("/app/image.ppm","r");
[?2004l[?2004h>   if(!f){perror("open");return 1;}
[?2004l[?2004h>   char magic[8]; int w,h,maxv;
[?2004l[?2004h>   fscanf(f,"%s %d %d %d",magic,&w,&h,&maxv);
[?2004l[?2004h>   printf("%s %dx%d max=%d\n",magic,w,h,maxv);
[?2004l[?2004h>   int n=w*h;
[?2004l[?2004h>   int*r=malloc(n*sizeof(int)),*g=malloc(n*sizeof(int)),*b=malloc(n*sizeof(int));
[?2004l[?2004h>   for(int i=0;i<n;i++) fscanf(f,"%d %d %d",&r[i],&g[i],&b[i]);
[?2004l[?2004h>   // sample corners and center
[?2004l[?2004h>   int pts[][2]={{0,0},{w-1,0},{0,h-1},{w-1,h-1},{w/2,h/2},{w/2,0},{w/2,h-1},{0,h/2},{w-1,h/2}};
[?2004l[?2004h>   for(int i=0;i<9;i++){int x=pts[i][0],y=pts[i][1],idx=y*w+x;printf("(%d,%d): %d %d %d\n",x,y,r[idx],g[idx],b[idx]);}
[?2004l[?2004h>   // unique colors
[?2004l[?2004h>   int uniq=0; for(int i=0;i<n;i++) if(r[i]==r[0]&&g[i]==g[0]&&b[i]==b[0]) uniq++;
[?2004l[?2004h>   printf("pixels matching first: %d/%d\n",uniq,n);
[?2004l[?2004h>   // sample row 0 every 100 px
[?2004l[?2004h>   printf("row0: "); for(int x=0;x<w;x+=100)printf("(%d,%d,%d)%s",r[x],g[x],b[x],x+100<w?" ":""); printf("\n");
[?2004l[?2004h>   // sample col 0 every 50 rows
[?2004l[?2004h>   printf("col0: "); for(int y=0;y<h;y+=50){int idx=y*w;printf("(%d,%d,%d)%s",r[idx],g[idx],b[idx],y+50<h?" ":"");} printf("\n");
[?2004l[?2004h>   // sample middle row
[?2004l[?2004h>   printf("row300: "); for(int x=0;x<w;x+=100){int idx=300*w+x;printf("(%d,%d,%d)%s",r[idx],g[idx],b[idx],x+100<w?" ":"");} printf("\n");
[?2004l[?2004h>   // find where colors change in col w/2
[?2004l[?2004h>   printf("col400 transitions:\n"); int prev=-1; for(int y=0;y<h;y++){int idx=y*w+400;int c=r[idx]*65536+g[idx]*256+b[idx];if(c!=prev){printf("y=%d: %d %d %d\n"",y,r[idx],g[idx],b[idx]);prev=c;}}
[?2004l[?2004h>   // count unique colors total (sample)
[?2004l[?2004h>   printf("corner colors: tl=%d,%d,%d tr=%d,%d,%d bl=%d,%d,%d br=%d,%d,%d\n",r[0],g[0],b[0],r[w-1],g[w-1],b[w-1],r[(h-1)*w],g[(h-1)*w],b[(h-1)*w],r[(h-1)*w+w-1]],g[(h-1)*w+w-1],b[(h-1)*w+w-1]);
[?2004l[?2004h>   return 0;
[?2004l[?2004h> }
