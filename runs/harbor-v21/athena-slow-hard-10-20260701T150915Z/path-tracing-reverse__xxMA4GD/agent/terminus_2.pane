[?2004l[?2004h>   printf("sphere bounds: x[%d,%d] y[%d,%d] center=(%d,%d) w=%d h=%d\n",minx,maxx,miny,maxy,(minx+maxx)/2,(miny+maxy)/2,maxx-minx,maxy-miny);
