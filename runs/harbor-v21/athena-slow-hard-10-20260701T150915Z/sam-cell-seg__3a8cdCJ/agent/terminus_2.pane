[?2004l[?2004h> 
[?2004l[?2004h> def largest_connected_component(mask):
[?2004l[?2004h>     """Return the largest 8-connected component of a boolean mask."""
[?2004l[?2004h>     mask_u8 = mask.astype(np.uint8)
[?2004l[?2004h>     num_labels, labels, stats, _ = cv2.connectedComponentsWithStats(mask_u8, connectivity=8)
[?2004l[?2004h>     if num_labels <= 1:
