[?2004l[?2004h> def bbox_to_ellipse_polyline(xmin, ymin, xmax, ymax, n_points=24):
[?2004l[?2004h>     """Create a non-rectangular closed polyline (ellipse) from a bounding box."""
[?2004l[?2004h>     cx = (xmin + xmax) / 2.0
[?2004l[?2004h>     cy = (ymin + ymax) / 2.0
[?2004l  [?2004h>     rx = max((xmax - xmin) / 2.0, 0.5)
[?2004l[?2004h>     ry = max((ymax - ymin) / 2.0, 0.5)
[?2004l[?2004h>     angles = np.linspace(0, 2 * np.pi, n_points, endpoint=False)
[?2004l[?2004h>     xs = cx + rx * np.cos(angles)
[?2004l[?2004h>     ys = cy + ry * np.sin(angles)
[?2004l[?2004h>     pts = np.column_stack([xs, ys])
[?2004l[?2004h>     pts = np.vstack([pts, pts[0:1]])
[?2004l[?2004h>     return pts
