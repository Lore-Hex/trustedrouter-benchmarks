[?2004l[?2004h> 
[?2004l[?2004h>         poly_mask = poly_mask & ~occupied
[?2004l[?2004h>         poly_mask = largest_connected_component(poly_mask)
[?2004l[?2004h> 
[?2004l[?2004h>         if poly_mask.sum() == 0:
[?2004l[?2004h>             return pts, mask
[?2004l[?2004h> 
[?2004l[?2004h>         if np.array_equal(poly_mask, mask):
