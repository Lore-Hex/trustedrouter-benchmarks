[?2004l[?2004h>         mask = mask & ~occupied
[?2004l[?2004h>         mask = largest_connected_component(mask)
[?2004l[?2004h>     if mask.sum() == 0:
[?2004l[?2004h>         return None, np.zeros((h, w), dtype=bool)
[?2004l[?2004h> 
[?2004l[?2004h>     pts = None
