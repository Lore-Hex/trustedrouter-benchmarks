[?2004l[?2004h> 
[?2004l[?2004h> def contour_to_closed_polyline(contour, epsilon=1.0):
[?2004l[?2004h>     """Simplify a contour and return a closed polyline as an Nx2 array of (x, y)."""
[?2004l[?2004h>     approx = cv2.approxPolyDP(contour, epsilon, True)
[?2004l[?2004h>     pts = approx.squeeze(1).astype(np.float64)
[?2004l[?2004h>     if pts.ndim == 1:
[?2004l[?2004h>         pts = pts.reshape(1, 2)
