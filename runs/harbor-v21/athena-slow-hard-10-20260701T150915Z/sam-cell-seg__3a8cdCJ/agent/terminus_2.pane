[?2004l[?2004h> 
[?2004l[?2004h> new = '''def raw_contour_to_closed_polyline(mask):
[?2004l[?2004h>     """Extract the raw external contour of a mask as a closed polyline (no simplification)."""
[?2004l[?2004h>     contour = largest_contour(mask)
[?2004l[?2004h>     if contour is None:
[?2004l[?2004h>         return None
[?2004l[?2004h>     pts = contour.squeeze(1).astype(np.float64)
[?2004l[?2004h>     if pts.ndim == 1:
[?2004l[?2004h>         pts = pts.reshape(1, 2)
[?2004l[?2004h>     if len(pts) < 3:
[?2004l[?2004h>         return None
[?2004l[?2004h>     if not np.array_equal(pts[0], pts[-1]):
[?2004l[?2004h>         pts = np.vstack([pts, pts[0:1]])
[?2004l[?2004h>     return pts
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def extract_non_overlapping_polyline(initial_mask, occupied, h, w, fallback_bbox):
[?2004l[?2004h>     """Extract a closed polyline whose rasterization does not overlap occupied pixels."""
[?2004l[?2004h>     mask = initial_mask & ~occupied
[?2004l[?2004h>     mask = largest_connected_component(mask)
[?2004l[?2004h> 
[?2004l[?2004h>     if mask.sum() == 0:
[?2004l[?2004h>         mask = get_fallback_mask(fallback_bbox, occupied, h, w)
[?2004l[?2004h>     if mask.sum() == 0:
[?2004l[?2004h>         xmin, ymin = fallback_bbox[0], fallback_bbox[1]
[?2004l[?2004h>         mask[max(0, ymin) : min(h, ymin + 2), max(0, xmin) : min(w, xmin + 2)] = True
[?2004l[?2004h>         mask = mask & ~occupied
[?2004l[?2004h>         mask = largest_connected_component(mask)
[?2004l[?2004h>     if mask.sum() == 0:
[?2004l[?2004h>         return None, np.zeros((h, w), dtype=bool)
