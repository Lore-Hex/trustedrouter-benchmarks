[?2004l[?2004h> def load_mobile_sam(weights_path):
[?2004l[?2004h>     """Build MobileSAM vit_t and load weights on CPU without modifying source."""
[?2004l[?2004h>     sam = sam_model_registry["vit_t"]()
[?2004l[?2004h>     try:
