[?2004l[?2004h>     largest_label = 1 + int(np.argmax(stats[1:, cv2.CC_STAT_AREA]))
[?2004l[?2004h>     return labels == largest_label
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def largest_contour(mask):
[?2004l[?2004h>     """Return the largest external contour of a binary mask."""
[?2004l[?2004h>     contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>     if not contours:
[?2004l[?2004h>         return None
