[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> async def run_tasks(tasks: List[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:
[?2004l[?2004h>     """
[?2004l[?2004h>     Run async tasks with limited concurrency.
[?2004l[?2004h> 
[?2004l[?2004h>     Args:
[?2004l[?2004h>         tasks: List of callables that return awaitables (e.g., async lambda or functools.partial)
[?2004l[?2004h>         max_concurrent: Maximum number of tasks to run concurrently
[?2004l[?2004h> 
[?2004l[?2004h>     The function handles KeyboardInterrupt (SIGINT) gracefully by allowing
[?2004l[?2004h>     currently running tasks to finish their cleanup code (finally blocks)
[?2004l[?2004h>     before exiting.
[?2004l[?2004h>     """
[?2004l[?2004h>     semaphore = asyncio.Semaphore(max_concurrent)
[?2004l[?2004h> 
[?2004l[?2004h>     async def run_one(task: Callable[[], Awaitable[None]]) -> None:
[?2004l[?2004h>         async with semaphore:
[?2004l[?2004h>             await task()
[?2004l[?2004h> 
[?2004l[?2004h>     async def runner() -> None:
[?2004l[?2004h>         # Create tasks but don't start them all at once; wrap in run_one for semaphore
[?2004l[?2004h>         coros = [run_one(t) for t in tasks]
[?2004l[?2004h>         await asyncio.gather(*coros, return_exceptions=True)
[?2004l[?2004h> 
[?2004l[?2004h>     # Set up a handler for SIGINT that does NOT raise immediately;
[?2004l[?2004h>     # instead we cancel the main asyncio task gracefully.
[?2004l[?2004h>     loop = asyncio.get_running_loop()
[?2004l[?2004h> 
[?2004l[?2004h>     # We create a future to signal shutdown
[?2004l[?2004h>     shutdown_event = asyncio.Event()
[?2004l[?2004h> 
[?2004l[?2004h>     def _signal_handler():
[?2004l[?2004h>         shutdown_event.set()
[?2004l[?2004h> 
[?2004l[?2004h>     loop.add_signal_handler(signal.SIGINT, _signal_handler)
[?2004l[?2004h> 
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Create the main task
[?2004l[?2004h>         main_task = asyncio.create_task(runner())
[?2004l[?2004h> 
[?2004l[?2004h>         # Wait for either completion or shutdown signal
[?2004l[?2004h>         done, pending = await asyncio.wait(
[?2004l[?2004h>             [main_task, asyncio.create_task(shutdown_event.wait())],
[?2004l[?2004h>             return_when=asyncio.FIRST_COMPLETED,
[?2004l[?2004h>         )
[?2004l[?2004h> 
[?2004l[?2004h>         # If shutdown was requested (and main_task is still pending), cancel it
[?2004l[?2004h>         if main_task in pending:
[?2004l[?2004h>             main_task.cancel()
[?2004l[?2004h>             try:
[?2004l[?2004h>                 await main_task
[?2004l[?2004h>             except asyncio.CancelledError:
[?2004l[?2004h>                 pass
[?2004l[?2004h> 
[?2004l[?2004h>         # Propagate any exception from main_task (but not CancelledError)
[?2004l[?2004h>         if main_task in done:
[?2004l[?2004h>             exc = main_task.exception()
[?2004l[?2004h>             if exc and not isinstance(exc, asyncio.CancelledError):
[?2004l[?2004h>                 raise exc
[?2004l[?2004h> 
[?2004l[?2004h>     finally:
[?2004l[?2004h>         # Remove the signal handler to avoid interfering after exit
[?2004l[?2004h>         try:
[?2004l[?2004h>             loop.remove_signal_handler(signal.SIGINT)
[?2004l[?2004h>         except (NotImplementedError, ValueError):
[?2004l[?2004h>             pass
