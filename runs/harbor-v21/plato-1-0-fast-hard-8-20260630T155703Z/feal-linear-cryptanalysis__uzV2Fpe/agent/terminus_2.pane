[?2004l[?2004h>     R0 = get_right(pt)
[?2004l[?2004h>     
[?2004l[?2004h>     # From CT: merge(R4, L4 xor R4), so get_left = R4, get_right = L4 xor R4
[?2004l[?2004h>     R4 = get_left(ct)
[?2004l[?2004h>     L4_xor_R4 = get_right(ct)
[?2004l[?2004h>     L4 = L4_xor_R4 ^ R4
[?2004l[?2004h>     
[?2004l[?2004h>     # For the last round:
[?2004l[?2004h>     # R3 = L4
[?2004l[?2004h>     # L3 = R4 xor f(R3 xor K3)
[?2004l[?2004h>     # 
[?2004l[?2004h>     # The equation:
[?2004l[?2004h>     # P(K3) = L3_18 xor P(R3) xor R4_18 xor 1
[?2004l[?2004h>     # where L3_18 = (L3 >> 18) & 1, R4_18 = (R4 >> 18) & 1
[?2004l[?2004h>     # P(R3) = parity of bits 0,8,16,24 of R3
[?2004l[?2004h>     
[?2004l[?2004h>     L0_18 = (L0 >> 18) & 1
[?2004l[?2004h>     R0_18 = (R0 >> 18) & 1
[?2004l[?2004h>     R4_18 = (R4 >> 18) & 1
[?2004l[?2004h>     
[?2004l[?2004h>     # Also for round 0 equation:
[?2004l[?2004h>     # R1_18 = L0_18 xor P(R0') xor P(K0) xor 1
[?2004l[?2004h>     # where R0' = R0 xor L0
[?2004l[?2004h>     
[?2004l[?2004h>     pair_data.append({
[?2004l[?2004h>         'L0': L0, 'R0': R0,
[?2004l[?2004h>         'R4': R4, 'L4': L4,
[?2004l[?2004h>         'L0_18': L0_18, 'R0_18': R0_18,
[?2004l[?2004h>         'R4_18': R4_18,
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Preprocessed {len(pair_data)} pairs")
[?2004l[?2004h> 
[?2004l[?2004h> # Step 1: Find K3
[?2004l[?2004h> def find_K3():
[?2004l[?2004h>     print("\n=== Finding K3 (last round key) ===")
[?2004l[?2004h>     print(f"Searching 2^20 possible keys...")
[?2004l[?2004h>     
[?2004l[?2004h>     for k3_seed in range(0x100000):
[?2004l[?2004h>         if k3_seed % 0x1000 == 0:
[?2004l[?2004h>             print(f"  Progress: {k3_seed / 0x100000 * 100:.1f}%", end='\r')
[?2004l[?2004h>             sys.stdout.flush()
[?2004l[?2004h>         
[?2004l[?2004h>         k3_exp = expand(k3_seed)
[?2004l[?2004h>         
[?2004l[?2004h>         first_bit = None
[?2004l[?2004h>         consistent = True
[?2004l[?2004h>         
[?2004l[?2004h>         for pd in pair_data:
[?2004l[?2004h>             # Compute (L3, R3) from partial decryption
[?2004l[?2004h>             R3 = pd['L4']
[?2004l[?2004h>             mixed = f_function(R3 ^ k3_exp)
[?2004l[?2004h>             L3 = pd['R4'] ^ mixed
[?2004l[?2004h>             
[?2004l[?2004h>             # Compute P(K3) from equation
[?2004l[?2004h>             L3_18 = (L3 >> 18) & 1
[?2004l[?2004h>             P_R3 = parity_bits_0_8_16_24(R3)
[?2004l[?2004h>             
[?2004l[?2004h>             # P(K3) = L3_18 xor P(R3) xor R4_18 xor 1
[?2004l[?2004h>             computed_bit = L3_18 ^ P_R3 ^ pd['R4_18'] ^ 1
[?2004l[?2004h>             
[?2004l[?2004h>             if first_bit is None:
[?2004l[?2004h>                 first_bit = computed_bit
[?2004l[?2004h>             elif computed_bit != first_bit:
[?2004l[?2004h>                 consistent = False
[?2004l[?2004h>                 break
[?2004l[?2004h>         
[?2004l[?2004h>         if consistent:
[?2004l[?2004h>             print(f"\n  Found consistent K3: 0x{k3_seed:05x}")
[?2004l[?2004h>             print(f"  Expanded: 0x{k3_exp:08x}")
[?2004l[?2004h>             print(f"  Parity bit: {first_bit}")
[?2004l[?2004h>             return k3_seed, k3_exp, first_bit
[?2004l[?2004h>     
[?2004l[?2004h>     print("\n  No consistent K3 found!")
[?2004l[?2004h>     return None, None, None
[?2004l[?2004h> 
[?2004l[?2004h> k3_seed, k3_exp, k3_parity = find_K3()
[?2004l[?2004h> 
[?2004l[?2004h> if k3_seed is None:
[?2004l[?2004h>     print("Failed to find K3")
[?2004l[?2004h>     sys.exit(1)
[?2004l[?2004h> 
