[?2004l[?2004h>     uint8_t x1_xor_x0 = (ror2_y1 - y[2]) & 0xFF;
[?2004l[?2004h>     x[1] = x1_xor_x0 ^ x[0];
[?2004l[?2004h>     x[3] = (ror2_y3 - y[2]) & 0xFF;
[?2004l[?2004h>     uint8_t x3_xor_x2 = (ror2_y2 - x1_xor_x0 - 1) & 0xFF;
[?2004l[?2004h>     x[2] = x3_xor_x2 ^ x[3];
[?2004l[?2004h>     return x[0] | (x[1] << 8) | (x[2] << 16) | (x[3] << 24);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> uint64_t encrypt(uint64_t plaintext, uint32_t *keys) {
[?2004l[?2004h>     uint32_t left = getleft(plaintext);
[?2004l[?2004h>     uint32_t right = getright(plaintext);
[?2004l[?2004h>     right ^= left;
[?2004l[?2004h>     for (int r = 0; r < 4; r++) {
[?2004l[?2004h>         uint32_t mixed = f_function(right ^ keys[r]);
[?2004l[?2004h>         uint32_t temp = right;
[?2004l[?2004h>         right = left ^ mixed;
[?2004l[?2004h>         left = temp;
[?2004l[?2004h>     }
[?2004l[?2004h>     left ^= right;
[?2004l[?2004h>     return merge(right, left);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> // Precompute reverse expand mapping
[?2004l[?2004h> #define REV_SIZE 1048576
[?2004l[?2004h> uint32_t rev_map[REV_SIZE]; // maps expanded key hash to seed (or 0xFFFFFFFF if not found)
[?2004l[?2004h> uint32_t rev_map_size;
[?2004l[?2004h> 
[?2004l[?2004h> void build_rev_map() {
[?2004l[?2004h>     for (int i = 0; i < REV_SIZE; i++) rev_map[i] = 0xFFFFFFFF;
[?2004l[?2004h>     for (uint32_t s = 0; s < 0x100000; s++) {
[?2004l[?2004h>         uint32_t e = expand(s);
[?2004l[?2004h>         uint32_t idx = (e ^ (e >> 16)) & 0xFFFFF; // simple hash
[?2004l[?2004h>         rev_map[idx] = s; // overwrite collisions - not perfect but OK for verification
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> int is_valid_expanded(uint32_t e) {
[?2004l[?2004h>     // Check if there exists a 20-bit seed that expands to e
[?2004l[?2004h>     for (uint32_t s = 0; s < 0x100000; s++) {
[?2004l[?2004h>         if (expand(s) == e) return 1;
[?2004l[?2004h>     }
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     // Read pairs
[?2004l[?2004h>     FILE *fp = fopen("/app/pairs.txt", "r");
[?2004l[?2004h>     if (!fp) { printf("Cannot open pairs.txt\n"); return 1; }
[?2004l[?2004h>     
[?2004l[?2004h>     uint64_t pt[32], ct[32];
[?2004l", p[?2004h>     int n = 0;
[?2004l[?2004h>     char line[256];
[?2004l[?2004h>     while (fgets(line, sizeof(line), fp) && n < 32) {
[?2004l[?2004h>         unsigned long long p, c;
[?2004l[?2004h>         if (sscanf(line, "%llu %llu", &p, &c) == 2) {
[?2004l[?2004h>             pt[n] = p;
[?2004l[?2004h>             ct[n] = c;
[?2004l[?2004h>             n++;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(fp);
[?2004l[?2004h>     printf("Loaded %d pairs\n", n);
[?2004l[?2004h>     
[?2004l[?2004h>     // K3 already known
[?2004l[?2004h>     uint32_t k3_seed = 0xb74a5;
[?2004l[?2004h>     uint32_t k3_exp = expand(k3_seed);
[?2004l[?2004h>     printf("K3: seed=0x%05x, expanded=0x%08x\n", k3_seed, k3_exp);
[?2004l[?2004h>     
[?2004l[?2004h>     // Precompute L1 for each pair
[?2004l[?2004h>     uint32_t L0[32], R0[32], L1[32];
[?2004l[?2004h>     uint32_t R4[32], L4[32];
[?2004l[?2004h>     // Also precompute (L3,R3) by partial decrypt with K3
[?2004l[?2004h>     uint32_t L3[32], R3[32];
[?2004l[?2004h>     
[?2004l[?2004h>     for (int i = 0; i < n; i++) {
[?2004l[?2004h>         L0[i] = getleft(pt[i]);
[?2004l[?2004h>         R0[i] = getright(pt[i]);
[?2004l[?2004h>         L1[i] = R0[i] ^ L0[i];
[?2004l[?2004h>         
[?2004l[?2004h>         R4[i] = getleft(ct[i]);
[?2004l[?2004h>         uint32_t L4_xor_R4 = getright(ct[i]);
[?2004l[?2004h>         L4[i] = L4_xor_R4 ^ R4[i];
[?2004l[?2004h>         
[?2004l[?2004h>         // Undo round 3
[?2004l[?2004h>         R3[i] = L4[i];
[?2004l[?2004h>         L3[i] = R4[i] ^ f_function(R3[i] ^ k3_exp);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     printf("Brute-forcing K2...\n");
[?2004l[?2004h>     
[?2004l[?2004h>     int found = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     for (uint32_t k2_seed = 0; k2_seed < 0x100000 && !found; k2_seed++) {
[?2004l[?2004h>         if (k2_seed % 0x100 == 0) {
[?2004l[?2004h>             printf("\rProgress: %d / %d", k2_seed, 0x100000);
[?2004l[?2004h>             fflush(stdout);
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         uint32_t k2_exp = expand(k2_seed);
[?2004l[?2004h>         
[?2004l[?2004h>         // Undo round 2 using first pair
[?2004l[?2004h>         uint32_t R2 = L3[0];
[?2004l[?2004h>         uint32_t L2 = R3[0] ^ f_function(R2 ^ k2_exp);
[?2004l[?2004h>         
[?2004l[?2004h>         // From round 1: R2 = L1 xor f(R1 xor K1) => f(R1 xor K1) = R2 xor L1
[?2004l[?2004h>         // And L2 = R1
[?2004l[?2004h>         uint32_t R1 = L2;  // L2 = R1
[?2004l[?2004h>         uint32_t k1_exp = f_inverse(R2 ^ L1[0]) ^ R1;
[?2004l[?2004h>         
[?2004l[?2004h>         // From round 0: R1 = L0 xor f(L1 xor K0) => f(L1 xor K0) = L0 xor R1
[?2004l[?2004h>         uint32_t k0_exp = f_inverse(L0[0] ^ R1) ^ L1[0];
[?2004l[?2004h>         
[?2004l[?2004h>         // Now verify these expanded keys against all pairs
[?2004l[?2004h>         uint32_t keys[4] = {k0_exp, k1_exp, k2_exp, k3_exp};
[?2004l[?2004h>         
[?2004l[?2004h>         int ok = 1;
[?2004l[?2004h>         for (int i = 0; i < n; i++) {
[?2004l[?2004h>             uint64_t ct_test = encrypt(pt[i], keys);
[?2004l[?2004h>             if (ct_test != ct[i]) {
[?2004l[?2004h>                 ok = 0;
[?2004l[?2004h>                 break;
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         if (ok) {
[?2004l[?2004h>             printf("\n\nFound keys!\n");
[?2004l[?2004h>             printf("K0 expanded: 0x%08x\n", k0_exp);
[?2004l[?2004h>             printf("K1 expanded: 0x%08x\n", k1_exp);
[?2004l[?2004h>             printf("K2 expanded: 0x%08x\n", k2_exp);
[?2004l[?2004h>             printf("K3 expanded: 0x%08x\n", k3_exp);
[?2004l[?2004h>             
[?2004l[?2004h>             // Find seeds
[?2004l[?2004h>             printf("\nSeeds:\n");
[?2004l[?2004h>             uint32_t seeds[4] = {0};
[?2004l[?2004h>             uint32_t exps[4] = {k0_exp, k1_exp, k2_exp, k3_exp};
[?2004l[?2004h>             for (int j = 0; j < 4; j++) {
[?2004l[?2004h>                 for (uint32_t s = 0; s < 0x100000; s++) {
[?2004l[?2004h>                     if (expand(s) == exps[j]) {
[?2004l[?2004h>                         seeds[j] = s;
[?2004l[?2004h>                         printf("  K%d seed: 0x%05x\n", j, s);
[?2004l[?2004h>                         break;
[?2004l[?2004h>                     }
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             // Now decrypt ciphertexts.txt
[?2004l[?2004h>             printf("\nDecrypting ciphertexts.txt...\n");
[?2004l[?2004h>             fp = fopen("/app/ciphertexts.txt", "r");
[?2004l[?2004h>             FILE *out = fopen("/app/plaintexts.txt", "w");
[?2004l[?2004h>             if (!fp || !out) {
[?2004l[?2004h>                 printf("Error opening files\n");
[?2004l[?2004h>                 return 1;
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             while (fgets(line, sizeof(line), fp)) {
[?2004l[?2004h>                 unsigned long long c;
