[?2004l[?2004h>                     // Decrypt
[?2004l[?2004h>                     uint32_t left = getright(c);
[?2004l[?2004h>                     uint32_t right = getleft(c);
[?2004l[?2004h>                     left ^= right;
[?2004l[?2004h>                     for (int r = 3; r >= 0; r--) {
[?2004l[?2004h>                         uint32_t temp = left;
[?2004l[?2004h>                         left = right;
[?2004l[?2004h>                         uint32_t mixed = f_function(temp ^ keys[r]);
[?2004l[?2004h>                         right = temp;
[?2004l[?2004h>                         left ^= mixed;
[?2004l[?2004h>                     }
[?2004l[?2004h>                     right ^= left;
[?2004l[?2004h>                     uint64_t p = merge(left, right);
[?2004l[?2004h>                     fprintf(out, "%lu\n", p);
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
