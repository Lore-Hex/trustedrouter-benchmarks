[?2004l[?2004h> from attack import *
[?2004l[?2004h> 
[?2004l[?2004h> # Constants
[?2004l[?2004h> MASK = 0xFF
[?2004l[?2004h> 
[?2004l[?2004h> def rol2(x):
[?2004l[?2004h>     return ((x << 2) | (x >> 6)) & 0xFF
[?2004l[?2004h> 
[?2004l[?2004h> def ror2(x):
[?2004l[?2004h>     return ((x << 6) | (x >> 2)) & 0xFF
[?2004l[?2004h> 
[?2004l[?2004h> def g_function(a, b, x):
[?2004l[?2004h>     temp = (a + b + x) & 0xFF
[?2004l[?2004h>     return ((temp << 2) | (temp >> 6)) & 0xFF
[?2004l[?2004h> 
[?2004l[?2004h> def f_inverse(output):
[?2004l[?2004h>     """Invert the f_function: given output, find all possible inputs"""
[?2004l[?2004h>     # Extract bytes from output (big-endian format)
[?2004l[?2004h>     y = [0, 0, 0, 0]
[?2004l[?2004h>     temp = output
[?2004l[?2004h>     for i in range(4):
[?2004l[?2004h>         y[i] = temp & 0xFF
[?2004l[?2004h>         temp >>= 8
[?2004l[?2004h>     
[?2004l[?2004h>     # y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)
[?2004l[?2004h>     # y[3] = g_function(x[3], y[2], 0)
[?2004l[?2004h>     # y[1] = g_function(x[1] ^ x[0], y[2], 0)
[?2004l[?2004h>     # y[0] = g_function(x[0], y[1], 1)
[?2004l[?2004h>     
[?2004l[?2004h>     # ror2(y[3]) = (x[3] + y[2]) mod 256
[?2004l[?2004h>     # ror2(y[1]) = ((x[1] ^ x[0]) + y[2]) mod 256
[?2004l[?2004h>     # ror2(y[2]) = ((x[3] ^ x[2]) + (x[1] ^ x[0]) + 1) mod 256
[?2004l[?2004h>     # ror2(y[0]) = (x[0] + y[1] + 1) mod 256
[?2004l[?2004h>     
[?2004l[?2004h>     ror2_y3 = ror2(y[3])
[?2004l[?2004h>     ror2_y1 = ror2(y[1])
[?2004l[?2004h>     ror2_y2 = ror2(y[2])
[?2004l[?2004h>     ror2_y0 = ror2(y[0])
[?2004l[?2004h>     
[?2004l[?2004h>     # From y[3] = g(x[3], y[2], 0):
[?2004l[?2004h>     # x[3] = (ror2(y[3]) - y[2]) mod 256
[?2004l[?2004h>     # But we don't know y[2] yet...
[?2004l[?2004h>     # Actually we do: y[2] is known from output
[?2004l[?2004h>     y2 = y[2]
[?2004l[?2004h>     
[?2004l[?2004h>     # From y[1] = g(x[1]^x[0], y[2], 0):
[?2004l[?2004h>     # x1_xor_x0 = (ror2(y[1]) - y[2]) mod 256
[?2004l[?2004h>     x1_xor_x0 = (ror2_y1 - y2) & MASK
[?2004l[?2004h>     
[?2004l[?2004h>     # From y[0] = g(x[0], y[1], 1):
[?2004l[?2004h>     # x[0] = (ror2(y[0]) - y[1] - 1) mod 256
[?2004l[?2004h>     x0 = (ror2_y0 - y[1] - 1) & MASK
[?2004l[?2004h>     
[?2004l[?2004h>     # From y[3] = g(x[3], y[2], 0):
[?2004l[?2004h>     # x[3] = (ror2(y[3]) - y[2]) mod 256
[?2004l[?2004h>     x3 = (ror2_y3 - y2) & MASK
[?2004l[?2004h>     
[?2004l[?2004h>     # From x1_xor_x0 = x[1] ^ x[0]:
[?2004l[?2004h>     x1 = x1_xor_x0 ^ x0
[?2004l[?2004h>     
[?2004l[?2004h>     # From y[2] = g(x[3]^x[2], x[1]^x[0], 1):
[?2004l[?2004h>     # ror2(y[2]) = ((x[3]^x[2]) + (x[1]^x[0]) + 1) mod 256
[?2004l[?2004h>     # (x[3]^x[2]) = (ror2(y[2]) - (x[1]^x[0]) - 1) mod 256
[?2004l[?2004h>     x3_xor_x2 = (ror2_y2 - x1_xor_x0 - 1) & MASK
[?2004l[?2004h>     x2 = x3_xor_x2 ^ x3
[?2004l[?2004h>     
[?2004l[?2004h>     # Combine bytes into input (little-endian)
[?2004l[?2004h>     input_val = x[0] | (x[1] << 8) | (x[2] << 16) | (x[3] << 24)
[?2004l[?2004h>     
[?2004l[?2004h>     return input_val & 0xFFFFFFFF
[?2004l[?2004h> 
[?2004l[?2004h> # Test f_inverse
[?2004l[?2004h> print("Testing f_inverse...")
[?2004l[?2004h> all_ok = True
[?2004l[?2004h> for i in range(10000):
[?2004l[?2004h>     x = i * 1234567 & 0xFFFFFFFF  # Some varied inputs
[?2004l[?2004h>     y = f_function(x)
[?2004l[?2004h>     x_recovered = f_inverse(y)
[?2004l[?2004h>     # Check if f(x_recovered) equals y
[?2004l[?2004h>     y2 = f_function(x_recovered)
[?2004l[?2004h>     if y != y2:
[?2004l[?2004h>         print(f"Error: f(0x{x:08x}) = 0x{y:08x}, f_inverse gave 0x{x_recovered:08x}, f(that) = 0x{y2:08x}")
[?2004l[?2004h>         all_ok = False
[?2004l[?2004h>         break
[?2004l[?2004h> 
[?2004l[?2004h> if all_ok:
[?2004l[?2004h>     print("f_inverse works correctly!")
[?2004l[?2004h>     
[?2004l[?2004h>     # Now let's check if f is injective
[?2004l[?2004h>     # Test if different inputs can produce same output
[?2004l[?2004h>     outputs = {}
[?2004l[?2004h>     collisions = 0
[?2004l[?2004h>     for i in range(100000):
[?2004l[?2004h>         x = i * 9999991 & 0xFFFFFFFF
[?2004l[?2004h>         y = f_function(x)
[?2004l[?2004h>         if y in outputs:
[?2004l[?2004h>             collisions += 1
