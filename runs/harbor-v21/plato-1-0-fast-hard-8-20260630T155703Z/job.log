Sending keys: ['cat > /app/attack.py << \'EOF\'\nimport sys\n\n# FEAL cipher implementation in Python\n\ndef getleft(x):\n    return (x >> 32) & 0xFFFFFFFF\n\ndef getright(x):\n    return x & 0xFFFFFFFF\n\ndef merge(left, right):\n    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)\n\ndef expand(key):\n    # key is 20-bit value (0 to 0xFFFFF)\n    # In C: return key ^ (key << 16) ^ (key * 12345);\n    # All operations are on uint32_t (32-bit unsigned)\n    k = key & 0xFFFFFFFF\n    result = (k ^ (k << 16) ^ (k * 12345)) & 0xFFFFFFFF\n    return result\n\ndef g_function(a, b, x):\n    temp = (a + b + x) & 0xFF\n    return ((temp << 2) | (temp >> 6)) & 0xFF\n\ndef f_function(input_val):\n    x = [0, 0, 0, 0]\n    for i in range(4):\n        x[i] = input_val & 0xFF\n        input_val >>= 8\n    \n    y = [0, 0, 0, 0]\n    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)\n    y[3] = g_function(x[3], y[2], 0)\n    y[1] = g_function(x[1] ^ x[0], y[2], 0)\n    y[0] = g_function(x[0], y[1], 1)\n    \n    output = 0\n    for i in range(4):\n        output |= (y[i] & 0xFF) << (8 * i)\n    \n    return output & 0xFFFFFFFF\n\ndef encrypt(plaintext, keys):\n    # keys is list of 4 expanded round keys (32-bit each)\n    left = getleft(plaintext)\n    right = getright(plaintext)\n    \n    # Pre-round mixing\n    right ^= left\n    \n    # 4 rounds\n    for round_num in range(4):\n        mixed = f_function(right ^ keys[round_num])\n        temp = right\n        right = left ^ mixed\n        left = temp\n    \n    # Post-round mixing\n    left ^= right\n    \n    # Swap and combine\n    return merge(right, left)\n\ndef decrypt(ciphertext, keys):\n    left = getright(ciphertext)  # reversed\n    right = getleft(ciphertext)\n    \n    # Reverse post-round mixing\n    left ^= right\n    \n    # Reverse 4 rounds\n    for round_num in range(3, -1, -1):\n        temp = left\n        left = right\n        mixed = f_function(temp ^ keys[round_num])\n        right = temp\n        left ^= mixed\n    \n    # Reverse pre-round mixing\n    right ^= left\n    \n    return merge(left, right)\n\ndef set_keys(seeds):\n    # seeds is list of 4 20-bit values\n    return [expand(s & 0xFFFFF) for s in seeds]\n\n# Test with provided pairs\npairs = []\nwith open(\'/app/pairs.txt\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if line:\n            p, c = line.split()\n            pairs.append((int(p), int(c)))\n\nprint(f"Loaded {len(pairs)} plaintext-ciphertext pairs")\n\n# Let\'s verify the cipher works by testing with some random keys\n# We can use the compiled binary to verify\nEOF\npython3 /app/attack.py\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
