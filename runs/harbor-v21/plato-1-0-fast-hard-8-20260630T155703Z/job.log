Sending keys: ['cat > /app/steal.py << \'EOF\'\nimport numpy as np\nfrom forward import forward\n\n# Numerical gradient using central differences\ndef grad_f(x, h=1e-6):\n    """Compute gradient of forward at point x using central differences."""\n    n = len(x)\n    g = np.zeros(n)\n    for i in range(n):\n        x_plus = x.copy()\n        x_minus = x.copy()\n        x_plus[i] += h\n        x_minus[i] -= h\n        g[i] = (forward(x_plus) - forward(x_minus)) / (2 * h)\n    return g\n\n# Try to find activation boundaries by sampling along a line\ndef find_change_vectors(x0, d, n_samples=2000, t_range=5.0):\n    """Sample along line x0 + t*d, find gradient changes and return the change vectors."""\n    ts = np.linspace(-t_range, t_range, n_samples)\n    prev_grad = None\n    change_vectors = []\n    \n    for t in ts:\n        x = x0 + t * d\n        g = grad_f(x)\n        if prev_grad is not None:\n            diff = g - prev_grad\n            # If gradient changed significantly\n            if np.linalg.norm(diff) > 1e-7:\n                change_vectors.append(diff)\n        prev_grad = g\n    \n    return change_vectors\n\nif __name__ == \'__main__\':\n    np.random.seed(42)\n    \n    all_vectors = []\n    \n    # Try multiple random starting points and directions\n    for _ in range(50):\n        x0 = np.random.randn(10)\n        d = np.random.randn(10)\n        d = d / np.linalg.norm(d)\n        vecs = find_change_vectors(x0, d, n_samples=1000, t_range=5.0)\n        \n        for v in vecs:\n            # Normalize direction and remove duplicates\n            norm = np.linalg.norm(v)\n            if norm > 1e-7:\n                v_unit = v / norm\n                # Check if this direction already exists (up to sign)\n                found = False\n                threshold = 1e-4\n                for existing in all_vectors:\n                    # Compare normalized vectors, allowing sign flip\n                    cos_sim = abs(np.dot(v_unit, existing / np.linalg.norm(existing)))\n                    if cos_sim > 1 - threshold:\n                        found = True\n                        break\n                if not found:\n                    all_vectors.append(v)\n        \n        if len(all_vectors) >= 20:\n            break\n    \n    print(f"Found {len(all_vectors)} unique gradient change vectors")\n    \n    # Build A1 from these vectors (each vector is proportional to a row of A1)\n    # The actual scaling includes the A2 factor, but we only need rows up to scaling\n    # So we can just use the vectors directly as rows\n    n_found = len(all_vectors)\n    if n_found >= 20:\n        stolen_A1 = np.zeros((20, 10))\n        for i in range(20):\n            stolen_A1[i] = all_vectors[i]\n        # Normalize each row to unit length (since scaling is arbitrary)\n        for i in range(20):\n            norm = np.linalg.norm(stolen_A1[i])\n            if norm > 0:\n                stolen_A1[i] = stolen_A1[i] / norm\n        np.save(\'/app/stolen_A1.npy\', stolen_A1)\n        print("Saved A1 to /app/stolen_A1.npy")\n    else:\n        print(f"Only found {n_found} vectors, need 20")\n        # Save whatever we found\n        if n_found > 0:\n            stolen_A1 = np.array(all_vectors[:min(n_found, 20)])\n            if len(stolen_A1.shape) == 1:\n                stolen_A1 = stolen_A1.reshape(1, -1)\n            np.save(\'/app/stolen_A1.npy\', stolen_A1)\n            print("Saved partial A1")\nEOF\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
