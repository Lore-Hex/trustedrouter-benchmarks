// \
use std::env;
// \
fn fib(n: i32) -> i32 {
// \
    if n <= 1 { return 1; }
// \
    let mut a = 1;
// \
    let mut b = 1;
// \
    for _ in 2..=n {
// \
        let c = a + b;
// \
        a = b;
// \
        b = c;
// \
    }
// \
    b
// \
}
// \
fn main() {
// \
    let args: Vec<String> = env::args().collect();
// \
    let n: i32 = args.get(1).and_then(|s| s.parse().ok()).unwrap_or(0);
// \
    println!("{}", fib(n));
// \
}
