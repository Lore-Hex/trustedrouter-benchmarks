typedef unsigned long long u64;$
$
u64 fib(int n) {$
    u64 a = 1, b = 1;$
    for (int i = 0; i < n; i++) {$
        u64 t = a + b;$
        a = b;$
        b = t;$
    }$
    return a;$
}$
$
int main(int argc, char** argv) {$
    if (argc < 2) return 1;$
    int n = atoi(argv[1]);$
    printf("%llu\n", fib(n));$
    return 0;$
}$
//\$
*/$
