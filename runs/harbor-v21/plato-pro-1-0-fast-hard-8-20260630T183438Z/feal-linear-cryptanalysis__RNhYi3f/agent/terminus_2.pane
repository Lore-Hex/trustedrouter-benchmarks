cat > /app/flat.c <<'C'
#include <stdio.h>
#include <stdint.h>
#include <stdlib.h>

uint8_t g(uint8_t a, uint8_t b, uint8_t x) {
    uint8_t t=(a+b+x)&0xFF;
    return ((t<<2)|(t>>6))&0xFF;
}

uint32_t f(uint32_t inp) {
    uint8_t x[4]; uint32_t v=inp;
    for (int i=0;i<4;i++){ x[i]=v&0xFF; v>>=8; }
    uint8_t y[4];
    y[2]=g(x[3]^x[2], x[1]^x[0], 1);
    y[3]=g(x[3], y[2], 0);
    y[1]=g(x[1]^x[0], y[2], 0);
    y[0]=g(x[0], y[1], 1);
    uint32_t out=0;
    for (int i=0;i<4;i++) out|=((uint32_t)y[i])<<(8*i);
    return out;
}

int popc32(uint32_t x){ return __builtin_popcount(x); }

// Full LAT for F over all single input masks (32) and single output masks (32)
int main(){
  printf("F: perfect/strong single-bit linear approximations (bias counts out of 2^32):\n");
  // For exact, sample all inputs impossible. Use 2^24 random inputs for speed? 
  // Actually just use 1<<20 iterations for speed.
  uint32_t N=1<<22;
  for (int im=0; im<32; im++){
    for (int om=0; om<32; om++){
      uint32_t cnt=0;
      uint32_t r=12345;
      for (uint32_t i=0;i<N;i++){
        r = r*1103515245u+12345u;
        uint32_t inp = r;
        uint32_t out = f(inp);
        if (((popc32(inp&(1u<<im)) + popc32(out&(1u<<om))) & 1)==0) cnt++;
      }
      int bias = (int)cnt - (int)N/2; // wrong, use abs
      double frac = (double)cnt/N - 0.5;
      if (abs(bias) > N/8){
        printf("in_mask=%d out_mask=%d cnt=%u/%u bias=%d frac=%.4f\n", im, om, cnt, N, bias, frac);
      }
    }
  }
  // Also check the known perfect relation: input bit0 of each byte (mask 0x010101) -> output bit18 (bit2 of byte2)
  // input mask bits: bit0=0x1, bit8=0x100, bit16=0x10000, bit24=0x1000000 -> 0x01010101 (all bit0 of each byte)
  // But relation is XOR of bit0 of each input byte = parity of (inp & 0x01010101)
  // output bit: y2 is byte 2, bit2 of y2 -> bit 18 of output
  {
    uint32_t imask=0x01010101;
    uint32_t omask=1u<<18;
    uint32_t cnt=0; uint32_t r=99999;
    for (uint32_t i=0;i<N;i++){
      r=r*1103515245u+12345u; uint32_t inp=r; uint32_t out=f(inp);
      if (((popc32(inp&imask)+popc32(out&omask))&1)==0) cnt++;
    }
    printf("Perfect relation test: in=0x%08x out=0x%08x cnt=%u/%u bias=%d\n", imask, omask, cnt, N, (int)cnt-(int)N/2);
  }
  return 0;
}
