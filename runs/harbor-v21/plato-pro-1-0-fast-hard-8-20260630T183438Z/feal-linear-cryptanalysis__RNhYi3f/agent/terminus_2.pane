cat > /app/fsearch2.c <<'C'
#include <stdio.h>
#include <stdint.h>
#include <stdlib.h>
#include <string.h>

uint8_t g(uint8_t a, uint8_t b, uint8_t x){ uint8_t t=(a+b+x)&0xFF; return ((t<<2)|(t>>6))&0xFF; }
uint32_t f(uint32_t inp){
  uint8_t x[4]; uint32_t v=inp;
  for(int i=0;i<4;i++){x[i]=v&0xFF;v>>=8;}
  uint8_t y[4];
  y[2]=g(x[3]^x[2],x[1]^x[0],1);
  y[3]=g(x[3],y[2],0);
  y[1]=g(x[1]^x[0],y[2],0);
  y[0]=g(x[0],y[1],1);
  uint32_t out=0;
  for(int i=0;i<4;i++) out|=((uint32_t)y[i])<<(8*i);
  return out;
}
int main(){
  uint32_t N=1<<20;
  uint8_t *in=malloc(N*4), *out=malloc(N*4); // store as bytes: in[4*i + byte]
  uint32_t r=12345;
  for(uint32_t i=0;i<N;i++){ r=r*1103515245u+12345u; uint32_t v=r; uint32_t o=f(r);
    for(int b=0;b<4;b++){ in[4*i+b]=v&0xFF; v>>=8; out[4*i+b]=o&0xFF; o>>=8; }
  }
  // Precompute per-byte parity for each interesting bit
  // input bits: 0,2,8,10,16,18,24,26 -> per byte j (0-3), local bit 0 or 2
  // output bits: all 32, but also per byte.
  // For speed, precompute for each sample: parity of each mask candidate via tables.
  // Build lookup: par_bit[byte][bit] for each sample is just the bit.
  // We'll compute on the fly but smartly: precompute parity arrays for candidate input masks (256) and output masks (32) as bit arrays.
  uint8_t *pin=malloc(N*256), *pout=malloc(N*32); // too big (256MB each). Reduce N.
  // Instead test each mask sequentially but use precomputed per-byte bit arrays.
  // Precompute 4 byte-bit arrays for each of 8 input bit positions (4 bytes x 2 bits) and 4 bytes x 8 bits output.
  // Simpler: just reduce to N=1<<18 and accept smaller.
  free(in); free(out); free(pin); free(pout);
  // Redo with smaller N and bit-packed approach
  N=1<<18;
  uint8_t *ib=malloc(N*4), *ob=malloc(N*4);
  r=12345;
  for(uint32_t i=0;i<N;i++){ r=r*1103515245u+12345u; uint32_t v=r,o=f(r);
    for(int b=0;b<4;b++){ ib[4*i+b]=v&0xFF; v>>=8; ob[4*i+b]=o&0xFF; o>>=8; }
  }
  uint32_t input_bits[8]={0,2,8,10,16,18,24,26};
  int n_in=0; uint32_t in_masks[256];