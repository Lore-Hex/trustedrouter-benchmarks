[?2004l[?2004h>     y[1] = _g(x[1] ^ x[0], y[2], 0)
[?2004l[?2004h>     y[0] = _g(x[0], y[1], 1)
[?2004l[?2004h>     out = 0
[?2004l[?2004h>     for i in range(4):
[?2004l[?2004h>         out |= y[i] << (8 * i)
[?2004l[?2004h>     return out & 0xFFFFFFFF
