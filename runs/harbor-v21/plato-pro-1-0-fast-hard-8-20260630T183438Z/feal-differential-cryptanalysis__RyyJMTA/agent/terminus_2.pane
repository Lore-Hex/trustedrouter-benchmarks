[?2004l[?2004h> from feal import f_function
[?2004l[?2004h> import random, collections
[?2004l[?2004h> 
[?2004l[?2004h> # Deterministic F diffs:
[?2004l[?2004h> det = {0:0, 0x8080:2, 0x80800000:0x2000000, 0x80808080:0x2000002}
[?2004l[?2004h> 
[?2004l[?2004h> def fdiff_distribution(d, n=2000):
[?2004l[?2004h>     cnt=collections.Counter()
[?2004l[?2004h>     for _ in range(n):
[?2004l[?2004h>         x=random.randint(0,0xFFFFFFFF)
[?2004l[?2004h>         cnt[f_function(x^d)^f_function(x)] += 1
[?2004l[?2004h>     return cnt
[?2004l[?2004h> 
[?2004l[?2004h> def feistel_step(dL,dR):
[?2004l[?2004h>     return dR, dL ^ det[dR]
[?2004l[?2004h> 
[?2004l[?2004h> # Try chaining deterministic differences through rounds.
[?2004l[?2004h> # If dR is not in det, not deterministic. Search initial dL,dR from chosen premix combos
[?2004l[?2004h> # where premix dL = dP_L, dR_premix = dP_R ^ dP_L. We can choose arbitrary dL,dR premix because plaintext difference can realize any premix diffs.
[?2004l[?2004h> # Search all pairs of deterministic input diffs as premix dR and dL? Any 32-bit dL, dR, but dR must be det for round1.
[?2004l[?2004h> for dR0 in det:
[?2004l[?2004h>     for dL0 in det:
[?2004l[?2004h>         dL,dR=dL0,dR0
[?2004l[?2004h>         steps=[(dL,dR)]
[?2004l[?2004h>         ok=True
[?2004l[?2004h>         for r in range(3):
[?2004l[?2004h>             if dR in det:
[?2004l[?2004h>                 dL,dR=feistel_step(dL,dR)
[?2004l[?2004h>                 steps.append((dL,dR))
[?2004l[?2004h>             else:
[?2004l[?2004h>                 ok=False
[?2004l[?2004h>                 break
[?2004l[?2004h>         if ok:
[?2004l[?2004h>             print('premix', hex(dL0), hex(dR0), '-> before round4', hex(dL), hex(dR))
[?2004l[?2004h>             print('  steps', [(hex(a),hex(b)) for a,b in steps])
