[?2004l[?2004h>         p1 = ((L & 0xFFFFFFFF) << 32) | (R & 0xFFFFFFFF)
[?2004l[?2004h>         p2 = (((L ^ DPL) & 0xFFFFFFFF) << 32) | ((R ^ DPR) & 0xFFFFFFFF)
[?2004l[?2004h>         c1 = encrypt_fn(p1)
[?2004l[?2004h>         c2 = encrypt_fn(p2)
