[?2004hroot@7d23c0568844:/app# python3 - <<'PY'
[?2004l[?2004h> det = {0:0, 0x8080:2, 0x80800000:0x2000000, 0x80808080:0x2000002}
[?2004l[?2004h> detvals=list(det.keys())
[?2004l[?2004h> 
[?2004l[?2004h> def propagate(dL,dR):
[?2004l[?2004h>     return dR, dL ^ det[dR]
[?2004l[?2004h> 
[?2004l[?2004h> # We need sequence dR0,dR1,dR2,dR3 deterministic. dR_r is F input to round r+1.
[?2004l[?2004h> # Relation: dR_{r+1} = dL_r ^ det[dR_r], dL_{r+1}=dR_r.
[?2004l[?2004h> # So dL_r = dR_{r+1} ^ det[dR_r].
[?2004l[?2004h> # Starting premix dL0, dR0. dR1 = dL0 ^ det[dR0]. We can choose any dR0,dR1,dR2,dR3 from detvals.
[?2004l[?2004h> # Then dL0 = dR1 ^ det[dR0], dL1 = dR0, dL2=dR1, dL3=dR2.
[?2004l[?2004h> # Before round4 state is dL3,dR3.
[?2004l[?2004h> for dR0 in detvals:
[?2004l[?2004h>     if dR0==0: continue
[?2004l[?2004h>     for dR1 in detvals:
[?2004l[?2004h>         dL0 = dR1 ^ det[dR0]
[?2004l[?2004h>         for dR2 in detvals:
[?2004l[?2004h>             # need dR2 = dL1 ^ det[dR1] = dR0 ^ det[dR1]
[?2004l[?2004h>             if dR2 != (dR0 ^ det[dR1]):
[?2004l[?2004h>                 continue
[?2004l[?2004h>             for dR3 in detvals:
[?2004l[?2004h>                 # need dR3 = dL2 ^ det[dR2] = dR1 ^ det[dR2]
[?2004l[?2004h>                 if dR3 != (dR1 ^ det[dR2]):
[?2004l[?2004h>                     continue
[?2004l[?2004h>                 print('premix dL0', hex(dL0), 'dR0', hex(dR0))
[?2004l[?2004h>                 print('  dR1',hex(dR1),'dR2',hex(dR2),'dR3',hex(dR3),'before round4',hex(dR1),hex(dR3))
[?2004l[?2004h>                 # Also before last round dL3=dR2, dR3=dR3
[?2004l[?2004h>                 print('  before round4 dL3=dR2', hex(dR2), 'dR3', hex(dR3))
[?2004l[?2004h>                 print('  plaintext dPL=dL0, dPR = dR0 ^ dL0 =', hex(dL0), hex(dR0 ^ dL0))
[?2004l[?2004h> PY
