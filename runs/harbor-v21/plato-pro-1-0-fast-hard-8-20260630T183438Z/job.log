Sending keys: ['cat > /app/steal.py <<\'PY\'\nimport os\nimport numpy as np\nimport forward\n\nd = 10\nn_neurons = 20\noutput_path = "/app/stolen_A1.npy"\n\n\ndef f(x):\n    return forward.forward(np.asarray(x, dtype=float))\n\n\ndef grad_at(x, eps=1e-3):\n    """Estimate the gradient of the scalar output at x using central differences."""\n    g = np.zeros(d)\n    for i in range(d):\n        xp = x.copy()\n        xp[i] += eps\n        xm = x.copy()\n        xm[i] -= eps\n        g[i] = (f(xp) - f(xm)) / (2 * eps)\n    return g\n\n\ndef find_kinks_on_line(c, v, tmin=-5.0, tmax=5.0, n=6001, thr=1e-4, merge=5):\n    """\n    Detect kink points along the line x = c + t*v by looking for\n    large second derivative of f(c + t*v).  For each kink, estimate\n    the gradient jump vector across the kink.\n    """\n    ts = np.linspace(tmin, tmax, n)\n    ys = np.array([f(c + t * v) for t in ts])\n    dy = np.diff(ys) / np.diff(ts)\n    ddy = np.diff(dy)\n\n    idx = np.where(np.abs(ddy) > thr)[0]\n\n    # Merge adjacent detections belonging to the same kink.\n    groups = []\n    for i in idx:\n        if groups and i - groups[-1][-1] <= merge:\n            groups[-1].append(i)\n        else:\n            groups.append([i])\n\n    kinks = []\n    for gidx in groups:\n        gidx = np.array(gidx)\n        w = np.abs(ddy[gidx])\n        tloc = np.dot(ts[gidx], w) / w.sum()\n\n        # Points clearly before and after the kink.\n        t_before = ts[max(gidx[0] - 10, 0)] - 0.03\n        t_after = ts[min(gidx[-1] + 10, len(ts) - 1)] + 0.03\n        x_before = c + t_before * v\n        x_after = c + t_after * v\n\n        g_before = grad_at(x_before, 1e-3)\n        g_after = grad_at(x_after, 1e-3)\n        jump = g_after - g_before\n\n        if np.linalg.norm(jump) > 1e-6:\n            kinks.append((tloc, c + tloc * v, jump))\n\n    return kinks\n\n\ndef collect_directions(n_lines=50, seed0=0):\n    """\n    Run random line probes and collect normalized kink gradient jump vectors.\n    """\n    vecs = []\n    for s in range(n_lines):\n        rng = np.random.default_rng(seed0 + s)\n        c = rng.normal(size=d) * 0.4\n        v = rng.normal(size=d)\n        v = v / np.linalg.norm(v)\n\n        for tloc, xk, jump in find_kinks_on_line(c, v):\n            u = jump / np.linalg.norm(jump)\n            # Canonical sign so the same physical neuron direction maps\n            # to the same vector regardless of crossing direction.\n            if u[np.argmax(np.abs(u))] < 0:\n                u = -u\n            vecs.append(u)\n\n    return np.array(vecs)\n\n\ndef cluster_directions(vecs, threshold=0.995):\n    """Greedy cosine clustering; merge clusters until stable."""\n    centers = []\n    members = []\n\n    for u in vecs:\n        found = False\n        for ci, ce in enumerate(centers):\n            if abs(np.dot(u, ce)) > threshold:\n                members[ci].append(u)\n                found = True\n                break\n        if not found:\n            centers.append(u.copy())\n            members.append([u])\n\n    # Recursively merge clusters that become close after averaging.\n    changed = True\n    while changed:\n        changed = False\n        m = len(centers)\n        for i in range(m):\n            for j in range(i + 1, m):\n                if abs(np.dot(centers[i], centers[j])) > threshold:\n                    combined = members[i] + members[j]\n                    new_center = np.mean(combined, axis=0)\n                    new_center = new_center / np.linalg.norm(new_center)\n                    centers[i] = new_center\n                    members[i] = combined\n                    del centers[j]\n                    del members[j]\n                    changed = True\n                    break\n            if changed:\n                break\n\n    centers = np.asarray(centers, dtype=float)\n    centers = centers / np.linalg.norm(centers, axis=1, keepdims=True)\n    counts = np.array([len(mm) for mm in members])\n    return centers, counts\n\n\ndef main():\n    vecs = collect_directions(n_lines=50, seed0=1)\n    centers, counts = cluster_directions(vecs, threshold=0.995)\n\n    # The 20 true neuron directions have far more support than noise clusters.\n    # Take the top-20 sorted by member count.  If there are fewer than 20,\n    # the matrix gets padded with zero rows.\n    order = np.argsort(-counts)\n    selected = np.zeros((n_neurons, d))\n    for k in range(min(n_neurons, len(centers))):\n        selected[k] = centers[order[k]]\n\n    np.save(output_path, selected)\n    print(f"Saved recovered A1 matrix with shape {selected.shape} to {output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPY\npython3 /app/steal.py\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
