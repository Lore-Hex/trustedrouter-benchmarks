 ^ 1\n# where p(x)=parity(x&mask).\n\nFOUT = 0x00040000\nFIN  = 0x01010101\ndef par(x, m): return bin(x & m).count('1') % 2\n\n# Let's try to express things in terms of known L0,R0 and key parities.\n# L0=PL, R0=PL^PR.\n# p(L0 & any) known from plaintext; p(R0 & any) known too.\n# Round0: p(R1 & FOUT) = p(L0 & FOUT) ^ p(R0 & FIN) ^ k0fin ^ 1\n#   where k0fin = p(K0 & FIN)\n# Round1: p(R2 & FOUT) = p(L1 & FOUT) ^ p(R1 & FIN) ^ k1fin ^ 1\n#   L1=R0, so p(L1 & FOUT)=p(R0 & FOUT)\n#   But we need p(R1 & FIN), not p(R1 & FOUT). Different mask! So unless FIN=FOUT, we can't chain directly.\n# FIN != FOUT, so we can't simply chain the same relation. Need either a relation with FIN=FOUT (same mask in/out) or handle mask transitions.\nprint('FIN=%08x FOUT=%08x, same? %s'%(FIN,FOUT,FIN==FOUT))\n\n# Let's search for perfect/super strong F relations where input mask = output mask (so they chain),\n# or more generally find all strong multi-bit relations.\n# Let's do an exhaustive search over a restricted set of input masks (combinations of bit0 of each byte) and output masks (single or few bits).\n# Actually let's compute the full F truth table for these masks using a large sample.\nimport random\nrandom.seed(7)\nN=5000000\ninp_samples=[random.getrandbits(32) for _ in range(N)]\nout_samples=[f(x) for x in inp_samples]\n\nbest=[]\n# Search input masks: subsets of {0,8,16,24} (bit0 of each byte) plus maybe bit2 of bytes\ninput_bits=[0,2,8,10,16,18,24,26]  # bit0 and bit2 of each byte\noutput_bits=list(range(32))\nfrom itertools import combinations, product\n\ndef parval(x,m): return bin(x&m).count('1')%2\n\n# Try all input masks from pairs of those bits, output masks single bit\nin_masks=[0]\nfor b in input_bits: in_masks.append(1<<b)\nfor b1 in input_bits:\n  for b2 in input_bits:\n    if b1<b2: in_masks.append((1<<b1)|(1<<b2))\nfor b1 in input_bits:\n  for b2 in input_bits:\n    for b3 in input_bits:\n      if b1<b2<b3: in_masks.append((1<<b1)|(1<<b2)|(1<<b3))\nfor b1 in input_bi