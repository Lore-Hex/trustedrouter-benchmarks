Sending keys: ["cat > /tmp/explore4.py <<'PY'\nimport feal\nfrom feal import f_function, getleft, getright, merge\n\n# known keys for simulation\ntrue_keys = [0x12345678, 0x23456789, 0x3456789a, 0x456789ab, 0x56789abc, 0x6789abcd]\n\ndef encrypt_fn(pt):\n    return feal.encrypt(pt) if False else None\n\n# Use feal with our internal simulation to simulate chosen plaintext oracle with true keys in feal.key\nfeal.key[:] = true_keys[:]\ndef oracle(pt):\n    return feal.encrypt(pt)\n\ndef rec_LR(ct):\n    # L4 = getright(ct) ^ getleft(ct); R4 = getleft(ct)\n    return (getright(ct) ^ getleft(ct), getleft(ct))\n\ndef seed_to_key(seed):\n    return (seed * 1234567) & 0xFFFFFFFF\n\nimport random\nrandom.seed(0)\npairs=[]\nfor _ in range(4):\n    base = random.randint(0, (1<<64)-1)\n    a = base\n    b = base ^ 0x100000001\n    ca = oracle(a)\n    cb = oracle(b)\n    pairs.append((a,b,ca,cb))\n\n# For each candidate seed, compute dL3 for each pair and see if constant\nfrom collections import Counter\ncand_ok=[]\nfor seed in range(0x10000):\n    k5 = seed_to_key(seed)\n    ds=[]\n    for a,b,ca,cb in pairs:\n        L4a,R4a = rec_LR(ca)\n        L4b,R4b = rec_LR(cb)\n        R3a = L4a\n        R3b = L4b\n        L3a = R4a ^ f_function(R3a ^ k5)\n        L3b = R4b ^ f_function(R3b ^ k5)\n        ds.append(L3a ^ L3b)\n    if len(set(ds)) == 1:\n        cand_ok.append((seed, k5, ds[0]))\nprint('candidates with constant dL3:', len(cand_ok))\nfor x in cand_ok[:20]:\n    print(hex(x[0]), hex(x[1]), hex(x[2]))\nprint('true key5', hex(true_keys[5]))\nPY\nPYTHONPATH=/app python3 /tmp/explore4.py\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
