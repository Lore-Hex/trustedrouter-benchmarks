[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import os
[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> VIDEO = '/app/video.mp4'
[?2004l[?2004h> FRAMES_DIR = '/app/frames2'
[?2004l[?2004h> OUTPUT = '/app/solution.txt'
[?2004l[?2004h> OCR_ALL = '/app/ocr_all.txt'
[?2004l[?2004h> FPS = 2
[?2004l[?2004h> 
[?2004l[?2004h> # Step 1: Extract frames
[?2004l[?2004h> print("Extracting frames...", flush=True)
[?2004l[?2004h> os.makedirs(FRAMES_DIR, exist_ok=True)
[?2004l[?2004h> subprocess.run(['ffmpeg', '-y', '-i', VIDEO, '-vf', f'fps={FPS}',
[?2004l[?2004h>                 f'{FRAMES_DIR}/f%04d.png'], capture_output=True, timeout=60)
[?2004l[?2004h> 
[?2004l[?2004h> # Step 2: OCR each frame and collect data
[?2004l[?2004h> print("OCR processing...", flush=True)
[?2004l[?2004h> frame_data = []
[?2004l[?2004h> all_ocr = []
[?2004l[?2004h> 
[?2004l[?2004h> for fname in sorted(os.listdir(FRAMES_DIR)):
[?2004l[?2004h>     if not fname.endswith('.png'):
[?2004l[?2004h>         continue
[?2004l[?2004h>     fpath = os.path.join(FRAMES_DIR, fname)
[?2004l[?2004h>     result = subprocess.run(['tesseract', fpath, 'stdout'],
[?2004l[?2004h>                           capture_output=True, text=True, timeout=10)
[?2004l[?2004h>     text = result.stdout
[?2004l[?2004h>     all_ocr.append(f'=== {fname} ===\n{text}\n')
[?2004l[?2004h> 
[?2004l[?2004h>     # Extract Moves counter
[?2004l[?2004h>     moves_match = re.search(r'Moves:\s*(\d+)', text)
[?2004l[?2004h>     moves_count = int(moves_match.group(1)) if moves_match else None
[?2004l[?2004h> 
[?2004l[?2004h>     # Extract ">" lines with possible parenthetical continuations
[?2004l[?2004h>     lines = [l.rstrip() for l in text.split('\n')]
[?2004l[?2004h>     prompt_lines = []
[?2004l[?2004h>     for i, line in enumerate(lines):
[?2004l[?2004h>         stripped = line.strip()
[?2004l[?2004h>         if stripped.startswith('>'):
[?2004l[?2004h>             move = stripped[1:].strip().replace('_', '').strip()
[?2004l[?2004h>             # Check for continuation (parenthetical on next line)
[?2004l[?2004h>             if i + 1 < len(lines):
[?2004l[?2004h>                 next_stripped = lines[i+1].strip()
[?2004l[?2004h>                 if next_stripped.startswith('(') and ')' in next_stripped:
[?2004l[?2004h>                     cont = next_stripped.strip('()').strip()
[?2004l[?2004h>                     if move:
[?2004l[?2004h>                         move = move + ' ' + cont
[?2004l[?2004h>                     else:
[?2004l[?2004h>                         move = cont
[?2004l[?2004h>             if move:
[?2004l[?2004h>                 prompt_lines.append(move)
[?2004l[?2004h> 
[?2004l[?2004h>     frame_data.append((fname, moves_count, prompt_lines))
[?2004l[?2004h> 
[?2004l[?2004h> # Save OCR results
[?2004l[?2004h> with open(OCR_ALL, 'w') as f:
[?2004l[?2004h>     f.write('\n'.join(all_ocr))
[?2004l[?2004h> 
[?2004l[?2004h> # Step 3: Extract moves using Moves counter
[?2004l[?2004h> print("Extracting moves...", flush=True)
[?2004l[?2004h> moves = []
[?2004l[?2004h> last_count = 0
[?2004l[?2004h> 
[?2004l[?2004h> for fname, count, prompt_lines in frame_data:
[?2004l[?2004h>     if count is not None and count > last_count:
[?2004l[?2004h>         diff = count - last_count
[?2004l[?2004h>         if diff == 1:
[?2004l[?2004h>             if prompt_lines:
[?2004l[?2004h>                 moves.append(prompt_lines[-1])
[?2004l[?2004h>         else:
[?2004l[?2004h>             # Multiple new moves - take last diff prompt lines
[?2004l[?2004h>             for i in range(diff):
[?2004l[?2004h>                 idx = len(prompt_lines) - diff + i
[?2004l[?2004h>                 if 0 <= idx < len(prompt_lines):
[?2004l[?2004h>                     moves.append(prompt_lines[idx])
[?2004l[?2004h>         last_count = count
[?2004l[?2004h>     elif count is not None and count < last_count:
[?2004l[?2004h>         # OCR error, ignore
[?2004l[?2004h>         pass
[?2004l[?2004h> 
[?2004l[?2004h> # Write output
