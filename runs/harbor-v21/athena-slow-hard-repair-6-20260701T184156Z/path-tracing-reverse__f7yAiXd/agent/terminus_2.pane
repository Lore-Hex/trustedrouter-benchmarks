[?2004l[?2004h> my ($h,@v)=split(/\s+/,$p);
[?2004l[?2004h> my @px=@v[3..$#v];
[?2004l[?2004h> # Find sphere boundary by sampling around center
[?2004l[?2004h> for my $y (250,260,270,280,290,300,310,320,330,340,350){
[?2004l[?2004h>   print "y=$y:";
[?2004l[?2004h>   for my $x (340,350,360,370,380,390,400,410,420,430,440,450,460){
[?2004l[?2004h>     my $i=($y*800+$x)*3;
[?2004l[?2004h>     print " $x=($px[$i],$px[$i+1],$px[$i+2])";
[?2004l[?2004h>   }
[?2004l[?2004h>   print "\n";
[?2004l[?2004h> }
