[?2004lcat > /tmp/cmp_region.pl <<'EOF'
open A,"/tmp/orig_img.ppm"; local $/; my $pa=<A>;
open B,"/tmp/rev_img.ppm"; local $/; my $pb=<B>;
my ($ha,@va)=split(/\s+/,$pa);
my ($hb,@vb)=split(/\s+/,$pb);
my @oa=@va[3..$#va];
my @ob=@vb[3..$#vb];
my $diffs=0;
for my $i (0..$#oa){
  if($oa[$i] ne $ob[$i]){
    my $pi=int($i/3);
    my $y=int($pi/800);
    my $x=$pi%800;
    if($diffs<50){print "y=$y x=$x o=($oa[$i*3-($i-$i%3)],$oa[$i*3-($i-$i%3)+1],$oa[$i*3-($i-$i%3)+2]) r=($ob[$i*3-($i-$i%3)],$ob[$i*3-($i-$i%3)+1],$ob[$i*3-($i-$i%3)+2])\n";}
    $diffs++;
  }
}
print "total=$diffs\n";
EOF
