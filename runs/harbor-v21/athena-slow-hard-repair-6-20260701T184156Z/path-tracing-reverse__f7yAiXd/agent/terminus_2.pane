cat > /tmp/terrain_sample.pl <<'EOF'
open F,"/tmp/orig_img.ppm"; local $/; my $p=<F>;
my ($h,@v)=split(/\s+/,$p);
my @px=@v[3..$#v];
for my $y (300,310,320,330,340,350,400,450,500,550,599){
  print "y=$y:";
  for my $x (380,390,400,410,420,430,440,450,460,470,480,500,550,600,650,700,750,799){
    my $i=($y*800+$x)*3;
    print " $x=($px[$i],$px[$i+1],$px[$i+2])";
  }
  print "\n";
}
EOF
