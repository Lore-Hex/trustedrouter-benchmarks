open F,"/tmp/orig_img.ppm"; local $/; my $p=<F>;
my ($h,@v)=split(/\s+/,$p);
my @px=@v[3..$#v];
for my $y (300,350,400,450,500){
  print "y=$y: ";
  for my $x (0..19){
    my $i=($y*800+$x)*3;
    my $r=$px[$i];
    print ($r==152 ? "H" : $r==67 ? "L" : $r==51 ? "S" : $r==20 ? "s" : "?");
  }
  print "\n";
}
