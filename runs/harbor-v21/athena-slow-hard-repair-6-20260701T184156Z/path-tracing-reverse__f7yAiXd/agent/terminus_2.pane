[?2004l[?2004h> static Vec vsub(Vec a,Vec b){return (Vec){a.x-b.x,a.y-b.y,a.z-b.z};}
[?2004l[?2004h> static Vec vmul(Vec a,float s){return (Vec){a.x*s,a.y*s,a.z*s};}
[?2004l[?2004h> static float vdot(Vec a,Vec b){return a.x*b.x+a.y*b.y+a.z*b.z;}
[?2004l[?2004h> static float vlen(Vec a){return sqrtf(a.x*a.x+a.y*a.y+a.z*a.z);}
[?2004l[?2004h> static Vec vnorm(Vec a){float l=vlen(a);return (Vec){a.x/l,a.y/l,a.z/l};}
[?2004l[?2004h> 
[?2004l[?2004h> static int sphere_intersect(Ray r, Vec c, float rad, float *t, Vec *n){
[?2004l[?2004h>   Vec oc=vsub(r.o,c);
