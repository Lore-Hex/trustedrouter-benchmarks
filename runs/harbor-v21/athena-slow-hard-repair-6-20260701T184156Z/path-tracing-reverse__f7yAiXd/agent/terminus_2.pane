cat > /tmp/terrain_cmp.pl <<'EOF'
open A,"/tmp/orig_img.ppm"; local $/; my $pa=<A>;
open B,"/tmp/rev_img.ppm"; local $/; my $pb=<B>;
my ($ha,@va)=split(/\s+/,$pa);
my ($hb,@vb)=split(/\s+/,$pb);
my @oa=@va[3..$#va];
my @ob=@vb[3..$#vb];
for my $y (300,350,400,450,500){
  print "y=$y\n";
  for my $x (0..40){
    my $i=($y*800+$x)*3;
    my $o="$oa[$i]";
    my $r="$ob[$i]";
    print "" . ($o ne $r ? "X" : ".");
  }
  print "\n";
}
EOF
