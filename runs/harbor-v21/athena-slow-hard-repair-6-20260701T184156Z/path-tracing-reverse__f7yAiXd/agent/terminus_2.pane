[?2004l[?2004h> open F,"/app/image.ppm"; local $/; my $p=<F>;
[?2004l[?2004h> my ($h,@v)=split(/\s+/,$p);
[?2004l[?2004h> my @px=@v[3..$#v];
[?2004l[?2004h> # Sample every 40 pixels horizontally at key rows
[?2004l[?2004h> for my $y (0,50,100,150,200,250,280,290,295,300,305,310,320,350,400,450,500,550,599){
[?2004l[?2004h>   print "y=$y:";
[?2004l[?2004h>   for my $x (0,100,200,300,350,360,370,380,390,400,410,420,430,440,450,500,600,700,799){
[?2004l[?2004h>     my $i=($y*800+$x)*3;
[?2004l[?2004h>     print " $x=($px[$i],$px[$i+1],$px[$i+2])";
[?2004l[?2004h>   }
[?2004l[?2004h>   print "\n";
[?2004l[?2004h> }
