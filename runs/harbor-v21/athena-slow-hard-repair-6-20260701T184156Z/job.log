d r==g and g==b) and not (r==67 and r==g and g==b):\n            k='dark' if r==g==b else 'red'\n            if k not in cnt: cnt[k]=[x,y,x,y,0]\n            c=cnt[k]; c[0]=min(c[0],x);c[1]=min(c[1],y);c[2]=max(c[2],x);c[3]=max(c[3],y);c[4]+=1\nprint(cnt)\nPY\n"] min_timeout_sec: 3.0 max_timeout_sec: 180.0
