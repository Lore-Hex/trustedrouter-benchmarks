Sending keys: ['cat > /app/extract_moves.py << \'PYEOF\'\n#!/usr/bin/env python3\nimport subprocess\nimport os\nimport re\n\nVIDEO = \'/app/video.mp4\'\nFRAMES_DIR = \'/app/frames2\'\nOUTPUT = \'/app/solution.txt\'\nOCR_ALL = \'/app/ocr_all.txt\'\nFPS = 2\n\n# Step 1: Extract frames\nprint("Extracting frames...", flush=True)\nos.makedirs(FRAMES_DIR, exist_ok=True)\nsubprocess.run([\'ffmpeg\', \'-y\', \'-i\', VIDEO, \'-vf\', f\'fps={FPS}\',\n                f\'{FRAMES_DIR}/f%04d.png\'], capture_output=True, timeout=60)\n\n# Step 2: OCR each frame and collect data\nprint("OCR processing...", flush=True)\nframe_data = []\nall_ocr = []\n\nfor fname in sorted(os.listdir(FRAMES_DIR)):\n    if not fname.endswith(\'.png\'):\n        continue\n    fpath = os.path.join(FRAMES_DIR, fname)\n    result = subprocess.run([\'tesseract\', fpath, \'stdout\'],\n                          capture_output=True, text=True, timeout=10)\n    text = result.stdout\n    all_ocr.append(f\'=== {fname} ===\\n{text}\\n\')\n\n    # Extract Moves counter\n    moves_match = re.search(r\'Moves:\\s*(\\d+)\', text)\n    moves_count = int(moves_match.group(1)) if moves_match else None\n\n    # Extract ">" lines with possible parenthetical continuations\n    lines = [l.rstrip() for l in text.split(\'\\n\')]\n    prompt_lines = []\n    for i, line in enumerate(lines):\n        stripped = line.strip()\n        if stripped.startswith(\'>\'):\n            move = stripped[1:].strip().replace(\'_\', \'\').strip()\n            # Check for continuation (parenthetical on next line)\n            if i + 1 < len(lines):\n                next_stripped = lines[i+1].strip()\n                if next_stripped.startswith(\'(\') and \')\' in next_stripped:\n                    cont = next_stripped.strip(\'()\').strip()\n                    if move:\n                        move = move + \' \' + cont\n                    else:\n                        move = cont\n            if move:\n                prompt_lines.append(move)\n\n    frame_data.append((fname, moves_count, prompt_lines))\n\n# Save OCR results\nwith open(OCR_ALL, \'w\') as f:\n    f.write(\'\\n\'.join(all_ocr))\n\n# Step 3: Extract moves using Moves counter\nprint("Extracting moves...", flush=True)\nmoves = []\nlast_count = 0\n\nfor fname, count, prompt_lines in frame_data:\n    if count is not None and count > last_count:\n        diff = count - last_count\n        if diff == 1:\n            if prompt_lines:\n                moves.append(prompt_lines[-1])\n        else:\n            # Multiple new moves - take last diff prompt lines\n            for i in range(diff):\n                idx = len(prompt_lines) - diff + i\n                if 0 <= idx < len(prompt_lines):\n                    moves.append(prompt_lines[idx])\n        last_count = count\n    elif count is not None and count < last_count:\n        # OCR error, ignore\n        pass\n\n# Write output\nwith open(OUTPUT, \'w\') as f:\n    for m in moves:\n        f.write(m + \'\\n\')\n\nprint(f"Extracted {len(moves)} moves")\nfor i, m in enumerate(moves):\n    print(f"{i+1}: {m}")\nPYEOF\npython3 /app/extract_moves.py\n'] min_timeout_sec: 45.0 max_timeout_sec: 180.0
