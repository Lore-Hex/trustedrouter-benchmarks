Sending keys: ['cat > /app/ocr_parallel.py << \'PYEOF\'\n#!/usr/bin/env python3\nimport subprocess\nimport os\nimport concurrent.futures\n\nFRAMES_DIR = \'/app/frames1\'\n\ndef ocr_frame(fname):\n    fpath = os.path.join(FRAMES_DIR, fname)\n    txtpath = fpath + \'.txt\'\n    try:\n        result = subprocess.run([\'tesseract\', fpath, \'stdout\'],\n                              capture_output=True, text=True, timeout=30)\n        with open(txtpath, \'w\') as f:\n            f.write(result.stdout)\n        return fname, True, \'\'\n    except subprocess.TimeoutExpired:\n        return fname, False, \'TIMEOUT\'\n    except Exception as e:\n        return fname, False, str(e)\n\nframes = sorted([f for f in os.listdir(FRAMES_DIR) if f.endswith(\'.png\')])\n# Remove already processed files\nframes = [f for f in frames if not os.path.exists(os.path.join(FRAMES_DIR, f + \'.txt\'))]\nprint(f"Processing {len(frames)} frames...", flush=True)\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=2) as executor:\n    futures = {executor.submit(ocr_frame, f): f for f in frames}\n    done = 0\n    ok = 0\n    for future in concurrent.futures.as_completed(futures):\n        fname, success, err = future.result()\n        done += 1\n        if success:\n            ok += 1\n        else:\n            print(f"FAIL {fname}: {err}", flush=True)\n        if done % 20 == 0 or done == len(frames):\n            print(f"{done}/{len(frames)} done, {ok} ok", flush=True)\n\nprint(f"Complete: {ok}/{len(frames)} succeeded")\nPYEOF\npython3 /app/ocr_parallel.py\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
