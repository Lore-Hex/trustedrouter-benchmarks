[?2004l[?2004h> with open('image.ppm','rb') as f:
[?2004l[?2004h>     data=f.read()
[?2004l[?2004h> idx=0
[?2004l[?2004h> def tok():
[?2004l[?2004h>     global idx
[?2004l[?2004h>     while idx<len(data) and data[idx] in b' \t\n\r': idx+=1
[?2004l[?2004h>     s=b''
[?2004l[?2004h>     while idx<len(data) and data[idx] not in b' \t\n\r':
[?2004l[?2004h>         s+=data[idx:idx+1]; idx+=1
[?2004l[?2004h>     return s
[?2004l[?2004h> tok();W=int(tok());H=int(tok());int(tok())
[?2004l[?2004h> pix=[int(x) for x in bytes(data[idx:]).split()]
[?2004l[?2004h> def P(x,y):
[?2004l[?2004h>     i=(y*W+x)*3; return (pix[i],pix[i+1],pix[i+2])
