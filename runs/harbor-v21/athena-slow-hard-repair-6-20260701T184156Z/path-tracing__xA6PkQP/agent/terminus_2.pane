[?2004l[?2004h> print('=== sky y=449')
[?2004l[?2004h> for x in range(0,W,10):
[?2004l[?2004h>     r,g,b=P(x,449)
[?2004l[?2004h>     if x<50 or x%200==0 or x>2380: print(x,r,g)
