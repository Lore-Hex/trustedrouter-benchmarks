[?2004hroot@0c21e2283564:/app# python3 - <<'PY'
[?2004l[?2004h> with open('image.ppm','rb') as f:
[?2004l[?2004h>     data=f.read()
[?2004l[?2004h> idx=0
[?2004l[?2004h> def tok():
[?2004l[?2004h>     global idx
[?2004l[?2004h>     while idx<len(data) and data[idx] in b' \t\n\r': idx+=1
[?2004l[?2004h>     s=b''
[?2004l[?2004h>     while idx<len(data) and data[idx] not in b' \t\n\r':
[?2004l[?2004h>         s+=data[idx:idx+1]; idx+=1
[?2004l[?2004h>     return s
[?2004l[?2004h> tok();W=int(tok());H=int(tok());int(tok())
[?2004l[?2004h> pix=[int(x) for x in bytes(data[idx:]).split()]
[?2004l[?2004h> def P(x,y):
[?2004l[?2004h>     i=(y*W+x)*3; return (pix[i],pix[i+1],pix[i+2])
[?2004l[?2004h> # 1. Sky formula: sample R,G at grid
[?2004l[?2004h> print('=== SKY GRID R,G')
[?2004l[?2004h> for y in range(0,900,100):
[?2004l[?2004h>     row=[]
[?2004l[?2004h>     for x in range(0,W,200):
[?2004l[?2004h>         r,g,b=P(x,y)
[?2004l[?2004h>         row.append((r,g))
[?2004l[?2004h>     print(y,row)
[?2004l[?2004h> # 2. Checkerboard rule
[?2004l[?2004h> print('=== CHECKER')
[?2004l[?2004h> for y in [900,901,902,1000,1500,1799]:
[?2004l[?2004h>     print(y,[(x%2,P(x,y)[0]) for x in range(10)])
[?2004l[?2004h> # 3. Red object: find left/right edges per row
[?2004l[?2004h> print('=== RED EDGES')
[?2004l[?2004h> for y in range(805,1180,10):
[?2004l[?2004h>     xs=[]
[?2004l[?2004h>     for x in range(W):
[?2004l[?2004h>         r,g,b=P(x,y)
[?2004l[?2004h>         if b<100 and r>g and not (r==g==b):
[?2004l[?2004h>             xs.append(x)
[?2004l[?2004h>     if xs:
[?2004l[?2004h>         print(y,min(xs),max(xs),len(xs),P(min(xs),y),P(max(xs),y))
[?2004l[?2004h>     else:
[?2004l[?2004h>         print(y,'none')
[?2004l[?2004h> # 4. Red object center vertical color
[?2004l[?2004h> print('=== RED CENTER')
[?2004l[?2004h> for y in range(805,1180,20):
[?2004l[?2004h>     print(y,P(1200,y))
[?2004l[?2004h> # 5. Dark objects: find non-checker, non-red below 900
[?2004l[?2004h> print('=== DARK OBJECTS')
[?2004l[?2004h> for y in range(900,H,50):
[?2004l[?2004h>     xs=[]
[?2004l[?2004h>     for x in range(W):
[?2004l[?2004h>         r,g,b=P(x,y)
[?2004l[?2004h>         if r==g==b and r not in (152,67):
[?2004l[?2004h>             xs.append((x,r))
[?2004l[?2004h>     if xs:
[?2004l[?2004h>         print(y,xs[:5],xs[-5:],len(xs))
