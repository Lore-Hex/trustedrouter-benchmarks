[?2004l[?2004h>         OPTIONAL { ?student uni:hasGraduationDate ?graduationDate . }
[?2004l[?2004h>         FILTER(!BOUND(?graduationDate) || ?graduationDate >= "2025-08-16"^^xsd:date)
[?2004l[?2004h>       }
[?2004l[?2004h>       GROUP BY ?professor ?dept
[?2004l[?2004h>       HAVING (COUNT(DISTINCT ?student) > 10)
[?2004l[?2004h>     }
[?2004l[?2004h>   }
[?2004l[?2004h> }
