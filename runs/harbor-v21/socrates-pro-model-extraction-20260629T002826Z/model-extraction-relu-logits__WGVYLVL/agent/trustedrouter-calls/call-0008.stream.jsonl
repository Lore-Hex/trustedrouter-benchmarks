t few\\n    relative_error = np.linalg.norm(extracted_rows[i] - A2[0,i] * A1[i]) / np.linalg.norm(A2[0,i] * A1[i])\\n    max_error = max(max_error, relative_error)\\n    print(f'Neuron {i}: error = {relative_error:.8f}')\\nprint(f'Max error (first 3): {max_error:.8f}')\\n\\\"\\n\",\n      \"duration\": 10.0\n    }\n  ]\n}"}, "event": "worker.done", "index": 0, "model": "cerebras/zai-glm-4.7", "stage": "worker"}}}
