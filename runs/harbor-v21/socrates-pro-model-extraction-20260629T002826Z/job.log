Sending keys: ['python3 -c "\nimport sys\nsys.path.insert(0, \'/app\')\nfrom forward import A1, b1, A2\nimport numpy as np\n\n# For each neuron, try to find an input that only activates that neuron\n# Input should satisfy: A1[i] @ x + b1[i] > 0 and A1[j] @ x + b1[j] < 0 for all j != i\n\ndef find_single_neuron_input(neuron_idx, attempts=1000):\n    for _ in range(attempts):\n        # Start with a direction that activates the target neuron\n        direction = A1[neuron_idx]  # x along this row should activate it\n        # Add random noise to potentially suppress others\n        x = direction + np.random.randn(10) * 0.5\n        # Scale appropriately\n        x = x * 5.0\n        h = np.dot(A1, x) + b1\n        active = np.where(h > 0)[0]\n        if len(active) == 1 and active[0] == neuron_idx:\n            return x\n    return None\n\nsingle_inputs = {}\nfor i in range(20):\n    x = find_single_neuron_input(i, attempts=10000)\n    if x is not None:\n        single_inputs[i] = x\n        print(f\'Neuron {i}: found single-activation input\')\n    else:\n        print(f\'Neuron {i}: no single activation found\')\n\nprint(f\'\\nFound single activations for {len(single_inputs)} out of 20 neurons\')\n"\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
