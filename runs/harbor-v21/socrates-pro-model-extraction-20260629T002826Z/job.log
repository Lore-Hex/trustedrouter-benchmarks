Sending keys: ['cat > /app/steal.py << \'EOF\'\nimport numpy as np\nimport sys\n\n# Import the forward function\nsys.path.insert(0, \'/app\')\nfrom forward import forward\n\ndef numerical_gradient(f, x, eps=1e-5):\n    """Compute numerical gradient of f at point x"""\n    grad = np.zeros_like(x, dtype=float)\n    fx = f(x)\n    for i in range(len(x)):\n        dx = np.zeros_like(x, dtype=float)\n        dx[i] = eps\n        grad[i] = (f(x + dx) - fx) / eps\n    return grad\n\ndef extract_a1():\n    np.random.seed(42)\n    \n    # Sample many random points and compute gradients\n    n_samples = 2000\n    points = []\n    gradients = []\n    \n    print("Sampling gradients...")\n    for i in range(n_samples):\n        x = np.random.randn(10) * 5.0\n        g = numerical_gradient(forward, x)\n        points.append(x)\n        gradients.append(g)\n    \n    points = np.array(points)\n    gradients = np.array(gradients)\n    \n    # Find pairs where the gradient changes significantly\n    # These indicate a boundary crossing\n    print("Finding boundary crossings...")\n    extracted_rows = []\n    \n    # Check all pairs (or a subset for efficiency)\n    for i in range(len(gradients)):\n        for j in range(i+1, len(gradients)):\n            diff = gradients[i] - gradients[j]\n            norm_diff = np.linalg.norm(diff)\n            norm_gi = np.linalg.norm(gradients[i])\n            norm_gj = np.linalg.norm(gradients[j])\n            \n            if norm_diff > 0.01:  # Significant difference\n                # Normalize the difference\n                diff_normalized = diff / norm_diff\n                \n                # Check if this is a new direction (not already extracted)\n                is_new = True\n                for row in extracted_rows:\n                    row_norm = np.linalg.norm(row)\n                    if row_norm > 0:\n                        cos_sim = abs(np.dot(diff_normalized, row / row_norm))\n                        if cos_sim > 0.99:\n                            is_new = False\n                            break\n                \n                if is_new:\n                    extracted_rows.append(diff)\n                    print(f"Found new direction: {len(extracted_rows)} extracted, norm_diff = {norm_diff:.4f}")\n                    \n                    if len(extracted_rows) >= 20:\n                        break\n        if len(extracted_rows) >= 20:\n            break\n    \n    print(f"\\nExtracted {len(extracted_rows)} rows")\n    \n    # Stack into matrix\n    A1_extracted = np.array(extracted_rows[:20])\n    return A1_extracted\n\nif __name__ == "__main__":\n    A1_extracted = extract_a1()\n    print(f"Extracted A1 shape: {A1_extracted.shape}")\n    np.save("/app/stolen_A1.npy", A1_extracted)\n    print("Saved to /app/stolen_A1.npy")\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
