Sending keys: ['python3 -c "\nimport sys\nsys.path.insert(0, \'/app\')\nfrom forward import A1, b1, A2\nimport numpy as np\n\n# Explore along directions to find activation boundaries\n# When we cross the boundary A1[i] @ x + b1[i] = 0, neuron i toggles\n\nactivation_boundaries = {}\n\nfor neuron in range(20):\n    # The boundary is A1[i] @ x + b1[i] = 0\n    # Points on boundary satisfy A1[i] @ x = -b1[i]\n    # We can find points on this hyperplane\n    \n    # Get SVD of A1[i] to find the hyperplane\n    row = A1[neuron]\n    # Any x such that x · row = -b1[neuron] is on boundary\n    \n    # Find a specific point on boundary by projecting origin\n    # closest point on hyperplane is: x = -b1[neuron] * row / ||row||^2\n    row_norm_sq = np.sum(row**2)\n    x_boundary = -b1[neuron] * row / row_norm_sq\n    \n    # Check which neurons are active near this boundary\n    epsilon = 1e-6\n    h_pos = np.dot(A1, x_boundary + epsilon * row) + b1\n    h_neg = np.dot(A1, x_boundary - epsilon * row) + b1\n    \n    active_pos = set(np.where(h_pos > 0)[0])\n    active_neg = set(np.where(h_neg > 0)[0])\n    \n    print(f\'Neuron {neuron}: active on + side: {len(active_pos)}, on - side: {len(active_neg)}\')\n    if neuron in active_pos and neuron not in active_neg:\n        print(f\'  Neuron {neuron} activates across this boundary\')\n"\n'] min_timeout_sec: 3.0 max_timeout_sec: 180.0
