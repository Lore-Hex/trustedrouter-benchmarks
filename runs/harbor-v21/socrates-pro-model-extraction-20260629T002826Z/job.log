Sending keys: ['python3 -c "\nimport numpy as np\nfrom forward import forward, A1, b1, A2\n\ndef numerical_gradient(f, x, eps=1e-5):\n    grad = np.zeros_like(x, dtype=float)\n    fx = f(x)\n    for i in range(len(x)):\n        dx = np.zeros_like(x, dtype=float)\n        dx[i] = eps\n        grad[i] = (f(x + dx) - fx) / eps\n    return grad\n\nnp.random.seed(42)\n\n# Start from origin and move along directions\nn_directions = 50\nstep_size = 0.5\nmax_steps = 50\n\nextracted_differences = []\n\nfor d_idx in range(n_directions):\n    direction = np.random.randn(10)\n    direction = direction / np.linalg.norm(direction)\n    \n    # Start from origin\n    x = np.zeros(10)\n    g_prev = numerical_gradient(forward, x)\n    \n    for step in range(max_steps):\n        x_new = x + direction * step_size\n        g_new = numerical_gradient(forward, x_new)\n        \n        # Check for significant gradient change\n        diff = g_new - g_prev\n        norm_diff = np.linalg.norm(diff)\n        \n        if norm_diff > 0.01:  # Boundary crossing detected\n            # Normalize and check if new\n            if norm_diff > 1e-10:\n                diff_norm = diff / norm_diff\n                is_new = True\n                for d in extracted_differences:\n                    if np.abs(np.dot(diff_norm, d / np.linalg.norm(d))) > 0.999:\n                        is_new = False\n                        break\n                if is_new:\n                    extracted_differences.append(diff)\n                    print(f\'Direction {d_idx}, step {step}: found new diff, total {len(extracted_differences)}\')\n                    if len(extracted_differences) >= 20:\n                        break\n            g_prev = g_new\n        x = x_new\n    \n    if len(extracted_differences) >= 20:\n        break\n\nprint(f\'Extracted {len(extracted_differences)} differences\')\n\n# Verify against true A1\nA1_extracted = np.array(extracted_differences[:20] if len(extracted_differences) >= 20 el