[?2004l[?2004h>     if total_frames == 0:
[?2004l[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute frame-to-frame motion features
[?2004l[?2004h>     prev_gray = None
[?2004l[?2004h>     bottom_ys = []
[?2004l[?2004h>     areas = []
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(total_frames):
[?2004l[?2004h>         gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>         gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>         
[?2004l[?2004h>         if prev_gray is not None:
[?2004l[?2004h>             diff = cv2.absdiff(gray, prev_gray)
[?2004l[?2004h>             _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>             
[?2004l[?2004h>             kernel = np.ones((3, 3), np.uint8)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>             motion[:200, :] = 0
[?2004l[?2004h>             
[?2004l[?2004h>             y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>             
[?2004l[?2004h>             if len(y_indices) > 50:
[?2004l[?2004h>                 bottom_y = float(np.max(y_indices))
[?2004l[?2004h>                 area = float(len(y_indices))
[?2004l[?2004h>             else:
[?2004l[?2004h>                 bottom_y = 0.0
[?2004l[?2004h>                 area = 0.0
[?2004l[?2004h>             
[?2004l[?2004h>             bottom_ys.append(bottom_y)
[?2004l[?2004h>             areas.append(area)
[?2004l[?2004h>         else:
[?2004l[?2004h>             bottom_ys.append(0.0)
[?2004l[?2004h>             areas.append(0.0)
[?2004l[?2004h>         
[?2004l[?2004h>         prev_gray = gray
[?2004l[?2004h>     
[?2004l[?2004h>     
[?2004l[?2004h>     bottom_ys = np.array(bottom_ys, dtype=float)
[?2004l[?2004h>     areas = np.array(areas, dtype=float)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find active frames (significant motion)
[?2004l[?2004h>     active_mask = areas > 500
[?2004l[?2004h>     active_indices = np.where(active_mask)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     if len(active_indices) < 10:
[?2004l[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Determine ground level from the first few active frames
[?2004l[?2004h>     if len(active_indices) > 3:
[?2004l[?2004h>         early_bottoms = bottom_ys[active_indices[:min(10, len(active_indices))]]
[?2004l[?2004h>         ground_level = np.median(early_bottoms)
[?2004l[?2004h>     else:
[?2004l[?2004h>         ground_level = 340.0
[?2004l[?2004h>     
[?2004l[?2004h>     # Allow a margin below ground level (the athlete's feet can be slightly below ground perspective)
[?2004l[?2004h>     ground_threshold = ground_level - 5  # tolerance
[?2004let return to ground level
    landing_frame = None
    
    for i in range(min_frame + 1, min(len(bottom_ys), min_frame + 25)):
        if i < len(bottom_ys) and bottom_ys[i] >= ground_threshold and areas[i] > 500:
            landing_frame = i
            break
    
    # If not found by ground level, find by positive velocity (feet going down)
    if landing_frame is None:
        for i in range(min_frame, min(len(bottom_ys) - 1, min_frame + 20)):
            if areas[i] > 500 and areas[i+1] > 500:
                if bottom_ys[i+1] > bottom_ys[i]:
                    if i+2 < len(bottom_ys) and bottom_ys[i+2] > bottom_ys[i+1]:
                        landing_frame = i + 1
                        break
    
    # Fallback
    if takeoff_frame is None:
        before_peak = active_indices[active_indices < min_frame]
        if len(before_peak) > 3:
            takeoff_frame = before_peak[-3]
        else:
            takeoff_frame = max(1, min_frame - 5)
    
    if landing_frame is None:
        after_peak = active_indices[active_indices > min_frame]
        if len(after_peak) > 3:
            landing_frame = after_peak[3]
        else:
            landing_frame = min(min_frame + 5, len(bottom_ys) - 1)
    
    # Ensure takeoff < landing
    if takeoff_frame >= landing_frame:
        landing_frame = takeoff_frame + 1
        if landing_frame >= len(bottom_ys):
            landing_frame = len(bottom_ys) - 1
    
    return int(takeoff_frame), int(landing_frame)


def main():
    if len(sys.argv) < 2:
        print("Usage: python jump_analyzer.py <video_path>")
        sys.exit(1)
    
    video_path = sys.argv[1]
    takeoff, landing = analyze_jump(video_path)
    
    if takeoff is None or landing is None:
        print("Could not detect jump frames", file=sys.stderr)
        output = {
            'jump_takeoff_frame_number': 0,
            'jump_land_frame_number': 0
        }
    else:
        output = {
            'jump_takeoff_frame_number': takeoff,
            'jump_land_frame_number': landing
        }
    
    output_path = '/app/output.toml'
    with open(output_path, 'w') as f:
        toml.dump(output, f)
    
    print(f"Takeoff frame: {output['jump_takeoff_frame_number']}")
    print(f"Landing frame: {output['jump_land_frame_number']}")
    print(f"Output written to {output_path}")


