[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's try a completely different approach:
[?2004l[?2004h> # Use the color difference between the athlete's dark silhouette and the background
[?2004l[?2004h> # The athlete wears a dark outfit, so they appear darker than the track
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Tracking athlete by looking for dark regions against background ===")
[?2004l[?2004h> print("Frame | blob_bottom_y | blob_centroid_y | blob_centroid_x | blob_area | feet_above_ground")
[?2004l[?2004h> 
[?2004l[?2004h> GROUND_LEVEL = 520
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Instead of absolute difference, look for regions where the current frame
[?2004l[?2004h>     # is SIGNIFICANTLY DARKER than the background (athlete silhouette)
[?2004l[?2004h>     # The athlete is darker, so bg_gray - gray > threshold
[?2004l[?2004h>     darker_mask = cv2.subtract(bg_gray, gray)
[?2004l[?2004h>     _, thresh = cv2.threshold(darker_mask, 30, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Also look for regions that are SIGNIFICANTLY LIGHTER (maybe the athlete's clothes)
[?2004l[?2004h>     lighter_mask = cv2.subtract(gray, bg_gray)
[?2004l[?2004h>     _, lighter_thresh = cv2.threshold(lighter_mask, 30, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Combine
[?2004l[?2004h>     combined = cv2.bitwise_or(thresh, lighter_thresh)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     combined = cv2.morphologyEx(combined, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     combined = cv2.morphologyEx(combined, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(combined > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         weights = combined[y_indices, x_indices]
[?2004l[?2004h>         centroid_y = np.average(y_indices, weights=weights)
[?2004l[?2004h>         centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>         area = len(y_indices)
[?2004l[?2004h>         feet_above = GROUND_LEVEL - bottom_y
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 5 == 0 or (i >= 80 and i <= 119):
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:13d} | {centroid_y:15.1f} | {centroid_x:15.1f} | {area:8d} | {feet_above:16d}")
[?2004l[?2004h>     else:
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>13} | {'':>15} | {'':>15} | {'':>8} | {'':>16}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> EOF
