[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if prev_gray is not None:
[?2004l[?2004h>         diff = cv2.absdiff(gray, prev_gray)
[?2004l[?2004h>         _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)  # Lower threshold
[?2004l[?2004h>         
[?2004l[?2004h>         # Only look at lower portion (y > 200)
[?2004l[?2004h>         motion[:200, :] = 0
[?2004l[?2004h>         
[?2004l[?2004h>         # Clean
[?2004l[?2004h>         kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>         motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>         motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>         
[?2004l[?2004h>         y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>         
[?2004l[?2004h>         if len(y_indices) > 100:  # Filter noise
[?2004l[?2004h>             bottom_y = np.max(y_indices)
[?2004l[?2004h>             top_y = np.min(y_indices)
[?2004l[?2004h>             centroid_y = np.mean(y_indices)
[?2004l[?2004h>             centroid_x = np.mean(x_indices)
[?2004l[?2004h>             area = len(y_indices)
[?2004l[?2004h>             
[?2004l[?2004h>             if i % 5 == 0 or (i >= 50 and i <= 75):
[?2004l[?2004h>                 print(f"{i:3d}   | {bottom_y:5d} | {top_y:4d}  | {centroid_y:7.1f} | {area:5d}")
