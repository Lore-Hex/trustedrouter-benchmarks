[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the image content more holistically
[?2004l[?2004h> # by computing the frame-to-frame difference and tracking the largest blob
[?2004l[?2004h> 
[?2004l[?2004h> # First, let's understand the camera view:
[?2004l[?2004h> # - Background: track with a hurdle somewhere
[?2004l[?2004h> # - Athlete runs from one side, jumps over hurdle, continues
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the difference between consecutive frames to track motion
[?2004l[?2004h> 
[?2004l[?2004h> prev_gray = None
[?2004l[?2004h> print("Frame-to-frame analysis:")
[?2004l[?2004h> print("Frame | motion_centroid_x | motion_centroid_y | bottom_of_motion | top_of_motion | area")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if prev_gray is not None:
[?2004l[?2004h>         diff = cv2.absdiff(gray, prev_gray)
[?2004l[?2004h>         _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>         
[?2004l[?2004h>         # Clean
[?2004l[?2004h>         kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>         motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>         motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>         
[?2004l[?2004h>         y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>         
[?2004l[?2004h>         if len(y_indices) > 0:
[?2004l[?2004h>             weights = motion[y_indices, x_indices]
[?2004l[?2004h>             centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>             centroid_y = np.average(y_indices, weights=weights)
[?2004l[?2004h>             bottom_y = np.max(y_indices)
[?2004l[?2004h>             top_y = np.min(y_indices)
[?2004l[?2004h>             area = len(y_indices)
[?2004l[?2004h>         else:
[?2004l[?2004h>             centroid_x = 0
[?2004l[?2004h>             centroid_y = 0
[?2004l[?2004h>             bottom_y = 0
[?2004l[?2004h>             top_y = 0
[?2004l[?2004h>             area = 0
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 10 == 0 or i == 119:
[?2004l[?2004h>             print(f"{i:3d}   | {centroid_x:16.1f} | {centroid_y:16.1f} | {bottom_y:14d} | {top_y:12d} | {area:6d}")
[?2004l[?2004h>     
[?2004l[?2004h>     prev_gray = gray
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> EOF
