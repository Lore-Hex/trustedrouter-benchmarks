[?2004l[?2004h> 
[?2004l[?2004h> # Let's use frame-to-frame difference to track motion
[?2004l[?2004h> prev_gray = None
[?2004l[?2004h> print("\n=== Frame-to-frame motion tracking (y=200-520) ===")
[?2004l[?2004h> print("Frame | bottom_y | top_y | centroid_y | area")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
