[?2004l[?2004h>         if len(before_peak) > 5:
[?2004l[?2004h>             takeoff_frame = before_peak[5]  # skip first few frames
[?2004l[?2004h>     
[?2004l[?2004h>     # Landing: find the first frame after the peak where feet return to ground
[?2004l[?2004h>     landing_frame = None
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(min_frame + 1, min(len(bottom_ys), min_frame + 25)):
[?2004l[?2004h>         if i < len(bottom_ys) and bottom_ys[i] >= ground_level and areas[i] > 500:
[?2004l[?2004h>             landing_frame = i
[?2004l[?2004h>             break
[?2004l[?2004h>     
[?2004l[?2004h>     # If not found by ground level, find by positive velocity (feet going down)
[?2004l[?2004h>     if landing_frame is None:
[?2004l[?2004h>         for i in range(min_frame, min(len(bottom_ys) - 1, min_frame + 20)):
[?2004l[?2004h>             if areas[i] > 500 and areas[i+1] > 500:
[?2004l[?2004h>                 if bottom_ys[i+1] > bottom_ys[i]:
[?2004l[?2004h>                     if i+2 < len(bottom_ys) and bottom_ys[i+2] > bottom_ys[i+1]:
[?2004l[?2004h>                         landing_frame = i + 1
[?2004l[?2004h>                         break
[?2004l[?2004h>     
[?2004l[?2004h>     # Fallback
[?2004l[?2004h>     if takeoff_frame is None:
[?2004l[?2004h>         before_peak = active_indices[active_indices < min_frame]
[?2004l[?2004h>         if len(before_peak) > 3:
[?2004l[?2004h>             takeoff_frame = before_peak[-3]  # 3 frames before peak
