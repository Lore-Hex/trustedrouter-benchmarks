[?2004l[?2004h> def analyze_jump(video_path):
[?2004l[?2004h>     """
[?2004l[?2004h>     Analyze a hurdle jump video and detect takeoff and landing frames.
[?2004l[?2004h>     """
[?2004lone:
[?2004h>     cap = cv2.VideoCapture(video_path)
[?2004l[?2004h>     
[?2004l[?2004h>     # Read all frames
[?2004l[?2004h>     frames = []
[?2004l[?2004h>     while True:
