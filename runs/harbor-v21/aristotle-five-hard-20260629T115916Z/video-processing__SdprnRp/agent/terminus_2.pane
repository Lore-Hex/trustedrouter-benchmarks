[?2004l[?2004h>         if abs(diff) > 15:
[?2004l[?2004h>             print(f"y={y:3d}: val={val:3d}, change={diff:4d}")
[?2004l[?2004h> 
[?2004l[?2004h> print("\n\n===== Let's look for the hurdle (bright horizontal bar) =====")
[?2004l[?2004h> # The hurdle should be a horizontal line of bright pixels
[?2004l[?2004h> # Let's scan rows from y=200 to y=400 (likely height of hurdle)
[?2004l[?2004h> # and find rows with high average brightness
[?2004l[?2004h> 
[?2004l[?2004h> for y in range(200, 400):
[?2004l[?2004h>     row = gray[y, :]
[?2004l[?2004h>     mean_val = np.mean(row)
[?2004l[?2004h>     std_val = np.std(row)
[?2004l[?2004h>     # High mean and high std might indicate a white bar against darker background
[?2004l[?2004h>     if mean_val > 130 and std_val > 25:
[?2004l[?2004h>         print(f"y={y}: mean={mean_val:.1f}, std={std_val:.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
