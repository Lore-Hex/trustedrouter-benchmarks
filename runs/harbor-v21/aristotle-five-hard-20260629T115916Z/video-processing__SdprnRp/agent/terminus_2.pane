[?2004l[?2004h>             if areas[i] > 500 and areas[i+1] > 500 and bottom_ys[i+1] < bottom_ys[i]:
[?2004l[?2004h>                 if areas[i+2] > 500 and bottom_ys[i+2] < bottom_ys[i+1]:
[?2004l[?2004h>                     takeoff_frame = i + 1
[?2004l[?2004h>                     break
[?2004l[?2004h>     
[?2004l[?2004h>     # If still not found, use the first active frame before the peak
[?2004l[?2004h>     if takeoff_frame is None:
