[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's examine the vertical profile of the difference image
[?2004l[?2004h> # We want to find where the MOVING athlete is
[?2004l[?2004h> # The athlete will create a region of difference
[?2004l[?2004h> # But we need to isolate the athlete from other noise
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at a specific region: the track area (bottom half of frame)
[?2004l[?2004h> # and track how the athlete's silhouette changes
[?2004l[?2004h> 
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's examine specific frames and print the vertical profile
[?2004l[?2004h> # of a narrow horizontal strip (x=400 to 600, which seems to be where the athlete runs)
[?2004l[?2004h> 
[?2004l[?2004h> print("Vertical profile of columns 400-600 (sum per row):")
[?2004l[?2004h> for fn in [0, 30, 50, 60, 65, 70, 75, 80, 90, 100, 110, 119]:
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, fn)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         continue
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     
[?2004l[?2004h>     # Look at a specific x range where the athlete runs
[?2004l[?2004h>     # From earlier data, center_x seems to be around 400-600
[?2004l[?2004h>     x_start, x_end = 300, 700
[?2004l[?2004h>     strip = diff[:, x_start:x_end]
[?2004l[?2004h>     
[?2004l[?2004h>     # Vertical projection (sum across columns for each row)
[?2004l[?2004h>     vert_proj = np.sum(strip, axis=1)
[?2004l[?2004h>     
[?2004l[?2004h>     # Normalize
[?2004l[?2004h>     max_val = np.max(vert_proj) if np.max(vert_proj) > 0 else 1
[?2004l[?2004h>     vert_proj_norm = vert_proj / max_val * 50
[?2004l[?2004h>     
[?2004l[?2004h>     # Print as simple histogram
[?2004l[?2004h>     print(f"\nFrame {fn}:")
[?2004l[?2004h>     for y in range(0, 540, 20):
[?2004l[?2004h>         bar = int(vert_proj_norm[y])
[?2004l[?2004h>         print(f"{y:3d}: {'#' * bar}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> EOF
