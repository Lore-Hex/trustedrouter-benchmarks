[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Save key frames every 5 frames
[?2004l[?2004h> for i in range(0, 120, 5):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, frame = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         cv2.imwrite(f'/app/full_{i:03d}.jpg', frame)
[?2004l[?2004h>         
[?2004l[?2004h>         # Also compute a better difference
[?2004l[?2004h>         if i == 0:
[?2004l[?2004h>             bg = frame.copy()
[?2004l[?2004h>         else:
[?2004l[?2004h>             diff = cv2.absdiff(bg, frame)
[?2004l[?2004h>             gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>             # Apply some blur to reduce noise
[?2004l[?2004h>             blurred = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>             _, thresh = cv2.threshold(blurred, 20, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>             
[?2004l[?2004h>             # Morphological operations to connect parts
[?2004l[?2004h>             kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>             thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>             thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>             
[?2004l[?2004h>             # Find contours
[?2004l[?2004h>             contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>             
[?2004l[?2004h>             # Get all contours' bounding boxes combined
[?2004l[?2004h>             if contours:
[?2004l[?2004h>                 all_x, all_y, all_w, all_h = [], [], [], []
[?2004l[?2004h>                 for cnt in contours:
[?2004l[?2004h>                     area = cv2.contourArea(cnt)
[?2004l[?2004h>                     if area > 500:  # Filter small noise
[?2004l[?2004h>                         x, y, w, h = cv2.boundingRect(cnt)
[?2004l[?2004h>                         all_x.append(x)
[?2004l[?2004h>                         all_y.append(y)
[?2004l[?2004h>                         all_w.append(x+w)
[?2004l[?2004h>                         all_h.append(y+h)
[?2004l[?2004h>                 
[?2004l[?2004h>                 if all_x:
[?2004l[?2004h>                     min_x = min(all_x)
[?2004l[?2004h>                     min_y = min(all_y)
[?2004l[?2004h>                     max_x = max(all_w)
[?2004l[?2004h>                     max_y = max(all_h)
[?2004l[?2004h>                     print(f"Frame {i:3d}: bbox=({min_x},{min_y},{max_x-min_x},{max_y-min_y}), bottom={max_y}, height={max_y-min_y}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> print("\nDone saving frames")
