[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at specific frames to understand the scene better
[?2004l[?2004h> # Check frame 50 (approaching hurdle), 60 (maybe jumping), 70 (in air), 80 (landing)
[?2004l[?2004h> for i in [50, 55, 60, 65, 70, 75, 80, 85, 90]:
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, frame = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         # Save for inspection
[?2004l[?2004h>         cv2.imwrite(f'/app/debug_{i}.jpg', frame)
[?2004l[?2004h>         
[?2004l[?2004h>         diff = cv2.absdiff(bg, frame)
[?2004l[?2004h>         gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>         _, thresh = cv2.threshold(gray, 30, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>         
[?2004l[?2004h>         # Find contours to get bounding box of motion
