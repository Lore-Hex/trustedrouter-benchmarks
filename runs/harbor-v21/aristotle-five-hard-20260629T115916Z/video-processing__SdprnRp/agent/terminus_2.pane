[?2004l[?2004h> # Let's find the ground level by looking at the track surface
[?2004l[?2004h> # The track should be a relatively uniform, flat surface
[?2004l[?2004h> # We can estimate the ground level by looking at where the track starts
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at vertical profile at different x positions
[?2004l[?2004h> print("Finding ground level at different x positions:")
[?2004l[?2004h> print("x    | ground_y")
[?2004l[?2004h> 
[?2004l[?2004h> for x in range(0, 960, 50):
[?2004l[?2004h>     # Look down the column to find where the bright sky ends and darker track begins
[?2004l[?2004h>     col = bg_gray[:, x]
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the row where intensity drops below some threshold
[?2004l[?2004h>     # Sky is bright (>150), track is darker (~130-140)
[?2004l[?2004h>     # Actually let's look for the first row (from top) where pixel value is stable
[?2004l[?2004h>     
[?2004l[?2004h>     # The ground level is where the gradient is high (transition from sky to track)
[?2004l[?2004h>     # But there might be stadium structures, the hurdle, etc.
[?2004l[?2004h>     
[?2004l[?2004h>     # Let's find the first row from the bottom where the value
[?2004l[?2004h>     # is significantly different from the row above?
[?2004l[?2004h>     
[?2004l[?2004h>     # Actually let's just look at the bottom portion - the track should be
[?2004l[?2004h>     # relatively uniform (low std dev)
[?2004l[?2004h>     for y in range(520, 200, -1):
[?2004l[?2004h>         strip = bg_gray[y-5:y+5, max(0,x-10):min(960,x+10)]
[?2004l[?2004h>         std = np.std(strip)
[?2004l[?2004h>         if std < 5:  # very uniform = track surface
[?2004l[?2004h>             print(f"{x:3d}  | {y}")
[?2004l[?2004h>             break
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
