[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the background image and find:
[?2004l[?2004h> # 1. The track runnway
[?2004l[?2004h> # 2. The hurdle position
[?2004l[?2004h> # 3. The direction the athlete runs
[?2004l[?2004h> 
[?2004l[?2004h> # Let's examine horizontal strips to find the hurdle
[?2004l[?2004h> # Hurdles typically have a white horizontal top bar
[?2004l[?2004h> 
[?2004l[?2004h> # Let's search for white horizontal bars
[?2004l[?2004h> print("Searching for white horizontal structures (hurdle):")
[?2004l[?2004h> gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Look at rows with high average intensity and high contrast
[?2004l[?2004h> for y in range(100, 500):
[?2004l[?2004h>     row = gray[y, :]
[?2004l[?2004h>     mean_val = np.mean(row)
