[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's try frame-to-frame difference
[?2004l[?2004h> frames = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     frames.append(gray)
[?2004l[?2004h> 
[?2004l[?2004h> print("Analyzing frame-to-frame differences...")
[?2004l[?2004h> print("\nFrame | diff_sum | bottom_motion_y | top_motion_y")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(1, 120):
[?2004l[?2004h>     # Difference between consecutive frames
[?2004l[?2004h>     diff = cv2.absdiff(frames[i], frames[i-1])
[?2004l[?2004h>     
[?2004l[?2004h>     # Apply blur
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Threshold
[?2004l[?2004h>     _, thresh = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Morphology
[?2004l[?2004h>     kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>     thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Get vertical projection (only for the bottom half of frame, y > 100)
[?2004l[?2004h>     # to avoid sky noise
[?2004l[?2004h>     lower_half = thresh[100:, :]
[?2004l[?2004h>     vert_proj = np.sum(lower_half, axis=1) / 255.0
[?2004l[?2004h>     
[?2004l[?2004h>     # Find rows with motion
[?2004l[?2004h>     motion_rows = np.where(vert_proj > 5)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     diff_sum = np.sum(vert_proj)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(motion_rows) > 0:
[?2004l[?2004h>         bottom_y = np.max(motion_rows) + 100  # add back the offset
[?2004l[?2004h>         top_y = np.min(motion_rows) + 100
[?2004l[?2004h>     else:
[?2004l[?2004h>         bottom_y = 0
[?2004l[?2004h>         top_y = 0
[?2004l[?2004h>     
[?2004l[?2004h>     if i % 5 == 0 or i < 5:
[?2004l[?2004h>         print(f"{i:3d}    | {diff_sum:7.0f}  | {bottom_y:4d}         | {top_y:4d}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> EOF
