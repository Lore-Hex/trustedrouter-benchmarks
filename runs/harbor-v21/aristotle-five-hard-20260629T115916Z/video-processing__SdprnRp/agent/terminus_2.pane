[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # The ground level (track surface) seems to be around y=520
[?2004l[?2004h> # Let's compute the distance from the bottom of motion to the ground
[?2004l[?2004h> 
[?2004l[?2004h> print("Frame | bottom_y | ground_dist | centroid_y | area | motion_type")
[?2004l[?2004h> 
[?2004l[?2004h> prev_bottom = 0
[?2004l[?2004h> prev_dist = 0
[?2004l[?2004h> takeoff_frame = None
[?2004l[?2004h> land_frame = None
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         weights = motion[y_indices, x_indices]
[?2004l[?2004h>         centroid_y = np.average(y_indices, weights=weights)
[?2004l[?2004h>         centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>         area = len(y_indices)
[?2004l[?2004h>         
[?2004l[?2004h>         # Distance from bottom of motion to ground level
[?2004l[?2004h>         ground_dist = 520 - bottom_y  # positive means feet are above ground
[?2004l[?2004h>         
[?2004l[?2004h>         # Determine motion type based on changes
[?2004l[?2004h>         if prev_bottom > 0:
[?2004l[?2004h>             if bottom_y < prev_bottom - 20 and ground_dist > 20:
[?2004l[?2004h>                 motion_type = "TAKEOFF"
[?2004l[?2004h>             elif bottom_y > prev_bottom + 20 and prev_dist > 20:
[?2004l[?2004h>                 motion_type = "LANDING"
[?2004l[?2004h>             elif area > 50000:
[?2004l[?2004h>                 motion_type = "AIRBORNE"
[?2004l[?2004h>             else:
[?2004l[?2004h>                 motion_type = "RUNNING"
[?2004l[?2004h>         else:
[?2004l[?2004h>             motion_type = "START"
[?2004l[?2004h>         
[?2004l[?2004h>         print(f"{i:3d}   | {bottom_y:5d}    | {ground_dist:5d}     | {centroid_y:8.1f} | {area:6d} | {motion_type:>10}")
[?2004l[?2004h>         
[?2004l[?2004h>         prev_bottom = bottom_y
[?2004l[?2004h>         prev_dist = ground_dist
[?2004l[?2004h>     else:
[?2004l[?2004h>         print(f"{i:3d}   | {'':>5}    | {'':>5}     | {'':>8} | {'':>6} | {'':>10}")
[?2004l[?2004h>         prev_bottom = 0
[?2004l[?2004h>         prev_dist = 0
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
