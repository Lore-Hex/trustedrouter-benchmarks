[?2004l[?2004h>             takeoff_frame = max(1, min_frame - 5)
[?2004l[?2004h>     
[?2004l[?2004h>     if landing_frame is None:
[?2004l[?2004h>         after_peak = active_indices[active_indices > min_frame]
[?2004l[?2004h>         if len(after_peak) > 3:
[?2004l[?2004h>             landing_frame = after_peak[3]  # 3 frames after peak
[?2004l[?2004h>         else:
[?2004l[?2004h>             landing_frame = min(min_frame + 5, len(bottom_ys) - 1)
[?2004l[?2004h>     
[?2004l[?2004h>     # Ensure takeoff < landing
[?2004l[?2004h>     if takeoff_frame >= landing_frame:
