[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the hurdle in the background image
[?2004l[?2004h> # Hurdles are typically white/red structures with horizontal bars
[?2004l[?2004h> 
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Look for vertical/horizontal edges that might indicate the hurdle
[?2004l[?2004h> # The hurdle should be a relatively bright structure against the darker background
[?2004l[?2004h> 
[?2004l[?2004h> # Let's use edge detection
[?2004l[?2004h> edges = cv2.Canny(gray, 50, 150)
[?2004l[?2004h> 
[?2004l[?2004h> # Look for horizontal lines (the top bar of the hurdle)
[?2004l[?2004h> # The hurdle's top bar should be a horizontal white line
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check the vertical profile to find the horizon/ground level
[?2004l[?2004h> print("Vertical profile at center column (x=480):")
[?2004l[?2004h> for y in range(0, 540, 2):
[?2004l[?2004h>     val = gray[y, 480]
[?2004l[?2004h>     # Print where there are significant changes
[?2004l[?2004h>     if y > 0:
