[?2004l[?2004h>         
[?2004l[?2004h>         print(f"{i:3d}   | {bottom_y:14d} | {centroid_y:16.1f} | {centroid_x:16.1f} | {area:9d} | {str(jumping):>10}")
[?2004l[?2004h>         
