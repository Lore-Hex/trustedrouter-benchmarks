[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's analyze the diff at specific x-range to find the athlete
[?2004l[?2004h> # The athlete should be in the middle of the frame (x=200-800)
[?2004l[?2004h> # and at y=300-520 (track area)
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Tracking athlete in track region (y=300-520, x=200-800) ===")
[?2004l[?2004h> print("Frame | bottom_y | top_y | centroid_y | area | note")
[?2004l[?2004h> 
[?2004l[?2004h> prev_bottom = 0
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Threshold
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 20, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract the track region
[?2004l[?2004h>     track_region = motion[300:520, 200:800]
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(track_region > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices) + 300  # add back y offset
[?2004l[?2004h>         top_y = np.min(y_indices) + 300
[?2004l[?2004h>         centroid_y = np.mean(y_indices) + 300
[?2004l[?2004h>         centroid_x = np.mean(x_indices) + 200
[?2004l[?2004h>         area = len(y_indices)
[?2004l[?2004h>         
[?2004l[?2004h>         # Detect takeoff: when the athlete's feet (bottom_y) rise significantly
[?2004l[?2004h>         # Feet rising = bottom_y decreasing (moving up in frame)
[?2004l[?2004h>         note = ""
[?2004l[?2004h>         if prev_bottom > 0:
[?2004l[?2004h>             if bottom_y < prev_bottom - 40:
[?2004l[?2004h>                 note = "TAKEOFF?"
[?2004l[?2004h>             elif bottom_y > prev_bottom + 40 and abs(prev_bottom - 520) < 30:
[?2004l[?2004h>                 note = "LANDING?"
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 5 == 0 or area > 5000:
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:5d} | {top_y:4d}  | {centroid_y:7.1f} | {area:5d} | {note}")
[?2004l[?2004h>         
[?2004l[?2004h>         prev_bottom = bottom_y
[?2004l[?2004h>     else:
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>5} | {'':>4}  | {'':>7} | {'':>5} |")
[?2004l[?2004h>         prev_bottom = 0
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
