[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> # Read background
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at specific rows to understand the scene
[?2004l[?2004h> print("Background analysis - examining different regions:")
[?2004l[?2004h> print("\nRow 260-280 (middle of frame):")
[?2004l[?2004h> for y in range(260, 280):
[?2004l[?2004h>     row = bg[y, :, :]
[?2004l[?2004h>     # Check for non-uniformities that might indicate the hurdle
[?2004l[?2004h>     mean_b, mean_g, mean_r = np.mean(row, axis=0)
[?2004l[?2004h>     std_b, std_g, std_r = np.std(row, axis=0)
[?2004l[?2004h>     print(f"  y={y}: mean=({mean_b:.0f},{mean_g:.0f},{mean_r:.0f}), std=({std_b:.0f},{std_g:.0f},{std_r:.0f})")
[?2004l[?2004h> 
[?2004l[?2004h> print("\nRow 400-420 (track area):")
[?2004l[?2004h> for y in range(400, 420):
[?2004l[?2004h>     row = bg[y, :, :]
[?2004l[?2004h>     mean_b, mean_g, mean_r = np.mean(row, axis=0)
[?2004l[?2004h>     std_b, std_g, std_r = np.std(row, axis=0)
[?2004l[?2004h>     print(f"  y={y}: mean=({mean_b:.0f},{mean_g:.0f},{mean_r:.0f}), std=({std_b:.0f},{std_g:.0f},{std_r:.0f})")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's also look for white structure (hurdle is usually white)
[?2004l[?2004h> # Check horizontal lines of white pixels
[?2004l[?2004h> print("\nSearching for white structure (hurdle):")
[?2004l[?2004h> gray_bg = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> # Look for rows with high average intensity (white hurdle)
[?2004l[?2004h> for y in range(0, bg.shape[0]):
[?2004l[?2004h>     row_mean = np.mean(gray_bg[y, :])
[?2004l[?2004h>     if row_mean > 150:  # Bright row (white hurdle)
[?2004l[?2004h>         std = np.std(gray_bg[y, :])
[?2004l[?2004h>         print(f"  y={y}: mean_brightness={row_mean:.0f}, std={std:.0f}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
