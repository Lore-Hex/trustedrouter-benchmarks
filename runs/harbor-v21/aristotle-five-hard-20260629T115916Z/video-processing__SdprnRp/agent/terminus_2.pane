[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Focus on the track region
[?2004l[?2004h>     track_region = gray[TRACK_TOP:TRACK_BOTTOM, :]
[?2004l[?2004h>     bg_track = bg_gray[TRACK_TOP:TRACK_BOTTOM, :]
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(track_region, bg_track)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 20, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find motion
[?2004l[?2004h>     y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         # Convert y back to original frame coordinates
[?2004l[?2004h>         bottom_y = np.max(y_indices) + TRACK_TOP
[?2004l[?2004h>         top_y = np.min(y_indices) + TRACK_TOP
[?2004l[?2004h>         weights = motion[y_indices, x_indices]
[?2004l[?2004h>         centroid_y = np.average(y_indices, weights=weights) + TRACK_TOP
[?2004l[?2004h>         centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>         area = len(y_indices)
