[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the background image to find the ground level
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # The track should be a relatively uniform surface. Let's analyze horizontal strips
[?2004l[?2004h> # to find where the ground/track is.
[?2004l[?2004h> 
[?2004l[?2004h> print("Analyzing background to find ground level:")
[?2004l[?2004h> print("\nRow | Mean | Std | Description")
[?2004l[?2004h> for y in range(0, 540, 20):
[?2004l[?2004h>     row = bg_gray[y, :]
[?2004l[?2004h>     mean_val = np.mean(row)
[?2004l[?2004h>     std_val = np.std(row)
[?2004l[?2004h>     print(f"{y:3d} | {mean_val:5.1f} | {std_val:5.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's also save the background image with some overlays
[?2004l[?2004h> # Look for the horizon or ground line
[?2004l[?2004h> # The ground/track should be where the brighter sky meets the darker track
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check the middle column (x=480) for a vertical profile
[?2004l[?2004h> print("\n\nVertical profile at x=480 (center of frame):")
[?2004l[?2004h> for y in range(0, 540, 5):
[?2004l[?2004h>     pixel = bg_gray[y, 480]
[?2004l[?2004h>     print(f"y={y:3d}: {pixel:3d}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
