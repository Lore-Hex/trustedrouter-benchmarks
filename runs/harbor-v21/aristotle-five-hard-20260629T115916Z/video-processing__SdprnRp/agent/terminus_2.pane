[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # For each frame, compute difference and find the bottom-most point of motion
[?2004l[?2004h> # We'll track the lowest point of the moving object (feet)
[?2004l[?2004h> 
[?2004l[?2004h> results = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, frame = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(bg, frame)
[?2004l[?2004h>     gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Use a threshold to get significant changes
[?2004l[?2004h>     _, thresh = cv2.threshold(gray, 30, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the bottom-most row with significant motion
[?2004l[?2004h>     # Look at vertical projection
[?2004l[?2004h>     vert_proj = np.sum(thresh, axis=1) / 255.0
[?2004l[?2004h>     
[?2004l[?2004h>     # Find rows with at least some motion
[?2004l[?2004h>     # We want the bottom of the athlete, so scan from bottom up
[?2004l[?2004h>     significant_rows = np.where(vert_proj > 10)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     if len(significant_rows) > 0:
[?2004l[?2004h>         bottom_y = np.max(significant_rows)
[?2004l[?2004h>         # Find top of the blob too
[?2004l[?2004h>         top_y = np.min(significant_rows)
[?2004l[?2004h>         total_motion = np.sum(vert_proj)
[?2004l[?2004h>         # Center of mass
[?2004l[?2004h>         weighted_y = np.sum(significant_rows * vert_proj[significant_rows]) / np.sum(vert_proj[significant_rows]) if np.sum(vert_proj[significant_rows]) > 0 ellse 0
[?2004l[?2004h>     else:
[?2004l[?2004h>         bottom_y = 0
[?2004l[?2004h>         top_y = 0
[?2004l[?2004h>         total_motion = 0
[?2004l[?2004h>         weighted_y = 0
[?2004l[?2004h>     
[?2004l[?2004h>     results.append((i, bottom_y, top_y, weighted_y, total_motion))
[?2004l[?2004h>     
[?2004l[?2004h>     if i < 10 or (i % 10 == 0):
[?2004l[?2004h>         print(f"Frame {i:3d}: bottom_y={bottom_y:3d}, top_y={top_y:3d}, center_y={weighted_y:5.1f}, motion={total_motion:6.0f}")
[?2004l[?2004h> 
[?2004l[?2004h> print("\nFull data:")
[?2004l[?2004h> for r in results:
[?2004l[?2004h>     print(f"{r[0]:3d} {r[1]:3d} {r[2]:3d} {r[3]:5.1f} {r[4]:6.0f}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
