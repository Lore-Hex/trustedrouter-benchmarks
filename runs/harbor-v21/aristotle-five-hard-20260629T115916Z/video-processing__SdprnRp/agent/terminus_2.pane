[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's examine a few frames and look at horizontal scanlines to find the athlete
[?2004l[?2004h> # The athlete is a dark silhouette against the track
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Horizontal scanline at y=400 for various frames ===")
[?2004l[?2004h> print("(Looking for dark pixels indicating athlete silhouette)")
[?2004l[?2004h> 
[?2004l[?2004h> for fn in [0, 30, 50, 60, 70, 80, 90, 100, 110, 119]:
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, fn)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         continue
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Look at row 400
[?2004l[?2004h>     row400 = gray[400, :]
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the minimum (darkest) value and its position
[?2004l[?2004h>     min_val = np.min(row400)
[?2004l[?2004h>     min_pos = np.argmin(row400)
[?2004l[?2004h>     mean_val = np.mean(row400)
[?2004l[?2004h>     
[?2004l[?2004h>     # Also look for regions that are significantly darker than the background mean
[?2004l[?2004h>     bg_row = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)[400, :]
[?2004l[?2004h>     bg_mean = np.mean(bg_row)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find pixels that are at least 20 units darker than background
[?2004l[?2004h>     dark_pixels = np.where((bg_row - row400) > 20)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Frame {fn:3d}: row_400 min={min_val} at x={min_pos}, mean={mean_val:.0f}, bg_mean={bg_mean:.0f}, dark_pixels={len(dark_pixels)}")
[?2004l[?2004h>     if len(dark_pixels) > 0:
[?2004l[?2004h>         print(f"         dark region: x={dark_pixels[0]}-{dark_pixels[-1]}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
