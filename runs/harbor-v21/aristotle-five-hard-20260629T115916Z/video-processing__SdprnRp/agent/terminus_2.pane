[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Read all frames
[?2004l[?2004h> frames = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         frames.append(f)
[?2004l[?2004h>     else:
[?2004l[?2004h>         break
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's track the athlete using a different approach:
[?2004l[?2004h> # The athlete is a dark object. Let's look at the bottom of the darkest region
[?2004l[?2004h> # that moves significantly between frames.
[?2004l[?2004h> 
[?2004l[?2004h> # First, get average background (first few frames)
[?2004l[?2004h> bg = np.mean([frames[0], frames[1], frames[2]], axis=0).astype(np.uint8)
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> print("Frame | feet_y | head_y | center_x | motion_area")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Difference from background
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Use adaptive threshold on diff to find motion
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean up
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the largest contour (hopefully the athlete)
[?2004l[?2004h>     contours, _ = cv2.findContours(motion, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>     
[?2004l[?2004h>     if contours:
[?2004l[?2004h>         # Get all contour points
[?2004l[?2004h>         all_pts = []
[?2004l[?2004h>         for c in contours:
[?2004l[?2004h>             area = cv2.contourArea(c)
[?2004l[?2004h>             if area > 200:  # filter small noise
[?2004l[?2004h>                 for pt in c:
[?2004l[?2004h>                     all_pts.append(pt[0])
[?2004l[?2004h>         
[?2004l[?2004h>         if all_pts:
[?2004l[?2004h>             all_pts = np.array(all_pts)
[?2004l[?2004h>             max_y = np.max(all_pts[:, 1])
[?2004l[?2004h>             min_y = np.min(all_pts[:, 1])
[?2004l[?2004h>             center_x = int(np.mean(all_pts[:, 0]))
[?2004l[?2004h>             motion_area = len(all_pts)
[?2004l[?2004h>             print(f"{i:3d}   | {max_y:4d}  | {min_y:4d}  | {center_x:4d}     | {motion_area:6d}")
[?2004l[?2004h>         else:
[?2004l[?2004h>             print(f"{i:3d}   |    0  |    0  |    0     |      0")
[?2004l[?2004h>     else:
[?2004l[?2004h>         print(f"{i:3d}   |    0  |    0  |    0     |      0")
[?2004l[?2004h> EOF
