[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Let's try frame-to-frame difference to reduce noise
[?2004l[?2004h> prev_frame = None
[?2004l[?2004h> results = []
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, frame = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     gray_bg = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Difference from background
[?2004l[?2004h>     diff_bg = cv2.absdiff(gray, gray_bg)
[?2004l[?2004h>     
[?2004l[?2004h>     # Apply Gaussian blur to reduce noise
[?2004l[?2004h>     diff_bg = cv2.GaussianBlur(diff_bg, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Threshold
[?2004l[?2004h>     _, thresh = cv2.threshold(diff_bg, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Morphological operations to clean up
[?2004l[?2004h>     kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>     thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find bottom-most row of the largest connected component
[?2004l[?2004h>     # Find all contours
[?2004l[?2004h>     contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h>     
[?2004l[?2004h>     if contours:
[?2004l[?2004h>         # Find the largest contour by area
[?2004l[?2004h>         largest = max(contours, key=cv2.contourArea)
[?2004l[?2004h>         
[?2004l[?2004h>         # Get bounding rect
[?2004l[?2004h>         x, y, w, h = cv2.boundingRect(largest)
[?2004l[?2004h>         bottom_y = y + h
[?2004l[?2004h>         center_x = x + w // 2
[?2004l[?2004h>         center_y = y + h // 2
[?2004l[?2004h>         area = cv2.contourArea(largest)
[?2004l[?2004h>         
[?2004l[?2004h>         # Also get the bottom-most y of the contour
[?2004l[?2004h>         # Get all points of the contour
[?2004l[?2004h>         pts = largest.squeeze()
[?2004l[?2004h>         if pts.ndim == 2:
[?2004l[?2004h>             max_y = np.max(pts[:, 1])
[?2004l[?2004h>             min_y = np.min(pts[:, 1])
[?2004l[?2004h>         else:
[?2004l[?2004h>             max_y = bottom_y
[?2004l[?2004h>             min_y = y
[?2004l[?2004h>         
[?2004l[?2004h>         results.append((i, bottom_y, max_y, min_y, center_x, center_y, area))
[?2004l[?2004h>     else:
[?2004l[?2004h>         results.append((i, 0, 0, 0, 0, 0, 0))
[?2004l[?2004h>     
[?2004l[?2004h>     prev_frame = frame
[?2004l[?2004h> 
[?2004l[?2004h> print("Frame | bottom_y | max_y | min_y | center_x | center_y | area")
[?2004l[?2004h> for r in results:
[?2004l[?2004h>     print(f"{r[0]:3d}   | {r[1]:4d}    | {r[2]:4d} | {r[3]:4d}  | {r[4]:4d}     | {r[5]:4d}    | {r[6]:6d}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
