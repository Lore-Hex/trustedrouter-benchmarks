[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Full frame analysis (no ROI restriction) ===")
[?2004l[?2004h> print("Frame | bottom_y | top_y | center_x | area | note")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Two approaches:
[?2004l[?2004h>     # 1. Regions darker than background (athlete silhouette)
[?2004l[?2004h>     darker = cv2.subtract(bg_gray, gray)
[?2004l[?2004h>     _, dark_mask = cv2.threshold(darker, 25, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # 2. Regions lighter than background (maybe athlete's clothes or reflections)
[?2004l[?2004h>     lighter = cv2.subtract(gray, bg_gray)
[?2004l[?2004h>     _, light_mask = cv2.threshold(lighter, 25, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Combine both
[?2004l[?2004h>     combined = cv2.bitwise_or(dark_mask, light_mask)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     combined = cv2.morphologyEx(combined, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     combined = cv2.morphologyEx(combined, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the largest connected component in the center region (x=200-800)
[?2004l[?2004h>     # where the athlete is likely to be
[?2004l[?2004h>     y_indices, x_indices = np.where(combined > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         center_x = int(np.mean(x_indices))
[?2004l[?2004h>         area = len(y_indices)
[?2004l[?2004h>         
[?2004l[?2004h>         note = ""
[?2004l[?2004h>         if i >= 45 and i <= 75:
[?2004l[?2004h>             note = "<< JUMP WINDOW"
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 5 == 0 or (i >= 40 and i <= 80):
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:5d} | {top_y:4d}  | {center_x:4d}   | {area:5d} | {note}")
[?2004l[?2004h>     else:
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>5} | {'':>4}  | {'':>4}   | {'':>5} |")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> EOF
