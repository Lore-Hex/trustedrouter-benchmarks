[?2004l[?2004h>         if not ret:
[?2004l[?2004h>             break
[?2004l[?2004h>         frames.append(frame)
[?2004l[?2004h>     cap.release()
[?2004l[?2004h>     
[?2004l[?2004h>     total_frames = len(frames)
[?2004l[?2004h>     if total_frames == 0:
[?2004l[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute frame-to-frame motion features
[?2004l[?2004h>     prev_gray = None
[?2004l[?2004h>     bottom_y_list = []
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(total_frames):
[?2004l[?2004h>         gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>         gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>         
[?2004l[?2004h>         if prev_gray is not None:
[?2004l[?2004h>             diff = cv2.absdiff(gray, prev_gray)
[?2004l[?2004h>             _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>             
[?2004l[?2004h>             # Clean up noise
[?2004l[?2004h>             kernel = np.ones((3, 3), np.uint8)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>             
[?2004l[?2004h>             # Only consider lower part of frame (where the track is)
[?2004l[?2004h>             # This avoids sky noise
[?2004l[?2004h>             motion[:200, :] = 0
[?2004l[?2004h>             
[?2004l[?2004h>             y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>             
[?2004l[?2004h>             if len(y_indices) > 100:
[?2004l[?2004h>                 bottom_y = np.max(y_indices)
[?2004l[?2004h>             else:
[?2004l[?2004h>                 bottom_y = 0
[?2004l[?2004h>             
[?2004l[?2004h>             bottom_y_list.append(bottom_y)
[?2004l[?2004h>         else:
[?2004l[?2004h>             bottom_y_list.append(0)
[?2004l[?2004h>         
[?2004l[?2004h>         prev_gray = gray
[?2004l[?2004h>     
[?2004l[?2004h>     # Now analyze the bottom_y trajectory to find takeoff and landing
[?2004l[?2004h>     # Takeoff: when bottom_y starts decreasing (feet rise)
[?2004l[?2004h>     # Landing: when bottom_y starts increasing after being airborne
[?2004l[?2004h>     
[?2004l[?2004h>     # First, smooth the data
[?2004l[?2004h>     def smooth(data, window=3):
[?2004l[?2004h>         smoothed = []
[?2004l[?2004h>         for i in range(len(data)):
[?2004l[?2004h>             start = max(0, i - window)
[?2004l[?2004h>             end = min(len(data), i + window + 1)
[?2004l[?2004h>             vals = [v for v in data[start:end] if v > 0]
[?2004l[?2004h>             if len(vals) > 0:
[?2004l[?2004h>                 smoothed.append(np.mean(vals))
[?2004l[?2004h>             else:
[?2004l[?2004h>                 smoothed.append(0)
[?2004l[?2004h>         return smoothed
[?2004l[?2004h>     
[?2004l[?2004h>     smoothed_bottoms = smooth(bottom_y_list)
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute velocity (first derivative)
[?2004l[?2004h>     velocities = []
[?2004l[?2004h>     for i in range(1, len(smoothed_bottoms)):
[?2004l[?2004h>         v = smoothed_bottoms[i] - smoothed_bottoms[i-1]
[?2004l[?2004h>         velocities.append(v)
[?2004l[?2004h>     
[?2004l[?2004h>     # Detect takeoff: look for sustained negative velocity (feet rising)
[?2004l[?2004h>     # We need several consecutive frames with negative velocity
[?2004l[?2004h>     takeoff_frame = None
[?2004l[?2004h>     for i in range(len(velocities) - 2):
[?2004l[?2004h>         frame_idx = i + 1  # velocity[i] corresponds to frame i+1
[?2004l[?2004h>         if (velocities[i] < -8 and 
[?2004l[?2004h>             velocities[i+1] < -8 and 
[?2004l[?2004h>             smoothed_bottoms[frame_idx] > 0):
[?2004l[?2004h>             # Takeoff likely starts here or earlier
[?2004l[?2004h>             # Find the exact frame where velocity first became negative
[?2004l[?2004h>             for j in range(max(0, i-3), i+1):
[?2004l[?2004h>                 if velocities[j] < -5 and velocities[j+1] < -5:
[?2004l[?2004h>                     takeoff_frame = j + 1  # frame index from velocity
[?2004l[?2004h>                     break
[?2004l[?2004h>             if takeoff_frame is not None:
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     # Detect landing: look for when feet return to ground after being airborne
[?2004l[?2004h>     # Find the frame after the apex where velocity is positive and significant
[?2004l[?2004h>     landing_frame = None
[?2004l[?2004h>     
[?2004l[?2004h>     # Find the apex (minimum smoothed bottoms)
[?2004l[?2004h>     min_frame = None
[?2004l[?2004h>     min_val = float('inf')
[?2004l[?2004h>     for i, b in enumerate(smoothed_bottoms):
[?2004l[?2004h>         if b > 0 and b < min_val:
[?2004l[?2004h>             min_val = b
[?2004l[?2004h>             min_frame = i
[?2004l[?2004h>     
[?2004l[?2004h>     if min_frame is not None:
[?2004l[?2004h>         # Look after the apex for landing
[?2004l[?2004h>         for i in range(min_frame, min(len(velocities), min_frame + 15)):
[?2004l[?2004h>             if velocities[i] > 8:
[?2004l[?2004h>                 landing_frame = i + 1  # velocity i corresponds to frame i+1
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     return takeoff_frame, landing_frame
[?2004l[?2004h> 
