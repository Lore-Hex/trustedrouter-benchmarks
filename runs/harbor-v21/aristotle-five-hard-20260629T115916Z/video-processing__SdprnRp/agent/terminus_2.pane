[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> 
[?2004l[?2004h> # Process all frames
[?2004l[?2004h> motion_centers = []
[?2004l[?2004h> motion_amounts = []
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, frame = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(bg, frame)
[?2004l[?2004h>     gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     _, thresh = cv2.threshold(gray, 25, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find where the motion is
[?2004l[?2004h>     y_indices, x_indices = np.where(thresh > 0)
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         center_y = int(np.mean(y_indices))
[?2004l[?2004h>         center_x = int(np.mean(x_indices))
[?2004l[?2004h>         motion_amount = len(y_indices)
[?2004l[?2004h>     else:
[?2004l[?2004h>         center_y = 0
[?2004l[?2004h>         center_x = 0
[?2004l[?2004h>         motion_amount = 0
[?2004l[?2004h>     
[?2004l[?2004h>     motion_centers.append((center_x, center_y))
[?2004l[?2004h>     motion_amounts.append(motion_amount)
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
[?2004l[?2004h> 
[?2004l[?2004h> # Print results
[?2004l[?2004h> print("Frame | MotionPx | CenterX | CenterY")
[?2004l[?2004h> for i, (cent, amt) in enumerate(zip(motion_centers, motion_amounts)):
[?2004l[?2004h>     print(f"{i:3d}   | {amt:6d}   | {cent[0]:4d}   | {cent[1]:4d}")
