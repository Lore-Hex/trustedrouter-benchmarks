[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's use a running median background model
[?2004l[?2004h> # Or just use frame 0 as background but filter out sky noise
[?2004l[?2004h> 
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's analyze what part of the frame has the most consistent background
[?2004l[?2004h> # Compute std of background across time for each pixel
[?2004l[?2004h> frames = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         frames.append(cv2.cvtColor(f, cv2.COLOR_BGR2GRAY))
[?2004l[?2004h> 
[?2004l[?2004h> # Compute pixel-wise variance
[?2004l[?2004h> stack = np.stack(frames, axis=0)
[?2004l[?2004h> pixel_var = np.var(stack, axis=0)
[?2004l[?2004h> 
[?2004l[?2004h> print("Pixel variance (showing regions of high variance = noise):")
[?2004l[?2004h> print(f"Max variance: {np.max(pixel_var)}")
[?2004l[?2004h> print(f"Mean variance: {np.mean(pixel_var)}")
[?2004l[?2004h> 
[?2004l[?2004h> # Find rows with high variance (noisy sky)
[?2004l[?2004h> row_var = np.mean(pixel_var, axis=1)
[?2004l[?2004h> print("\nRow-wise variance:")
[?2004l[?2004h> for y in range(0, 540, 20):
[?2004l[?2004h>     print(f"y={y:3d}: variance={row_var[y]:.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> # The track region should have low variance (stable)
[?2004l[?2004h> # The sky region should have higher variance (clouds, etc.)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's track motion only in the low-variance region
[?2004l[?2004h> low_var_mask = pixel_var < 50  # threshold for stable background
[?2004l[?2004h> 
[?2004l[?2004h> print("\n\nNow tracking motion only in stable background regions...")
[?2004l[?2004h> print("Frame | feet_y | feet_above_ground")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     diff = cv2.absdiff(frames[i], bg_gray)
[?2004l[?2004h>     
[?2004l[?2004h>     # Apply mask to only look at stable regions
[?2004l[?2004h>     diff[~low_var_mask] = 0
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Only look at bottom half of frame (y > 200)
[?2004l[?2004h>     motion[:200, :] = 0
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         ground_dist = 520 - bottom_y
[?2004l[?2004h>         if i % 5 == 0 or (i >= 100 and i <= 119):
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:5d} | {ground_dist:15d}")
[?2004l[?2004h>     else:
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>5} | {'':>15}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
