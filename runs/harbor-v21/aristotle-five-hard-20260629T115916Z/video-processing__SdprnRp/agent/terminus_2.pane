[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> import toml
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Read all frames
[?2004l[?2004h> frames = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         frames.append(f)
[?2004l[?2004h>     else:
[?2004l[?2004h>         break
[?2004l[?2004h> cap.release()
[?2004l[?2004h> 
[?2004l[?2004h> # Background = first frame
[?2004l[?2004h> bg_gray = cv2.cvtColor(frames[0], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute a more refined motion metric:
[?2004l[?2004h> # Track the vertical position of the bottom of the moving object
[?2004l[?2004h> # Use background subtraction but mask out the top half (sky noise)
[?2004l[?2004h> 
[?2004l[?2004h> print("=== Refined motion analysis ===")
[?2004l[?2004h> print("Frame | bottom_y | centroid_y | area | notes")
[?2004l[?2004h> 
[?2004l[?2004h> results = []
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Background subtraction
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     
[?2004l[?2004h>     # Threshold
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Focus on the track region (y=300-520, x=200-800)
[?2004l[?2004h>     # This avoids sky noise
[?2004l[?2004h>     roi = np.zeros_like(motion)
[?2004l[?2004h>     roi[300:520, 200:800] = 1
[?2004l[?2004h>     motion_roi = cv2.bitwise_and(motion, roi)
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(motion_roi > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 100:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         centroid_y = np.mean(y_indices)
[?2004l[?2004h>         centroid_x = np.mean(x_indices)
[?2004l[?2004h>         area = len(y_indices)
[?2004l[?2004h>         height = bottom_y - top_y
[?2004l[?2004h>         
[?2004l[?2004h>         results.append({
[?2004l[?2004h>             'frame': i,
[?2004l[?2004h>             'bottom_y': bottom_y,
[?2004l[?2004h>             'top_y': top_y,
[?2004l[?2004h>             'centroid_y': centroid_y,
[?2004l[?2004h>             'centroid_x': centroid_x,
[?2004l[?2004h>             'area': area,
[?2004l[?2004h>             'height': height
[?2004l[?2004h>         })
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:5d} | {centroid_y:8.1f} | {area:5d} |")
[?2004l[?2004h>     else:
[?2004l[?2004h>         results.append(None)
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>5} | {'':>8} | {'':>5} |")
[?2004l[?2004h> 
[?2004l[?2004h> # Now let's find takeoff and landing by looking at significant changes
[?2004l[?2004h> print("\n\n=== Detecting takeoff and landing ===")
[?2004l[?2004h> 
[?2004l[?2004h> # Takeoff: when bottom_y decreases significantly (feet rise)
[?2004l[?2004h> # Landing: when bottom_y increases significantly after takeoff
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at derivative of bottom_y
[?2004l[?2004h> prev_bottom = None
[?2004l[?2004h> prev_frame = None
[?2004l[?2004h> 
[?2004l[?2004h> takeoff_candidates = []
[?2004l[?2004h> land_candidates = []
[?2004l[?2004h> 
[?2004l[?2004h> for r in results:
[?2004l[?2004h>     if r is None:
[?2004l[?2004h>         prev_bottom = None
[?2004l[?2004h>         prev_frame = None
[?2004l[?2004h>         continue
[?2004l[?2004h>     
[?2004l[?2004h>     i = r['frame']
[?2004l[?2004h>     bottom = r['bottom_y']
[?2004l[?2004h>     
[?2004l[?2004h>     if prev_bottom is not None and prev_frame is not None:
[?2004l[?2004h>         # Change in bottom position
[?2004l[?2004h>         change = bottom - prev_bottom
[?2004l[?2004h>         
[?2004l[?2004h>         # Negative change = bottom moving UP (smaller y = higher in image)
[?2004l[?2004h>         # This could be takeoff (feet rising)
[?2004l[?2004h>         if change < -20 and bottom < 380:
[?2004l[?2004h>             print(f"Takeoff candidate at frame {i}: bottom_y {prev_bottom} -> {bottom} (change={change})")
[?2004l[?2004h>             takeoff_candidates.append(i)
[?2004l[?2004h>         
