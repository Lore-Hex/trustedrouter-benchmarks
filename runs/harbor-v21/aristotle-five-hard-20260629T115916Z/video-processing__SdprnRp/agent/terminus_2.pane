[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Check a few frames to understand the athlete's direction
[?2004l[?2004h> # Let's look at the horizontal position of the athlete over time
[?2004l[?2004h> 
[?2004l[?2004h> # Read background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> print("Frame | athlete_center_x | direction")
[?2004l[?2004h> prev_x = None
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find centroid of motion
[?2004l[?2004h>     y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         weights = motion[y_indices, x_indices]
[?2004l[?2004h>         centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>         
[?2004l[?2004h>         if prev_x is not None:
[?2004l[?2004h>             dx = centroid_x - prev_x
[?2004l[?2004h>             if dx > 5:
[?2004l[?2004h>                 dir = "right"
[?2004l[?2004h>             elif dx < -5:
[?2004l[?2004h>                 dir = "left"
[?2004l[?2004h>             else:
[?2004l[?2004h>                 dir = "still"
[?2004l[?2004h>         else:
[?2004l[?2004h>             dir = "-"
[?2004l[?2004h>             dx = 0
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 5 == 0:
[?2004l[?2004h>             print(f"{i:3d}     | {centroid_x:8.1f}          | {dir} (dx={dx:.1f})")
[?2004l[?2004h>         
[?2004l[?2004h>         prev_x = centroid_x
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
