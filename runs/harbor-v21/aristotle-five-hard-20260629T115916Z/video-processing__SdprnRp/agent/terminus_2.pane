[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the difference images to understand how the athlete appears
[?2004l[?2004h> # The athlete should appear as a dark silhouette against the track/hurdle
[?2004l[?2004h> 
[?2004l[?2004h> # Get background
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's examine the athlete's position at different frames
[?2004l[?2004h> # by looking at WHERE the pixel values change significantly
[?2004l[?2004h> 
[?2004l[?2004h> print("\n=== Analyzing athlete position relative to hurdle ===")
[?2004l[?2004h> print("Hurdle top bar at y=379, x=492-620")
[?2004l[?2004h> print("\nFrame | athlete_bottom_y | athlete_top_y | athlete_center_x | relative_to_hurdle")
[?2004l[?2004h> 
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         break
[?2004l[?2004h>     
[?2004l[?2004h>     gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute difference
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Threshold
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 20, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((5,5), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     # Focus on the region where the athlete would be (x=300-800, y=200-520)
[?2004l[?2004h>     # Create a mask for the region of interest
[?2004l[?2004h>     roi_mask = np.zeros_like(motion)
[?2004l[?2004h>     roi_mask[200:520, 300:800] = 1
[?2004l[?2004h>     motion_roi = cv2.bitwise_and(motion, roi_mask)
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(motion_roi > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         center_x = int(np.mean(x_indices))
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if athlete is above, at, or below hurdle
[?2004l[?2004h>         if bottom_y < 379:
[?2004l[?2004h>             rel = "ABOVE_HURDLE"
[?2004l[?2004h>         elif top_y > 379:
[?2004l[?2004h>             rel = "BELOW_HURDLE"
[?2004l[?2004h>         else:
[?2004l[?2004h>             rel = "AT_HURDLE"
[?2004l[?2004h>         
[?2004l[?2004h>         if i % 10 == 0 or i in [55, 56, 57, 58, 59, 60, 61, 62, 63, 64, 65]:
[?2004l[?2004h>             print(f"{i:3d}   | {bottom_y:16d} | {top_y:13d} | {center_x:16d} | {rel}")
[?2004l[?2004h>     else:
[?2004l[?2004h>         if i % 10 == 0:
[?2004l[?2004h>             print(f"{i:3d}   | {'':>16} | {'':>13} | {'':>16} | {'':>20}")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
