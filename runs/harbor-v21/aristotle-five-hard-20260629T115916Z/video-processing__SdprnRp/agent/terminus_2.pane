[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Read all frames
[?2004l[?2004h> frames = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     cap.set(cv2.CAP_PROP_POS_FRAMES, i)
[?2004l[?2004h>     ret, f = cap.read()
[?2004l[?2004h>     if ret:
[?2004l[?2004h>         frames.append(f)
[?2004l[?2004h>     else:
[?2004l[?2004h>         break
[?2004l[?2004h> cap.release()
[?2004l[?2004h> 
[?2004l[?2004h> # Use the first frame as background
[?2004l[?2004h> bg = frames[0].copy()
[?2004l[?2004h> bg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute centroid of motion for each frame
[?2004l[?2004h> # We'll track: centroid_y, bottom_y, and motion_area
[?2004l[?2004h> 
[?2004l[?2004h> data = []
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     
[?2004l[?2004h>     diff = cv2.absdiff(gray, bg_gray)
[?2004l[?2004h>     diff = cv2.GaussianBlur(diff, (5, 5), 0)
[?2004l[?2004h>     
[?2004l[?2004h>     _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>     
[?2004l[?2004h>     # Clean
[?2004l[?2004h>     kernel = np.ones((3,3), np.uint8)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>     motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>     
[?2004l[?2004h>     y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>     
[?2004l[?2004h>     if len(y_indices) > 0:
[?2004l[?2004h>         weights = motion[y_indices, x_indices]
[?2004l[?2004h>         centroid_y = np.average(y_indices, weights=weights)
[?2004l[?2004h>         centroid_x = np.average(x_indices, weights=weights)
[?2004l[?2004h>         bottom_y = np.max(y_indices)
[?2004l[?2004h>         top_y = np.min(y_indices)
[?2004l[?2004h>         motion_area = len(y_indices)
[?2004l[?2004h>         
[?2004l[?2004h>         # Also compute the extent (height) of the motion blob
[?2004l[?2004h>         height = bottom_y - top_y
[?2004l[?2004h>     else:
[?2004l[?2004h>         centroid_y = 0
[?2004l[?2004h>         centroid_x = 0
[?2004l[?2004h>         bottom_y = 0
[?2004l[?2004h>         top_y = 0
[?2004l[?2004h>         motion_area = 0
[?2004l[?2004h>         height = 0
[?2004l[?2004h>     
[?2004l[?2004h>     data.append({
[?2004l[?2004h>         'frame': i,
[?2004l[?2004h>         'centroid_y': centroid_y,
[?2004l[?2004h>         'centroid_x': centroid_x,
[?2004l[?2004h>         'bottom_y': bottom_y,
[?2004l[?2004h>         'top_y': top_y,
[?2004l[?2004h>         'area': motion_area,
[?2004l[?2004h>         'height': height
[?2004l[?2004h>     })
[?2004l[?2004h> 
[?2004l[?2004h> # Now let's look for the jump pattern
[?2004l[?2004h> # Takeoff should be when the athlete's body starts rising (centroid_y decreases)
[?2004l[?2004h> # Landing should be when it stops falling
[?2004l[?2004h> 
[?2004l[?2004h> print("Frame | centroid_y | bottom_y | top_y | area | height | cent_y_change")
[?2004l[?2004h> for i in range(120):
[?2004l[?2004h>     d = data[i]
[?2004l[?2004h>     if i > 0:
[?2004l[?2004h>         change = d['centroid_y'] - data[i-1]['centroid_y']
[?2004l[?2004h>     else:
[?2004l[?2004h>         change = 0
[?2004l[?2004h>     
[?2004l[?2004h>     if i % 5 == 0 or (i >= 45 and i <= 85):
[?2004l[?2004h>         print(f"{d['frame']:3d}   | {d['centroid_y']:8.1f}  | {d['bottom_y']:5d}  | {d['top_y']:4d}  | {d['area']:6d}  | {d['height']:4d}  | {change:8.1f}")
[?2004l[?2004h> EOF
