[?2004l[?2004h>     cap.release()
[?2004l[?2004h>     
[?2004l[?2004h>     total_frames = len(frames)
[?2004l[?2004h>     if total_frames == 0:
[?2004l[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute frame-to-frame motion features
[?2004l[?2004h>     prev_gray = None
[?2004l[?2004h>     motion_data = []  # list of (bottom_y, area) per frame
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(total_frames):
[?2004l[?2004h>         gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>         gray = cv2.GaussianBlur(gray, (5, 5), 0)
[?2004l[?2004h>         
[?2004l[?2004h>         if prev_gray is not None:
[?2004l[?2004h>             diff = cv2.absdiff(gray, prev_gray)
[?2004l[?2004h>             _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)
[?2004l[?2004h>             
[?2004l[?2004h>             # Clean up noise
[?2004l[?2004h>             kernel = np.ones((3, 3), np.uint8)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)
[?2004l[?2004h>             motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)
[?2004l[?2004h>             
[?2004l[?2004h>             # Only consider lower part of frame (where the track is)
[?2004l[?2004h>             motion[:200, :] = 0
[?2004l[?2004h>             
[?2004l[?2004h>             y_indices, x_indices = np.where(motion > 0)
[?2004l[?2004h>             
[?2004l[?2004h>             if len(y_indices) > 100:
[?2004l[?2004h>                 bottom_y = np.max(y_indices)
[?2004l[?2004h>                 area = len(y_indices)
[?2004l[?2004h>             else:
[?2004l[?2004h>                 bottom_y = 0
[?2004l[?2004h>                 area = 0
[?2004l[?2004h>             
[?2004l[?2004h>             motion_data.append((i, bottom_y, area))
[?2004l[?2004h>         else:
[?2004l[?2004h>             motion_data.append((0, 0, 0))
[?2004l[?2004h>         
[?2004l[?2004h>         prev_gray = gray
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract bottom_y values, filtering out zeros
[?2004l[?2004h>     bottom_ys = np.array([d[1] for d in motion_data])
[?2004l[?2004h>     areas = np.array([d[2] for d in motion_data])
[?2004l.e[?2004h>     
[?2004l[?2004h>     # Find frames with significant motion
[?2004l[?2004h>     active_frames = np.where(areas > 500)[0]
[?2004l [?2004h>     
[?2004l[?2004h>     if len(active_frames) < 10:
[?2004lng i[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Look for the jump pattern:
[?2004l[?2004h>     # 1. Find the minimum bottom_y (highest point of jump, feet highest)
[?2004l[?2004h>     #    This occurs when the athlete is in the air, feet at highest position
[?2004l[?2004h>     # 2. Takeoff is just before the minimum, when feet first start rising
[?2004l_fr[?2004h>     # 3. Landing is just after the minimum, when feet come back down
[?2004lat[?2004h>     
[?2004l'[?2004h>     # Find the minimum bottom_y among active frames
[?2004lw') as[?2004h>     valid_bottoms = bottom_ys.copy()
[?2004l[?2004h>     valid_bottoms[~np.isin(np.arange(len(valid_bottoms)), active_frames)] = 0
[?2004l[?2004h>     
[?2004lf"Lan[?2004h>     if np.max(valid_bottoms) == 0:
[?2004l[?2004h>         return None, None
[?2004lf"[?2004h>     
[?2004l[?2004h>     # The jump should show a clear decrease then increase in bottom_y
[?2004l[?2004h>     # Let's find the frame with minimum bottom_y (peak of jump)
[?2004l[?2004h>     min_frame = np.argmin(valid_bottoms) if np.min(valid_bottoms[valid_bottoms > 0]) < 300 else None
[?2004l[?2004h>     
[?2004l[?2004h>     if min_frame is None or valid_bottoms[min_frame] == 0 or valid_bottoms[min_frame] > 300:
[?2004l[?2004h>         # Fallback: use area minimum pattern
[?2004l[?2004h>         # During jump, area first decreases (feet leaving ground) then increases (body in air)
[?2004l[?2004h>         # Actually let's find the takeoff by looking for the first significant drop in bottom_y
[?2004l[?2004h>         return None, None
[?2004l[?2004h>     
[?2004l[?2004h>     # Find where bottom_y first drops significantly before the minimum (takeoff)
[?2004l[?2004h>     # And where bottom_y rises back after the minimum (landing)
[?2004l[?2004h>     
[?2004l[?2004h>     # Look before min_frame for the last frame where bottom_y was > some threshold
[?2004l[?2004h>     # (feet on ground)
[?2004l[?2004h>     ground_level = 340  # approximate ground level from running frames
[?2004l[?2004h>     
[?2004l[?2004h>     # Find takeoff: look backwards from min_frame to find when bottom_y was at ground level
[?2004l[?2004h>     # and then started dropping
[?2004l[?2004h>     takeoff_frame = None
[?2004l[?2004h>     for i in range(min_frame - 1, max(0, min_frame - 15), -1):
[?2004l[?2004h>         if bottom_ys[i] >= ground_level and areas[i] > 500:
[?2004l[?2004h>             # This is a running frame (feet on ground)
[?2004l[?2004h>             if i + 1 < min_frame and bottom_ys[i+1] < ground_level - 10:
[?2004l[?2004h>                 takeoff_frame = i + 1
[?2004l[?2004h>                 break
[?2004l[?2004h>     
[?2004l[?2004h>     # If we didn't find takeoff by threshold, find by gradient
[?2004l[?2004h>     if takeoff_frame is None:
[?2004l[?2004h>         # Find the steepest negative slope before min_frame
[?2004l[?2004h>         best_slope = -999
[?2004l[?2004h>         for i in range(max(5, min_frame - 15), min_frame):
[?2004l[?2004h>             if areas[i] > 500 and areas[i-1] > 500:
[?2004l[?2004h>                 slope = bottom_ys[i] - bottom_ys[i-1]
[?2004l[?2004h>                 if slope < best_slope:
[?2004l[?2004h>                     best_slope = slope
[?2004l[?2004h>                     takeoff_frame = i
[?2004l[?2004h>     
[?2004l[?2004h>     # Find landing: look forward from min_frame to find when bottom_y rises back to ground level
[?2004l[?2004h>     landing_frame = None
[?2004l[?2004h>     for i in range(min_frame + 1, min(total_frames, min_frame + 20)):
[?2004l[?2004h>         if i < len(bottom_ys) and bottom_ys[i] >= ground_level - 10 and areas[i] > 500:
[?2004l[?2004h>             landing_frame = i
[?2004l[?2004h>             break
[?2004l[?2004h>     
[?2004l[?2004h>     # If we didn't find landing by threshold, find by gradient
[?2004l[?2004h>     if landing_frame is None:
[?2004l[?2004h>         best_slope = 999
[?2004l[?2004h>         for i in range(min_frame, min(len(bottom_ys) - 1, min_frame + 15)):
[?2004l[?2004h>             if areas[i] > 500 and areas[i+1] > 500:
[?2004l[?2004h>                 slope = bottom_ys[i+1] - bottom_ys[i]
[?2004l[?2004h>                 if slope > 0 and slope < best_slope:
[?2004l[?2004h>                     best_slope = slope
[?2004l[?2004h>                     landing_frame = i + 1
[?2004l[?2004h>     
[?2004l[?2004h>     # If we still don't have valid frames, use fallback
[?2004l[?2004h>     if takeoff_frame is None or landing_frame is None:
[?2004l[?2004h>         # Simple fallback: find where area peaks after motion starts
[?2004l[?2004h>         # Takeoff at first frame with area > threshold
[?2004l[?2004h>         # Landing at last frame with area > threshold
[?2004l[?2004h>         active = np.where(areas > 1000)[0]
[?2004l[?2004h>         if len(active) > 10:
[?2004l[?2004h>             if takeoff_frame is None:
[?2004l[?2004h>                 takeoff_frame = active[5]  # 5th active frame
[?2004l[?2004h>             if landing_frame is None:
[?2004l[?2004h>                 landing_frame = active[-5]  # 5th from last active frame
[?2004l[?2004h>     
[?2004l[?2004h>     return takeoff_frame, landing_frame
[?2004l[?2004h> 
