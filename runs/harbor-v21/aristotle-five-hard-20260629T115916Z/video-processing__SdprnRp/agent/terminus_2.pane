[?2004hroot@ed7f778758f3:/app# python3 << 'EOF'
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> 
[?2004l[?2004h> cap = cv2.VideoCapture('example_video.mp4')
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at the first frame and find the ground line
[?2004l[?2004h> # The ground is where the sky meets the track
[?2004l[?2004h> 
[?2004l[?2004h> cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
[?2004l[?2004h> ret, bg = cap.read()
[?2004l[?2004h> gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h> 
[?2004l[?2004h> # Compute horizontal edges to find the horizon/ground line
[?2004l[?2004h> # The track surface should start at some y-coordinate
[?2004l[?2004h> 
[?2004l[?2004h> # Let's look at vertical gradient (difference between rows)
[?2004l[?2004h> # At the horizon, there should be a significant change
[?2004l[?2004h> print("Vertical gradient (diff between consecutive rows) at center column:")
[?2004l[?2004h> for y in range(1, 540):
[?2004l[?2004h>     diff = abs(int(gray[y, 480]) - int(gray[y-1, 480]))
[?2004l[?2004h>     if diff > 20:
[?2004l[?2004h>         print(f"y={y}: diff={diff}")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's also look at the row-wise standard deviation
[?2004l[?2004h> # The track should be relatively uniform, while the sky might have more variation
[?2004l[?2004h> print("\n\nRow-wise std dev at x=400-600:")
[?2004l[?2004h> for y in range(0, 540, 20):
[?2004l[?2004h>     strip = gray[y, 400:600]
[?2004l[?2004h>     mean_val = np.mean(strip)
[?2004l[?2004h>     std_val = np.std(strip)
[?2004l[?2004h>     print(f"y={y:3d}: mean={mean_val:.1f}, std={std_val:.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Now let's look for the hurdle
[?2004l[?2004h> # The hurdle should have horizontal and vertical white bars
[?2004l[?2004h> # Let's look for white regions in the background
[?2004l[?2004h> print("\n\nLooking for white regions (hurdle candidates):")
[?2004l[?2004h> # Threshold above 180
[?2004l[?2004h> white_mask = gray > 180
[?2004l[?2004h> # Find connected components
[?2004l[?2004h> from scipy import ndimage
[?2004l[?2004h> # Let's just scan for horizontal white lines
[?2004l[?2004h> for y in range(200, 400):
[?2004l[?2004h>     row = gray[y, :]
[?2004l[?2004h>     # Find runs of bright pixels
[?2004l[?2004h>     bright = row > 180
[?2004l[?2004h>     # Count length of continuous bright regions
[?2004l[?2004h>     changes = np.diff(bright.astype(int))
[?2004l[?2004h>     starts = np.where(changes == 1)[0]
[?2004l[?2004h>     ends = np.where(changes == -1)[0]
[?2004l[?2004h>     if len(starts) > 0 and len(ends) > 0:
[?2004l[?2004h>         for s, e in zip(starts, ends):
[?2004l[?2004h>             if e - s > 50:  # At least 50 pixels wide
[?2004l[?2004h>                 print(f"y={y}: bright bar at x={s}-{e} (width={e-s})")
[?2004l[?2004h> 
[?2004l[?2004h> cap.release()
