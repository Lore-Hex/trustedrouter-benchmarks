Sending keys: ['cat > /tmp/full_process.py << \'ENDPY\'\nimport os\nimport glob\nimport re\n\n# Load all OCR outputs from both directories\nocr_dirs = ["/tmp/ocr_output", "/tmp/ocr_hq"]\n\nall_files = []\nfor d in ocr_dirs:\n    files = glob.glob(os.path.join(d, "frame_*.txt"))\n    for f in files:\n        basename = os.path.basename(f)\n        # Extract frame number\n        frame_num = int(basename.split(\'_\')[1].split(\'.\')[0])\n        all_files.append((frame_num, d, f))\n\n# Sort by frame number\nall_files.sort(key=lambda x: x[0])\nprint(f"Total files: {len(all_files)}")\n\ndef get_last_command(text):\n    """Get the last command being typed."""\n    last_cmd = None\n    for line in text.split(\'\\n\'):\n        stripped = line.strip()\n        if stripped.startswith(\'>\') and len(stripped) > 1:\n            cmd = stripped[1:].strip()\n            if cmd and len(cmd) >= 1:\n                last_cmd = cmd\n    return last_cmd\n\ndef clean(cmd):\n    """Clean OCR artifacts."""\n    # Remove trailing special chars\n    cmd = re.sub(r\'[_.,]+$\', \'\', cmd)\n    cmd = cmd.strip()\n    # Skip if empty or single char\n    if len(cmd) <= 1:\n        return None\n    return cmd\n\n# Track typing changes\nprev_typing = None\nsequence = []\n\nfor frame_num, dir_path, filepath in all_files:\n    with open(filepath, \'r\') as f:\n        text = f.read()\n    \n    current_typing = get_last_command(text)\n    \n    if current_typing and current_typing != prev_typing:\n        if prev_typing:\n            cleaned = clean(prev_typing)\n            if cleaned:\n                sequence.append(cleaned)\n        prev_typing = current_typing\n\n# Add final command\nif prev_typing:\n    cleaned = clean(prev_typing)\n    if cleaned:\n        sequence.append(cleaned)\n\nprint(f"\\nTotal commands: {len(sequence)}")\nfor i, cmd in enumerate(sequence):\n    print(f"{i+1}. {cmd}")\n\nwith open("/app/solution.txt", "w") as f:\n    for cmd in sequence:\n        f.write(cmd + "\\n")\nprint(f"\\nSaved {len(sequence)} commands to /app/solution.txt")\nENDPY\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
