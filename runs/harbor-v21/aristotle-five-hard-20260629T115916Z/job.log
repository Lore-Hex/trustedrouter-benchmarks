Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Save key frames every 5 frames\nfor i in range(0, 120, 5):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, frame = cap.read()\n    if ret:\n        cv2.imwrite(f\'/app/full_{i:03d}.jpg\', frame)\n        \n        # Also compute a better difference\n        if i == 0:\n            bg = frame.copy()\n        else:\n            diff = cv2.absdiff(bg, frame)\n            gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)\n            # Apply some blur to reduce noise\n            blurred = cv2.GaussianBlur(gray, (5, 5), 0)\n            _, thresh = cv2.threshold(blurred, 20, 255, cv2.THRESH_BINARY)\n            \n            # Morphological operations to connect parts\n            kernel = np.ones((5,5), np.uint8)\n            thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)\n            thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)\n            \n            # Find contours\n            contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n            \n            # Get all contours\' bounding boxes combined\n            if contours:\n                all_x, all_y, all_w, all_h = [], [], [], []\n                for cnt in contours:\n                    area = cv2.contourArea(cnt)\n                    if area > 500:  # Filter small noise\n                        x, y, w, h = cv2.boundingRect(cnt)\n                        all_x.append(x)\n                        all_y.append(y)\n                        all_w.append(x+w)\n                        all_h.append(y+h)\n                \n                if all_x:\n                    min_x = min(all_x)\n                    min_y = min(all_y)\n                    max_x = max(all_w)\n                    max_y = max(all_h)\n                    print(f"Frame {i:3d}: bbox=({min_x},{min_y},{max_x-min_x},{max_y-min_y}), bottom={max_y}, height={max_y-min_y}")\n\ncap.release()\nprint("\\nDone saving frames")\nEOF\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
