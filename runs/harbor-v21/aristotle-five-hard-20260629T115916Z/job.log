Sending keys: ['cat > /app/jump_analyzer.py << \'EOF\'\nimport cv2\nimport numpy as np\nimport sys\nimport toml\n\ndef analyze_jump(video_path):\n    """\n    Analyze a hurdle jump video and detect takeoff and landing frames.\n    """\n    cap = cv2.VideoCapture(video_path)\n    \n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        frames.append(frame)\n    cap.release()\n    \n    total_frames = len(frames)\n    if total_frames == 0:\n        return None, None\n    \n    # Compute frame-to-frame motion features\n    prev_gray = None\n    bottom_ys = []\n    areas = []\n    \n    for i in range(total_frames):\n        gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        if prev_gray is not None:\n            diff = cv2.absdiff(gray, prev_gray)\n            _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)\n            \n            kernel = np.ones((3, 3), np.uint8)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n            motion[:200, :] = 0\n            \n            y_indices, x_indices = np.where(motion > 0)\n            \n            if len(y_indices) > 50:\n                bottom_y = np.max(y_indices)\n                area = len(y_indices)\n            else:\n                bottom_y = 0\n                area = 0\n            \n            bottom_ys.append(bottom_y)\n            areas.append(area)\n        else:\n            bottom_ys.append(0)\n            areas.append(0)\n        \n        prev_gray = gray\n    \n    \n    bottom_ys = np.array(bottom_ys, dtype=float)\n    areas = np.array(areas, dtype=float)\n    \n    # Find active frames (significant motion)\n    active_mask = areas > 500\n    active_indices = np.where(active_mask)[0]\n    \n    if len(active_indices) < 10:\n        return None, None\n    \n    # Determine ground level from the first few active frames\n    first_active = active_indices[min(5, len(active_indices)-1)]\n    # Use the median of bottom_y values from early active frames\n    early_bottoms = bottom_ys[active_indices[:min(10, len(active_indices))]]\n    ground_level = np.median(early_bottoms) if len(early_bottoms) > 0 else 340\n    \n    # Find the peak of the jump: minimum bottom_y among active frames\n    active_bottoms = bottom_ys[active_mask]\n    min_idx_in_active = np.argmin(active_bottoms)\n    min_frame = active_indices[min_idx_in_active]\n    min_value = active_bottoms[min_idx_in_active]\n    \n    if min_value > ground_level - 30 or min_value == 0:\n        return None, None\n    \n    # Takeoff: find the FIRST frame before the peak where feet start rising\n    takeoff_frame = None\n    \n    # Look for the first significant drop in bottom_y\n    for i in range(min_frame - 1, max(1, min_frame - 15), -1):\n        if areas[i] > 500 and bottom_ys[i] >= ground_level:\n            # Found a frame at ground level\n            if i + 1 < len(bottom_ys) and bottom_ys[i+1] < bottom_ys[i]:\n                # Next frame shows a drop - that\'s the takeoff\n                takeoff_frame = i + 1\n                break\n    \n    # If not found, look for where consecutive drops begin\n    if takeoff_frame is None:\n        for i in range(min_frame - 2, max(1, min_frame - 15), -1):\n            if areas[i] > 500 and areas[i+1] > 500 and bottom_ys[i+1] < bottom_ys[i]:\n                if areas[i+2] > 500 and bottom_ys[i+2] < bottom_ys[i+1]:\n                    takeoff_frame = i + 1\n                    break\n    \n    # If still not found, use the first active frame before the peak\n    if takeoff_frame is None:\n        before_peak = active_indices[active_indices < min_frame]\n        if len(before_peak) > 5:\n            takeoff_frame = before_peak[5]  # skip first few frames\n    \n    # Landing: find the first frame after the peak where feet return to ground\n    landing_frame = None\n    \n    for i in range(min_frame + 1, min(len(bottom_ys), min_frame + 25)):\n        if i < len(bottom_ys) and bottom_ys[i] >= ground_level and areas[i] > 500:\n            landing_frame = i\n            break\n    \n    # If not found by ground level, find by positive velocity (feet going down)\n    if landing_frame is None:\n        for i in range(min_frame, min(len(bottom_ys) - 1, min_frame + 20)):\n            if areas[i] > 500 and areas[i+1] > 500:\n                if bottom_ys[i+1] > bottom_ys[i]:\n                    if i+2 < len(bottom_ys) and bottom_ys[i+2] > bottom_ys[i+1]:\n                        landing_frame = i + 1\n                        break\n    \n    # Fallback\n    if takeoff_frame is None:\n        before_peak = active_indices[active_indices < min_frame]\n        if len(before_peak) > 3:\n            takeoff_frame = before_peak[-3]  # 3 frames before peak\n        else:\n            takeoff_frame = max(1, min_frame - 5)\n    \n    if landing_frame is None:\n        after_peak = active_indices[active_indices > min_frame]\n        if len(after_peak) > 3:\n            landing_frame = after_peak[3]  # 3 frames after peak\n        else:\n            landing_frame = min(min_frame + 5, len(bottom_ys) - 1)\n    \n    # Ensure takeoff < landing\n    if takeoff_frame >= landing_frame:\n        landing_frame = takeoff_frame + 1\n        if landing_frame >= len(bottom_ys):\n            landing_frame = len(bottom_ys) - 1\n    \n    return int(takeoff_frame), int(landing_frame)\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_path>")\n        sys.exit(1)\n    \n    video_path = sys.argv[1]\n    takeoff, landing = analyze_jump(video_path)\n    \n    if takeoff is None or landing is None:\n        print("Could not detect jump frames", file=sys.stderr)\n        output = {\n            \'jump_takeoff_frame_number\': 0,\n            \'jump_land_frame_number\': 0\n        }\n    else:\