ge)\n    float sphere_center[3] = {0, 0, 0};\n    float sphere_radius = 0.5f;\n    float sphere_color[3] = {0.2f, 0.04f, 0.04f};  // dark red\n    \n    // Light\n    float light_dir[3] = {0.5f, 0.5f, -0.5f};\n    vnorm(light_dir);\n    \n    fprintf(stderr, "Rendering...\\n");\n    \n    int idx = 0;\n    for (int y = 0; y < HEIGHT; y++) {\n        for (int x = 0; x < WIDTH; x++) {\n            // Generate ray\n            float u = (2.0f * (x + 0.5f) / WIDTH - 1.0f) * aspect;\n            float v = 1.0f - 2.0f * (y + 0.5f) / HEIGHT;\n            \n            float rd[3] = {u, v, 1};\n            vnorm(rd);\n            float ro[3] = {0, 0, -1.5f};\n            \n            float final_color[3] = {0, 0, 0};\n            \n            // Try sphere intersection\n            float t_hit;\n            float hit_pos[3], hit_norm[3];\n            int hit = intersect_sphere(ro, rd, sphere_center, sphere_radius, &t_hit, hit_pos, hit_norm);\n            \n            if (hit) {\n                // Simple diffuse + ambient\n                float diff = fmaxf(0, vdot(hit_norm, light_dir));\n                float amb = 0.1f;\n                float intensity = amb + diff * 0.9f;\n                \n                // Checkerboard pattern for specular highlight? No, just diffuse\n                final_color[0] = sphere_color[0] * intensity;\n                final_color[1] = sphere_color[1] * intensity;\n                final_color[2] = sphere_color[2] * intensity;\n                \n                // Add specular highlight\n                float view_dir[3];\n                vsub(view_dir, ro, hit_pos);\n                vnorm(view_dir);\n                float half[3];\n                vadd(half, light_dir, view_dir);\n                vnorm(half);\n                float spec = powf(fmaxf(0, vdot(hit_norm, half)), 20.0f);\n                final_color[0] += spec * 0.3f;\n                final_color[1] += spec * 0.3f;\n                final_color[2] += spec * 0.3f;\n            } else {\n                // Ground plane intersection (y = -0.5)\n                if (rd[1] < 0) {\n                    float t = (-0.5f - ro[1]) / rd[1];\n                    if (t > EPSILON) {\n                        float px = ro[0] + rd[0] * t;\n                        float pz = ro[2] + rd[2] * t;\n                        \n                        // Checkerboard\n                        int ix = (int)floorf(px);\n                        int iz = (int)floorf(pz);\n                        float pattern = ((ix + iz) & 1) ? 0.9f : 0.4f;\n                        \n                        // Fog based on distance\n                        float dist = sqrtf(px*px + pz*pz);\n                        float fog = fminf(1.0f, dist * 0.1f);\n                        float gray = pattern * (1 - fog) + 0.5f * fog;\n                        \n                        final_color[0] = gray;\n                        final_color[1] = gray;\n                        final_color[2] = gray;\n                    } else {\n                        // Sky\n                        float t = fmaxf(0, (rd[1] + 0.3f) / 1.3f);\n                        final_color[0] = 0.6f + t * 0.2f;\n                        final_color[1] = 0.75f + t * 0.1f;\n                        final_color[2] = 1.0f;\n                    }\n                } else {\n                    // Sky\n                    float t = rd[1];\n                    final_color[0] = 0.6f + t * 0.2f;\n                    final_color[1] = 0.75f + t * 0.1f;\n                    final_color[2] = 1.0f;\n                }\n            }\n            \n            // Clamp\n            final_color[0] = fmaxf(0, fminf(1, final_color[0]));\n            final_color[1] = fmaxf(0, fminf(1, final_color[1]));\n            final_color[2] = fmaxf(0, fminf(1, final_color[2]));\n            \n            image[idx++] = final_color[0];\n            image[idx++] = final_color[1];\n            image[idx++] = final_color[2];\n        }\n        \n        if