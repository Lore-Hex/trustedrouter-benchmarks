Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\n# Read first frame (background)\ncap = cv2.VideoCapture(\'example_video.mp4\')\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\n\n# Check some pixel values to understand the scene\nprint("Background image stats:")\nprint(f"Shape: {bg.shape}")\nprint(f"Mean pixel values (B,G,R): {np.mean(bg, axis=(0,1))}")\n\n# Check horizontal strip at different heights\nfor h in [100, 200, 300, 400, 500]:\n    strip = bg[h, :, :]\n    print(f"\\nRow {h} - Mean (B,G,R): {np.mean(strip, axis=0)}")\n\n# Let\'s also check the difference image structure\ncap.set(cv2.CAP_PROP_POS_FRAMES, 60)\nret, frame60 = cap.read()\ndiff = cv2.absdiff(bg, frame60)\nprint(f"\\nFrame 60 diff stats:")\nprint(f"Mean diff per channel (B,G,R): {np.mean(diff, axis=(0,1))}")\nprint(f"Max diff per channel: {np.max(diff, axis=(0,1))}")\n\n# Look at where the difference is largest\n# Compute grayscale diff\ngray_diff = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)\nprint(f"Max gray diff: {np.max(gray_diff)}")\nprint(f"Mean gray diff: {np.mean(gray_diff)}")\n\n# Let\'s threshold and see where the motion is\n_, thresh = cv2.threshold(gray_diff, 30, 255, cv2.THRESH_BINARY)\nmotion_pixels = np.where(thresh > 0)\nif len(motion_pixels[0]) > 0:\n    print(f"Motion at y range: {np.min(motion_pixels[0])} to {np.max(motion_pixels[0])}")\n    print(f"Motion at x range: {np.min(motion_pixels[1])} to {np.max(motion_pixels[1])}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 3.0 max_timeout_sec: 180.0
