n 0..radix^digits_needed-1\n        while True:\n            high = low + rng\n            max_val = radix ** digits_needed\n            if high <= max_val:\n                # Find the smallest target in [low, low+rng) that has exactly 'digits_needed' digits\n                target = low\n                if target < 0:\n                    target = 0\n                if target >= max_val:\n                    target = max_val - 1\n                # Convert target to base-radix, digits_needed digits\n                return self._to_bytes(target, digits_needed)\n            low *= radix\n            rng *= radix\n            digits_needed += 1\n\n    def _to_bytes(self, val, ndigits):\n        bs = []\n        for _ in range(ndigits):\n            d = val % radix\n            val //= radix\n            bs.append(d + 1)\n        bs.reverse()\n        return bytes(bs)\n\n\ndef compress(data):\n    enc = Encoder()\n    n = len(data)\n    \n    # LZ parse: greedy longest match with unlimited offset/length\n    symbols = []\n    i = 0\n    while i < n:\n        best_len = 0\n        best_off = 0\n        # Search all previous data for the longest match\n        # Limit search to avoid O(n^2) - but n is 4868, so fine\n        for off in range(1, i + 1):\n            l = 0\n            while i + l < n and data[i - off + l] == data[i + l]:\n                l += 1\n            if l > best_len:\n                best_len = l\n                best_off = off\n                if i + l >= n:  # matched until end\n                    break\n        if best_len >= 2:\n            symbols.append(('ref', best_off - 1, best_len - 1))\n            i += best_len\n        else:\n            b = data[i]\n            if b < 128:\n                sign = 0\n                val = b\n            else:\n                sign = 1\n                val = 256 - b\n            symbols.append(('lit', sign, val))\n            i += 1\n\n    sys.stderr.write(f'Number of symbols: {len(symbols)}\\n')\n    \n    # Encode number of symbols\n    enc.encode_integer(INTOFF, 0, len(symbols))\n\n    for idx, sym in enumerate(symbols):\n        if sym[0] == 'ref':\n            enc.encode_bit(1, 1)\n            enc.encode_integer(OFF1, 2, sym[1])  # offset - 1\n            enc.encode_integer(OFF2, 3, sym[2])  # len - 1\n        else:\n            enc.encode_bit(1, 0)\n            enc.encode_bit(8, sym[1])  # sign\n            enc.encode_integer(LITSIZE, 9, sym[2])  # value\n\n    result = enc.finish()\n    sys.stderr.write(f'Compressed size: {len(result)} bytes\\n')\n    return result\n\n\ndef main():\n    with open('/app/data.txt', 'rb') as f:\n        data = f.read()\n    comp = compress(data)\n    with open('/app/data.comp', 'wb') as f:\n        f.write(comp)\n    sys.stderr.write(f'Final compressed size: {len(comp)} bytes\\n')\n\nif __name__ == '__main__':\n    main()\nPYEOF\npython3 /app/enc_opt.py 2>&1\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
