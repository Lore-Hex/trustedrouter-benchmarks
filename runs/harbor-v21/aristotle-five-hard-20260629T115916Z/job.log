Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Read all frames\nframes = []\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if ret:\n        frames.append(f)\n    else:\n        break\ncap.release()\n\n# Use frame-to-frame difference for cleaner motion tracking\nprev_gray = None\nresults = []\n\nfor i in range(120):\n    gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n    \n    if prev_gray is not None:\n        diff = cv2.absdiff(gray, prev_gray)\n        _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)\n        \n        # Clean\n        kernel = np.ones((3,3), np.uint8)\n        motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n        motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n        \n        # Look at the lower portion (y > 200)\n        motion[:200, :] = 0\n        \n        y_indices, x_indices = np.where(motion > 0)\n        \n        if len(y_indices) > 100:\n            bottom_y = np.max(y_indices)\n            top_y = np.min(y_indices)\n            centroid_y = np.mean(y_indices)\n            centroid_x = np.mean(x_indices)\n            area = len(y_indices)\n        else:\n            bottom_y = 0\n            top_y = 0\n            centroid_y = 0\n            centroid_x = 0\n            area = 0\n        \n        results.append({\n            \'frame\': i,\n            \'bottom_y\': bottom_y,\n            \'top_y\': top_y,\n            \'centroid_y\': centroid_y,\n            \'centroid_x\': centroid_x,\n            \'area\': area\n        })\n    \n    prev_gray = gray\n\n# Print the data to analyze pattern\nprint("Frame | bottom_y | centroid_y | area")\nfor r in results:\n    i = r[\'frame\']\n    if i % 3 == 0 or (i >= 48 and i <= 78):\n        print(f"{i:3d}   | {r[\'bottom_y\']:5d} | {r[\'centroid_y\']:8.1f} | {r[\'area\']:5d}")\n\n# Find takeoff and landing\nprint("\\n\\n=== Looking for takeoff and landing ===")\n\n# Takeoff: when bottom_y starts decreasing (feet rise) significantly\n# Landing: when bottom_y increases back (feet come down)\n\n# Let\'s smooth the data first\ndef smooth(data, window=3):\n    smoothed = []\n    for i in range(len(data)):\n        start = max(0, i - window)\n        end = min(len(data), i + window + 1)\n        smoothed.append(np.mean(data[start:end]))\n    return smoothed\n\nbottoms = [r[\'bottom_y\'] for r in results]\n# Replace zeros with None for smoothing\nbottoms_clean = [b if b > 0 else np.nan for b in bottoms]\n# Forward fill\nlast_val = None\nfor i in range(len(bottoms_clean)):\n    if np.isnan(bottoms_clean[i]) or bottoms_clean[i] == 0:\n        if last_val is not None:\n            bottoms_clean[i] = last_val\n    else:\n        last_val = bottoms_clean[i]\n\nsmoothed_bottoms = smooth(bottoms_clean)\n\nprint("\\nSmoothed bottom_y:")\nfor i, b in enumerate(smoothed_bottoms):\n    if i % 5 == 0:\n        print(f"{i:3d}: {b:.1f}")\n\n# Find the minimum (highest point of jump)\nmin_idx = np.argmin([b if b > 0 else 999 for b in bottoms])\nprint(f"\\nMinimum bottom_y at frame {min_idx}: value={bottoms[min_idx]}")\n\n# The takeoff should be before the minimum, when feet start rising\n# The landing should be after the minimum, when feet come back down\n\n# Let\'s find when bottom_y first drops below a threshold (takeoff)\n# and when it comes back up (landing)\n\n# Use derivative: when velocity (change in bottom_y) becomes negative and large\nprint("\\n\\nVelocity (change in bottom_y):")\nvelocities = []\nfor i in range(1, len(smoothed_bottoms)):\n    v = smoothed_bottoms[i] - smoothed_bottoms[i-1]\n    velocities.append(v)\n    if i % 5 == 0 or (i >= 48 and i <= 78):\n        print(f"{i:3d}: {v:.1f}")\nEOF\n'] min_timeout_sec: 6.0 max_timeout_sec: 180.0
