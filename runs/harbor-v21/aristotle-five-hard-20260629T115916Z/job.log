Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Let\'s look at the image content more holistically\n# by computing the frame-to-frame difference and tracking the largest blob\n\n# First, let\'s understand the camera view:\n# - Background: track with a hurdle somewhere\n# - Athlete runs from one side, jumps over hurdle, continues\n\n# Let\'s look at the difference between consecutive frames to track motion\n\nprev_gray = None\nprint("Frame-to-frame analysis:")\nprint("Frame | motion_centroid_x | motion_centroid_y | bottom_of_motion | top_of_motion | area")\n\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if not ret:\n        break\n    \n    gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)\n    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n    \n    if prev_gray is not None:\n        diff = cv2.absdiff(gray, prev_gray)\n        _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)\n        \n        # Clean\n        kernel = np.ones((3,3), np.uint8)\n        motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n        motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n        \n        y_indices, x_indices = np.where(motion > 0)\n        \n        if len(y_indices) > 0:\n            weights = motion[y_indices, x_indices]\n            centroid_x = np.average(x_indices, weights=weights)\n            centroid_y = np.average(y_indices, weights=weights)\n            bottom_y = np.max(y_indices)\n            top_y = np.min(y_indices)\n            area = len(y_indices)\n        else:\n            centroid_x = 0\n            centroid_y = 0\n            bottom_y = 0\n            top_y = 0\n            area = 0\n        \n        if i % 10 == 0 or i == 119:\n            print(f"{i:3d}   | {centroid_x:16.1f} | {centroid_y:16.1f} | {bottom_y:14d} | {top_y:12d} | {area:6d}")\n    \n    prev_gray = gray\n\ncap.release()\nEOF\n'] min_timeout_sec: 6.0 max