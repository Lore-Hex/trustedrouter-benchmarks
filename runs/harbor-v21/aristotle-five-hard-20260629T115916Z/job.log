Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Let\'s look at the track area (y=240-520) and track motion more carefully\n# The track is relatively uniform, so the athlete will create significant difference\n\n# Get background\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\nbg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)\n\n# Define track region (y range from earlier analysis)\nTRACK_TOP = 240\nTRACK_BOTTOM = 520\n\nprint("Frame | track_bottom_y | track_centroid_y | track_centroid_x | track_area | is_jumping")\n\nprev_bottom = 0\nprev_centroid_y = 0\njumping = False\n\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if not ret:\n        break\n    \n    gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)\n    \n    # Focus on the track region\n    track_region = gray[TRACK_TOP:TRACK_BOTTOM, :]\n    bg_track = bg_gray[TRACK_TOP:TRACK_BOTTOM, :]\n    \n    diff = cv2.absdiff(track_region, bg_track)\n    diff = cv2.GaussianBlur(diff, (5, 5), 0)\n    \n    _, motion = cv2.threshold(diff, 20, 255, cv2.THRESH_BINARY)\n    \n    # Clean\n    kernel = np.ones((3,3), np.uint8)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n    \n    # Find motion\n    y_indices, x_indices = np.where(motion > 0)\n    \n    if len(y_indices) > 0:\n        # Convert y back to original frame coordinates\n        bottom_y = np.max(y_indices) + TRACK_TOP\n        top_y = np.min(y_indices) + TRACK_TOP\n        weights = motion[y_indices, x_indices]\n        centroid_y = np.average(y_indices, weights=weights) + TRACK_TOP\n        centroid_x = np.average(x_indices, weights=weights)\n        area = len(y_indices)\n        \n        # Detect takeoff: when bottom_y decreases significantly (feet rise)\n        if prev_bottom > 0 and bottom_y < prev_bottom - 30:\n            # Feet moved up by more than 30 pixels\n            jumping = True\n        elif prev_bottom > 0 and bottom_y > prev_bottom + 30 and jumping:\n            # Feet moved down by more than 30 pixels while was jumping\n            jumping = False\n        \n        print(f"{i:3d}   | {bottom_y:14d} | {centroid_y:16.1f} | {centroid_x:16.1f} | {area:9d} | {str(jumping):>10}")\n        \n        prev_bottom = bottom_y\n        prev_centroid_y = centroid_y\n    else:\n        print(f"{i:3d}   | {\'\':>14} | {\'\':>16} | {\'\':>16} | {\'\':>9} | {\'\':>10}")\n        prev_bottom = 0\n        prev_centroid_y = 0\n\ncap.release()\nEOF\n'] min_timeout_sec: 6.0 max_timeout_sec: 180.0
