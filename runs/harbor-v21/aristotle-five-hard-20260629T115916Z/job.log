Sending keys: ['cat > /tmp/comprehensive_extract.py << \'ENDPY\'\nimport os\nimport glob\n\nocr_dir = "/tmp/ocr_output"\n\nfiles = sorted(glob.glob(os.path.join(ocr_dir, "frame_*.txt")), key=lambda x: int(os.path.basename(x).split(\'_\')[1].split(\'.\')[0]))\nprint(f"Found {len(files)} OCR files")\n\ndef extract_commands(text):\n    """Extract ALL commands from lines starting with >."""\n    cmds = []\n    for line in text.split(\'\\n\'):\n        stripped = line.strip()\n        if stripped.startswith(\'>\') and len(stripped) > 1:\n            cmd = stripped[1:].strip()\n            if cmd and len(cmd) >= 1:\n                cmds.append(cmd)\n    return cmds\n\n# Collect commands in order of first appearance\nall_commands = []\ncommands_set = set()\n\nfor filepath in files:\n    with open(filepath, \'r\') as f:\n        text = f.read()\n    cmds = extract_commands(text)\n    for cmd in cmds:\n        if cmd not in commands_set:\n            commands_set.add(cmd)\n            all_commands.append(cmd)\n\nprint(f"\\nTotal unique commands: {len(all_commands)}")\nfor i, cmd in enumerate(all_commands):\n    print(f"{i+1}. {cmd}")\n\n# Save\nwith open("/app/solution.txt", "w") as f:\n    for cmd in all_commands:\n        f.write(cmd + "\\n")\nprint(f"\\nSaved {len(all_commands)} commands to /app/solution.txt")\nENDPY\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
