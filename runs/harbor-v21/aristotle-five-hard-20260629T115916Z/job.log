 v3 vd; sub(vd, ro, hp); nrm(vd);\n                v3 hf; add(hf, ld, vd); nrm(hf);\n                float sp = powf(fmaxf(0,dot(hn,hf)), 20);\n                col[0]+=sp*0.5f; col[1]+=sp*0.5f; col[2]+=sp*0.5f;\n            }\n            \n            v3 hp2, hn2;\n            t = pln(ro, rd, -0.5f, hp2, hn2);\n            if(t>0 && t<tmin) {\n                int ix = (int)floorf(hp2[0]*2);\n                int iz = (int)floorf(hp2[2]*2);\n                float ch = ((ix+iz)&1) ? 0.9f : 0.4f;\n                float ds = sqrtf(hp2[0]*hp2[0]+hp2[2]*hp2[2]);\n                float fg = fminf(1, ds*0.5f);\n                float gy = ch*(1-fg)+0.5f*fg;\n                col[0]=col[1]=col[2]=gy;\n            }\n            \n            if(tmin>1e9) {\n                float st = fmaxf(0, rd[1]*0.5f+0.5f);\n                col[0]=0.6f+st*0.2f; col[1]=0.75f+st*0.1f; col[2]=1;\n            }\n            \n            img[idx++]=fmaxf(0,fminf(1,col[0]));\n            img[idx++]=fmaxf(0,fminf(1,col[1]));\n            img[idx++]=fmaxf(0,fminf(1,col[2]));\n        }\n        if(j%60==0) fprintf(stderr,"\\rProgress: %.1f%%",100.*j/H);\n    }\n    \n    fprintf(stderr,"\\rProgress: 99.8%%\\n");\n    fprintf(stderr,"Rendering complete\\n");\n    \n    FILE *fp = fopen("image.ppm","w");\n    fprintf(fp,"P3\\n%d %d\\n255\\n",W,H);\n    for(i=0;i<W*H*3;i+=3)\n        fprintf(fp,"%d %d %d\\n",(int)(img[i]*255.99f),(int)(img[i+1]*255.99f),(int)(img[i+2]*255.99f));\n    fclose(fp);\n    \n    fprintf(stderr,"Wrote image to image.ppm\\n");\n    fprintf(stderr,"Done.\\n");\n    free(img);\n    return 0;\n}\nENDPROG\ngcc -static -o reversed mystery.c -lm 2>&1 && ./reversed 2>&1\n'] min_timeout_sec: 3.0 max_timeout_sec: 180.0
