= 31  # offset value (0..31), actual distance offset+1\n    max_len = (1 << (OFF2 + 1)) - 1 - (1 << OFF2)  # 3\n    max_len = 3  # length value (1..4)\n\n    symbols = []  # list of ('lit', byte) or ('ref', offset_val, len_val)\n    i = 0\n    n = len(data)\n    while i < n:\n        best_len = 0\n        best_off = 0\n        for off in range(1, min(i, 31) + 1):\n            # match starting at i-off\n            l = 0\n            while l < 4 and i + l < n and data[i - off + l] == data[i + l]:\n                l += 1\n            if l > best_len:\n                best_len = l\n                best_off = off\n        if best_len >= 2:\n            symbols.append(('ref', best_off - 1, best_len - 1))\n            i += best_len\n        else:\n            # literal: sign bit and get_integer(4, 9)\n            # value = get_integer(4, 9), byte = (1 - 2*sign) * value\n            # For byte 0..127: sign=0, value=byte. For high bytes, sign=1, value = 256 - byte.\n            b = data[i]\n            if b < 128:\n                sign = 0\n                val = b\n            else:\n                sign = 1\n                val = 256 - b\n            symbols.append(('lit', sign, val))\n            i += 1\n\n    # Encode number of symbols\n    enc.encode_integer(INTOFF, 0, len(symbols))\n\n    for sym in symbols:\n        if sym[0] == 'ref':\n            enc.encode_bit(1, 1)\n            enc.encode_integer(OFF1, 2, sym[1])  # offset - 1\n            enc.encode_integer(OFF2, 3, sym[2])  # len - 1\n        else:\n            enc.encode_bit(1, 0)\n            enc.encode_bit(8, sym[1])  # sign\n            enc.encode_integer(LITSIZE, 9, sym[2])  # value\n\n    return enc.finish()\n\n\ndef main():\n    with open('/app/data.txt', 'rb') as f:\n        data = f.read()\n    comp = compress(data)\n    with open('/app/data.comp', 'wb') as f:\n        f.write(comp)\n    sys.stderr.write(f'compressed size: {len(comp)} bytes\\n')\n\nif __name__ == '__main__':\n    main()\nPYEOF\npython3 