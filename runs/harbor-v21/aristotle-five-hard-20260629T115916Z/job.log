Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Get background\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\n\n# Let\'s try frame-to-frame difference to reduce noise\nprev_frame = None\nresults = []\n\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, frame = cap.read()\n    if not ret:\n        break\n    \n    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n    gray_bg = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)\n    \n    # Difference from background\n    diff_bg = cv2.absdiff(gray, gray_bg)\n    \n    # Apply Gaussian blur to reduce noise\n    diff_bg = cv2.GaussianBlur(diff_bg, (5, 5), 0)\n    \n    # Threshold\n    _, thresh = cv2.threshold(diff_bg, 15, 255, cv2.THRESH_BINARY)\n    \n    # Morphological operations to clean up\n    kernel = np.ones((3,3), np.uint8)\n    thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)\n    thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)\n    \n    # Find bottom-most row of the largest connected component\n    # Find all contours\n    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    \n    if contours:\n        # Find the largest contour by area\n        largest = max(contours, key=cv2.contourArea)\n        \n        # Get bounding rect\n        x, y, w, h = cv2.boundingRect(largest)\n        bottom_y = y + h\n        center_x = x + w // 2\n        center_y = y + h // 2\n        area = cv2.contourArea(largest)\n        \n        # Also get the bottom-most y of the contour\n        # Get all points of the contour\n        pts = largest.squeeze()\n        if pts.ndim == 2:\n            max_y = np.max(pts[:, 1])\n            min_y = np.min(pts[:, 1])\n        else:\n            max_y = bottom_y\n            min_y = y\n        \n        results.append((i, bottom_y, max_y, min_y, center_x, center_y, area))\n    else:\n        results.append((i, 0, 0, 0, 0, 0, 0))\n    \n    prev_frame = frame\n\nprint("Frame | bottom_y | max_y | min_y | center_x | center_y | area")\nfor r in results:\n    print(f"{r[0]:3d}   | {r[1]:4d}    | {r[2]:4d} | {r[3]:4d}  | {r[4]:4d}     | {r[5]:4d}    | {r[6]:6d}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
