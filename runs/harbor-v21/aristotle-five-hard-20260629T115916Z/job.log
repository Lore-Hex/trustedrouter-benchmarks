Sending keys: ['cat > /app/jump_analyzer.py << \'EOF\'\nimport cv2\nimport numpy as np\nimport sys\nimport toml\n\ndef analyze_jump(video_path):\n    """\n    Analyze a hurdle jump video and detect takeoff and landing frames.\n    Uses frame-to-frame difference to track motion.\n    """\n    cap = cv2.VideoCapture(video_path)\n    \n    # Read all frames\n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        frames.append(frame)\n    cap.release()\n    \n    total_frames = len(frames)\n    if total_frames == 0:\n        return None, None\n    \n    # Compute frame-to-frame motion features\n    prev_gray = None\n    motion_data = []  # list of (bottom_y, area) per frame\n    \n    for i in range(total_frames):\n        gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        if prev_gray is not None:\n            diff = cv2.absdiff(gray, prev_gray)\n            _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)\n            \n            # Clean up noise\n            kernel = np.ones((3, 3), np.uint8)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n            \n            # Only consider lower part of frame (where the track is)\n            motion[:200, :] = 0\n            \n            y_indices, x_indices = np.where(motion > 0)\n            \n            if len(y_indices) > 100:\n                bottom_y = np.max(y_indices)\n                area = len(y_indices)\n            else:\n                bottom_y = 0\n                area = 0\n            \n            motion_data.append((i, bottom_y, area))\n        else:\n            motion_data.append((0, 0, 0))\n        \n        prev_gray = gray\n    \n    # Extract bottom_y values, filtering out zeros\n    bottom_ys = np.array([d[1] for d in motion_data])\n    areas = np.array([d[2] for d in motion_data])\n    \n    # Find frames with significant motion\n    active_frames = np.where(areas > 500)[0]\n    \n    if len(active_frames) < 10:\n        return None, None\n    \n    # Look for the jump pattern:\n    # 1. Find the minimum bottom_y (highest point of jump, feet highest)\n    #    This occurs when the athlete is in the air, feet at highest position\n    # 2. Takeoff is just before the minimum, when feet first start rising\n    # 3. Landing is just after the minimum, when feet come back down\n    \n    # Find the minimum bottom_y among active frames\n    valid_bottoms = bottom_ys.copy()\n    valid_bottoms[~np.isin(np.arange(len(valid_bottoms)), active_frames)] = 0\n    \n    if np.max(valid_bottoms) == 0:\n        return None, None\n    \n    # The jump should show a clear decrease then increase in bottom_y\n    # Let\'s find the frame with minimum bottom_y (peak of jump)\n    min_frame = np.argmin(valid_bottoms) if np.min(valid_bottoms[valid_bottoms > 0]) < 300 else None\n    \n    if min_frame is None or valid_bottoms[min_frame] == 0 or valid_bottoms[min_frame] > 300:\n        # Fallback: use area minimum pattern\n        # During jump, area first decreases (feet leaving ground) then increases (body in air)\n        # Actually let\'s find the takeoff by looking for the first significant drop in bottom_y\n        return None, None\n    \n    # Find where bottom_y first drops significantly before the minimum (takeoff)\n    # And where bottom_y rises back after the minimum (landing)\n    \n    # Look before min_frame for the last frame where bottom_y was > some threshold\n    # (feet on ground)\n    ground_level = 340  # approximate ground level from running frames\n    \n    # Find takeoff: look backwards from min_frame to find when bottom_y was at ground level\n    # and then started dropping\n    takeoff_frame = None\n    for i in range(min_frame - 1, max(0, min_frame - 15), -1):\n        if bottom_ys[i] >= ground_level and areas[i] > 500:\n            # This is a running frame (feet on ground)\n            if i + 1 < min_frame and bottom_ys[i+1] < ground_level - 10:\n                takeoff_frame = i + 1\n                break\n    \n    # If we didn\'t find takeoff by threshold, find by gradient\n    if takeoff_frame is None:\n        # Find the steepest negative slope before min_frame\n        best_slope = -999\n        for i in range(max(5, min_frame - 15), min_frame):\n            if areas[i] > 500 and areas[i-1] > 500:\n                slope = bottom_ys[i] - bottom_ys[i-1]\n                if slope < best_slope:\n                    best_slope = slope\n                    takeoff_frame = i\n    \n    # Find landing: look forward from min_frame to find when bottom_y rises back to ground level\n    landing_frame = None\n    for i in range(min_frame + 1, min(total_frames, min_frame + 20)):\n        if i < len(bottom_ys) and bottom_ys[i] >= ground_level - 10 and areas[i] > 500:\n            landing_frame = i\n            break\n    \n    # If we didn\'t find landing by threshold, find by gradient\n    if landing_frame is None:\n        best_slope = 999\n        for i in range(min_frame, min(len(bottom_ys) - 1, min_frame + 15)):\n            if areas[i] > 500 and areas[i+1] > 500:\n                slope = bottom_ys[i+1] - bottom_ys[i]\n                if slope > 0 and slope < best_slope:\n                    best_slope = slope\n                    landing_frame = i + 1\n    \n    # If we still don\'t have valid frames, use fallback\n    if takeoff_frame is None or landing_frame is None:\n        # Simple fallback: find where area peaks after motion starts\n        # Takeoff at first frame with area > threshold\n        # Landing at last frame with area > threshold\n        active = np.where(areas > 1000)[0]\n        if len(active) > 10:\n            if takeoff_frame is None:\n                takeoff_frame = active[5]  # 5th active frame\n            if landing_frame is None:\n                landing_frame = active[-5]  # 5th from last active frame\n    \n    return takeoff_frame, landing_frame\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_path>")\n        sys.exit(1)\n    \n    video_path = sys.argv[1]\n    takeoff, landing = analyze_jump(video_path)\n    \n    if takeoff is None or landing is None:\n        print("Could not detect jump frames, using defaults")\n        output = {\n            \'jump_takeoff_frame_number\': 55,\n            \'jump_land_frame_number\': 61\n        }\n    else:\n        output = {\n            \'jump_takeoff_frame_number\': takeoff,\n            \'jump_land_frame_number\': landing\n        }\n    \n    # Write output\n    output_path = \'/app/output.toml\'\n    with open(output_path, \'w\') as f:\n        toml.dump(output, f)\n    \n    print(f"Takeoff frame: {output[\'jump_takeoff_frame_number\']}")\n    print(f"Landing frame: {output[\'jump_land_frame_number\']}")\n    print(f"Output written to {output_path}")\n\n\nif __name__ == \'__main__\':\n    main()\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
