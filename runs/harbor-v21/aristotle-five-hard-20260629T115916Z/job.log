Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Let\'s try frame-to-frame difference\nframes = []\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if not ret:\n        break\n    gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)\n    frames.append(gray)\n\nprint("Analyzing frame-to-frame differences...")\nprint("\\nFrame | diff_sum | bottom_motion_y | top_motion_y")\n\nfor i in range(1, 120):\n    # Difference between consecutive frames\n    diff = cv2.absdiff(frames[i], frames[i-1])\n    \n    # Apply blur\n    diff = cv2.GaussianBlur(diff, (5, 5), 0)\n    \n    # Threshold\n    _, thresh = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)\n    \n    # Morphology\n    kernel = np.ones((3,3), np.uint8)\n    thresh = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)\n    thresh = cv2.morphologyEx(thresh, cv2.MORPH_OPEN, kernel)\n    \n    # Get vertical projection (only for the bottom half of frame, y > 100)\n    # to avoid sky noise\n    lower_half = thresh[100:, :]\n    vert_proj = np.sum(lower_half, axis=1) / 255.0\n    \n    # Find rows with motion\n    motion_rows = np.where(vert_proj > 5)[0]\n    \n    diff_sum = np.sum(vert_proj)\n    \n    if len(motion_rows) > 0:\n        bottom_y = np.max(motion_rows) + 100  # add back the offset\n        top_y = np.min(motion_rows) + 100\n    else:\n        bottom_y = 0\n        top_y = 0\n    \n    if i % 5 == 0 or i < 5:\n        print(f"{i:3d}    | {diff_sum:7.0f}  | {bottom_y:4d}         | {top_y:4d}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 6.0 max_timeout_sec: 180.0
