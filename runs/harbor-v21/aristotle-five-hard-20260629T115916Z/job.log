Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Get background\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\n\n# Let\'s look at specific frames to understand the scene better\n# Check frame 50 (approaching hurdle), 60 (maybe jumping), 70 (in air), 80 (landing)\nfor i in [50, 55, 60, 65, 70, 75, 80, 85, 90]:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, frame = cap.read()\n    if ret:\n        # Save for inspection\n        cv2.imwrite(f\'/app/debug_{i}.jpg\', frame)\n        \n        diff = cv2.absdiff(bg, frame)\n        gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)\n        _, thresh = cv2.threshold(gray, 30, 255, cv2.THRESH_BINARY)\n        \n        # Find contours to get bounding box of motion\n        contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n        \n        # Find the largest contour (the athlete)\n        if contours:\n            largest = max(contours, key=cv2.contourArea)\n            x, y, w, h = cv2.boundingRect(largest)\n            print(f"Frame {i}: bbox=({x},{y},{w},{h}), bottom={y+h}, center=({x+w//2},{y+h//2})")\n\ncap.release()\nprint("\\nSaved debug frames")\nEOF\n'] min_timeout_sec: 3.0 max_timeout_sec: 180.0
