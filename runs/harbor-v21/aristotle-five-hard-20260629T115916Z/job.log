Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Let\'s examine the vertical profile of the difference image\n# We want to find where the MOVING athlete is\n# The athlete will create a region of difference\n# But we need to isolate the athlete from other noise\n\n# Let\'s look at a specific region: the track area (bottom half of frame)\n# and track how the athlete\'s silhouette changes\n\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\nbg_gray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)\n\n# Let\'s examine specific frames and print the vertical profile\n# of a narrow horizontal strip (x=400 to 600, which seems to be where the athlete runs)\n\nprint("Vertical profile of columns 400-600 (sum per row):")\nfor fn in [0, 30, 50, 60, 65, 70, 75, 80, 90, 100, 110, 119]:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, fn)\n    ret, f = cap.read()\n    if not ret:\n        continue\n    gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)\n    diff = cv2.absdiff(gray, bg_gray)\n    \n    # Look at a specific x range where the athlete runs\n    # From earlier data, center_x seems to be around 400-600\n    x_start, x_end = 300, 700\n    strip = diff[:, x_start:x_end]\n    \n    # Vertical projection (sum across columns for each row)\n    vert_proj = np.sum(strip, axis=1)\n    \n    # Normalize\n    max_val = np.max(vert_proj) if np.max(vert_proj) > 0 else 1\n    vert_proj_norm = vert_proj / max_val * 50\n    \n    # Print as simple histogram\n    print(f"\\nFrame {fn}:")\n    for y in range(0, 540, 20):\n        bar = int(vert_proj_norm[y])\n        print(f"{y:3d}: {\'#\' * bar}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
