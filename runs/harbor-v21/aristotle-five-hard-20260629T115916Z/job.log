Sending keys: ['cat > /app/jump_analyzer.py << \'EOF\'\nimport cv2\nimport numpy as np\nimport sys\nimport toml\n\ndef analyze_jump(video_path):\n    """\n    Analyze a hurdle jump video and detect takeoff and landing frames.\n    """\n    cap = cv2.VideoCapture(video_path)\n    \n    # Read all frames\n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        frames.append(frame)\n    cap.release()\n    \n    total_frames = len(frames)\n    if total_frames == 0:\n        return None, None\n    \n    # Compute frame-to-frame motion features\n    prev_gray = None\n    bottom_y_list = []\n    \n    for i in range(total_frames):\n        gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        if prev_gray is not None:\n            diff = cv2.absdiff(gray, prev_gray)\n            _, motion = cv2.threshold(diff, 10, 255, cv2.THRESH_BINARY)\n            \n            # Clean up noise\n            kernel = np.ones((3, 3), np.uint8)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n            motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n            \n            # Only consider lower part of frame (where the track is)\n            # This avoids sky noise\n            motion[:200, :] = 0\n            \n            y_indices, x_indices = np.where(motion > 0)\n            \n            if len(y_indices) > 100:\n                bottom_y = np.max(y_indices)\n            else:\n                bottom_y = 0\n            \n            bottom_y_list.append(bottom_y)\n        else:\n            bottom_y_list.append(0)\n        \n        prev_gray = gray\n    \n    # Now analyze the bottom_y trajectory to find takeoff and landing\n    # Takeoff: when bottom_y starts decreasing (feet rise)\n    # Landing: when bottom_y starts increasing after being airborne\n    \n    # First, smooth the data\n    def smooth(data, window=3):\n        smoothed = []\n        for i in range(len(data)):\n            start = max(0, i - window)\n            end = min(len(data), i + window + 1)\n            vals = [v for v in data[start:end] if v > 0]\n            if len(vals) > 0:\n                smoothed.append(np.mean(vals))\n            else:\n                smoothed.append(0)\n        return smoothed\n    \n    smoothed_bottoms = smooth(bottom_y_list)\n    \n    # Compute velocity (first derivative)\n    velocities = []\n    for i in range(1, len(smoothed_bottoms)):\n        v = smoothed_bottoms[i] - smoothed_bottoms[i-1]\n        velocities.append(v)\n    \n    # Detect takeoff: look for sustained negative velocity (feet rising)\n    # We need several consecutive frames with negative velocity\n    takeoff_frame = None\n    for i in range(len(velocities) - 2):\n        frame_idx = i + 1  # velocity[i] corresponds to frame i+1\n        if (velocities[i] < -8 and \n            velocities[i+1] < -8 and \n            smoothed_bottoms[frame_idx] > 0):\n            # Takeoff likely starts here or earlier\n            # Find the exact frame where velocity first became negative\n            for j in range(max(0, i-3), i+1):\n                if velocities[j] < -5 and velocities[j+1] < -5:\n                    takeoff_frame = j + 1  # frame index from velocity\n                    break\n            if takeoff_frame is not None:\n                break\n    \n    # Detect landing: look for when feet return to ground after being airborne\n    # Find the frame after the apex where velocity is positive and significant\n    landing_frame = None\n    \n    # Find the apex (minimum smoothed bottoms)\n    min_frame = None\n    min_val = float(\'inf\')\n    for i, b in enumerate(smoothed_bottoms):\n        if b > 0 and b < min_val:\n            min_val = b\n            min_frame = i\n    \n    if min_frame is not None:\n        # Look after the apex for landing\n        for i in range(min_frame, min(len(velocities), min_frame + 15)):\n            if velocities[i] > 8:\n                landing_frame = i + 1  # velocity i corresponds to frame i+1\n                break\n    \n    return takeoff_frame, landing_frame\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_path>")\n        sys.exit(1)\n    \n    video_path = sys.argv[1]\n    takeoff, landing = analyze_jump(video_path)\n    \n    if takeoff is None or landing is None:\n        print("Could not detect jump frames")\n        # Provide default fallback values\n        output = {\n            \'jump_takeoff_frame_number\': 0,\n            \'jump_land_frame_number\': 0\n        }\n    else:\n        output = {\n            \'jump_takeoff_frame_number\': takeoff,\n            \'jump_land_frame_number\': landing\n        }\n    \n    # Write output\n    output_path = \'/app/output.toml\'\n    with open(output_path, \'w\') as f:\n        toml.dump(output, f)\n    \n    print(f"Takeoff frame: {takeoff}")\n    print(f"Landing frame: {landing}")\n    print(f"Output written to {output_path}")\n\n\nif __name__ == \'__main__\':\n    main()\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
