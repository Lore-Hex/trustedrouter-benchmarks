Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Let\'s look at the first frame and find the ground line\n# The ground is where the sky meets the track\n\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\ngray = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)\n\n# Compute horizontal edges to find the horizon/ground line\n# The track surface should start at some y-coordinate\n\n# Let\'s look at vertical gradient (difference between rows)\n# At the horizon, there should be a significant change\nprint("Vertical gradient (diff between consecutive rows) at center column:")\nfor y in range(1, 540):\n    diff = abs(int(gray[y, 480]) - int(gray[y-1, 480]))\n    if diff > 20:\n        print(f"y={y}: diff={diff}")\n\n# Let\'s also look at the row-wise standard deviation\n# The track should be relatively uniform, while the sky might have more variation\nprint("\\n\\nRow-wise std dev at x=400-600:")\nfor y in range(0, 540, 20):\n    strip = gray[y, 400:600]\n    mean_val = np.mean(strip)\n    std_val = np.std(strip)\n    print(f"y={y:3d}: mean={mean_val:.1f}, std={std_val:.1f}")\n\n# Now let\'s look for the hurdle\n# The hurdle should have horizontal and vertical white bars\n# Let\'s look for white regions in the background\nprint("\\n\\nLooking for white regions (hurdle candidates):")\n# Threshold above 180\nwhite_mask = gray > 180\n# Find connected components\nfrom scipy import ndimage\n# Let\'s just scan for horizontal white lines\nfor y in range(200, 400):\n    row = gray[y, :]\n    # Find runs of bright pixels\n    bright = row > 180\n    # Count length of continuous bright regions\n    changes = np.diff(bright.astype(int))\n    starts = np.where(changes == 1)[0]\n    ends = np.where(changes == -1)[0]\n    if len(starts) > 0 and len(ends) > 0:\n        for s, e in zip(starts, ends):\n            if e - s > 50:  # At least 50 pixels wide\n                print(f"y={y}: bright bar at x={s}-{e} (width={e-s})")\n\ncap.release()\nEOF\n'] min_timeout_sec: 4.0 max_timeout_sec: 180.0
