Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Get background\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\n\n# Let\'s examine a few frames and look at horizontal scanlines to find the athlete\n# The athlete is a dark silhouette against the track\n\nprint("\\n=== Horizontal scanline at y=400 for various frames ===")\nprint("(Looking for dark pixels indicating athlete silhouette)")\n\nfor fn in [0, 30, 50, 60, 70, 80, 90, 100, 110, 119]:\n    cap.set(cv2.CAP_PROP_POS_FRAMES, fn)\n    ret, f = cap.read()\n    if not ret:\n        continue\n    gray = cv2.cvtColor(f, cv2.COLOR_BGR2GRAY)\n    \n    # Look at row 400\n    row400 = gray[400, :]\n    \n    # Find the minimum (darkest) value and its position\n    min_val = np.min(row400)\n    min_pos = np.argmin(row400)\n    mean_val = np.mean(row400)\n    \n    # Also look for regions that are significantly darker than the background mean\n    bg_row = cv2.cvtColor(bg, cv2.COLOR_BGR2GRAY)[400, :]\n    bg_mean = np.mean(bg_row)\n    \n    # Find pixels that are at least 20 units darker than background\n    dark_pixels = np.where((bg_row - row400) > 20)[0]\n    \n    print(f"Frame {fn:3d}: row_400 min={min_val} at x={min_pos}, mean={mean_val:.0f}, bg_mean={bg_mean:.0f}, dark_pixels={len(dark_pixels)}")\n    if len(dark_pixels) > 0:\n        print(f"         dark region: x={dark_pixels[0]}-{dark_pixels[-1]}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 4.0 max_timeout_sec: 180.0
