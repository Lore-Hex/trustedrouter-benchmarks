Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Read all frames\nframes = []\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if ret:\n        frames.append(f)\n    else:\n        break\ncap.release()\n\nbg_gray = cv2.cvtColor(frames[0], cv2.COLOR_BGR2GRAY)\n\nprint("Frame | bottom_y | centroid_y | area | feet_above_ground")\n\n# Track the bottom of motion (foot position)\n# Also track the area to detect when athlete is airborne\n\nresults = []\nfor i in range(120):\n    gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n    \n    diff = cv2.absdiff(gray, bg_gray)\n    _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)\n    \n    # Clean\n    kernel = np.ones((5,5), np.uint8)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n    \n    # Only look at y=300-520 (track area)\n    # But also keep a wider region for the airborne athlete (y=200-520)\n    motion[:200, :] = 0\n    \n    y_indices, x_indices = np.where(motion > 0)\n    \n    if len(y_indices) > 50:\n        bottom_y = np.max(y_indices)\n        top_y = np.min(y_indices)\n        centroid_y = np.mean(y_indices)\n        centroid_x = np.mean(x_indices)\n        area = len(y_indices)\n        feet_above = 520 - bottom_y  # positive = above ground level\n        \n        results.append({\n            \'frame\': i,\n            \'bottom_y\': bottom_y,\n            \'top_y\': top_y,\n            \'centroid_y\': centroid_y,\n            \'centroid_x\': centroid_x,\n            \'area\': area,\n            \'feet_above\': feet_above\n        })\n    else:\n        results.append(None)\n    \n    if i % 5 == 0 or (i >= 50 and i <= 80):\n        if len(y_indices) > 50:\n            print(f"{i:3d}   | {bottom_y:5d} | {centroid_y:8.1f} | {area:5d} | {feet_above:15d}")\n        else:\n            print(f"{i:3d}   | {\'\':>5} | {\'\':>8} | {\'\':>5} | {\'\':>15}")\n\n# Now detect takeoff and landing\nprint("\\n\\n=== Detection ===")\n\n# Look for patterns:\n# Takeoff: bottom_y decreases (feet rise) AND area starts increasing (body goes up)\n# Landing: bottom_y increases (feet come down) AND area starts decreasing\n\nprev_bottom = None\nprev_area = None\n\nfor r in results:\n    if r is None:\n        prev_bottom = None\n        prev_area = None\n        continue\n    \n    i = r[\'frame\']\n    bottom = r[\'bottom_y\']\n    area = r[\'area\']\n    \n    if prev_bottom is not None and prev_area is not None:\n        bottom_change = bottom - prev_bottom\n        area_change = area - prev_area\n        \n        # Detect takeoff: bottom moves up (negative change) and area starts growing\n        if bottom_change < -15 and area_change > 100:\n            print(f"TAKEOFF at frame {i}: bottom {prev_bottom}->{bottom}, area {prev_area}->{area}")\n        \n        # Detect landing: bottom moves down (positive change) after being high\n        if bottom_change > 15 and prev_bottom < 400:\n            print(f"LANDING at frame {i}: bottom {prev_bottom}->{bottom}, area {prev_area}->{area}")\n    \n    prev_bottom = bottom\n    prev_area = area\nEOF\n'] min_timeout_sec: 8.0 max_timeout_sec: 180.0
