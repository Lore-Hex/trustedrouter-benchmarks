Sending keys: ['cat > /tmp/clean_solution.py << \'ENDPY\'\nimport os\nimport glob\n\nocr_dir = "/tmp/ocr_output"\n\nfiles = sorted(glob.glob(os.path.join(ocr_dir, "frame_*.txt")), key=lambda x: int(os.path.basename(x).split(\'_\')[1].split(\'.\')[0]))\n\n# For each frame, extract all commands (both transcript and typing)\n# Then track the sequence of commands as they first appear\n\nall_cmds = []\nseen = set()\n\nfor filepath in files:\n    with open(filepath, \'r\') as f:\n        text = f.read()\n    \n    for line in text.split(\'\\n\'):\n        stripped = line.strip()\n        if stripped.startswith(\'>\') and len(stripped) > 1:\n            cmd = stripped[1:].strip()\n            if cmd and len(cmd) >= 1:\n                if cmd not in seen:\n                    seen.add(cmd)\n                    all_cmds.append(cmd)\n\n# Print them all\nfor i, cmd in enumerate(all_cmds):\n    print(f"{i+1}. {cmd}")\n\nprint(f"\\nTotal: {len(all_cmds)}")\n\nwith open("/app/solution.txt", "w") as f:\n    for cmd in all_cmds:\n        f.write(cmd + "\\n")\nENDPY\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
