Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Get background\ncap.set(cv2.CAP_PROP_POS_FRAMES, 0)\nret, bg = cap.read()\n\n# For each frame, compute difference and find the bottom-most point of motion\n# We\'ll track the lowest point of the moving object (feet)\n\nresults = []\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, frame = cap.read()\n    if not ret:\n        break\n    \n    diff = cv2.absdiff(bg, frame)\n    gray = cv2.cvtColor(diff, cv2.COLOR_BGR2GRAY)\n    \n    # Use a threshold to get significant changes\n    _, thresh = cv2.threshold(gray, 30, 255, cv2.THRESH_BINARY)\n    \n    # Find the bottom-most row with significant motion\n    # Look at vertical projection\n    vert_proj = np.sum(thresh, axis=1) / 255.0\n    \n    # Find rows with at least some motion\n    # We want the bottom of the athlete, so scan from bottom up\n    significant_rows = np.where(vert_proj > 10)[0]\n    \n    if len(significant_rows) > 0:\n        bottom_y = np.max(significant_rows)\n        # Find top of the blob too\n        top_y = np.min(significant_rows)\n        total_motion = np.sum(vert_proj)\n        # Center of mass\n        weighted_y = np.sum(significant_rows * vert_proj[significant_rows]) / np.sum(vert_proj[significant_rows]) if np.sum(vert_proj[significant_rows]) > 0 else 0\n    else:\n        bottom_y = 0\n        top_y = 0\n        total_motion = 0\n        weighted_y = 0\n    \n    results.append((i, bottom_y, top_y, weighted_y, total_motion))\n    \n    if i < 10 or (i % 10 == 0):\n        print(f"Frame {i:3d}: bottom_y={bottom_y:3d}, top_y={top_y:3d}, center_y={weighted_y:5.1f}, motion={total_motion:6.0f}")\n\nprint("\\nFull data:")\nfor r in results:\n    print(f"{r[0]:3d} {r[1]:3d} {r[2]:3d} {r[3]:5.1f} {r[4]:6.0f}")\n\ncap.release()\nEOF\n'] min_timeout_sec: 4.0 max_timeout_sec: 180.0
