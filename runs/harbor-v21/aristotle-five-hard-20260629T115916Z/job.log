Sending keys: ['cat > /tmp/extract_full_sequence.py << \'ENDPY\'\nimport os\nimport glob\nimport re\n\nocr_dir = "/tmp/ocr_output"\n\nfiles = sorted(glob.glob(os.path.join(ocr_dir, "frame_*.txt")), key=lambda x: int(os.path.basename(x).split(\'_\')[1].split(\'.\')[0]))\nprint(f"Files: {len(files)}")\n\ndef get_commands(text):\n    """Get all commands from lines starting with >."""\n    cmds = []\n    for line in text.split(\'\\n\'):\n        stripped = line.strip()\n        if stripped.startswith(\'>\') and len(stripped) > 1:\n            cmd = stripped[1:].strip()\n            if cmd and len(cmd) >= 1:\n                cmds.append(cmd)\n    return cmds\n\ndef clean(cmd):\n    """Clean OCR artifacts from command."""\n    cmd = re.sub(r\'[_.,\\s]+$\', \'\', cmd)\n    cmd = cmd.strip()\n    return cmd\n\n# Sequence of completed commands\nsequence = []\nprev_typing = None\nprev_completed = None\n\nfor filepath in files:\n    with open(filepath, \'r\') as f:\n        text = f.read()\n    \n    cmds = get_commands(text)\n    \n    if len(cmds) == 0:\n        continue\n    \n    current_typing = cmds[-1]\n    \n    # If we had a previous typing command\n    if prev_typing and current_typing != prev_typing:\n        # The previous typing command was just completed\n        completed = clean(prev_typing)\n        if completed and len(completed) >= 1:\n            sequence.append(completed)\n    \n    # Also check if there are new historical commands (from transcript)\n    # The second-to-last command is the most recently completed\n    if len(cmds) >= 2:\n        recent_completed = cmds[-2]\n        if recent_completed != prev_completed:\n            prev_completed = recent_completed\n    \n    prev_typing = current_typing\n\n# Add the last command\nif prev_typing:\n    completed = clean(prev_typing)\n    if completed and len(completed) >= 1:\n        sequence.append(completed)\n\nprint(f"\\nTotal commands: {len(sequence)}")\nfor i, cmd in enumerate(sequence):\n    print(f"