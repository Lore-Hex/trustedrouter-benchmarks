Sending keys: ['python3 << \'EOF\'\nimport cv2\nimport numpy as np\nimport toml\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\n\n# Read all frames\nframes = []\nfor i in range(120):\n    cap.set(cv2.CAP_PROP_POS_FRAMES, i)\n    ret, f = cap.read()\n    if ret:\n        frames.append(f)\n    else:\n        break\ncap.release()\n\n# Background = first frame\nbg_gray = cv2.cvtColor(frames[0], cv2.COLOR_BGR2GRAY)\n\n# Let\'s compute a more refined motion metric:\n# Track the vertical position of the bottom of the moving object\n# Use background subtraction but mask out the top half (sky noise)\n\nprint("=== Refined motion analysis ===")\nprint("Frame | bottom_y | centroid_y | area | notes")\n\nresults = []\n\nfor i in range(120):\n    gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n    gray = cv2.GaussianBlur(gray, (5, 5), 0)\n    \n    # Background subtraction\n    diff = cv2.absdiff(gray, bg_gray)\n    \n    # Threshold\n    _, motion = cv2.threshold(diff, 15, 255, cv2.THRESH_BINARY)\n    \n    # Clean\n    kernel = np.ones((5,5), np.uint8)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_CLOSE, kernel)\n    motion = cv2.morphologyEx(motion, cv2.MORPH_OPEN, kernel)\n    \n    # Focus on the track region (y=300-520, x=200-800)\n    # This avoids sky noise\n    roi = np.zeros_like(motion)\n    roi[300:520, 200:800] = 1\n    motion_roi = cv2.bitwise_and(motion, roi)\n    \n    y_indices, x_indices = np.where(motion_roi > 0)\n    \n    if len(y_indices) > 100:\n        bottom_y = np.max(y_indices)\n        top_y = np.min(y_indices)\n        centroid_y = np.mean(y_indices)\n        centroid_x = np.mean(x_indices)\n        area = len(y_indices)\n        height = bottom_y - top_y\n        \n        results.append({\n            \'frame\': i,\n            \'bottom_y\': bottom_y,\n            \'top_y\': top_y,\n            \'centroid_y\': centroid_y,\n            \'centroid_x\': centroid_x,\n            \'area\': area,\n            \'height\': height\n        })\n        \n        if i % 5 == 0:\n            print(f"{i:3d}   | {bottom_y:5d} | {centroid_y:8.1f} | {area:5d} |")\n    else:\n        results.append(None)\n        if i % 5 == 0:\n            print(f"{i:3d}   | {\'\':>5} | {\'\':>8} | {\'\':>5} |")\n\n# Now let\'s find takeoff and landing by looking at significant changes\nprint("\\n\\n=== Detecting takeoff and landing ===")\n\n# Takeoff: when bottom_y decreases significantly (feet rise)\n# Landing: when bottom_y increases significantly after takeoff\n\n# Let\'s look at derivative of bottom_y\nprev_bottom = None\nprev_frame = None\n\ntakeoff_candidates = []\nland_candidates = []\n\nfor r in results:\n    if r is None:\n        prev_bottom = None\n        prev_frame = None\n        continue\n    \n    i = r[\'frame\']\n    bottom = r[\'bottom_y\']\n    \n    if prev_bottom is not None and prev_frame is not None:\n        # Change in bottom position\n        change = bottom - prev_bottom\n        \n        # Negative change = bottom moving UP (smaller y = higher in image)\n        # This could be takeoff (feet rising)\n        if change < -20 and bottom < 380:\n            print(f"Takeoff candidate at frame {i}: bottom_y {prev_bottom} -> {bottom} (change={change})")\n            takeoff_candidates.append(i)\n        \n        # Positive change = bottom moving DOWN (larger y = lower in image)\n        # This could be landing (feet going down)\n        if change > 20 and bottom > 440 and prev_bottom < 400:\n            print(f"Landing candidate at frame {i}: bottom_y {prev_bottom} -> {bottom} (change={change})")\n            land_candidates.append(i)\n    \n    prev_bottom = bottom\n    prev_frame = i\n\n# Now let\'s also look at the area pattern\nprint("\\n\\n=== Area analysis ===")\nfor r in results:\n    if r is None:\n        continue\n    i = r[\'frame\']\n    if i >= 45 and i <= 75:\n        print(f"Frame {i}: area={r[\'area\']}, bottom_y={r[\'bottom_y\']}")\nEOF\n'] min_timeout_sec: 8.0 max_timeout_sec: 180.0
