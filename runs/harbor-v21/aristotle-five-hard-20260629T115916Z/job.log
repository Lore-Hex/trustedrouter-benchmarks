Sending keys: ['cat > /tmp/strategic_solve.py << \'ENDPY\'\nimport os\nimport subprocess\n\n# Use the 1fps frames (190 frames)\nframes_dir = "/tmp/frames3"\nframes = sorted([f for f in os.listdir(frames_dir) if f.endswith(\'.png\')], key=lambda x: int(x.split(\'_\')[1].split(\'.\')[0]))\nprint(f"Total frames: {len(frames)}")\n\ndef extract_commands(text):\n    """Extract all commands from lines starting with >."""\n    cmds = []\n    for line in text.split(\'\\n\'):\n        stripped = line.strip()\n        if stripped.startswith(\'>\') and len(stripped) > 1:\n            cmd = stripped[1:].strip()\n            if cmd and len(cmd) >= 1:\n                cmds.append(cmd)\n    return cmds\n\n# Process frames and collect all commands in order seen\nall_seen = []\nprev_cmds_set = set()\n\nfor i, frame_file in enumerate(frames):\n    frame_path = os.path.join(frames_dir, frame_file)\n    result = subprocess.run(["tesseract", frame_path, "stdout"], capture_output=True, text=True)\n    text = result.stdout\n    cmds = extract_commands(text)\n    \n    # Add commands that are NEW in this frame (not seen in previous frame)\n    for cmd in cmds:\n        if cmd not in prev_cmds_set:\n            if cmd not in all_seen:\n                all_seen.append(cmd)\n                print(f"{cmd}")\n    \n    prev_cmds_set = set(cmds)\n\nprint(f"\\nTotal: {len(all_seen)}")\n\nwith open("/app/solution.txt", "w") as f:\n    for cmd in all_seen:\n        f.write(cmd + "\\n")\nENDPY\n'] min_timeout_sec: 0.3 max_timeout_sec: 180.0
