t stops falling\n\nprint("Frame | centroid_y | bottom_y | top_y | area | height | cent_y_change")\nfor i in range(120):\n    d = data[i]\n    if i > 0:\n        change = d[\'centroid_y\'] - data[i-1][\'centroid_y\']\n    else:\n        change = 0\n    \n    if i % 5 == 0 or (i >= 45 and i <= 85):\n        print(f"{d[\'frame\']:3d}   | {d[\'centroid_y\']:8.1f}  | {d[\'bottom_y\']:5d}  | {d[\'top_y\']:4d}  | {d[\'area\']:6d}  | {d[\'height\']:4d}  | {change:8.1f}")\nEOF\n'] min_timeout_sec: 5.0 max_timeout_sec: 180.0
