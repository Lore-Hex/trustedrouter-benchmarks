[?2004l[?2004h> import os
[?2004l[?2004h> import subprocess
[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> frames_dir = "/tmp/frames3"
[?2004l[?2004h> commands = []
[?2004l[?2004h> 
[?2004l[?2004h> # Get sorted list of frame files
[?2004l[?2004h> frames = sorted([f for f in os.listdir(frames_dir) if f.endswith('.png')], key=lambda x: int(x.split('_')[1].split('.')[0]))
[?2004l[?2004h> print(f"Total frames: {len(frames)}")
[?2004l[?2004h> 
[?2004l[?2004h> for frame_file in frames:
[?2004l[?2004h>     frame_path = os.path.join(frames_dir, frame_file)
[?2004l[?2004h>     result = subprocess.run(["tesseract", frame_path, "stdout"], capture_output=True, text=True)
[?2004l[?2004h>     text = result.stdout
[?2004l[?2004h>     
[?2004l[?2004h>     # Look for lines that start with '>' (the prompt)
[?2004l[?2004h>     lines = text.split('\n')
[?2004l[?2004h>     for i, line in enumerate(lines):
[?2004l[?2004h>         stripped = line.strip()
[?2004l[?2004h>         # The prompt line might be like ">n" or "> n" or just ">"
[?2004l[?2004h>         if stripped.startswith('>'):
[?2004l[?2004h>             cmd = stripped[1:].strip()  # Remove the '>' and trim
[?2004l[?2004h>             if cmd:  # Non-empty command
[?2004l[?2004h>                 commands.append(cmd)
[?2004l[?2004h>                 print(f"{frame_file}: Command: {cmd}")
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nTotal commands found: {len(commands)}")
[?2004l[?2004h> print("All commands:")
[?2004l[?2004h> for i, cmd in enumerate(commands):
[?2004l[?2004h>     print(f"{i+1}. {cmd}")
[?2004l[?2004h> 
[?2004l[?2004h> # Save to file
[?2004l[?2004h> with open("/app/solution.txt", "w") as f:
[?2004l[?2004h>     for cmd in commands:
[?2004l[?2004h>         f.write(cmd + "\n")
[?2004l[?2004h> print("\nSaved to /app/solution.txt")
