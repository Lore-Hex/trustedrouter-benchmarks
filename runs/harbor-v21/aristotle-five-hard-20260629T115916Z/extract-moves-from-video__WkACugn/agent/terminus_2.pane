[?2004l[?2004h> import os
[?2004l[?2004h> import glob
[?2004l[?2004h> import re
[?2004l[?2004h> 
[?2004l[?2004h> ocr_dir = "/tmp/ocr_output"
[?2004l[?2004h> 
[?2004l[?2004h> files = sorted(glob.glob(os.path.join(ocr_dir, "frame_*.txt")), key=lambda x: int(os.path.basename(x).split('_')[1].split('.')[0]))
[?2004l[?2004h> print(f"Files: {len(files)}")
[?2004l[?2004h> 
[?2004l[?2004h> def get_commands(text):
[?2004l[?2004h>     """Extract all commands from lines starting with >."""
[?2004l[?2004h>     cmds = []
[?2004l[?2004h>     for line in text.split('\n'):
[?2004l[?2004h>         stripped = line.strip()
[?2004l[?2004h>         if stripped.startswith('>') and len(stripped) > 1:
[?2004l[?2004h>             cmd = stripped[1:].strip()
[?2004l[?2004h>             if cmd and len(cmd) >= 1:
[?2004l[?2004h>                 cmds.append(cmd)
[?2004l[?2004h>     return cmds
[?2004l[?2004h> 
[?2004l[?2004h> # Build sequence by looking at all transcript commands across frames
[?2004l[?2004h> # The transcript shows commands in order from oldest (top) to newest (bottom)
