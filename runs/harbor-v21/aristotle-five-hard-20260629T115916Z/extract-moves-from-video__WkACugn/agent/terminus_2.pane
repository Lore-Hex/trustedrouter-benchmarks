[?2004l[?2004h> video_path = "/app/video.mp4"
[?2004l[?2004h> output_dir = "/tmp/frames2"
[?2004l[?2004h> os.makedirs(output_dir, exist_ok=True)
[?2004l[?2004h> 
[?2004l[?2004h> # Extract frames every second (or keyframes)
[?2004l[?2004h> # First, let's get the duration from ffprobe
[?2004l[?2004h> result = subprocess.run(["ffprobe", "-v", "error", "-show_entries", "format=duration", "-of", "csv=p=0", video_path], capture_output=True, text=True)
[?2004l[?2004h> duration = float(result.stdout.strip())
[?2004l[?2004h> print(f"Duration: {duration}s")
[?2004l[?2004h> 
[?2004l[?2004h> # Extract frames at key intervals (every 0.5 seconds to capture all commands)
[?2004l[?2004h> # We'll use 0.5s intervals
[?2004l[?2004h> interval = 0.5
[?2004l[?2004h> for i in range(int(duration / interval) + 1):
