[?2004l[?2004h> for line in lines:
[?2004l[?2004h>     cmd = line.strip()
[?2004l[?2004h>     # Skip empty
[?2004l[?2004h>     if not cmd:
[?2004l[?2004h>         continue
[?2004l[?2004h>     # Skip partial commands (ending with certain chars)
[?2004l[?2004h>     if cmd.endswith('_') or cmd.endswith(',') or cmd.endswith('.'):
[?2004l[?2004h>         continue
[?2004l[?2004h>     # Skip single-character noise
