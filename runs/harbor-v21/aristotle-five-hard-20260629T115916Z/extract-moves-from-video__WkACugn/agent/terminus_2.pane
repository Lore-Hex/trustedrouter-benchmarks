[?2004l[?2004h> 
[?2004l[?2004h> def get_last_command(text):
[?2004l[?2004h>     """Get the last command being typed (last line starting with >)."""
[?2004l[?2004h>     last_cmd = None
[?2004l[?2004h>     for line in text.split('\n'):
[?2004l[?2004h>         stripped = line.strip()
[?2004l[?2004h>         if stripped.startswith('>') and len(stripped) > 1:
[?2004l[?2004h>             cmd = stripped[1:].strip()
[?2004l[?2004h>             if cmd and len(cmd) >= 1:
[?2004l[?2004h>                 last_cmd = cmd
[?2004l[?2004h>     return last_cmd
[?2004l[?2004h> 
[?2004l[?2004h> # Track typing changes across ALL frames
[?2004l[?2004h> prev_typing = None
