[?2004l[?2004h> def clean_cmd(cmd):
[?2004l[?2004h>     """Clean and validate a command."""
[?2004l[?2004h>     cmd = cmd.strip()
[?2004l[?2004h>     # Remove trailing special characters (partial commands)
[?2004l[?2004h>     cmd = re.sub(r'[_.,]+$', '', cmd)
[?2004l[?2004h>     cmd = cmd.strip()
[?2004l[?2004h>     if not cmd or len(cmd) < 1:
[?2004l[?2004h>         return None
[?2004l[?2004h>     return cmd
