[?2004l[?2004h> data {
[?2004l[?2004h>   int<lower=0> N;
[?2004l[?2004h>   int<lower=0> y[N];
[?2004l[?2004h>   int<lower=0> n[N];
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> parameters {
[?2004l[?2004h>   real<lower=0> alpha;
[?2004l[?2004h>   real<lower=0> beta;
[?2004l[?2004h>   vector<lower=0, upper=1>[N] theta;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> model {
[?2004l[?2004h>   // Prior: p(alpha, beta) proportional to (alpha + beta)^{-5/2}
[?2004l[?2004h>   target += -2.5 * log(alpha + beta);
[?2004l[?2004h> 
[?2004l[?2004h>   // Hierarchical prior: theta_i ~ Beta(alpha, beta)
[?2004l[?2004h>   theta ~ beta(alpha, beta);
[?2004l[?2004h> 
[?2004l[?2004h>   // Likelihood: y_i ~ Binomial(n_i, theta_i)
[?2004l[?2004h>   y ~ binomial(theta, n);
[?2004l[?2004h> }
