cat > /app/analysis.R << 'REOF'
[?2004l[?2004h> library(rstan)
[?2004l[?2004h> 
[?2004l[?2004h> # Set Stan options
[?2004l[?2004h> rstan_options(auto_write = TRUE)
[?2004l[?2004h> options(mc.cores = 4)
[?2004l[?2004h> 
[?2004l[?2004h> # Load data
[?2004l[?2004h> dat <- read.csv("/app/data.csv")
[?2004l[?2004h> stan_data <- list(
[?2004l[?2004h>   N = nrow(dat),
[?2004l[?2004h>   y = dat$y,
[?2004l[?2004h>   n = dat$n
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Fit model
[?2004l[?2004h> fit <- sampling(
[?2004l[?2004h>   stan_model(file = "/app/hierarchical_model.stan"),
[?2004l[?2004h>   data = stan_data,
[?2004l[?2004h>   chains = 4,
[?2004l[?2004h>   iter = 100000,
[?2004l[?2004h>   seed = 1
[?2004l[?2004h> )
[?2004l[?2004h> 
[?2004l[?2004h> # Extract posterior samples and compute means
[?2004l[?2004h> samples <- extract(fit)
[?2004l[?2004h> alpha_mean <- mean(samples$alpha)
[?2004l[?2004h> beta_mean <- mean(samples$beta)
[?2004l[?2004h> 
[?2004l[?2004h> cat("Posterior mean of alpha:", alpha_mean, "\n")
[?2004l[?2004h> cat("Posterior mean of beta:", beta_mean, "\n")
[?2004l[?2004h> 
[?2004l[?2004h> # Save results
[?2004l[?2004h> writeLines(as.character(alpha_mean), "/app/posterior_alpha_mean.txt")
[?2004l[?2004h> writeLines(as.character(beta_mean), "/app/posterior_beta_mean.txt")
[?2004l[?2004h> REOF
