[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> 
[?2004l[?2004h> #define W 2400
[?2004l[?2004h> #define H 1800
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { double x,y,z; } V;
[?2004l[?2004h> V add(V a, V b){ return (V){a.x+b.x,a.y+b.y,a.z+b.z}; }
[?2004l[?2004h> V sub(V a, V b){ return (V){a.x-b.x,a.y-b.y,a.z-b.z}; }
[?2004l[?2004h> V mul(V a, double t){ return (V){a.x*t,a.y*t,a.z*t}; }
[?2004l[?2004h> V scale(V a, V b){ return (V){a.x*b.x,a.y*b.y,a.z*b.z}; }
[?2004l[?2004h> double dot(V a, V b){ return a.x*b.x+a.y*b.y+a.z*b.z; }
[?2004l[?2004h> double len(V a){ return sqrt(dot(a,a)); }
[?2004l[?2004h> V norm(V a){ double l=len(a); return (V){a.x/l,a.y/l,a.z/l}; }
[?2004l[?2004h> 
[?2004l[?2004h> int main(){
[?2004l[?2004h>     FILE *f = fopen("reconstructed.ppm","w");
[?2004l[?2004h>     fprintf(f,"P3\n%d %d\n255\n",W,H);
[?2004l[?2004h>     
[?2004l[?2004h>     V origin = {0,0,0};
[?2004l[?2004h>     V sph_c = {0,-0.5,-5};
[?2004l[?2004h>     double sph_r = 1.0;
[?2004l[?2004h>     double ground_y = -1.5;
[?2004l[?2004h>     V light = norm((V){1,1,-0.5});
[?2004l[?2004h>     double ambient = 0.3;
[?2004l[?2004h>     V mat = {170.0/255.0, 34.0/255.0, 34.0/255.0};
[?2004l[?2004h>     
[?2004l[?2004h>     double vw = 4.0, vh = 2.0, fl = 1.0;
[?2004l[?2004h>     V hor = {vw, 0, 0};
[?2004l[?2004h>     V ver = {0, vh, 0};
[?2004l[?2004h>     V llc = {-vw/2.0, -vh/2.0, -fl};
[?2004l[?2004h>     
[?2004l[?2004h>     for(int py=0;py<H;py++){
[?2004l[?2004h>         for(int px=0;px<W;px++){
[?2004l[?2004h>             double u = (double)px/(W-1);
[?2004l[?2004h>             double v = 1.0 - (double)py/(H-1);
[?2004l[?2004h>             V dir = add(add(llc, mul(hor,u)), mul(ver,v));
[?2004l[?2004h>             dir = norm(dir);
[?2004l[?2004h>             
[?2004l[?2004h>             int hit_sph = 0;
[?2004l[?2004h>             double t_sph = 1e30;
[?2004l[?2004h>             V n_sph;
[?2004l[?2004h>             
[?2004l[?2004h>             V oc = sub(origin, sph_c);
[?2004l[?2004h>             double a = dot(dir,dir);
[?2004l[?2004h>             double b = dot(oc, dir);
[?2004l[?2004h>             double c2 = dot(oc,oc) - sph_r*sph_r;
[?2004l[?2004h>             double disc = b*b - a*c2;
[?2004l[?2004h>             if(disc > 0){
[?2004l[?2004h>                 double t = (-b - sqrt(disc))/a;
[?2004l[?2004h>                 if(t > 0.001){
[?2004l[?2004h>                     hit_sph = 1;
[?2004l[?2004h>                     t_sph = t;
[?2004l[?2004h>                     V hp = add(origin, mul(dir,t));
[?2004l[?2004h>                     n_sph = norm(sub(hp, sph_c));
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             int hit_gnd = 0;
[?2004l[?2004h>             double t_gnd = 1e30;
[?2004l[?2004h>             if(dir.y < -1e-9){
[?2004l[?2004h>                 t_gnd = (ground_y - origin.y)/dir.y;
[?2004l[?2004h>                 if(t_gnd > 0.001) hit_gnd = 1;
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             int r,g,bb;
[?2004l[?2004h>             if(hit_sph && t_sph < t_gnd){
[?2004l[?2004h>                 double d = dot(n_sph, light);
[?2004l[?2004h>                 double intensity = ambient + (d > 0 ? d : 0);
[?2004l[?2004h>                 if(intensity > 1.3) intensity = 1.3;
[?2004l[?2004h>                 r = (int)(mat.x * intensity * 255 + 0.5);
[?2004l[?2004h>                 g = (int)(mat.y * intensity * 255 + 0.5);
[?2004l[?2004h>                 bb = (int)(mat.z * intensity * 255 + 0.5);
[?2004l[?2004h>                 if(r>255)r=255; if(g>255)g=255; if(bb>255)bb=255;
[?2004l[?2004h>             } else if(hit_gnd){
[?2004l[?2004h>                 V hp = add(origin, mul(dir, t_gnd));
[?2004l[?2004h>                 int cx = (int)floor(hp.x);
[?2004l[?2004h>                 int cz = (int)floor(hp.z);
[?2004l[?2004h>                 int checker = ((cx+cz)&1);
[?2004l[?2004h>                 if(checker < 0) checker = !checker;
[?2004l[?2004h>                 int base = checker ? 152 : 67;
[?2004l[?2004h>                 
[?2004l[?2004h>                 int in_shadow = 0;
[?2004l[?2004h>                 V shadow_orig = add(hp, mul((V){0,1,0}, 0.001));
[?2004l[?2004h>                 V to_sph = sub(sph_c, shadow_orig);
[?2004l[?2004h>                 double ts = dot(to_sph, light);
[?2004l[?2004h>                 if(ts > 0){
[?2004l[?2004h>                     V closest = add(shadow_orig, mul(light, ts));
[?2004l[?2004h>                     double dist = len(sub(closest, sph_c));
[?2004l[?2004h>                     if(dist < sph_r) in_shadow = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>                 
[?2004l[?2004h>                 if(in_shadow){
[?2004l[?2004h>                     r = (int)(base * 0.3 + 0.5);
[?2004l[?2004h>                     g = r; bb = r;
[?2004l[?2004h>                 } else {
[?2004l[?2004h>                     r = base; g = base; bb = base;
[?2004l[?2004h>                 }
[?2004l[?2004h>             } else {
[?2004l[?2004h>                 double t2 = 0.5*(dir.y + 1.0);
[?2004l[?2004h>                 r = (int)((1.0-t2)*255 + t2*128 + 0.5);
[?2004l[?2004h>                 g = (int)((1.0-t2)*255 + t2*179 + 0.5);
[?2004l[?2004h>                 bb = (int)((1.0-t2)*255 + t2*255 + 0.5);
[?2004l[?2004h>             }
[?2004l[?2004h>             if(r<0)r=0;if(g<0)g=0;if(bb<0)bb=0;
[?2004l[?2004h>             if(r>255)r=255;if(g>255)g=255;if(bb>255)bb=255;
[?2004l[?2004h>             fprintf(f,"%d %d %d\n",r,g,bb);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
[?2004l[?2004h> CEOF
