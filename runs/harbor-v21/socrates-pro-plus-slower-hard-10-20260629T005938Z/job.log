Sending keys: ['cat > /app/convert_masks.py << \'PYEOF\'\nimport argparse\nimport os\nimport numpy as np\nimport pandas as pd\nimport cv2\nimport torch\nfrom PIL import Image\nfrom tqdm import tqdm\nfrom mobile_sam import sam_model_registry, SamPredictor\n\n\ndef load_image(rgb_path):\n    """Load RGB image as numpy array."""\n    image = Image.open(rgb_path).convert("RGB")\n    return np.array(image)\n\n\ndef masks_to_contours(mask):\n    """Convert a binary mask to a polyline (list of (x, y) points)."""\n    mask_uint8 = (mask.astype(np.uint8)) * 255\n    contours, _ = cv2.findContours(mask_uint8, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    if len(contours) == 0:\n        return None\n    # Pick the largest contour\n    contours = sorted(contours, key=cv2.contourArea, reverse=True)\n    contour = contours[0].squeeze(1)  # Nx2 array\n    # Close the polyline by appending the first point\n    contour = np.vstack([contour, contour[0:1]])\n    return contour\n\n\ndef resolve_overlaps(masks, scores):\n    """Resolve overlapping masks: assign each pixel to the mask with highest score."""\n    h, w = masks[0].shape\n    # Create a score-weighted label map\n    label_map = np.zeros((h, w), dtype=np.int32)\n    score_map = np.zeros((h, w), dtype=np.float32)\n    \n    # Sort by score (highest first) so higher-scoring masks take priority\n    order = np.argsort(-scores)\n    \n    for idx in order:\n        m = masks[idx]\n        # Only overwrite where this mask is active AND score is higher\n        update = m & (scores[idx] > score_map)\n        label_map[update] = idx + 1  # 1-indexed (0 = background)\n        score_map[update] = scores[idx]\n    \n    # Rebuild individual masks from label_map\n    resolved_masks = []\n    for idx in range(len(masks)):\n        resolved_masks.append(label_map == (idx + 1))\n    \n    return resolved_masks\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="Convert rectangle masks to polylines using MobileSAM.")\n    parser.add_argument("--weights_path", type=str, required=True, help="Path to MobileSAM weights.")\n    parser.add_argument("--output_path", type=str, required=True, help="Path to the output CSV file.")\n    parser.add_argument("--rgb_path", type=str, required=True, help="Path to the RGB image.")\n    parser.add_argument("--csv_path", type=str, required=True, help="Path to the metadata CSV.")\n    args = parser.parse_args()\n\n    # Load image\n    print("Loading image...")\n    image = load_image(args.rgb_path)\n    h, w = image.shape[:2]\n    print(f"Image size: {w}x{h}")\n\n    # Load CSV\n    print("Loading CSV...")\n    df = pd.read_csv(args.csv_path)\n    num_masks = len(df)\n    print(f"Number of masks: {num_masks}")\n\n    # Parse bounding boxes\n    xmins = df[\'xmin\'].values.astype(int)\n    xmaxs = df[\'xmax\'].values.astype(int)\n    ymins = df[\'ymin\'].values.astype(int)\n    ymaxs = df[\'ymax\'].values.astype(int)\n\n    # Load MobileSAM model\n    print("Loading MobileSAM model...")\n    model_type = "vit_t"\n    device = "cpu"\n    sam = sam_model_registry[model_type](checkpoint=args.weights_path)\n    sam.to(device=device)\n    sam.eval()\n    predictor = SamPredictor(sam)\n    print("Model loaded.")\n\n    # Set the image on the predictor (computes embedding once)\n    print("Computing image embedding...")\n    predictor.set_image(image)\n    print("Image embedding computed.")\n\n    # Run prediction for each mask\n    raw_masks = []\n    raw_scores = []\n    print("Running MobileSAM predictions...")\n    for i in tqdm(range(num_masks)):\n        box = np.array([xmins[i], ymins[i], xmaxs[i], ymaxs[i]])\n        masks, scores, logits = predictor.predict(\n            point_coords=None,\n            point_labels=None,\n            box=box,\n            multimask_output=True,\n        )\n        # Pick the mask with the highest score\n        best_idx = np.argmax(scores)\n        best_mask = masks[best_idx]\n        best_score = scores[best_idx]\n        raw_masks.append(best_mask)\n        raw_scores.append(best_score)\n    \n    raw_scores = np.array(raw_scores)\n    \n    # Resolve overlaps\n    print("Resolving overlaps...")\n    resolved_masks = resolve_overlaps(raw_masks, raw_scores)\n    \n    # Convert masks to polylines and update dataframe\n    print("Converting masks to polylines...")\n    new_xmins = []\n    new_xmaxs = []\n    new_ymins = []\n    new_ymaxs = []\n    new_coords_x = []\n    new_coords_y = []\n    \n    for i in tqdm(range(num_masks)):\n        mask = resolved_masks[i]\n        contour = masks_to_contours(mask)\n        \n        if contour is None:\n            # Fallback: use original bounding box as polyline\n            xs = [xmins[i], xmaxs[i], xmaxs[i], xmins[i], xmins[i]]\n            ys = [ymins[i], ymins[i], ymaxs[i], ymaxs[i], ymins[i]]\n            new_xmins.append(xmins[i])\n            new_xmaxs.append(xmaxs[i])\n            new_ymins.append(ymins[i])\n            new_ymaxs.append(ymaxs[i])\n        else:\n            xs = contour[:, 0].tolist()\n            ys = contour[:, 1].tolist()\n            new_xmins.append(int(min(xs)))\n            new_xmaxs.append(int(max(xs)))\n            new_ymins.append(int(min(ys)))\n            new_ymaxs.append(int(max(ys)))\n        \n        new_coords_x.append(\',\'.join(str(int(x)) for x in xs))\n        new_coords_y.append(\',\'.join(str(int(y)) for y in ys))\n    \n    # Update dataframe\n    df[\'xmin\'] = new_xmins\n    df[\'xmax\'] = new_xmaxs\n    df[\'ymin\'] = new_ymins\n    df[\'ymax\'] = new_ymaxs\n    df[\'coords_x\'] = new_coords_x\n    df[\'coords_y\'] = new_coords_y\n    \n    # Save output\n    df.to_csv(args.output_path, index=False)\n    print(f"Output saved to {args.output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
