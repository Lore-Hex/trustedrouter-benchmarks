atures)\n        # Split along dim=0 (output/features dimension)\n        weight_shards = master_weight.chunk(world_size, dim=0)\n        self.weight = nn.Parameter(weight_shards[rank].contiguous().clone())\n\n        if bias:\n            self.bias = nn.Parameter(\n                torch.zeros(\n                    self.out_features_per_rank,\n                    device=master_weight.device,\n                    dtype=master_weight.dtype,\n                )\n            )\n        else:\n            self.bias = None\n\n    def forward(self, x):\n        # Local matmul: x @ W_local^T + b_local\n        output_local = F.linear(x, self.weight, self.bias)\n        # All-gather: concatenate partial outputs along last dim\n        output = _AllGather.apply(output_local)\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    """Linear layer with weight partitioned along the input dimension.\n\n    Each rank holds a shard of shape (out_features, in_features // world_size).\n    The input to forward() is already the local scatter of the full input.\n    Forward computes the local matmul then all-reduces (sums) partial outputs.\n    Bias is full (not sharded) and applied after the all-reduce.\n    """\n\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n\n        assert in_features % world_size == 0\n\n        # master_weight shape: (out_features, in_features)\n        # Split along dim=1 (input dimension)\n        weight_shards = master_weight.chunk(world_size, dim=1)\n        self.weight = nn.Parameter(weight_shards[rank].contiguous().clone())\n\n        if bias:\n            self.bias = nn.Parameter(\n                torch.zeros(\n                    out_features,\n                    device=master_weight.device,\n                    dtype=master_weight.dtype,\n                )\n            )\n        else:\n            self.bias = None\n\n    def forward(self, x):\n        # Local matmul with pre-scattered input (no bias yet)\n        output_local = F.linear(x, self.weight)\n        # All-reduce: sum partial outputs across ranks\n        output = _AllReduce.apply(output_local)\n        # Add full bias after reduction\n        if self.bias is not None:\n            output = output + self.bias\n        return output\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
