Sending keys: ['cat > /app/gen_gates.py << \'PYEOF\'\n#!/usr/bin/env python3\n"""Generate gates.txt for fib(isqrt(N)) mod 2^32"""\n\nlines = []\nnext_sig = 0\n_zero = None\n_one = None\n\ndef reset():\n    global lines, next_sig, _zero, _one\n    lines = []\n    next_sig = 0\n    _zero = None\n    _one = None\n\ndef ns():\n    global next_sig\n    s = next_sig\n    next_sig += 1\n    return s\n\ndef C(val):\n    global _zero, _one\n    if val == 0:\n        if _zero is None:\n            _zero = ns()\n            lines.append(f"out{_zero} = 0")\n        return _zero\n    elif val == 1:\n        if _one is None:\n            _one = ns()\n            lines.append(f"out{_one} = 1")\n        return _one\n    raise ValueError\n\ndef NOT(a):\n    s = ns(); lines.append(f"out{s} = ~out{a}"); return s\n\ndef AND(a, b):\n    s = ns(); lines.append(f"out{s} = out{a} & out{b}"); return s\n\ndef OR(a, b):\n    s = ns(); lines.append(f"out{s} = out{a} | out{b}"); return s\n\ndef XOR(a, b):\n    s = ns(); lines.append(f"out{s} = out{a} ^ out{b}"); return s\n\ndef NOTv(v):\n    return [NOT(x) for x in v]\n\ndef ORr(v):\n    r = v[0]\n    for x in v[1:]:\n        r = OR(r, x)\n    return r\n\ndef ANDr(v):\n    r = v[0]\n    for x in v[1:]:\n        r = AND(r, x)\n    return r\n\ndef FA(a, b, ci):\n    p = XOR(a, b)\n    s = XOR(p, ci)\n    g = AND(a, b)\n    g2 = AND(p, ci)\n    co = OR(g, g2)\n    return s, co\n\ndef ADD(a, b, ci=None):\n    if ci is None: ci = C(0)\n    n = len(a)\n    res = []; carry = ci\n    for i in range(n):\n        s, carry = FA(a[i], b[i], carry)\n        res.append(s)\n    return res, carry\n\ndef ADDC(a, c):\n    if c == 0: return list(a)\n    n = len(a)\n    res = []; carry = None\n    for i in range(n):\n        cb = (c >> i) & 1\n        if carry is None and cb == 0:\n            res.append(a[i])\n        elif carry is None and cb == 1:\n            res.append(NOT(a[i]))\n            carry = a[i]\n        elif carry is not None and cb == 0:\n            res.append(XOR(a[i], carry))\n            carry = AND(a[i], carry)\n        else:\n            na = NOT(a[i])\n            res.append(XOR(na, carry))\n            carry = OR(a[i], carry)\n    return res\n\ndef SUB(a, b):\n    nb = NOTv(b)\n    return ADD(a, nb, C(1))\n\ndef MUX(sel, a, b):\n    ns_ = NOT(sel)\n    return OR(AND(sel, b), AND(ns_, a))\n\ndef MUXv(sel, a, b):\n    return [MUX(sel, ai, bi) for ai, bi in zip(a, b)]\n\ndef OH_MUX(sels, opts):\n    w = len(opts[0])\n    res = []\n    for bit in range(w):\n        terms = [AND(s, o[bit]) for s, o in zip(sels, opts)]\n        res.append(ORr(terms))\n    return res\n\ndef main():\n    reset()\n    global next_sig\n    \n    # Input self-copies\n    for i in range(32):\n        lines.append(f"out{i} = out{i}")\n    next_sig = 32\n    \n    n_bits = list(range(32))\n    \n    # isqrt via digit-by-digit method\n    RW = 34; SW = 17\n    rem = [C(0)] * RW\n    res = [C(0)] * SW\n    \n    for i in range(15, -1, -1):\n        nr = [C(0), C(0)] + rem[:RW-2]\n        b0, b1 = 2*i, 2*i+1\n        nr[0] = n_bits[b0] if b0 < 32 else C(0)\n        nr[1] = n_bits[b1] if b1 < 32 else C(0)\n        rem = nr\n        \n        d = [C(0)] * RW\n        d[0] = C(1)\n        for j in range(min(SW, RW-2)):\n            d[j+2] = res[j]\n        \n        diff, carry = SUB(rem, d)\n        cond = carry\n        rem = MUXv(cond, rem, diff)\n        res = [cond] + res[:SW-1]\n    \n    isqrt_r = res\n    \n    # Sequential state\n    CW = 17; FW = 32\n    ctr = [ns() for _ in range(CW)]\n    fa = [ns() for _ in range(FW)]\n    fb = [ns() for _ in range(FW)]\n    \n    # Conditions\n    k_gt_0 = ORr(isqrt_r[:CW])\n    ctr_0 = ANDr([NOT(b) for b in ctr])\n    c_sp = AND(ctr_0, k_gt_0)\n    nsp = NOT(c_sp)\n    \n    kp = list(isqrt_r[:CW])\n    while len(kp) < CW: kp.append(C(0))\n    rem_, _ = SUB(kp, ctr)\n    \n    ge4 = ORr(rem_[2:])\n    lt4 = NOT(ge4)\n    r1 = AND(lt4, AND(rem_[0], NOT(rem_[1])))\n    r2 = AND(lt4, AND(NOT(rem_[0]), rem_[1]))\n    r3 = AND(lt4, AND(rem_[0], rem_[1]))\n    \n    c4 = AND(nsp, ge4)\n    c3 = AND(nsp, r3)\n    c2 = AND(nsp, r2)\n    c1 = AND(nsp, r1)\n    ca = OR(c_sp, OR(c4, OR(c3, OR(c2, c1))))\n    c0 = NOT(ca)\n    \n    # Fib additions\n    t1, _ = ADD(fa, fb)\n    t2, _ = ADD(t1, fb)\n    t3, _ = ADD(t1, t2)\n    t4, _ = ADD(t2, t3)\n    \n    Z = [C(0)] * FW\n    O = [C(1)] + [C(0)] * (FW-1)\n    \n    na = OH_MUX([c0,c1,c2,c3,c4,c_sp], [fa,fb,t1,t2,t3,Z])\n    nb = OH_MUX([c0,c1,c2,c3,c4,c_sp], [fb,t1,t2,t3,t4,O])\n    \n    # Counter\n    p1 = ADDC(ctr, 1)\n    p2 = ADDC(ctr, 2)\n    p3 = ADDC(ctr, 3)\n    p4 = ADDC(ctr, 4)\n    oc = [C(1)] + [C(0)] * (CW-1)\n    nc = OH_MUX([c0,c1,c2,c3,c4,c_sp], [ctr,p1,p2,p3,p4,oc])\n    \n    # Feedback\n    for i in range(CW): lines.append(f"out{ctr[i]} = out{nc[i]}")\n    for i in range(FW): lines.append(f"out{fa[i]} = out{na[i]}")\n    for i in range(FW): lines.append(f"out{fb[i]} = out{nb[i]}")\n    \n    # Output: last 32 signals = fb\n    for i in range(FW):\n        s = ns()\n        lines.append(f"out{s} = out{fb[i]}")\n    \n    with open("gates.txt", "w") as f:\n        for l in lines:\n            f.write(l + "\\n")\n    \n    print(f"Signals: {next_sig}, Lines: {len(lines)}")\n\nif __name__ == "__main__":\n    main()\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
