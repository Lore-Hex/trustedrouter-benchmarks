Sending keys: ['cat > /app/validate_random.py <<\'PY\'\nimport json, os, re, random, sys, chess\n\nrules = json.load(open(\'/app/re.json\'))\nprint(\'pairs\', len(rules), \'bytes\', os.path.getsize(\'/app/re.json\'), file=sys.stderr)\n\ndef run_solution(fen):\n    for pattern, repl in rules:\n        fen = re.sub(pattern, repl, fen)\n    return [\' \'.join(x.split(\' \')[:-2]) for x in fen.split(\'\\n\')]\n\ndef expected(board):\n    exp = set()\n    for m in board.legal_moves:\n        if m.promotion and m.promotion != chess.QUEEN:\n            continue\n        c = board.copy(); c.push(m)\n        exp.add(\' \'.join(c.fen().split(\' \')[:-2]))\n    return exp\n\ndef get_positions(n, seed, max_plies=60):\n    random.seed(seed)\n    positions = []\n    seen = set()\n    while len(positions) < n:\n        b = chess.Board()\n        for _ in range(random.randint(0, max_plies)):\n            moves = list(b.legal_moves)\n            if not moves:\n                break\n            b.push(random.choice(moves))\n        if b.turn == chess.WHITE and not b.is_game_over() and b.fen() not in seen:\n            seen.add(b.fen())\n            positions.append(b)\n    return positions\n\nn = int(sys.argv[1]) if len(sys.argv) > 1 else 20\nseed = int(sys.argv[2]) if len(sys.argv) > 2 else 12345\npositions = get_positions(n, seed)\nfail = 0\nfor i, b in enumerate(positions, 1):\n    fen = b.fen()\n    got = set(run_solution(fen))\n    exp = expected(b)\n    ok = got == exp\n    if not ok:\n        fail += 1\n    print(f\'{i}: {"ok" if ok else "FAIL"} got={len(got)} exp={len(exp)} {fen}\')\n    if not ok:\n        print(\'  extra:\', sorted(got - exp)[:5])\n        print(\'  missing:\', sorted(exp - got)[:5])\nprint(f\'failures {fail}/{n}\', file=sys.stderr)\nsys.exit(1 if fail else 0)\nPY\npython3 /app/validate_random.py 5 12345\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
