[?2004l[?2004h>         else:
[?2004l[?2004h>             t_hi = t_mid
[?2004l[?2004h>     return 0.5 * (t_lo + t_hi)
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def gradient_jump(x0, d, t_kink, margin):
[?2004l[?2004h>     p_left = x0 + (t_kink - margin) * d
[?2004l[?2004h>     p_right = x0 + (t_kink + margin) * d
[?2004l[?2004h>     return grad(p_right) - grad(p_left)
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def normalized(v):
[?2004l[?2004h>     n = np.linalg.norm(v)
[?2004l[?2004h>     if n < 1e-15:
[?2004l[?2004h>         return v
[?2004l[?2004h>     return v / n
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def have_vec(v, vecs, tol=1e-3):
[?2004l[?2004h>     vn = normalized(v)
[?2004l[?2004h>     for w in vecs:
[?2004l[?2004h>         wn = normalized(w)
[?2004l[?2004h>         if abs(abs(np.dot(vn, wn)) - 1.0) < tol:
[?2004l[?2004h>             return True
[?2004l[?2004h>     return False
[?2004l[?2004h> 
