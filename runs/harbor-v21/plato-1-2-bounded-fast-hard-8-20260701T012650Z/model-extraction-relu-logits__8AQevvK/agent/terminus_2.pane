[?2004l[?2004h>         s_left = (f(x0 + t_mid * d) - f(x0 + (t_mid - dt) * d)) / dt
[?2004l[?2004h>         s_right = (f(x0 + (t_mid + dt) * d) - f(x0 + t_mid * d)) / dt
[?2004l[?2004h>         if abs(s_right - s_left) <= 1e-13:
[?2004l[?2004h>             return t_mid
[?2004l[?2004h>         t_q = 0.5 * (t_mid + t_hi)
[?2004l[?2004h>         s_right_far = (f(x0 + (t_q + dt) * d) - f(x0 + (t_q - dt) * d)) / (2 * dt)
