[?2004l[?2004h> def scan_line(seed):
[?2004l[?2004h>     rng = np.random.default_rng(seed)
[?2004l[?2004h>     x0 = rng.normal(0, 0.3, size=DIM)
[?2004l[?2004h>     d = rng.normal(0, 1, size=DIM)
[?2004l[?2004h>     d = d / np.linalg.norm(d)
[?2004l[?2004h> 
[?2004l[?2004h>     t_range = 6.0
[?2004l[?2004h>     n_points = 4000
[?2004l[?2004h>     ts = np.linspace(-t_range, t_range, n_points)
[?2004l[?2004h>     vals = np.array([f(x0 + t * d) for t in ts], dtype=float)
[?2004l[?2004h>     dt = ts[1] - ts[0]
[?2004l[?2004h> 
[?2004l[?2004h>     slopes = np.diff(vals) / dt
[?2004l[?2004h>     changes = np.abs(np.diff(slopes))
[?2004l[?2004h>     thresh = max(1e-9, changes.max() * 1e-6)
[?2004l[?2004h>     idxs = np.where(changes > thresh)[0]
[?2004l[?2004h> 
[?2004l[?2004h>     groups = []
[?2004l[?2004h>     for idx in idxs:
[?2004l[?2004h>         if groups and idx <= groups[-1][-1] + 1:
[?2004l[?2004h>             groups[-1].append(idx)
[?2004l[?2004h>         else:
