[?2004l[?2004h>         b = min(len(ts) - 1, a + 1)
[?2004l[?2004h>         t_kink = refine_kink(x0, d, ts[a], ts[b])
[?2004l[?2004h>         margin = max(1e-3, 0.05 * dt)
