Sending keys: ["cat > /tmp/zork_refined.py <<'PY'\nimport os, re, glob, subprocess\nfrom PIL import Image\nimport pytesseract\n\nVIDEO='/app/video.mp4'\nFRAMES='/tmp/zork_frames_5fps_clean'\nOUT='/app/solution.txt'\nos.makedirs(FRAMES, exist_ok=True)\nfor f in glob.glob(FRAMES+'/*.png'): os.remove(f)\n\nsubprocess.run(['ffmpeg','-y','-hide_banner','-loglevel','error','-i',VIDEO,'-vf','fps=5',os.path.join(FRAMES,'frame_%06d.png')], check=True)\nframes=sorted(glob.glob(FRAMES+'/*.png'))\nprint('frames', len(frames))\n\ndef ocr_region(im, box, psm=6, scale=3, thr=150):\n    crop=im.convert('L').crop(box)\n    crop=crop.resize((crop.width*scale, crop.height*scale))\n    bw=crop.point(lambda x: 0 if x < thr else 255, '1')\n    return pytesseract.image_to_string(bw, config=f'--psm {psm}')\n\ndef norm(s):\n    s=s.replace('»','>').replace('_','').replace('|','')\n    s=re.sub(r'\\s+',' ',s).strip()\n    return s\n\ndef get_moves(im):\n    w,h=im.size\n    txt=ocr_region(im, (0,0,w,int(h*0.08)), psm=7, scale=3)\n    m=re.search(r'Moves?\\s*:?\\s*(\\d+)', txt, re.I)\n    if m: return int(m.group(1))\n    txt2=ocr_region(im, (0,0,w,int(h*0.10)), psm=6, scale=3)\n    m=re.search(r'Moves?\\s*:?\\s*(\\d+)', txt2, re.I)\n    if m: return int(m.group(1))\n    return None\n\ndef clean_cmd(s):\n    s=norm(s)\n    s=re.sub(r'^[>\\s]+','',s)\n    s=s.lstrip('>').strip()\n    s=re.sub(r'[\\\\|_]+$','',s).strip()\n    s=re.sub(r'\\s+',' ',s).strip()\n    return s\n\ndef is_game_output(s):\n    low=s.lower()\n    patterns=[\n        'done.', 'taken.', 'you are', 'you hear', 'you see', 'there is', 'there are',\n        'on the ground', 'suspicious-looking', 'stiletto', 'scream', 'butt', 'angry',\n        'this is', 'it is', 'can be seen', 'strange passage', 'cyclops room',\n        'slide room', 'mine entrance', 'squeaky room', 'white cliffs beach',\n        'damp cave', 'loud room', 'treasure room', 'jewel-encrusted', 'platinum bar',\n        'silver chalice', 'the thief', 'deflates.', 'your own feet', 'heavy iron chain',\n        'end of the chain', 'three sides', 'more'\n    ]\n    return any(p in low for p in patterns)\n\ndef looks_like_move(s):\n    if not s or is_game_output(s): return False\n    low=s.lower()\n    if re.fullmatch(r'(n|s|e|w|u|d|ne|nw|se|sw)', low): return True\n    if re.fullmatch(r'[a-z0-9 ,\\.\\-]{1,50}', low) and not re.search(r'\\d{4,}', low):\n        first=low.split()[0] if low.split() else ''\n        verbs={'get','take','drop','put','open','close','light','kill','slay','move','push','pull',\n               'set','raise','lower','wave','dig','shove','give','wind','pray','save','look',\n               'inventory','read','rub','climb','pour','fill','blow','throw','attack','drink',\n               'eat','count','wait','board','disembark','launch','land','unwrap','tie','untie',\n               'turn','press','type','enter','go','examine','lock','unlock','inflate','deflate',\n               'pump','squeeze','touch','kick','jump','swim','cross','leave','follow','shoot',\n               'solve','ring','board','deflate','inflate','launch','pump'}\n        if first in verbs: return True\n    return False\n\nstates=[]\nfor idx,p in enumerate(frames):\n    t=idx/5.0\n    im=Image.open(p)\n    w,h=im.size\n    mv=get_moves(im)\n    ptxt=ocr_region(im, (0,int(h*0.82),w,h), psm=7, scale=4, thr=140)\n    lines=[norm(x) for x in ptxt.splitlines() if x]\n    cmd=''\n    for l in reversed(lines):\n        c=clean_cmd(l)\n        if c:\n            cmd=c\n            break\n    states.append((t,mv,cmd))\n\nevents=[]\nprev_mv=None\nprev_cmd=''\nfor i,(t,mv,cmd) in enumerate(states):\n    committed=False\n    if mv is not None and prev_mv is not None and mv > prev_mv:\n        events.append((t,prev_mv,mv,prev_cmd,'moves'))\n        prev_cmd=''\n        committed=True\n    elif cmd == '' and prev_cmd != '':\n        events.append((t,prev_mv,mv,prev_cmd,'reset'))\n        prev_cmd=''\n        committed=True\n    if not committed and cmd and cmd != prev_cmd:\n        prev_cmd=cmd\n    if mv is not None:\n        prev_mv=mv\n\nfinal=[]\nfor t,pm,cm,cmd,kind in events:\n    c=clean_cmd(cmd)\n    if not c: continue\n    if not looks_like_move(c): continue\n    if final and c == final[-1]: continue\n    final.append(c)\n\nwith open(OUT,'w') as f:\n    for m in final:\n        f.write(m+'\\n')\n\nprint('events', len(events))\nprint('final moves', len(final))\nfor i,m in enumerate(final,1):\n    print(i,m)\nPY\npython3 /tmp/zork_refined.py\n"] min_timeout_sec: 60.0 max_timeout_sec: 180.0
