Sending keys: ["cat > /tmp/zork_extract.py <<'PY'\nimport os, re, glob, subprocess\nfrom PIL import Image\nimport pytesseract\n\nVIDEO='/app/video.mp4'\nFRAMES='/tmp/zork_frames_5fps'\nOUT='/app/solution.txt'\nos.makedirs(FRAMES, exist_ok=True)\nfor f in glob.glob(FRAMES+'/*.png'): os.remove(f)\n\n# Extract frames at 5 fps with sequence timestamps.\nsubprocess.run(['ffmpeg','-y','-hide_banner','-loglevel','error','-i',VIDEO,'-vf','fps=5',os.path.join(FRAMES,'frame_%06d.png')], check=True)\nframes=sorted(glob.glob(FRAMES+'/*.png'))\nprint('frames', len(frames))\n\ndef ocr_prompt(im):\n    w,h=im.size\n    # Bottom 22% usually contains final prompt line; OCR a little more for context.\n    crop=im.convert('L').crop((0,int(h*0.78),w,h))\n    # Upscale for better OCR\n    crop=crop.resize((crop.width*3, crop.height*3))\n    # Threshold around white text on black background\n    bw=crop.point(lambda x: 0 if x < 140 else 255, '1')\n    txt=pytesseract.image_to_string(bw, config='--psm 6')\n    return txt\n\ndef clean_prompt_line(s):\n    s=s.strip()\n    # Remove leading prompt and common OCR prefixes\n    s=re.sub(r'^[>\\s]+','',s)\n    s=s.lstrip('>')\n    # Remove cursor artifacts and common OCR noise\n    s=s.replace('_','').strip()\n    # Normalize some OCR errors\n    s=s.replace('|','').strip()\n    return s.strip()\n\nstates=[]\nprev=None\nseq=[]\nfor idx,p in enumerate(frames):\n    t=idx/5.0\n    im=Image.open(p)\n    txt=ocr_prompt(im)\n    lines=[x.strip() for x in txt.splitlines() if x.strip()]\n    prompt=''\n    # Prefer last line that starts with '>' or looks like prompt content\n    for l in reversed(lines):\n        if l.startswith('>') or l in ['n.','w','e','s','get','get bag','open mailbox','open']:\n            prompt=clean_prompt_line(l)\n            break\n    if not prompt and lines:\n        # Sometimes '>' is recognized separately; use last nonempty line if short\n        cand=clean_prompt_line(lines[-1])\n        if len(cand)<=40:\n            prompt=cand\n    # Track character-by-character progression: keep growing commands, commit when it shrinks/changes to new text\n    if prompt and prompt!=prev:\n        seq.append((t,prompt))\n        prev=prompt\n    states.append((t,prompt))\n\n# Print raw prompt-state changes for debugging\nprint('\\nRAW PROMPT CHANGES:')\nfor t,p in seq:\n    print(f'{t:.2f}: {p!r}')\n\n# Reconstruct moves: a move is a stable completed command.\n# Keep the longest variant before it resets to empty/shorter/new command; filter artifacts.\nmoves=[]\nlast=None\nfor t,p in seq:\n    p=p.strip()\n    if not p:\n        continue\n    # Skip obvious OCR fragments/noise\n    if re.fullmatch(r'[a-z]{1,2}|mu|te|d_|mm|[0-9]+', p, re.I):\n        # keep very short legitimate direction commands n/s/e/w/u/d but skip others unless stable\n        if p.lower() not in {'n','s','e','w','u','d','ne','nw','se','sw'}:\n            continue\n    if p!=last:\n        moves.append(p)\n        last=p\n\n# Deduplicate consecutive identical only (already done) and remove trailing punctuation artifacts\nclean=[]\nfor m in moves:\n    m=m.rstrip('.')\n    m=re.sub(r'\\s+',' ',m).strip()\n    if m:\n        clean.append(m)\n\nwith open(OUT,'w') as f:\n    for m in clean:\n        f.write(m+'\\n')\n\nprint('\\nCANDIDATE MOVES:', len(clean))\nfor i,m in enumerate(clean,1):\n    print(i,m)\nprint('\\nWROTE', OUT)\nPY\npython3 /tmp/zork_extract.py\n"] min_timeout_sec: 30.0 max_timeout_sec: 180.0
