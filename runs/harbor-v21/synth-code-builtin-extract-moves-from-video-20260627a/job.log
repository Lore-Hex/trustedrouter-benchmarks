Sending keys: ["cat > /app/work/extract_final_v1.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\nprompt_frames=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    for line in txt.splitlines():\n        s=line.strip()\n        if not s.startswith('>'):\n            continue\n        s=s[1:].strip()\n        if s.endswith('_'):\n            continue\n        s=s.rstrip('._ ').strip()\n        if not s:\n            continue\n        s=re.sub(r'\\s+',' ',s).strip()\n        prompt_frames.append((idx,s))\n\n# Collapse typing continuations and keep first appearance of each completed command.\ncollapsed=[]\nfor idx,s in prompt_frames:\n    if collapsed and collapsed[-1][1] == s:\n        continue\n    if collapsed and s.startswith(collapsed[-1][1]) and len(s) > len(collapsed[-1][1]):\n        collapsed[-1] = (idx, s)\n        continue\n    if collapsed and collapsed[-1][1].startswith(s) and len(collapsed[-1][1]) - len(s) <= 2:\n        continue\n    collapsed.append((idx,s))\n\n# Deduplicate by first appearance while preserving order.\nseen={}\norder=[]\nfor idx,s in collapsed:\n    if s not in seen:\n        seen[s]=idx\n        order.append((idx,s))\n\nwith open('/app/work/logs/final_v1.log','w') as f:\n    for n,(idx,s) in enumerate(order,1):\n        f.write(f'{n:03d} f{idx:03d} {s}\\n')\nprint('final_v1_count', len(order))\nprint('first20', order[:20])\nprint('last20', order[-20:])\nPY\npython3 /app/work/extract_final_v1.py\nwc -l /app/work/logs/final_v1.log\nsed -n '1,120p' /app/work/logs/final_v1.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
