Sending keys: ["cat > /app/work/extract_moves_v1.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\ndef clean_prompt(s):\n    s=s.strip()\n    if not s.startswith('>'):\n        return ''\n    s=s[1:].strip()\n    s=s.rstrip('._').strip()\n    s=s.replace(',,', ',').strip()\n    return s\n\nraw_cmds=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    lines=[l.rstrip() for l in txt.splitlines() if l.strip()]\n    prompts=[clean_prompt(l) for l in lines if l.strip().startswith('>')]\n    prompts=[p for p in prompts if p]\n    if prompts:\n        raw_cmds.append((idx,prompts[-1]))\n\ncmds=[]\nprev_idx=None\nprev_cmd=None\nfor idx,cmd in raw_cmds:\n    if prev_cmd is None:\n        prev_idx, prev_cmd = idx, cmd\n        continue\n    if cmd == prev_cmd:\n        continue\n    # Treat strict typing extension as same command in progress\n    if cmd.startswith(prev_cmd):\n        prev_idx, prev_cmd = idx, cmd\n        continue\n    # Sometimes OCR loses a comma/space; accept very small typoed extensions manually later.\n    cmds.append((prev_idx, prev_cmd))\n    prev_idx, prev_cmd = idx, cmd\nif prev_cmd:\n    cmds.append((prev_idx, prev_cmd))\n\nwith open('/app/work/logs/moves_v1.log','w') as f:\n    for i,(idx,cmd) in enumerate(cmds,1):\n        f.write(f'{i:03d} f{idx:03d} {cmd}\\n')\nprint('candidate_count', len(cmds))\nprint('first', cmds[:10])\nprint('last', cmds[-10:])\nPY\npython3 /app/work/extract_moves_v1.py\nwc -l /app/work/logs/moves_v1.log\nsed -n '1,120p' /app/work/logs/moves_v1.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
