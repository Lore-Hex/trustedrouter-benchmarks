ke drop put open close move kill again ring read rub set lower raise wind pray dig board launch pump echo save drink wait look give show wave blow pour turn tie untie climb jump enter push pull fill y g'.split())\n\ndef fix_cmd(s):\n    s=s.strip().rstrip('._').strip()\n    s=re.sub(r'\\s+',' ',s).strip()\n    return fixes.get(s,s)\n\ndef clean_prompt(s):\n    s=s.strip()\n    if not s.startswith('>'):\n        return ''\n    s=s[1:].strip().rstrip('._').strip()\n    s=re.sub(r'\\s+',' ',s).strip()\n    return fix_cmd(s)\n\ndef normalize_bottom(s):\n    s=re.sub(r'[^A-Za-z0-9>, ._]',' ',s)\n    s=re.sub(r'\\s+',' ',s).strip()\n    had=s.startswith('>')\n    if had:\n        s=s[1:].strip()\n    s=s.rstrip('._').strip()\n    return fix_cmd(s), had\n\ndef is_commandlike(c):\n    if not c:\n        return False\n    if len(c)>45:\n        return False\n    if not re.search(r'[A-Za-z]', c):\n        return False\n    parts=c.split()\n    first=parts[0].lower().strip('.,') if parts else ''\n    if first in common:\n        return True\n    if c.lower() in ['y','again','g']:\n        return True\n    if c in fixes.values():\n        return True\n    return False\n\n# Parse 1fps OCR\nframes=[]\nfor idx,p in enumerate(ocr1,1):\n    txt=open(p,errors='ignore').read()\n    m=re.search(r'Moves?:\\s*(\\d+)', txt)\n    mv=int(m.group(1)) if m else None\n    prompts=[]\n    for line in txt.splitlines():\n        c=clean_prompt(line)\n        if c:\n            prompts.append(c)\n    frames.append({'idx':idx,'mv':mv,'prompts':prompts})\n\nanchors=[(i,frames[i]['mv']) for i in range(len(frames)) if frames[i]['mv'] is not None]\n\ndef b5_to_1fps(i):\n    return max(1, min(len(frames), (i+4)//5))\n\n# Parse dense bottom5 and segment typed commands\nb5_lines=[]\nfor idx,p in enumerate(bottom5,1):\n    raw=open(p,errors='ignore').read().strip()\n    n,h=normalize_bottom(raw)\n    b5_lines.append({'idx':idx,'cmd':n,'had':h})\n\nsegments=[]\ncur=None\nfor r in b5_lines:\n    c=r['cmd']\n    i=r['idx']\n    if r['had'] and c:\n        if cur is None:\n            cur=(i,c)\n        elif c.startswith(cur[1]) or (len(cur[1])>=3 and c.startswith(cur[1][:-1])):\n            cur=(i,c)\n        elif cur[1].startswith(c) and len(cur[1])-len(c)<=3:\n            pass\n        else:\n            segments.append(cur)\n            cur=(i,c)\n    else:\n        if cur:\n            segments.append(cur)\n            cur=None\nif cur:\n    segments.append(cur)\n\nb5_cmds=[]\nfor i,c in segments:\n    c=fix_cmd(c)\n    if is_commandlike(c):\n        b5_cmds.append((i,c))\n\nb5_ded=[]\nfor i,c in b5_cmds:\n    if b5_ded and b5_ded[-1][1]==c:\n        continue\n    b5_ded.append((i,c))\n\n# Build interval candidates aligned to move-count anchors\nfinal=[]\nprev_i, prev_mv = 0, 0\nfor end_i, end_mv in anchors:\n    if end_mv <= prev_mv:\n        continue\n    delta = end_mv - prev_mv\n    interval=[(b5_to_1fps(i), c) for i,c in b5_ded if prev_i < b5_to_1fps(i) <= end_i]\n    if not interval:\n        for j in range(max(0,prev_i), end_i+1):\n            if frames[j]['prompts']:\n                interval.append((frames[j]['idx'], frames[j]['prompts'][-1]))\n    # Remove pure prefixes of later commands\n    kept=[]\n    for n,(j,c) in enumerate(interval):\n        is_prefix=False\n        for jj,cc in interval[n+1:]:\n            if cc.startswith(c) and len(cc)>len(c):\n                is_prefix=True\n                break\n        if not is_prefix:\n            kept.append((j,c))\n    chosen=kept[-delta:] if delta <= len(kept) else kept\n    final.extend(chosen)\n    prev_i, prev_mv = end_i, end_mv\n\nded_final=[]\nfor j,c in final:\n    if ded_final and ded_final[-1][1]==c:\n        continue\n    ded_final.append((j,c))\n\nwith open('/app/work/logs/robust_v2.log','w') as f:\n    for n,(j,c) in enumerate(ded_final,1):\n        f.write(f'{n:03d} f{j:03d} {c}\\n')\n\nprint('robust_v2_count', len(ded_final))\nprint('expected', 262)\nprint('match', len(ded_final)==262)\nprint('first40', ded_final[:40])\nprint('last40', ded_final[-40:])\nPY\npython3 /app/work/robust_extractor_v2.py\nwc -l /app/work/logs/robust_v2.log\nsed -n '1,140p' /app/work/logs/robust_v2.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
