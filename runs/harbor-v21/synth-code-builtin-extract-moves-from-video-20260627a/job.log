Sending keys: ["cat > /app/work/extract_scrollback.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\ndef clean_prompt(line):\n    s=line.strip()\n    if not s.startswith('>'):\n        return ''\n    s=s[1:].strip()\n    s=s.rstrip('._').strip()\n    s=s.replace(',,', ',').strip()\n    return s\n\nseen={}\norder=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    for line in txt.splitlines():\n        c=clean_prompt(line)\n        if not c:\n            continue\n        if c not in seen:\n            seen[c]=idx\n            order.append(c)\n\nfiltered=[]\nfor i,cmd in enumerate(order):\n    fno=seen[cmd]\n    keep=True\n    for j in range(i+1, len(order)):\n        cmd2=order[j]\n        fno2=seen[cmd2]\n        if fno <= fno2 <= fno+8 and cmd2.startswith(cmd):\n            keep=False\n            break\n        if fno2 > fno+8:\n            break\n    if keep:\n        filtered.append((fno, cmd))\n\nwith open('/app/work/logs/moves_scrollback.log','w') as f:\n    for i,(fno,cmd) in enumerate(filtered,1):\n        f.write(f'{i:03d} f{fno:03d} {cmd}\\n')\nprint('candidate_count', len(filtered))\nprint('first', filtered[:20])\nprint('last', filtered[-20:])\nPY\npython3 /app/work/extract_scrollback.py\nwc -l /app/work/logs/moves_scrollback.log\nsed -n '1,220p' /app/work/logs/moves_scrollback.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
Sending keys: ["cat > /app/work/diff_move_counts.py <<'PY'\nimport glob, os, re\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\nrows=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    m=re.search(r'Moves?:\\s*(\\d+)', txt)\n    mv=int(m.group(1)) if m else None\n    lines=[l.rstrip() for l in txt.splitlines() if l.strip()]\n    prompts=[l.strip() for l in lines if l.lstrip().startswith('>')]\n    lastgame=''\n    for l in reversed(lines):\n        if not l.lstrip().startswith('>'):\n            lastgame=l.strip()\n            break\n    rows.append((idx,mv,prompts,lastgame))\n\nprint('MOVE PROGRESSION')\nlast=None\nfor idx,mv,prompts,lg in rows:\n    if mv is not None and mv!=last:\n        print(f'f{idx:03d} mv={mv} prompts={prompts} lastgame={lg[:100]!r}')\n        last=mv\n\nprint('\\nTRANSITION CONTEXT')\nfor i,(idx,mv,prompts,lg) in enumerate(rows):\n    prev_mv=rows[i-1][1] if i>0 else None\n    if mv is not None and prev_mv is not None and mv!=prev_mv:\n        print(f'\\nTRANSITION f{idx:03d} mv {prev_mv}->{mv}')\n        for j in range(max(0,i-2), min(len(rows),i+3)):\n            print(f'  f{rows[j][0]:03d} mv={rows[j][1]} prompts={rows[j][2]} lastgame={rows[j][3][:80]!r}')\nPY\npython3 /app/work/diff_move_counts.py > /app/work/logs/diff_move_counts.log 2>&1\nwc -l /app/work/logs/diff_move_counts.log\nsed -n '1,220p' /app/work/logs/diff_move_counts.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
