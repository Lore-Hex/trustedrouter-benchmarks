Sending keys: ['cat > /app/work/full_prompt_transitions.py <<\'PY\'\n#!/usr/bin/env python3\nimport glob, os, re\nfrom collections import defaultdict\n\nfs = sorted(glob.glob(\'/app/work/ocr/frame_*.txt\'), key=lambda p:int(os.path.basename(p).split(\'_\')[1].split(\'.\')[0]))\n\n# OCR corrections accumulated from observed OCR errors\nfixes = {\n    \'n.\':\'n\',\n    \'gY\':\'y\', \'Y\':\'y\',\n    \'G\':\'again\', \'g\':\'again\',\n    \'move,\':\'move rug\',\n    \'open tra\':\'open trap\',\n    \'ulysse\':\'ulysses\',\n    \'pu,\':\'put\',\n    \'Dopen\':\'open\',\n    \'elose\':\'close\',\n    \'eage\':\'cage\', \'ceage\':\'cage\', \'ca_\':\'cage\',\n    \'mirro\':\'mirror\',\n    \'temp\':\'temple\', \'tem_\':\'temple\',\n    \'rin\':\'ring\',\n    \'get all fr\':\'get all from cage\', \'get all from _\':\'get all from cage\', \'get all from ca_\':\'get all from cage\',\n    \'get lamp,clove,sc\':\'get lamp,clove,screwdriver\',\n    \'get lamp,clove,screw\':\'get lamp,clove,screwdriver\',\n    \'put torch,scr\':\'put torch,screwdriver\',\n    \'get huge, tor\':\'get huge,torch\',\n    \'get head, jade,cup,egg,go\':\'get head,jade,cup,egg,golden\',\n    \'get head, jade,cup,egg, golden\':\'get head,jade,cup,egg,golden\',\n    \'put all\':\'put all in case\',\n    \'e,\':\'e\',\n    \'d.\':\'d\',\n    \'wW\':\'w\',\n    \'1li\':\'lid\', \'1lid\':\'lid\',\n}\n\ndef clean_prompt(line):\n    s = line.strip()\n    if not s.startswith(\'>\'):\n        return \'\'\n    s = s[1:].strip()\n    s = s.rstrip(\'._\').strip()\n    s = re.sub(r\'\\s+\', \' \', s).strip()\n    return fix_cmd(s)\n\ndef fix_cmd(s):\n    # iterative repair for comma artifacts and OCR fixes\n    s = s.replace(\',,\', \',\').strip()\n    if s in fixes:\n        s = fixes[s]\n    # normalize spacing around commas without adding spaces if OCR omitted them\n    s = re.sub(r\'\\s*,\\s*\', \',\', s)\n    # restore common multiword command spacing where commas should be ", "\n    s = s.replace(\',\', \', \')\n    s = re.sub(r\'\\s+\', \' \', s).strip()\n    if s in fixes:\n        s = fixes[s]\n    return s\n\n# Collect all prompt lines with frame numbers\nall_prompts = []\nfor idx, p in enumerate(fs, 1):\n    txt = open(p, errors=\'ignore\').read()\n    for line in txt.splitlines():\n        c = clean_prompt(line)\n        if c:\n            all_prompts.append((idx, c))\n\n# Collapse typing continuations: if new string is an extension of previous, update previous.\ncollapsed = []\nfor idx, c in all_prompts:\n    if collapsed:\n        li, lc = collapsed[-1]\n        if c.startswith(lc) and len(c) > len(lc):\n            collapsed[-1] = (idx, c)\n            continue\n        if lc.startswith(c) and len(lc) - len(c) <= 2:\n            continue\n    collapsed.append((idx, c))\n\n# Remove stale prefix-only scrollback artifacts: if a prompt is a strict prefix of a later prompt\n# appearing within 8 frames, treat it as incomplete typing and drop it.\nfiltered = []\nfor n, (idx, c) in enumerate(collapsed):\n    is_prefix = False\n    for jj, cc in collapsed[n+1:n+30]:\n        if cc.startswith(c) and len(cc) > len(c):\n            is_prefix = True\n            break\n        if jj - idx > 8:\n            break\n    if not is_prefix:\n        filtered.append((idx, c))\n\n# Deduplicate consecutive identical commands only; keep repeats separated by other commands.\nfinal = []\nseen_first = {}\nfor idx, c in filtered:\n    if final and final[-1][1] == c:\n        continue\n    if final and c.startswith(final[-1][1]) and len(c) > len(final[-1][1]):\n        final[-1] = (idx, c)\n        continue\n    if final and final[-1][1].startswith(c) and len(final[-1][1]) - len(c) <= 2:\n        continue\n    final.append((idx, c))\n\nwith open(\'/app/work/logs/full_prompt_transitions.log\', \'w\') as f:\n    for n, (idx, c) in enumerate(final, 1):\n        f.write(f\'{n:03d} f{idx:03d} {c}\\n\')\n\nprint(\'full_prompt_transitions_count\', len(final))\nprint(\'expected\', 262)\nprint(\'first40\', final[:40])\nprint(\'last40\', final[-40:])\nPY\npython3 /app/work/full_prompt_transitions.py\nwc -l /app/work/logs/full_prompt_transitions.log\nsed -n \'1,120p\' /app/work/logs/full_prompt_transitions.log\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
