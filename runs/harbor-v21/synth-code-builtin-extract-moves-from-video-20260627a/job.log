Sending keys: ['python3 - <<\'PY\'\nimport glob, os, re, json\n\nfs=sorted(glob.glob(\'/app/work/ocr/frame_*.txt\'), key=lambda p:int(os.path.basename(p).split(\'_\')[1].split(\'.\')[0]))\n\nrows=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors=\'ignore\').read()\n    m=re.search(r\'Moves?:\\s*(\\d+)\', txt)\n    mv=int(m.group(1)) if m else None\n    lines=[l.rstrip() for l in txt.splitlines() if l.strip()]\n    prompts=[]\n    for l in reversed(lines):\n        s=l.strip()\n        if s.startswith(\'>\'):\n            c=s[1:].strip().rstrip(\'._\').strip()\n            c=re.sub(r\'\\s+\',\' \',c).strip()\n            prompts.append(c)\n            prompts.reverse()\n            break\n    rows.append({\'idx\':idx,\'mv\':mv,\'last_cmd\':prompts[-1] if prompts else \'\'})\n\n# Print move count changes for validation\nprint(\'MOVE COUNT CHANGES:\')\nlast=None\nfor r in rows:\n    if r[\'mv\'] is not None and r[\'mv\'] != last:\n        print(f"f{r[\'idx\']:03d} mv={r[\'mv\']} last_cmd={r[\'last_cmd\']!r}")\n        last=r[\'mv\']\n\nprint(\'\\\\nTOTAL FRAMES:\', len(rows))\nprint(\'LAST FRAME:\', rows[-1])\nPY\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
Sending keys: ["python3 - <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\nrows=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    m=re.search(r'Moves?:\\s*(\\d+)', txt)\n    mv=int(m.group(1)) if m else None\n    lines=[l.rstrip() for l in txt.splitlines() if l.strip()]\n    # collect all prompt lines in order\n    all_prompts=[]\n    for l in lines:\n        s=l.strip()\n        if s.startswith('>'):\n            c=s[1:].strip().rstrip('._').strip()\n            c=re.sub(r'\\s+',' ',c).strip()\n            all_prompts.append(c)\n    rows.append({'idx':idx,'mv':mv,'prompts':all_prompts,'txt':txt})\n\n# Build candidate moves from move-count increments.\n# For each transition where mv increases by k, collect k commands from prompt history\n# between previous and current frame. Prefer prompts that are new/updated in that interval.\ncandidates=[]\nprev_mv=0\nseen=set()\nfor i in range(len(rows)):\n    r=rows[i]\n    if r['mv'] is None:\n        continue\n    if r['mv'] > prev_mv:\n        k = r['mv'] - prev_mv\n        # Get prompts from frames since last move frame up to this frame\n        start = 0 if prev_mv == 0 else next((j for j in range(i-1,-1,-1) if rows[j]['mv'] == prev_mv), 0)\n        # Get unique typed prompts in this interval, preserving frame order\n        interval=[]\n        for j in range(start, i+1):\n            for p in rows[j]['prompts']:\n                if p and p not in seen:\n                    interval.append((j, p))\n                    seen.add(p)\n        # For multiple moves, take last k unique prompts (or all if fewer)\n        for j,p in interval[-k:]:\n            candidates.append((j, p))\n        prev_mv = r['mv']\n\n# Deduplicate consecutive identical candidates\nfinal=[]\nfor j,p in candidates:\n    if not final or final[-1] != p:\n        final.append((j,p))\n\nwith open('/app/work/logs/moves_movecount_v1.log', 'w') as f:\n    for n,(j,p) in enumerate(final,1):\n        f.write(f'{n:03d} f{j+1:03d} {p}\\n')\nprint('candidate_count', len(final))\nprint('first10', final[:10])\nprint('last10', final[-10:])\nPY\nwc -l /app/work/logs/moves_movecount_v1.log\nsed -n '1,60p' /app/work/logs/moves_movecount_v1.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
