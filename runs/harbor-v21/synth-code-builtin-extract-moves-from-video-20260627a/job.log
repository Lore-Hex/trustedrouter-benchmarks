 pray dig board launch pump echo save drink wait look give show wave blow pour turn tie untie climb jump enter push pull fill y g'.split())\n\ndef fix_cmd(s):\n    s=s.strip().rstrip('._').strip()\n    s=re.sub(r'\\s+',' ',s).strip()\n    return fixes.get(s,s)\n\ndef clean_prompt(s):\n    s=s.strip()\n    if not s.startswith('>'):\n        return ''\n    s=s[1:].strip().rstrip('._').strip()\n    s=re.sub(r'\\s+',' ',s).strip()\n    return fix_cmd(s)\n\ndef normalize_bottom(s):\n    s=re.sub(r'[^A-Za-z0-9>, ._]',' ',s)\n    s=re.sub(r'\\s+',' ',s).strip()\n    had_prompt=s.startswith('>')\n    if had_prompt:\n        s=s[1:].strip()\n    s=s.rstrip('._').strip()\n    s=fix_cmd(s)\n    return s, had_prompt\n\n# Parse 1fps OCR\nframes=[]\nfor idx,p in enumerate(ocr1,1):\n    txt=open(p,errors='ignore').read()\n    m=re.search(r'Moves?:\\s*(\\d+)', txt)\n    mv=int(m.group(1)) if m else None\n    prompts=[]\n    for l in txt.splitlines():\n        c=clean_prompt(l)\n        if c:\n            prompts.append(c)\n    frames.append({'idx':idx,'mv':mv,'prompts':prompts})\n\nanchors=[(i,frames[i]['mv']) for i in range(len(frames)) if frames[i]['mv'] is not None]\n\ndef b5_to_1fps(i):\n    return max(1, min(len(frames), (i+4)//5))\n\n# Parse dense bottom5 and create submitted command segments\nb5=[]\nfor idx,p in enumerate(bottom5,1):\n    raw=open(p,errors='ignore').read().strip()\n    norm,had=normalize_bottom(raw)\n    b5.append({'idx':idx,'cmd':norm if norm else '', 'had_prompt':had})\n\ndef is_commandlike(c):\n    if not c:\n        return False\n    if len(c)>45:\n        return False\n    if not re.search(r'[A-Za-z]', c):\n        return False\n    first=c.split()[0].lower().strip('.,') if c.split() else ''\n    if first in common:\n        return True\n    if c.lower() in ['y','again','g']:\n        return True\n    # allow fixed multiword commands even if first token OCR-merged\n    if c in fixes.values():\n        return True\n    return False\n\n# Build segments on