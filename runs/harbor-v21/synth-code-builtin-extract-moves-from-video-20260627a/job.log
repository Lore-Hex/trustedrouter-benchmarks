Sending keys: ["cat > /app/work/extract_dense_progression.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/bottom5/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\nif not fs:\n    raise SystemExit('no bottom5 files')\n\ndef norm(s):\n    s=s.strip()\n    s=re.sub(r'[^A-Za-z0-9>, ._]', ' ', s)\n    s=re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nrows=[]\nfor idx,p in enumerate(fs,1):\n    raw=open(p,errors='ignore').read().strip()\n    line=norm(raw)\n    cur=line\n    if cur.startswith('>'):\n        cur=cur[1:].strip()\n    rows.append((idx,cur,line))\n\ngroups=[]\ncur_group=None\nfor idx,cur,line in rows:\n    if cur:\n        if cur_group is None:\n            cur_group=(idx,cur)\n        else:\n            last_idx,last_cmd=cur_group\n            if cur.startswith(last_cmd) or (len(last_cmd)>=2 and cur.startswith(last_cmd[:-1])):\n                cur_group=(idx,cur)\n            else:\n                groups.append(cur_group)\n                cur_group=(idx,cur)\n    else:\n        if cur_group is not None:\n            groups.append(cur_group)\n            cur_group=None\nif cur_group:\n    groups.append(cur_group)\n\ncands=[]\nfor idx,cmd in groups:\n    cmd=cmd.rstrip('._').strip()\n    if not cmd:\n        continue\n    if cands and cands[-1][1] == cmd and idx - cands[-1][0] <= 10:\n        continue\n    cands.append((idx,cmd))\n\nwith open('/app/work/logs/dense_progression.log','w') as f:\n    for n,(idx,cmd) in enumerate(cands,1):\n        f.write(f'{n:04d} fr{idx:05d} {cmd}\\n')\nprint('dense_candidate_count', len(cands))\nprint('first10', cands[:10])\nprint('last10', cands[-10:])\nPY\npython3 /app/work/extract_dense_progression.py\nwc -l /app/work/logs/dense_progression.log\nsed -n '1,120p' /app/work/logs/dense_progression.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
