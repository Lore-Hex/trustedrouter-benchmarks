Sending keys: ["cat > /app/work/extract_dense_submits.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/bottom5/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\ndef normalize(s):\n    s=re.sub(r'[^A-Za-z0-9>, ._]', ' ', s)\n    s=re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nlines=[]\nfor idx,p in enumerate(fs,1):\n    raw=open(p,errors='ignore').read().strip()\n    n=normalize(raw)\n    if n.startswith('>'):\n        n=n[1:].strip()\n    lines.append(n)\n\nprev_state=None\nsubmits=[]\ncurrent=None\nfor i,line in enumerate(lines,1):\n    if not line:\n        if current and current not in (prev_state,):\n            submits.append((i, current))\n            prev_state=current\n            current=None\n        continue\n    if current and (line.startswith(current) or (len(current)>=3 and line.startswith(current[:-1]))):\n        current=line\n        continue\n    if current and current.startswith(line) and len(current)-len(line) <= 3:\n        continue\n    if current and current not in (prev_state,):\n        submits.append((i, current))\n        prev_state=current\n    current=line\nif current and current != prev_state:\n    submits.append((len(lines), current))\n\nwith open('/app/work/logs/dense_submits.log','w') as f:\n    for n,(i,c) in enumerate(submits,1):\n        f.write(f'{n:03d} f{i:05d} {c}\\n')\nprint('submits_count', len(submits))\nprint('first20', submits[:20])\nprint('last20', submits[-20:])\nPY\npython3 /app/work/extract_dense_submits.py\nwc -l /app/work/logs/dense_submits.log\nsed -n '1,120p' /app/work/logs/dense_submits.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
