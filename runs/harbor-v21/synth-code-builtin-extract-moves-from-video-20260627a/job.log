Sending keys: ["cat > /app/work/extract_anchored.py <<'PY'\nimport glob, os, re\n\nfs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))\n\nfixes = {\n    'nuge':'huge', 'torcn':'torch', 'torc':'torch', 'tor':'torch',\n    'elose':'close', 'Dopen':'open', 'dopen':'open', '1lid':'lid', '1li':'li',\n    'eage':'cage', 'ceage':'cage', 'ca_':'cage', 'ca':'cage',\n    'pu,':'put', 'pu':'put',\n    'mirro':'mirror', 'temp':'temple', 'tem':'temple',\n    'rin':'ring',\n    'get all fr':'get all from cage', 'get all from _':'get all from cage', 'get all from ca_':'get all from cage',\n    'get lamp,clove':'get lamp,clove,screwdriver', 'get lamp,clove,sc':'get lamp,clove,screwdriver',\n    'get lamp,clove,screw':'get lamp,clove,screwdriver',\n    'put torch,scr':'put torch,screwdriver', 'put torch,screw':'put torch,screwdriver',\n    'get huge, tor':'get huge,torch', 'get huge,torc':'get huge,torch', 'get nuge,torcn':'get huge,torch',\n    'get head, jade,cup,egg,go':'get head,jade,cup,egg,golden', 'get head, jade,cup,egg, golden':'get head,jade,cup,egg,golden',\n    'get head, jade,cup,egg,gold':'get head,jade,cup,egg,golden', 'get head, Jade ,cup,egg,goiden':'get head,jade,cup,egg,golden',\n    'Wind ac':'wind canary', 'Wind canary':'wind canary', 'win':'wind canary',\n    'get egg,sow':'get egg,sword,lamp', 'get egg, sword,1':'get egg,sword,lamp',\n    'ulysse':'ulysses', 'ulyss':'ulysses',\n    'gY':'y', 'Y':'y', 'G':'again',\n    'n.':'n',\n    'move,':'move rug',\n    'open tra':'open trap',\n    'g':'again',\n}\n\ndef clean_prompt(s):\n    s=s.strip()\n    if not s.startswith('>'):\n        return ''\n    s=s[1:].strip().rstrip('._').strip()\n    s=re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nframes=[]\nfor idx,p in enumerate(fs,1):\n    txt=open(p,errors='ignore').read()\n    m=re.search(r'Moves?:\\s*(\\d+)', txt)\n    mv=int(m.group(1)) if m else None\n    prompts=[]\n    for l in txt.splitlines():\n        c=clean_prompt(l)\n        if c:\n            prompts.append(c)\n    frames.append({'idx':idx,'mv':mv,'prompts':prompts})\n\n# If no move count anchors, fallback to ordered unique full prompts with prefix collapse.\nmove_frames=[(i, frames[i]['mv']) for i in range(len(frames)) if frames[i]['mv'] is not None]\nif not move_frames:\n    seen=[]\n    for f in frames:\n        for p in f['prompts']:\n            if p and (not seen or not p.startswith(seen[-1])):\n                seen.append(p)\n    with open('/app/work/logs/moves_anchored.log','w') as out:\n        for n,p in enumerate(seen,1):\n            out.write(f'{n:03d} f??? {p}\\n')\n    print('candidate_count', len(seen))\n    raise SystemExit\n\ncandidates=[]\nprev_i, prev_mv = 0, 0\nfor end_i, end_mv in move_frames:\n    delta = end_mv - prev_mv\n    interval=[]\n    for j in range(prev_i, end_i+1):\n        for p in frames[j]['prompts']:\n            if p:\n                interval.append((j,p))\n    # Collapse typing continuations within interval: keep later longer strings unless new root.\n    collapsed=[]\n    for j,p in interval:\n        if collapsed and p.startswith(collapsed[-1][1]):\n            collapsed[-1]=(j,p)\n        elif collapsed and collapsed[-1][1].startswith(p) and len(collapsed[-1][1]) - len(p) <= 2:\n            continue\n        else:\n            collapsed.append((j,p))\n    # Prefer unique completed strings in interval; remove prefixes of later strings.\n    kept=[]\n    for j,p in collapsed:\n        is_prefix=False\n        for jj,pp in collapsed:\n            if jj > j and pp.startswith(p) and len(pp) > len(p):\n                is_prefix=True\n                break\n        if not is_prefix:\n            kept.append((j,p))\n    chosen = kept[-delta:] if delta >= 1 else kept[-1:]\n    if delta > 1 and len(chosen) < delta and kept:\n        chosen = kept[-delta:]\n    for j,p in chosen:\n        candidates.append((frames[j]['idx'], p))\n    prev_i, prev_mv = end_i, end_mv\n\n# Deduplicate consecutive identical and apply fixes.\nfinal=[]\nfor idx,p in candidates:\n    if p in fixes:\n        p=fixes[p]\n    if not final and p:\n        final.append((idx,p))\n        continue\n    if final and final[-1][1] == p:\n        continue\n    if final and p.startswith(final[-1][1]):\n        continue\n    if p:\n        final.append((idx,p))\n\nwith open('/app/work/logs/moves_anchored.log','w') as f:\n    for n,(idx,cmd) in enumerate(final,1):\n        f.write(f'{n:03d} f{idx:03d} {cmd}\\n')\nprint('candidate_count', len(final))\nprint('first20', final[:20])\nprint('last20', final[-20:])\nPY\npython3 /app/work/extract_anchored.py\nwc -l /app/work/logs/moves_anchored.log\nsed -n '1,100p' /app/work/logs/moves_anchored.log\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
