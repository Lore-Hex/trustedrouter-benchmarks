[?2004l[?2004h>     frames.append({'idx':idx,'mv':mv,'prompts':prompts})
[?2004l[?2004h> 
[?2004l[?2004h> # Move-count anchors
[?2004l[?2004h> anchors=[(i,frames[i]['mv']) for i in range(len(frames)) if frames[i]['mv'] is not None]
[?2004l[?2004h> 
[?2004l[?2004h> # Dense bottom5 lines (frame index at 5fps)
[?2004l[?2004h> b5=[]
[?2004l[?2004h> for idx,p in enumerate(bottom5,1):
