[?2004l[?2004h>             cur=(i,line)
[?2004l[?2004h>         elif cur[1].startswith(line) and len(cur[1])-len(line)<=3:
[?2004l[?2004h>             pass
[?2004l[?2004h>         else:
[?2004l[?2004h>             segments.append(cur)
[?2004l[?2004h>             cur=(i,line)
[?2004l[?2004h>     else:
[?2004l[?2004h>         if cur:
[?2004l[?2004h>             segments.append(cur)
[?2004l[?2004h>             cur=None
[?2004l[?2004h> if cur:
[?2004l[?2004h>     segments.append(cur)
[?2004l[?2004h> 
[?2004l[?2004h> # Filter obvious game-text fragments: no letters or long narrative strings.
[?2004l[?2004h> filtered=[]
