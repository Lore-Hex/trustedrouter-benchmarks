[?2004l[?2004h> 
[?2004l[?2004h> candidates=[]
[?2004l[?2004h> prev_i, prev_mv = 0, 0
[?2004l[?2004h> for end_i, end_mv in move_frames:
[?2004l[?2004h>     delta = end_mv - prev_mv
[?2004l[?2004h>     interval=[]
[?2004l[?2004h>     for j in range(prev_i, end_i+1):
[?2004l[?2004h>         for p in frames[j]['prompts']:
[?2004l[?2004h>             if p:
[?2004l[?2004h>                 interval.append((j,p))
[?2004l[?2004h>     # Collapse typing continuations within interval: keep later longer strings unless new root.
[?2004l[?2004h>     collapsed=[]
[?2004l[?2004h>     for j,p in interval:
[?2004l[?2004h>         if collapsed and p.startswith(collapsed[-1][1]):
[?2004l[?2004h>             collapsed[-1]=(j,p)
[?2004l[?2004h>         elif collapsed and collapsed[-1][1].startswith(p) and len(collapsed[-1][1]) - len(p) <= 2:
[?2004l[?2004h>             continue
[?2004l[?2004h>         else:
[?2004l[?2004h>             collapsed.append((j,p))
[?2004l[?2004h>     # Prefer unique completed strings in interval; remove prefixes of later strings.
[?2004l[?2004h>     kept=[]
[?2004l[?2004h>     for j,p in collapsed:
[?2004l[?2004h>         is_prefix=False
[?2004l[?2004h>         for jj,pp in collapsed:
[?2004l[?2004h>             if jj > j and pp.startswith(p) and len(pp) > len(p):
[?2004l[?2004h>                 is_prefix=True
[?2004l[?2004h>                 break
[?2004l[?2004h>         if not is_prefix:
[?2004l[?2004h>             kept.append((j,p))
[?2004l[?2004h>     chosen = kept[-delta:] if delta >= 1 else kept[-1:]
[?2004l[?2004h>     if delta > 1 and len(chosen) < delta and kept:
[?2004l[?2004h>         chosen = kept[-delta:]
[?2004l[?2004h>     for j,p in chosen:
[?2004l[?2004h>         candidates.append((frames[j]['idx'], p))
[?2004l[?2004h>     prev_i, prev_mv = end_i, end_mv
[?2004l[?2004h> 
[?2004l[?2004h> # Deduplicate consecutive identical and apply fixes.
[?2004l[?2004h> final=[]
