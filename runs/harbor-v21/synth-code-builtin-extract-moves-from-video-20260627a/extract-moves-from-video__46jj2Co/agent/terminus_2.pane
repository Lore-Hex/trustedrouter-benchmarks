[?2004hroot@84675a12e8e4:/app# echo '=== move progression ==='; python3 - <<'PY'
[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> fs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> last=None
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     m=re.search(r'Moves?:\s*(\d+)', txt)
[?2004l[?2004h>     if m:
[?2004l[?2004h>         mv=int(m.group(1))
[?2004l[?2004h>         if mv!=last:
[?2004l[?2004h>             lines=[l.strip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>             lastp=[l for l in lines if l.startswith('>')]
[?2004l[?2004h>             print(f'f{idx:03d} mv={mv} prompts={lastp[-3:]}')
[?2004l[?2004h>             last=mv
[?2004l[?2004h> PY
