[?2004l[?2004h> 
[?2004l[?2004h> # Detect dense submit groups: non-empty prompt continuation followed by blank or new root.
[?2004l[?2004h> dense=[]
[?2004l[?2004h> cur=None
[?2004l[?2004h> for i,line in enumerate(b5,1):
[?2004l[?2004h>     if line:
[?2004l[?2004h>         if cur is None:
[?2004l[?2004h>             cur=(i,line)
[?2004l[?2004h>         else:
[?2004l[?2004h>             if line.startswith(cur[1]) or (len(cur[1])>=3 and line.startswith(cur[1][:-1])):
[?2004l[?2004h>                 cur=(i,line)
[?2004l[?2004h>             elif cur[1].startswith(line) and len(cur[1])-len(line) <= 3:
[?2004l[?2004h>                 pass
[?2004l[?2004h>             else:
[?2004l[?2004h>                 dense.append(cur)
[?2004l[?2004h>                 cur=(i,line)
[?2004l[?2004h>     else:
[?2004l[?2004h>         if cur:
[?2004l[?2004h>             dense.append(cur)
[?2004l[?2004h>             cur=None
[?2004l[?2004h> if cur:
[?2004l[?2004h>     dense.append(cur)
[?2004l[?2004h> 
[?2004l[?2004h> # Map dense 5fps frame index to 1fps frame index (1fps frame n corresponds roughly 5fps frames 5n-4..5n)
[?2004l[?2004h> def b5_to_1fps(i):
[?2004l[?2004h>     return max(1, min(len(frames), (i+4)//5))
[?2004l[?2004h> 
[?2004l[?2004h> # Build interval commands from move-count anchors and 1fps prompt history.
[?2004l[?2004h> cands=[]
[?2004l[?2004h> if anchors:
[?2004l[?2004h>     prev_i, prev_mv = 0, 0
[?2004l[?2004h>     for end_i, end_mv in anchors:
[?2004l[?2004h>         delta = end_mv - prev_mv
[?2004l[?2004h>         if delta <= 0:
[?2004l[?2004h>             continue
[?2004l[?2004h>         interval=[]
[?2004l[?2004h>         for j in range(prev_i, end_i+1):
[?2004l[?2004h>             for p in frames[j]['prompts']:
[?2004l[?2004h>                 interval.append((frames[j]['idx'], p))
[?2004l[?2004h>         # Collapse typing continuations but preserve distinct root commands/repeats.
[?2004l[?2004h>         collapsed=[]
[?2004l[?2004h>         for j,p in interval:
[?2004l[?2004h>             if collapsed and (p.startswith(collapsed[-1][1]) or collapsed[-1][1].startswith(p)):
[?2004l[?2004h>                 if len(p) >= len(collapsed[-1][1]):
[?2004l[?2004h>                     collapsed[-1]=(j,p)
[?2004l[?2004h>             else:
[?2004l[?2004h>                 collapsed.append((j,p))
[?2004l[?2004h>         # Remove pure prefixes that are substrings of later commands, but keep repeats.
