[?2004l[?2004h>     s = s.rstrip('._').strip()
[?2004l[?2004h>     s = re.sub(r'\s+', ' ', s).strip()
[?2004l[?2004h>     return fix_cmd(s)
[?2004l[?2004h> 
[?2004l[?2004h> def fix_cmd(s):
[?2004l[?2004h>     # iterative repair for comma artifacts and OCR fixes
[?2004l[?2004h>     s = s.replace(',,', ',').strip()
[?2004l[?2004h>     if s in fixes:
[?2004l[?2004h>         s = fixes[s]
[?2004l[?2004h>     # normalize spacing around commas without adding spaces if OCR omitted them
[?2004l[?2004h>     s = re.sub(r'\s*,\s*', ',', s)
[?2004l[?2004h>     # restore common multiword command spacing where commas should be ", "
[?2004l[?2004h>     s = s.replace(',', ', ')
[?2004l[?2004h>     s = re.sub(r'\s+', ' ', s).strip()
[?2004l[?2004h>     if s in fixes:
[?2004l[?2004h>         s = fixes[s]
[?2004l[?2004h>     return s
