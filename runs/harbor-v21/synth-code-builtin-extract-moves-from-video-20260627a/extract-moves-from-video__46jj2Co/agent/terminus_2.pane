[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> 
[?2004l[?2004h> fs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> 
[?2004l[?2004h> def clean_prompt(s):
[?2004l[?2004h>     s=s.strip()
[?2004l[?2004h>     if not s.startswith('>'):
[?2004l[?2004h>         return ''
[?2004l[?2004h>     s=s[1:].strip()
[?2004l[?2004h>     s=s.rstrip('._').strip()
[?2004l[?2004h>     s=s.replace(',,', ',').strip()
[?2004l[?2004h>     return s
[?2004l[?2004h> 
[?2004l[?2004h> raw_cmds=[]
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     prompts=[clean_prompt(l) for l in lines if l.strip().startswith('>')]
[?2004l[?2004h>     prompts=[p for p in prompts if p]
[?2004l[?2004h>     if prompts:
[?2004l[?2004h>         raw_cmds.append((idx,prompts[-1]))
[?2004l[?2004h> 
[?2004l[?2004h> cmds=[]
[?2004l[?2004h> prev_idx=None
[?2004l[?2004h> prev_cmd=None
[?2004l[?2004h> for idx,cmd in raw_cmds:
[?2004l[?2004h>     if prev_cmd is None:
[?2004l[?2004h>         prev_idx, prev_cmd = idx, cmd
[?2004l[?2004h>         continue
[?2004l[?2004h>     if cmd == prev_cmd:
[?2004l[?2004h>         continue
[?2004l[?2004h>     # Treat strict typing extension as same command in progress
[?2004l[?2004h>     if cmd.startswith(prev_cmd):
[?2004l[?2004h>         prev_idx, prev_cmd = idx, cmd
[?2004l[?2004h>         continue
[?2004l[?2004h>     # Sometimes OCR loses a comma/space; accept very small typoed extensions manually later.
[?2004l[?2004h>     cmds.append((prev_idx, prev_cmd))
[?2004l[?2004h>     prev_idx, prev_cmd = idx, cmd
[?2004l[?2004h> if prev_cmd:
[?2004l[?2004h>     cmds.append((prev_idx, prev_cmd))
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/work/logs/moves_v1.log','w') as f:
[?2004l[?2004h>     for i,(idx,cmd) in enumerate(cmds,1):
