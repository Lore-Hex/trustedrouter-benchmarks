[?2004l[?2004h>         interval=[(b5_to_1fps(i), c) for i,c in b5_ded if prev_i < b5_to_1fps(i) <= end_i]
[?2004l[?2004h>         # If no dense interval commands, fallback to 1fps prompt history last commands
