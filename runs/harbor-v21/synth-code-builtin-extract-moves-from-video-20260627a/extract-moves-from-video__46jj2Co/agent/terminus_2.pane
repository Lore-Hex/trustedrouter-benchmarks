[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> 
[?2004l[?2004h> bottom5=sorted(glob.glob('/app/work/bottom5/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> 
[?2004l[?2004h> fixes={
[?2004l[?2004h>     'gY':'y','Y':'y','G':'again','g':'again',
[?2004l[?2004h>     'move,':'move rug','open tra':'open trap',
[?2004l[?2004h>     'ulysse':'ulysses','ulyss':'ulysses',
[?2004l[?2004h>     'pu,':'put','pu':'put',
[?2004l[?2004h>     'Dopen':'open','dopen':'open',
[?2004l[?2004h>     'elose':'close','ceage':'cage','eage':'cage','ca_':'cage','ca':'cage',
[?2004l[?2004h>     'mirro':'mirror',
[?2004l[?2004h>     'temp':'temple','tem':'temple','tem_':'temple',
[?2004l[?2004h>     'rin':'ring','dro':'drop',
[?2004l[?2004h>     'get all fr':'get all from cage','get all from _':'get all from cage','get all from ca_':'get all from cage',
[?2004l[?2004h>     'get a rom Cage':'get all from cage',
[?2004l[?2004h>     'get lamp,clove':'get lamp,clove,screwdriver','get lamp,clove,sc':'get lamp,clove,screwdriver','get lamp,clove,screw':'get lamp,clove,screwdriver',
[?2004l[?2004h>     'put torch,scr':'put torch,screwdriver','put torch,screw':'put torch,screwdriver',
[?2004l[?2004h>     'get huge, tor':'get huge,torch','get huge,torc':'get huge,torch','get nuge,torcn':'get huge,torch','get huge,tor':'get huge,torch',
[?2004l[?2004h>     'get egg,sow':'get egg,sword,lamp','get egg, sword,1':'get egg,sword,lamp',
[?2004l[?2004h>     'get head, jade,cup,egg,go':'get head,jade,cup,egg,golden',
[?2004l[?2004h>     'get head, jade,cup,egg, golden':'get head,jade,cup,egg,golden',
[?2004l[?2004h>     'get head, jade,cup,egg,gold':'get head,jade,cup,egg,golden',
[?2004l[?2004h>     'get head, Jade ,cup,egg,goiden':'get head,jade,cup,egg,golden',
[?2004l[?2004h>     'Wind ac':'wind canary','Wind canary':'wind canary','win':'wind canary','win_':'wind canary',
[?2004l[?2004h>     '1li':'lid','1lid':'lid','Lid':'lid','lid':'lid',
[?2004l[?2004h>     'wW':'w','e,':'e','d.':'d','ne.':'ne',
[?2004l[?2004h>     'n.':'n',
[?2004l[?2004h>     'case':'case',
[?2004l[?2004h>     'put all':'put all in case',
[?2004l[?2004h>     'p':'put all in case',
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> common=set('n s e w u d ne nw se sw get take drop put open close move kill again ring read rub set lower raise wind pray dig board launch pump echo save drink  wait look give show wave blow pour turn tie untie climb jump enter push pull fill y g'.split())
[?2004l[?2004h> 
[?2004l[?2004h> def normalize_bottom(s):
[?2004l[?2004h>     s=re.sub(r'[^A-Za-z0-9>, ._]',' ',s)
[?2004l[?2004h>     s=re.sub(r'\s+',' ',s).strip()
[?2004l[?2004h>     had=s.startswith('>')
[?2004l[?2004h>     if had:
[?2004l[?2004h>         s=s[1:].strip()
[?2004l[?2004h>     s=s.rstrip('._').strip()
[?2004l[?2004h>     if s in fixes:
[?2004l[?2004h>         s=fixes[s]
[?2004l[?2004h>     return s, had
[?2004l[?2004h> 
[?2004l[?2004h> lines=[]
[?2004l[?2004h> for idx,p in enumerate(bottom5,1):
[?2004l[?2004h>     raw=open(p,errors='ignore').read().strip()
[?2004l[?2004h>     n,h=normalize_bottom(raw)
[?2004l[?2004h>     lines.append({'idx':idx,'cmd':n,'had':h})
[?2004l[?2004h> 
[?2004l[?2004h> def is_commandlike(c):
[?2004l[?2004h>     if not c:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if len(c)>45:
[?2004l[?2004h>         return False
[?2004l[?2004h>     if not re.search(r'[A-Za-z]', c):
[?2004l[?2004h>         return False
[?2004l[?2004h>     parts=c.split()
[?2004l[?2004h>     first=parts[0].lower().strip('.,') if parts else ''
[?2004l[?2004h>     if first in common:
[?2004l[?2004h>         return True
[?2004l[?2004h>     if c.lower() in ['y','again','g']:
[?2004l[?2004h>         return True
[?2004l[?2004h>     if c in fixes.values():
[?2004l[?2004h>         return True
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> segments=[]
[?2004l[?2004h> cur=None
[?2004l[?2004h> for r in lines:
[?2004l[?2004h>     c=r['cmd']
[?2004l[?2004h>     i=r['idx']
[?2004l[?2004h>     if r['had'] and c and is_commandlike(c):
[?2004l[?2004h>         if cur is None:
[?2004l[?2004h>             cur=(i,c)
[?2004l[?2004h>         elif c.startswith(cur[1]) or (len(cur[1])>=3 and c.startswith(cur[1][:-1])):
[?2004l[?2004h>             cur=(i,c)
[?2004l[?2004h>         elif cur[1].startswith(c) and len(cur[1])-len(c)<=3:
[?2004l[?2004h>             pass
[?2004l[?2004h>         else:
[?2004l[?2004h>             segments.append(cur)
[?2004l[?2004h>             cur=(i,c)
[?2004l[?2004h>     else:
[?2004l[?2004h>         if cur:
[?2004l[?2004h>             segments.append(cur)
[?2004l[?2004h>             cur=None
[?2004l[?2004h> if cur:
[?2004l[?2004h>     segments.append(cur)
[?2004l[?2004h> 
[?2004l[?2004h> final=[]
[?2004l[?2004h> for i,c in segments:
[?2004l[?2004h>     c=fixes.get(c,c)
[?2004l[?2004h>     if final and final[-1][1]==c:
[?2004l[?2004h>         continue
[?2004l[?2004h>     final.append((i,c))
[?2004l[?2004h> 
[?2004l[?2004h> def b5_to_1fps(i):
[?2004l[?2004h>     return max(1, min(190, (i+4)//5))
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/work/logs/bottom5_prompt_hunter.log','w') as f:
[?2004l[?2004h>     for n,(i,c) in enumerate(final,1):
[?2004l[?2004h>         f.write(f'{n:03d} b5={i:05d} f={b5_to_1fps(i):03d} {c}\n')
