[?2004hroot@84675a12e8e4:/app# cat > /app/work/extract_candidates.py <<'PY'
[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> 
[?2004l[?2004h> fs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> 
[?2004l[?2004h> data=[]
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     m=re.search(r'Moves?:\s*(\d+)', txt)
[?2004l[?2004h>     mv=int(m.group(1)) if m else None
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     prompts=[l.strip() for l in lines if l.lstrip().startswith('>')]
[?2004l[?2004h>     data.append((idx, mv, prompts))
[?2004l[?2004h> 
[?2004l[?2004h> print('MOVE COUNT CHANGES:')
[?2004l[?2004h> last=None
[?2004l[?2004h> for idx,mv,prompts in data:
[?2004l[?2004h>     if mv is not None and mv != last:
[?2004l[?2004h>         print(f'f{idx:03d} moves={mv} prompts={prompts}')
[?2004l[?2004h>         last=mv
[?2004l[?2004h> 
[?2004l[?2004h> print('\\nALL FRAMES PROMPTS:')
[?2004l[?2004h> for idx,mv,prompts in data:
[?2004l[?2004h>     if prompts:
[?2004l[?2004h>         print(f'{idx:03d} mv={mv}: ' + ' | '.join(prompts))
[?2004l[?2004h> 
[?2004l[?2004h> # Candidate completed commands: when last prompt changes to a new root command,
[?2004l[?2004h> # take the last non-empty prompt before the change if it is not just a partial cursor artifact.
[?2004l[?2004h> # This is a first-pass report only.
[?2004l[?2004h> cands=[]
[?2004l[?2004h> prev=None
[?2004l[?2004h> for idx,mv,prompts in data:
[?2004l[?2004h>     cur=prompts[-1] if prompts else None
[?2004l[?2004h>     if cur is None:
[?2004l[?2004h>         continue
[?2004l[?2004h>     cmd=cur.lstrip('>').strip()
[?2004l[?2004h>     if prev is None:
[?2004l[?2004h>         prev=cmd
[?2004l[?2004h>         continue
[?2004l[?2004h>     if cmd == prev:
[?2004l[?2004h>         continue
[?2004l[?2004h>     if cmd.startswith(prev) or prev.endswith('_'):
[?2004l[?2004h>         prev=cmd
[?2004l[?2004h>         continue
[?2004l[?2004h>     cands.append((idx, mv, prev))
[?2004l[?2004h>     prev=cmd
[?2004l[?2004h> if prev:
[?2004l[?2004h>     cands.append((len(fs), data[-1][1], prev))
[?2004l[?2004h> 
[?2004l[?2004h> print('\\nCANDIDATES:')
[?2004l[?2004h> for i,(idx,mv,cmd) in enumerate(cands,1):
[?2004l[?2004h>     print(f'{i:03d} f{idx:03d} mv={mv} cmd={cmd!r}')
[?2004l[?2004h> print('candidate_count', len(cands))
[?2004l[?2004h> PY
