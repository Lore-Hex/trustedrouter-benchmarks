[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> 
[?2004l[?2004h> fs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> 
[?2004l[?2004h> rows=[]
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     m=re.search(r'Moves?:\s*(\d+)', txt)
[?2004l[?2004h>     mv=int(m.group(1)) if m else None
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     # collect all prompt lines in order
[?2004l[?2004h>     all_prompts=[]
[?2004l[?2004h>     for l in lines:
[?2004l[?2004h>         s=l.strip()
[?2004l[?2004h>         if s.startswith('>'):
[?2004l[?2004h>             c=s[1:].strip().rstrip('._').strip()
[?2004l[?2004h>             c=re.sub(r'\s+',' ',c).strip()
[?2004l[?2004h>             all_prompts.append(c)
[?2004l[?2004h>     rows.append({'idx':idx,'mv':mv,'prompts':all_prompts,'txt':txt})
[?2004l[?2004h> 
[?2004l[?2004h> # Build candidate moves from move-count increments.
[?2004l[?2004h> # For each transition where mv increases by k, collect k commands from prompt history
[?2004l[?2004h> # between previous and current frame. Prefer prompts that are new/updated in that interval.
[?2004l[?2004h> candidates=[]
[?2004l[?2004h> prev_mv=0
[?2004l[?2004h> seen=set()
[?2004l[?2004h> for i in range(len(rows)):
[?2004l[?2004h>     r=rows[i]
[?2004l[?2004h>     if r['mv'] is None:
[?2004l[?2004h>         continue
[?2004l[?2004h>     if r['mv'] > prev_mv:
[?2004l[?2004h>         k = r['mv'] - prev_mv
[?2004l[?2004h>         # Get prompts from frames since last move frame up to this frame
[?2004l[?2004h>         start = 0 if prev_mv == 0 else next((j for j in range(i-1,-1,-1) if rows[j]['mv'] == prev_mv), 0)
[?2004l[?2004h>         # Get unique typed prompts in this interval, preserving frame order
[?2004l[?2004h>         interval=[]
[?2004l[?2004h>         for j in range(start, i+1):
[?2004l[?2004h>             for p in rows[j]['prompts']:
[?2004l[?2004h>                 if p and p not in seen:
[?2004l[?2004h>                     interval.append((j, p))
[?2004l[?2004h>                     seen.add(p)
[?2004l[?2004h>         # For multiple moves, take last k unique prompts (or all if fewer)
[?2004l[?2004h>         for j,p in interval[-k:]:
[?2004l[?2004h>             candidates.append((j, p))
[?2004l[?2004h>         prev_mv = r['mv']
[?2004l[?2004h> 
[?2004l[?2004h> # Deduplicate consecutive identical candidates
[?2004l[?2004h> final=[]
[?2004l[?2004h> for j,p in candidates:
[?2004l[?2004h>     if not final or final[-1] != p:
[?2004l[?2004h>         final.append((j,p))
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/work/logs/moves_movecount_v1.log', 'w') as f:
[?2004l[?2004h>     for n,(j,p) in enumerate(final,1):
[?2004l[?2004h>         f.write(f'{n:03d} f{j+1:03d} {p}\n')
[?2004l[?2004h> print('candidate_count', len(final))
