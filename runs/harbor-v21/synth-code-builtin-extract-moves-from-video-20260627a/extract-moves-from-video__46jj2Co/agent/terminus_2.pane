[?2004l[?2004h>     if typed:
[?2004l[?2004h>         hits+=1
[?2004l[?2004h>         print(os.path.basename(p), 'PROMPT_LINES:', ' || '.join(typed[-3:]))
[?2004l[?2004h> print('frames_with_typed_prompt', hits)
[?2004l[?2004h> PY
