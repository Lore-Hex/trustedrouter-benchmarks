[?2004l[?2004h>     txt=pytesseract.image_to_string(im)
[?2004l[?2004h>     open(p.replace('/frames/','/ocr/').replace('.png','.txt'),'w').write(txt)
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     prompts=[l for l in lines if l.lstrip().startswith('>')]
