[?2004l[?2004h> def normalize(s):
[?2004l[?2004h>     s=re.sub(r'[^A-Za-z0-9>, ._]',' ',s)
[?2004l[?2004h>     s=re.sub(r'\s+',' ',s).strip()
[?2004l[?2004h>     if s.startswith('>'):
[?2004l[?2004h>         s=s[1:].strip()
[?2004l[?2004h>     s=s.rstrip('._').strip()
