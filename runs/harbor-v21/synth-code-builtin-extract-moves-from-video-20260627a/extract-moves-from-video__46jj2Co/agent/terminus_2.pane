[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     prompts=[l.strip() for l in lines if l.lstrip().startswith('>')]
[?2004l[?2004h>     lastgame=''
[?2004l[?2004h>     for l in reversed(lines):
[?2004l[?2004h>         if not l.lstrip().startswith('>'):
[?2004l[?2004h>             lastgame=l.strip()
[?2004l[?2004h>             break
[?2004l[?2004h>     print(f'{idx:03d}: PROMPTS=[{" | ".join(prompts)}] LASTGAME={lastgame[:120]!r}')
[?2004l[?2004h> PY
