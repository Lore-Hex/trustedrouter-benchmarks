[?2004l[?2004h>         current=line
[?2004l[?2004h>         continue
[?2004l[?2004h>     if current and current.startswith(line) and len(current)-len(line) <= 3:
[?2004l[?2004h>         continue
[?2004l[?2004h>     if current and current not in (prev_state,):
[?2004l[?2004h>         submits.append((i, current))
[?2004l[?2004h>         prev_state=current
[?2004l[?2004h>     current=line
[?2004l[?2004h> if current and current != prev_state:
