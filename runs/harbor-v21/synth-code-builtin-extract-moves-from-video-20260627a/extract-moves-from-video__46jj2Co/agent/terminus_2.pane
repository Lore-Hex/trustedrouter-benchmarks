[?2004hroot@84675a12e8e4:/app# cat > /app/work/diff_move_counts.py <<'PY'
[?2004l[?2004h> import glob, os, re
[?2004l[?2004h> fs=sorted(glob.glob('/app/work/ocr/frame_*.txt'), key=lambda p:int(os.path.basename(p).split('_')[1].split('.')[0]))
[?2004l[?2004h> rows=[]
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     m=re.search(r'Moves?:\s*(\d+)', txt)
[?2004l[?2004h>     mv=int(m.group(1)) if m else None
[?2004l[?2004h>     lines=[l.rstrip() for l in txt.splitlines() if l.strip()]
[?2004l[?2004h>     prompts=[l.strip() for l in lines if l.lstrip().startswith('>')]
[?2004l[?2004h>     lastgame=''
[?2004l[?2004h>     for l in reversed(lines):
[?2004l[?2004h>         if not l.lstrip().startswith('>'):
[?2004l[?2004h>             lastgame=l.strip()
[?2004l[?2004h>             break
[?2004l[?2004h>     rows.append((idx,mv,prompts,lastgame))
[?2004l[?2004h> 
[?2004l[?2004h> print('MOVE PROGRESSION')
[?2004l[?2004h> last=None
[?2004l[?2004h> for idx,mv,prompts,lg in rows:
[?2004l[?2004h>     if mv is not None and mv!=last:
[?2004l[?2004h>         print(f'f{idx:03d} mv={mv} prompts={prompts} lastgame={lg[:100]!r}')
[?2004l[?2004h>         last=mv
[?2004l[?2004h> 
[?2004l[?2004h> print('\nTRANSITION CONTEXT')
[?2004l[?2004h> for i,(idx,mv,prompts,lg) in enumerate(rows):
[?2004l[?2004h>     prev_mv=rows[i-1][1] if i>0 else None
[?2004l[?2004h>     if mv is not None and prev_mv is not None and mv!=prev_mv:
[?2004l[?2004h>         print(f'\nTRANSITION f{idx:03d} mv {prev_mv}->{mv}')
[?2004l[?2004h>         for j in range(max(0,i-2), min(len(rows),i+3)):
[?2004l[?2004h>             print(f'  f{rows[j][0]:03d} mv={rows[j][1]} prompts={rows[j][2]} lastgame={rows[j][3][:80]!r}')
[?2004l[?2004h> PY
