[?2004l[?2004h>         for n,(j,p) in enumerate(collapsed):
[?2004l[?2004h>             is_prefix=False
[?2004l[?2004h>             for jj,pp in collapsed[n+1:]:
[?2004l[?2004h>                 if pp.startswith(p) and len(pp) > len(p):
[?2004l[?2004h>                     is_prefix=True
[?2004l[?2004h>                     break
[?2004l[?2004h>             if not is_prefix:
[?2004l[?2004h>                 kept.append((j,p))
