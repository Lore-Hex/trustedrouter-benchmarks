[?2004l[?2004h> frames=[]
[?2004l[?2004h> for idx,p in enumerate(fs,1):
[?2004l[?2004h>     txt=open(p,errors='ignore').read()
[?2004l[?2004h>     m=re.search(r'Moves?:\s*(\d+)', txt)
[?2004l[?2004h>     mv=int(m.group(1)) if m else None
[?2004l[?2004h>     prompts=[]
[?2004l[?2004h>     for l in txt.splitlines():
[?2004l[?2004h>         c=clean_prompt(l)
[?2004l[?2004h>         if c:
[?2004l[?2004h>             prompts.append(c)
[?2004l[?2004h>     frames.append({'idx':idx,'mv':mv,'prompts':prompts})
[?2004l[?2004h> 
[?2004l[?2004h> # If no move count anchors, fallback to ordered unique full prompts with prefix collapse.
[?2004l[?2004h> move_frames=[(i, frames[i]['mv']) for i in range(len(frames)) if frames[i]['mv'] is not None]
[?2004l[?2004h> if not move_frames:
[?2004l[?2004h>     seen=[]
[?2004l[?2004h>     for f in frames:
[?2004l[?2004h>         for p in f['prompts']:
[?2004l[?2004h>             if p and (not seen or not p.startswith(seen[-1])):
[?2004l[?2004h>                 seen.append(p)
[?2004l[?2004h>     with open('/app/work/logs/moves_anchored.log','w') as out:
[?2004l[?2004h>         for n,p in enumerate(seen,1):
[?2004l[?2004h>             out.write(f'{n:03d} f??? {p}\n')
[?2004l[?2004h>     print('candidate_count', len(seen))
