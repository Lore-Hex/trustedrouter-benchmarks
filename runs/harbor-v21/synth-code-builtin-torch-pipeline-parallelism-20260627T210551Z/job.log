Sending keys: ['cat > /tmp/test_pp.py <<\'PY\'\nfrom __future__ import annotations\n\nimport os\nimport sys\nimport math\nimport traceback\nimport torch\nimport torch.distributed as dist\nimport torch.multiprocessing as mp\nimport torch.nn.functional as F\nfrom transformers import LlamaForCausalLM, LlamaConfig\n\nsys.path.insert(0, \'/app\')\nfrom pipeline_parallel import train_step_pipeline_afab, _partition\n\n\ndef make_cfg():\n    return LlamaConfig(\n        vocab_size=128,\n        hidden_size=32,\n        intermediate_size=64,\n        num_hidden_layers=4,\n        num_attention_heads=4,\n        num_key_value_heads=4,\n        max_position_embeddings=16,\n        use_cache=False,\n        rms_norm_eps=1e-6,\n        tie_word_embeddings=False,\n    )\n\n\ndef worker(rank, world_size, port, results):\n    try:\n        os.environ[\'MASTER_ADDR\'] = \'127.0.0.1\'\n        os.environ[\'MASTER_PORT\'] = str(port)\n        dist.init_process_group(\'gloo\', rank=rank, world_size=world_size)\n        torch.manual_seed(123)\n        cfg = make_cfg()\n        model = LlamaForCausalLM(cfg).to(device=torch.device(\'cpu\'), dtype=torch.float64)\n        for p in model.parameters():\n            p.requires_grad_(True)\n\n        # Use identical deterministic data on all ranks. Only rank 0 passes inputs;\n        # only last rank passes targets.\n        torch.manual_seed(456)\n        inputs = [torch.randint(0, cfg.vocab_size, (2, 8), dtype=torch.long) for _ in range(2)]\n        targets = [torch.randint(0, cfg.vocab_size, (2, 8), dtype=torch.long) for _ in range(2)]\n\n        in_list = inputs if rank == 0 else []\n        tg_list = targets if rank == world_size - 1 else []\n        loss = train_step_pipeline_afab(model, in_list, tg_list, torch.device(\'cpu\'), torch.float64)\n\n        total_layers = len(model.model.layers)\n        local_start, local_end = _partition(0, total_layers, world_size, rank)\n        grads = {}\n        for i, layer in enumerate(model.model.layers[local_start:local_end]):\n            for n, p in layer.named_parameters():\n                if p.grad is not None:\n                    grads[f\'model.layers.{local_start + i}.{n}\'] = p.grad.detach().clone()\n        if rank == 0:\n            p = model.model.embed_tokens.weight\n            if p.grad is not None:\n                grads[\'model.embed_tokens.weight\'] = p.grad.detach().clone()\n        if rank == world_size - 1:\n            for n, p in model.model.norm.named_parameters():\n                if p.grad is not None:\n                    grads[f\'model.norm.{n}\'] = p.grad.detach().clone()\n            for n, p in model.lm_head.named_parameters():\n                if p.grad is not None:\n                    grads[f\'lm_head.{n}\'] = p.grad.detach().clone()\n\n        results[rank] = {\'ok\': True, \'loss\': None if loss is None else float(loss.detach()), \'grads\': grads, \'local_start\': local_start, \'local_end\': local_end}\n        dist.barrier()\n        dist.destroy_process_group()\n    except Exception as e:\n        tb = traceback.format_exc()\n        try:\n            dist.destroy_process_group()\n        except Exception:\n            pass\n        results[rank] = {\'ok\': False, \'error\': str(e), \'traceback\': tb}\n\n\ndef reference():\n    torch.manual_seed(123)\n    cfg = make_cfg()\n    model = LlamaForCausalLM(cfg).to(device=torch.device(\'cpu\'), dtype=torch.float64)\n    for p in model.parameters():\n        p.requires_grad_(True)\n    torch.manual_seed(456)\n    inputs = [torch.randint(0, cfg.vocab_size, (2, 8), dtype=torch.long) for _ in range(2)]\n    targets = [torch.randint(0, cfg.vocab_size, (2, 8), dtype=torch.long) for _ in range(2)]\n    model.train()\n    for p in model.parameters():\n        if p.grad is not None:\n            p.grad = None\n    total_loss = 0.0\n    num_mb = len(inputs)\n    for mb in range(num_mb):\n        out = model(input_ids=inputs[mb], labels=targets[mb])\n        loss = out.loss / num_mb\n        total_loss += float(loss.detach())\n        loss.backward()\n    grads = {}\n    for n, p in model.named_parameters():\n        if p.grad is not None:\n            grads[n] = p.grad.detach().clone()\n    return total_loss, grads, model\n\n\ndef run_world(world_size, port):\n    print(f\'===== world_size={world_size} =====\', flush=True)\n    mgr = mp.Manager()\n    results = mgr.dict()\n    ctx = mp.get_context(\'spawn\')\n    procs = [ctx.Process(target=worker, args=(r, world_size, port, results)) for r in range(world_size)]\n    for p in procs:\n        p.start()\n    for p in procs:\n        p.join(60)\n    for p in procs:\n        if p.is_alive():\n            p.terminate()\n            print(\'terminated alive process\', flush=True)\n    res = dict(results)\n    for r in range(world_size):\n        rr = res.get(r, {})\n        if not rr.get(\'ok\'):\n            print(f\'rank {r} failed:\\n{rr.get("traceback", rr.get("error"))}\', flush=True)\n            return False\n        print(f\'rank {r}: layers={rr["local_start"]}:{rr["local_end"]} loss={rr["loss"]}\', flush=True)\n\n    ref_loss, ref_grads, ref_model = reference()\n    print(f\'reference loss={ref_loss}\', flush=True)\n\n    if world_size == 1:\n        last_loss = res[0][\'loss\']\n        if not (last_loss is not None and math.isclose(last_loss, ref_loss, rel_tol=1e-6, abs_tol=1e-9)):\n            print(\'loss mismatch\', last_loss, ref_loss, flush=True)\n            return False\n\n    max_abs = 0.0\n    mismatches = []\n    for r in range(world_size):\n        for name, g in res[r][\'grads\'].items():\n            if name not in ref_grads:\n                print(\'missing reference grad\', name, flush=True)\n                return False\n            ref_g = ref_grads[name]\n            diff = (g - ref_g).abs().max().item()\n            max_abs = max(max_abs, diff)\n            if diff > 1e-6:\n                mismatches.append((name, diff))\n    print(f\'max grad diff vs reference: {max_abs}\',