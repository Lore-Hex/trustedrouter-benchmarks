ads[n] = p.grad.detach().clone()\n    return total_loss, grads\n\n\ndef run_world(world_size, port):\n    print(f\'===== variable world_size={world_size} =====\', flush=True)\n    mgr = mp.Manager()\n    results = mgr.dict()\n    ctx = mp.get_context(\'spawn\')\n    procs = [ctx.Process(target=worker, args=(r, world_size, port, results)) for r in range(world_size)]\n    for p in procs:\n        p.start()\n    for p in procs:\n        p.join(60)\n    for p in procs:\n        if p.is_alive():\n            p.terminate()\n    res = dict(results)\n    for r in range(world_size):\n        rr = res.get(r, {})\n        if not rr.get(\'ok\'):\n            print(f\'rank {r} failed:\\n{rr.get("traceback", rr.get("error"))}\', flush=True)\n            return False\n        print(f\'rank {r}: layers={rr["local_start"]}:{rr["local_end"]} loss={rr["loss"]}\', flush=True)\n    ref_loss, ref_grads = reference()\n    print(f\'reference loss={ref_loss}\', flush=True)\n    max_abs = 0.0\n    mismatches = []\n    for r in range(world_size):\n        for name, g in res[r][\'grads\'].items():\n            if name not in ref_grads:\n                print(\'missing reference grad\', name, flush=True)\n                return False\n            ref_g = ref_grads[name]\n            diff = (g - ref_g).abs().max().item()\n            max_abs = max(max_abs, diff)\n            if diff > 1e-6:\n                mismatches.append((name, diff))\n    print(f\'max grad diff vs reference: {max_abs}\', flush=True)\n    if mismatches:\n        print(\'mismatches:\', mismatches[:20], flush=True)\n        return False\n    return True\n\n\ndef main():\n    ok = True\n    for ws in (1, 2):\n        ok = run_world(ws, 29600 + ws) and ok\n    print(\'VARIABLE TESTS\', \'PASS\' if ok else \'FAIL\', flush=True)\n    sys.exit(0 if ok else 1)\n\n\nif __name__ == \'__main__\':\n    main()\nPY\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
