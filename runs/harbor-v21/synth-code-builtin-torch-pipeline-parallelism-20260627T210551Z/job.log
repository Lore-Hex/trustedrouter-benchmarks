Sending keys: ['cat > /app/pipeline_parallel.py <<\'PY\'\nfrom __future__ import annotations\n\nimport torch\nimport torch.distributed as dist\nimport torch.nn.functional as F\nfrom torch.distributed import P2POp\n\n\ndef _partition(start: int, end: int, world_size: int, rank: int) -> tuple[int, int]:\n    """Return balanced ``[local_start, local_end)`` decoder-layer indices for this rank."""\n    n = end - start\n    base = n // world_size\n    rem = n % world_size\n    local_start = start + rank * base + min(rank, rem)\n    local_count = base + (1 if rank < rem else 0)\n    return local_start, local_start + local_count\n\n\ndef _p2p_op(op):\n    """Submit a single P2P operation and wait for it to complete."""\n    for work in dist.batch_isend_irecv([op]):\n        work.wait()\n\n\ndef _make_causal_mask(hidden_states: torch.Tensor) -> torch.Tensor:\n    """Create a Llama-compatible 4D additive causal mask."""\n    bsz, seq_len = hidden_states.shape[0], hidden_states.shape[1]\n    min_dtype = torch.finfo(hidden_states.dtype).min\n    mask = torch.full((seq_len, seq_len), min_dtype, device=hidden_states.device, dtype=hidden_states.dtype)\n    mask = torch.triu(mask, diagonal=1)\n    return mask.unsqueeze(0).unsqueeze(0).expand(bsz, 1, seq_len, seq_len).contiguous()\n\n\ndef train_step_pipeline_afab(model, inputs, targets, device, dtype):\n    """Run one all-forward-all-backward pipeline-parallel training step for LlamaForCausalLM.\n\n    Args:\n        model: LlamaForCausalLM instance. Decoder layers are partitioned across\n            pipeline ranks. Embeddings are owned by rank 0; final norm and lm\n            head are owned by the last rank.\n        inputs: list of input-id microbatch tensors on rank 0.\n        targets: list of target-id microbatch tensors on the last rank.\n        device: torch device.\n        dtype: torch dtype.\n    """\n    rank = dist.get_rank()\n    world_size = dist.get_world_size()\n\n    model.train()\n\n    # Rank 0 owns the input microbatches. Broadcast their count and shape so all\n    # ranks know how many forwards/backwards to run and what hidden state shape\n    # to expect.\n    if rank == 0:\n        if not inputs:\n            count_tensor = torch.tensor([0, 0, 1], dtype=torch.long, device=device)\n        else:\n            mb_shape = list(inputs[0].shape)\n            count_tensor = torch.tensor([len(inputs), mb_shape[0], mb_shape[1]], dtype=torch.long, device=device)\n    else:\n        count_tensor = torch.tensor([0, 0, 1], dtype=torch.long, device=device)\n\n    dist.broadcast(count_tensor, src=0)\n    num_microbatches = int(count_tensor[0].item())\n    batch_size = int(count_tensor[1].item())\n    seq_len = int(count_tensor[2].item())\n\n    if num_microbatches == 0:\n        return None\n\n    total_layers = len(model.model.layers)\n    local_start, local_end = _partition(0, total_layers, world_size, rank)\n    local_layers = model.model.layers[local_start:local_end]\n    is_first = rank == 0\n    is_last = rank == world_size - 1\n    hidden_size = model.config.hidden_size\n\n    # Clear existing gradients before accumulating contributions from all microbatches.\n    for param in model.parameters():\n        if param.requires_grad and param.grad is not None:\n            param.grad = None\n\n    # Saved forward state for each microbatch for AFAB backward.\n    saved = []\n    last_loss = None\n\n    # ALL FORWARD\n    for mb in range(num_microbatches):\n        if is_first:\n            input_ids = inputs[mb].to(device=device, dtype=torch.long)\n            hidden = model.model.embed_tokens(input_ids).to(device=device, dtype=dtype)\n        else:\n            recv_shape = (batch_size, seq_len, hidden_size)\n            recv_buf = torch.empty(recv_shape, device=device, dtype=dtype)\n            _p2p_op(P2POp(dist.irecv, recv_buf, rank - 1))\n            hidden = recv_buf\n\n        hidden.requires_grad_(True)\n        position_ids = torch.arange(seq_len, device=device).unsqueeze(0)\n        position_embeddings = model.model.rotary_emb(hidden, position_ids=position_ids)\n        attn_mask = _make_causal_mask(hidden)\n\n        out = hidden\n        for layer in local_layers:\n            out = layer(\n                out,\n                attention_mask=attn_mask,\n                position_ids=position_ids,\n                past_key_values=None,\n                use_cache=False,\n                position_embeddings=position_embeddings,\n            )\n\n        if is_last:\n            # Compute scaled cross-entropy on last rank for this microbatch.\n            # Match transformers 5.12 ForCausalLMLoss: upcast logits to float and\n            # shift labels by one position.\n            normed = model.model.norm(out)\n            logits = model.lm_head(normed).float()\n            target = targets[mb].to(device=device, dtype=torch.long)\n            shift_labels = F.pad(target, (0, 1), value=-100)[..., 1:].contiguous()\n            loss = F.cross_entropy(\n                logits.view(-1, logits.size(-1)),\n                shift_labels.view(-1),\n                ignore_index=-100,\n            ) / num_microbatches\n            last_loss = loss\n            saved.append((hidden, out, attn_mask, position_embeddings, loss))\n        else:\n            saved.append((hidden, out, attn_mask, position_embeddings))\n            if not is_first:\n                send_buf = hidden.grad\n                if send_buf is None:\n                    send_buf = torch.zeros_like(hidden)\n                send_buf = send_buf.detach().to(device=device, dtype=dtype).contiguous()\n                _p2p_op(P2POp(dist.isend, send_buf, rank - 1))\n\n    # ALL BACKWARD\n    for mb in range(num_microbatches):\n        if is_last:\n            hidden, out, attn_mask, position_embeddings, loss = saved[mb]\n            loss.backward()\n        else:\n            hidden, out, attn_mask, position_embeddings = saved[mb]\n            grad_buf = torch.empty_like(out)\n         