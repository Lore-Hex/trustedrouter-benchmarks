[?2004l[?2004h> import sys
[?2004l[?2004h> import cv2
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> import toml
[?2004l[?2004h> 
[?2004l[?2004h> def analyze_jump(video_path):
[?2004l[?2004h>     cap = cv2.VideoCapture(video_path)
[?2004l[?2004h>     if not cap.isOpened():
[?2004l[?2004h>         print(f"Error: Cannot open video {video_path}", file=sys.stderr)
[?2004l[?2004h>         sys.exit(1)
[?2004l[?2004h> 
[?2004l[?2004h>     # Read the first frame as background (no runner)
[?2004l[?2004h>     ret, bg_frame = cap.read()
[?2004l[?2004h>     if not ret:
[?2004l[?2004h>         print("Error: Cannot read first frame", file=sys.stderr)
[?2004l[?2004h>         sys.exit(1)
[?2004l[?2004h>     
[?2004l[?2004h>     bg_gray = cv2.cvtColor(bg_frame, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>     bg_gray = cv2.GaussianBlur(bg_gray, (21, 21), 0)
[?2004l[?2004h> 
[?2004l[?2004h>     # Store athlete position data per frame
[?2004l[?2004h>     # We track: bottom_y (feet position in image coords, lower value = higher position)
[?2004l[?2004h>     frame_data = []  # list of (frame_number, bottom_y, center_x, area)
[?2004l[?2004h> 
[?2004l[?2004h>     frame_idx = 0
[?2004l[?2004h>     while True:
[?2004l[?2004h>         ret, frame = cap.read()
[?2004l[?2004h>         if not ret:
[?2004l[?2004h>             break
[?2004l[?2004h>         frame_idx += 1
[?2004l[?2004h> 
[?2004l[?2004h>         gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
[?2004l[?2004h>         gray = cv2.GaussianBlur(gray, (21, 21), 0)
[?2004l[?2004h> 
[?2004l[?2004h>         # Compute absolute difference from background
[?2004l[?2004h>         diff = cv2.absdiff(bg_gray, gray)
[?2004l[?2004h>         _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)
[?2004l[?2004h> 
[?2004l[?2004h>         # Morphological operations to clean up
[?2004l[?2004h>         kernel = np.ones((5, 5), np.uint8)
[?2004l[?2004h>         thresh = cv2.dilate(thresh, kernel, iterations=2)
[?2004l[?2004h>         thresh = cv2.erode(thresh, kernel, iterations=1)
[?2004l[?2004h> 
[?2004l[?2004h>         contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
[?2004l[?2004h> 
[?2004l[?2004h>         # Find the largest contour with sufficient area (the athlete)
[?2004l[?2004h>         best_contour = None
[?2004l[?2004h>         best_area = 0
[?2004l[?2004h>         for c in contours:
[?2004l[?2004h>             area = cv2.contourArea(c)
[?2004l[?2004h>             if area > best_area and area > 3000:
[?2004l[?2004h>                 best_area = area
[?2004l[?2004h>                 best_contour = c
[?2004l[?2004h> 
[?2004l[?2004h>         if best_contour is not None:
[?2004l[?2004h>             x, y, w, h = cv2.boundingRect(best_contour)
[?2004l[?2004h>             bottom_y = y + h
[?2004l[?2004h>             center_x = x + w // 2
[?2004l[?2004h>             frame_data.append((frame_idx, bottom_y, center_x, best_area))
[?2004l[?2004h>         else:
[?2004l[?2004h>             frame_data.append((frame_idx, None, None, None))
[?2004l[?2004h> 
[?2004l[?2004h>     cap.release()
[?2004l[?2004h> 
[?2004l[?2004h>     # Extract frames where athlete is detected
[?2004l[?2004h>     detected = [(f, by, cx, a) for f, by, cx, a in frame_data if by is not None]
[?2004l[?2004h>     
[?2004l[?2004h>     if not detected:
[?2004l[?2004h>         print("Error: No athlete detected in video", file=sys.stderr)
[?2004l[?2004h>         sys.exit(1)
[?2004l[?2004h> 
[?2004l[?2004h>     # Find the peak of the jump (minimum bottom_y = highest position)
[?2004l[?2004h>     min_bottom_y = min(by for _, by, _, _ in detected)
[?2004l[?2004h>     peak_frame = [f for f, by, _, _ in detected if by == min_bottom_y][0]
[?2004l[?2004h> 
[?2004l[?2004h>     # Compute ground level from running frames
[?2004l[?2004h>     # The ground level is roughly the median of all bottom_y values
[?2004l[?2004h>     # Since most frames show running (not jumping), median approximates ground level
[?2004l[?2004h>     all_bottom_y = [by for _, by, _, _ in detected]
[?2004l[?2004h>     ground_level = np.median(all_bottom_y)
[?2004l[?2004h> 
[?2004l[?2004h>     # Set threshold: if bottom_y is below this, athlete is in the air
[?2004l[?2004h>     # threshold is between ground level and peak
[?2004l[?2004h>     threshold = ground_level - 0.35 * (ground_level - min_bottom_y)
[?2004l[?2004h> 
[?2004l[?2004h>     # Find takeoff frame: last frame before/at peak where bottom_y is above threshold
[?2004l[?2004h>     # (i.e., athlete is still on the ground)
[?2004l[?2004h>     takeoff_frame = None
[?2004l[?2004h>     for f, by, cx, a in sorted(detected, key=lambda x: x[0]):
[?2004l[?2004h>         if f > peak_frame:
[?2004l[?2004h>             break
[?2004l[?2004h>         if by > threshold:
[?2004l[?2004h>             takeoff_frame = f
[?2004l[?2004h>         else:
[?2004l[?2004h>             # Once we're below threshold, we've found the jump has started
[?2004l[?2004h>             if takeoff_frame is not None:
[?2004l[?2004h>                 break
[?2004l[?2004h> 
[?2004l[?2004h>     # Find landing frame: first frame after peak where bottom_y is back above threshold
[?2004l[?2004h>     land_frame = None
[?2004l[?2004h>     for f, by, cx, a in sorted(detected, key=lambda x: x[0]):
[?2004l[?2004h>         if f <= peak_frame:
[?2004l[?2004h>             continue
[?2004l[?2004h>         if by > threshold:
[?2004l[?2004h>             land_frame = f
[?2004l[?2004h>             break
[?2004l[?2004h> 
[?2004l[?2004h>     if takeoff_frame is None or land_frame is None:
[?2004l[?2004h>         print("Error: Could not determine takeoff or landing frame", file=sys.stderr)
[?2004l[?2004h>         sys.exit(1)
[?2004l[?2004h> 
[?2004l[?2004h>     return takeoff_frame, land_frame
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     if len(sys.argv) < 2:
[?2004l[?2004h>         print("Usage: python3 jump_analyzer.py <video.mp4>", file=sys.stderr)
[?2004l[?2004h>         sys.exit(1)
[?2004l[?2004h> 
[?2004l[?2004h>     video_path = sys.argv[1]
[?2004l[?2004h>     takeoff, landing = analyze_jump(video_path)
[?2004l[?2004h> 
[?2004l[?2004h>     result = {
[?2004l[?2004h>         "jump_takeoff_frame_number": takeoff,
[?2004l[?2004h>         "jump_land_frame_number": landing
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h>     output_path = "/app/output.toml"
[?2004l[?2004h>     with open(output_path, "w") as f:
[?2004l[?2004h>         toml.dump(result, f)
[?2004l[?2004h> 
[?2004l[?2004h>     print(f"Takeoff frame: {takeoff}")
[?2004l[?2004h>     print(f"Landing frame: {landing}")
[?2004l[?2004h>     print(f"Output written to {output_path}")
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == "__main__":
[?2004l[?2004h>     main()
