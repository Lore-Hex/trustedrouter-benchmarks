[?2004l[?2004h> req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
[?2004l[?2004h> resp = urllib.request.urlopen(req, timeout=30)
[?2004l[?2004h> data = json.loads(resp.read())
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Total proteins: {data['count']}")
[?2004l[?2004h> 
[?2004l[?2004h> # Look for proteins with ex_max near 505 or em_max near 610
[?2004l[?2004h> results = []
[?2004l[?2004h> for p in data.get('results', []):
[?2004l[?2004h>     for state in p.get('states', []):
[?2004l[?2004h>         ex = state.get('ex_max')
