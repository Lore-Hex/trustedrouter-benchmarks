[?2004l[?2004h>         w = seq[i:i+50]
[?2004l[?2004h>         g = gc(w)
[?2004l[?2004h>         if g < 0.30 or g > 0.70:
[?2004l[?2004h>             bad.append((i, g))
[?2004l[?2004h>     return bad
[?2004l[?2004h> 
