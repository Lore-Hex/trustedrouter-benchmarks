[?2004l[?2004h> # Codon table - multiple codons per amino acid with varying GC content
[?2004l[?2004h> codon_table = {
[?2004l[?2004h>     'A': ['GCT','GCC','GCA','GCG'],
[?2004l[?2004h>     'R': ['CGT','CGC','CGA','CGG','AGA','AGG'],
[?2004l[?2004h>     'N': ['AAT','AAC'],
[?2004l[?2004h>     'D': ['GAT','GAC'],
[?2004l[?2004h>     'C': ['TGT','TGC'],
[?2004l[?2004h>     'Q': ['CAA','CAG'],
[?2004l[?2004h>     'E': ['GAA','GAG'],
[?2004l[?2004h>     'G': ['GGT','GGC','GGA','GGG'],
[?2004l[?2004h>     'H': ['CAT','CAC'],
[?2004l[?2004h>     'I': ['ATT','ATC','ATA'],
[?2004l[?2004h>     'L': ['TTA','TTG','CTT','CTC','CTA','CTG'],
[?2004l[?2004h>     'K': ['AAA','AAG'],
[?2004l[?2004h>     'M': ['ATG'],
[?2004l[?2004h>     'F': ['TTT','TTC'],
[?2004l[?2004h>     'P': ['CCT','CCC','CCA','CCG'],
[?2004l[?2004h>     'S': ['TCT','TCC','TCA','TCG','AGT','AGC'],
[?2004l[?2004h>     'T': ['ACT','ACC','ACA','ACG'],
[?2004l[?2004h>     'W': ['TGG'],
[?2004l[?2004h>     'Y': ['TAT','TAC'],
[?2004l[?2004h>     'V': ['GTT','GTC','GTA','GTG'],
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> def gc(s):
[?2004l[?2004h>     return (s.count('G')+s.count('C'))/len(s) if s else 0
[?2004l[?2004h> 
[?2004l[?2004h> # Protein components
[?2004l[?2004h> flag = "DYKDDDDK"
[?2004l[?2004h> clover_pdb = "MGSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK"
[?2004l[?2004h> clover = clover_pdb[1:]
[?2004l[?2004h> dhfr = "ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCCFEILERR"
[?2004l[?2004h> mcherry_pdb = "MVSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK"
[?2004l[?2004h> mcherry = mcherry_pdb[1:]
[?2004l[?2004h> snap = "GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR"
[?2004l[?2004h> gs = "GGSGGSGGSG"
[?2004l[?2004h> 
