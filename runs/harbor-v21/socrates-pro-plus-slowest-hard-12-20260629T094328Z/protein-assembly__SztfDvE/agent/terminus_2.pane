[?2004l[?2004h> 
[?2004l[?2004h> # Codon optimization with GC window constraint
[?2004l[?2004h> # Greedy: for each AA, choose codon that keeps running GC balanced toward 50%
[?2004l[?2004h> def optimize(protein, attempts=2000):
[?2004l[?2004h>     best = None
[?2004l[?2004h>     for attempt in range(attempts):
[?2004l[?2004h>         dna = []
[?2004l[?2004h>         for aa in protein:
[?2004l[?2004h>             codons = codon_table[aa]
[?2004l[?2004h>             # Score codons by how they keep recent window GC near 0.5
[?2004l[?2004h>             recent = ''.join(dna)[-47:]
[?2004l[?2004h>             def score(c):
[?2004l[?2004h>                 w = (recent + c)[-50:]
[?2004l[?2004h>                 return abs(gc(w) - 0.5)
[?2004l[?2004h>             # Add randomness
[?2004l[?2004h>             scored = sorted(codons, key=lambda c: score(c) + random.random()*0.05)
[?2004l[?2004h>             dna.append(scored[0])
[?2004l[?2004h>         seq = ''.join(dna)
[?2004l[?2004h>         # Validate GC windows
[?2004l[?2004h>         ok = True
[?2004l[?2004h>         for i in range(len(seq)-49):
[?2004l[?2004h>             w = seq[i:i+50]
[?2004l[?2004h>             g = gc(w)
[?2004l[?2004h>             if g < 0.30 or g > 0.70:
[?2004l[?2004h>                 ok = False
[?2004l[?2004h>                 break
[?2004l[?2004h>         if ok:
[?2004l[?2004h>             return seq
[?2004l[?2004h>         if best is None:
[?2004l[?2004h>             best = seq
[?2004l[?2004h>     return best
[?2004l[?2004h> 
[?2004l[?2004h> seq = optimize(protein)
