[?2004l[?2004h> my $egfp_fwd = best_anneal_fwd($egfp, 4, $target);
[?2004l[?2004h> my $egfp_rev = best_anneal_rev($egfp, 711, $target);
[?2004l[?2004h> die "No valid EGFP primers" unless $egfp_fwd && $egfp_rev;
[?2004l[?2004h> print "Fwd: $egfp_fwd->{seq} Tm=$egfp_fwd->{tm} len=$egfp_fwd->{len}\n";
[?2004l[?2004h> print "Rev: $egfp_rev->{seq} Tm=$egfp_rev->{tm} len=$egfp_rev->{len}\n";
[?2004l[?2004h> print "Tm diff: ", abs($egfp_fwd->{tm}-$egfp_rev->{tm}), "\n";
[?2004l[?2004h> 
[?2004l[?2004h> push @primers, {name=>'egfp_fwd', seq=>lc("cgcgGGTCTCA" . $j1_oh . $egfp_fwd->{seq})};
[?2004l[?2004h> push @primers, {name=>'egfp_rev', seq=>lc("cgcgGGTCTCA" . rc($j2_oh) . $egfp_rev->{seq})};
[?2004l[?2004h> 
