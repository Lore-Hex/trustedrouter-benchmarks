[?2004l[?2004h> print "Rev: $inp_r->{seq} Tm=$inp_r->{tm} len=$inp_r->{len}\n";
[?2004l[?2004h> print "Tm diff: $inp_d\n";
[?2004l[?2004h> 
[?2004l[?2004h> push @primers, {name=>'input_fwd', seq=>lc("cgcgGGTCTCA" . $j4_oh . $inp_f->{seq})};
[?2004l[?2004h> push @primers, {name=>'input_rev', seq=>lc("cgcgGGTCTCA" . rc($j1_oh) . $inp_r->{seq})};
[?2004l[?2004h> 
[?2004l[?2004h> # --- EGFP ---
