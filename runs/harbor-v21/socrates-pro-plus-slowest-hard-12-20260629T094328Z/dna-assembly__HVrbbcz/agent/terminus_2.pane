[?2004hroot@984965c9e0a4:/app# cat > verify.pl << 'ENDSCRIPT'
[?2004l[?2004h> use strict;
[?2004l[?2004h> use warnings;
[?2004l[?2004h> 
[?2004l[?2004h> my %seq; my $name;
[?2004l[?2004h> open(F,"sequences.fasta"); while(<F>){chomp; if(/^>(\S+)/){$name=$1;next;} $seq{$name}.=uc($_);} close F;
[?2004l[?2004h> 
[?2004l[?2004h> sub rc { my $s=uc(shift); $s=reverse($s); $s=~tr/ACGT/TGCA/; return $s; }
[?2004l[?2004h> 
[?2004l[?2004h> # Read primers
[?2004l[?2004h> my %prim; my $pn;
[?2004l[?2004h> open(P,"primers.fasta"); while(<P>){chomp; if(/^>(\S+)/){$pn=$1;next;} $prim{$pn}.=uc($_);} close P;
[?2004l[?2004h> 
[?2004l[?2004h> my $inp = $seq{input};
[?2004l[?2004h> my $egfp = $seq{egfp};
[?2004l[?2004h> my $flag = $seq{flag};
[?2004l[?2004h> my $snap = $seq{snap};
[?2004l[?2004h> my $out = $seq{output};
[?2004l[?2004h> 
[?2004l[?2004h> # Simulate PCR: each fragment is amplified by fwd + rev primers
[?2004l[?2004h> # The PCR product = fwd_primer + template_region + rc(rev_primer minus its own annealing... )
[?2004l[?2004h> # Actually PCR product top strand = fwd_primer_full ... then continues through template ... to rc(rev_primer_full)
[?2004l[?2004h> # Simpler: PCR product = fwd_primer_overhang_part + [annealing region through to rev annealing] + rc(rev overhang part)
[?2004l[?2004h> 
[?2004l[?2004h> # For each fragment, the product after BsaI digestion yields a fragment with 4nt overhangs.
[?2004l[?2004h> # Let me reconstruct each fragment's contribution to the final assembly.
[?2004l[?2004h> 
[?2004l[?2004h> # BsaI: GGTCTC(N1) cuts leaving 4nt 5' overhang. 
[?2004l[?2004h> # Primer structure: cgcg GGTCTC A [4nt OH] [anneal]
[?2004l[?2004h> # After cut: the 4nt OH + anneal region is retained in the fragment (with OH as sticky end)
[?2004l[?2004h> 
[?2004l[?2004h> # Reconstruct the assembled product (the part between/including overhangs)
[?2004l[?2004h> # Fragment = [4nt fwd OH] + [annealed template region] ending with last template base, then the next fragment's 4nt OH (which is the rev OH of this one) is shaared
[?2004l[?2004h> 
[?2004l[?2004h> # Let me build each fragment's double-stranded insert sequence (top strand from fwd OH start to just before rev OH... )
[?2004l[?2004h> 
[?2004l[?2004h> # input_fwd: OH=TAAT + anneal GAGGATCCC... (input[691:])
[?2004l[?2004h> # input_rev: OH=rc = ATGA reversed... the rev primer OH part rc gives ATGA at J1
[?2004l[?2004h> 
[?2004l[?2004h> # The assembled output should be circular. Let me reconstruct linearly starting at J1 (ATGA / pos210 in output).
[?2004l[?2004h> 
[?2004l[?2004h> # Fragment EGFP: spans J1(ATGA) to J2(AAGG)
[?2004l[?2004h> #   = ATGA + egfp[4..710] + ... up to AAGG
[?2004l[?2004h> # In output: output[210..922+4]
[?2004l[?2004h> 
[?2004l[?2004h> # Let me just verify each annealing region maps correctly and reconstruct.
[?2004l[?2004h> 
[?2004l[?2004h> # EGFP fragment in assembled = output[210 .. 926] (J1 start to J2 end)
[?2004l[?2004h> my $egfp_frag = substr($out, 210, 926-210);
[?2004l[?2004h> print "EGFP frag (assembled): ", substr($egfp_frag,0,20), "...", substr($egfp_frag,-20), " len=", length($egfp_frag), "\n";
[?2004l[?2004h> 
[?2004l[?2004h> # Verify the egfp primers produce this
[?2004l[?2004h> # egfp_fwd full = cgcgGGTCTCA + ATGA + GCAAGGGCGAGGAGCTG
[?2004l[?2004h> # After digestion, fragment starts with ATGA (overhang) then GCAAGGG...
[?2004l[?2004h> # egfp top strand: ATGA + (egfp annealing region onwards to rev)
[?2004l[?2004h> my $ef = $prim{egfp_fwd};
[?2004l[?2004h> my $er = $prim{egfp_rev};
[?2004l[?2004h> print "egfp_fwd: $ef\n";
[?2004l[?2004h> print "egfp_rev: $er\n";
[?2004l[?2004h> # fwd OH+anneal (after cgcgGGTCTCA = 11 chars)
[?2004l[?2004h> my $ef_part = substr($ef, 11);  # ATGA + anneal
[?2004l[?2004h> my $er_part = substr($er, 11);  # rc(AAGG)=CCTT + rc(anneal)
[?2004l[?2004h> print "ef_part: $ef_part\n";
[?2004l[?2004h> print "er_part: $er_part\n";
[?2004l[?2004h> # The fragment top strand = ef_part ... template ... then ends. The 3' end = rc(er_part)
[?2004l[?2004h> my $er_rc = rc($er_part);
[?2004l[?2004h> print "rc(er_part): $er_rc\n";
[?2004l[?2004h> 
[?2004l[?2004h> # EGFP fragment top strand should start with ef_part and end with er_rc
[?2004l[?2004h> if (index($egfp_frag, $ef_part) == 0) { print "EGFP fwd matches start: OK\n"; } else { print "EGFP fwd MISMATCH\n"; }
[?2004l[?2004h> if (substr($egfp_frag, -length($er_rc)) eq $er_rc) { print "EGFP rev matches end: OK\n"; } else { print "EGFP rev END: ", substr($egfp_frag,-length($er_rc)), "" vs $er_rc\n"; }
[?2004l[?2004h> 
[?2004l[?2004h> # Now reconstruct full output from 4 fragments and check
[?2004l[?2004h> # Fragment boundaries in output (each fragment includes its starting 4nt OH, ends just before next OH... but OHs are shared)
[?2004l[?2004h> # Circular assembly: 
[?2004l[?2004h> #  EGFP: output[210..922] (start at J1 OH, end just before J2 OH) -> but OH shared
[?2004l[?2004h> # Let me reconstruct: output = EGFP_frag(210..922) + FLAG_frag(922..1006) + SNAP_frag(1006..1551) + INPUT_frag(1551..end + 0..210)
[?2004l[?2004h> my $recon = substr($out,210,922-210) . substr($out,922,1006-922) . substr($out,1006,1551-1006) . substr($out,1551,length($out)-1551) . substr($out,0,210);
[?2004l[?2004h> print "\nReconstructed length: ", length($recon), " vs output ", length($out), "\n";
[?2004l[?2004h> # This is output rotated to start at 210
[?2004l[?2004h> my $rotated = substr($out,210) . substr($out,0,210);
[?2004l[?2004h> if ($recon eq $rotated) { print "Reconstruction matches rotated output: OK\n"; } else { print "Reconstruction MISMATCH\n"; }
