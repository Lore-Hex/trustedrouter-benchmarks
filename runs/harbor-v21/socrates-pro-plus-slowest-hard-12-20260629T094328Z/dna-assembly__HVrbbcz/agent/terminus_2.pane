[?2004l[?2004h>     my $extra = substr($s, 10, 1);
[?2004l[?2004h>     my $oh = substr($s, 11, 4);
[?2004l[?2004h>     my $anneal = substr($s, 15);
[?2004l[?2004h>     print "$p->{name}: spacer=$spacer BsaI=$bsai extra=$extra OH=$oh anneal_len=".length($anneal)." full_len=".length($s)."\n";
[?2004l[?2004h> }
