[?2004l[?2004h> print "Rev: $snap_rev->{seq} Tm=$snap_rev->{tm} len=$snap_rev->{len}\n";
[?2004l[?2004h> print "Tm diff: ", abs($snap_fwd->{tm}-$snap_rev->{tm}), "\n";
