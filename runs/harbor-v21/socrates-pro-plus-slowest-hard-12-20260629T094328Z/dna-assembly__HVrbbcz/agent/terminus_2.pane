[?2004l[?2004h>         my $rs = $rev_end - $len + 1;
[?2004l[?2004h>         next if $rs < 0;
[?2004l[?2004h>         my $sr = substr($template, $rs, $len);
[?2004l[?2004h>         next if length($sr) < $len;
[?2004l[?2004h>         my $sru = uc($sr);
[?2004l[?2004h>         next if $sru =~ /GGTCTC/ || $sru =~ /GAGACC/;
[?2004l[?2004h>         $tm = get_tm($sru);
[?2004l[?2004h>         push @rev_cands, {seq=>rc($sru), tm=>$tm, len=>$len} if $tm >= 58 && $tm <= 72;
[?2004l[?2004h>     }
[?2004l[?2004h>     my $best_diff = 999;
[?2004l[?2004h>     my ($best_f, $best_r);
[?2004l[?2004h>     for my $f (@fwd_cands) {
[?2004l[?2004h>         for my $r (@rev_cands) {
[?2004l[?2004h>             my $d = abs($f->{tm} - $r->{tm});
[?2004l[?2004h>             if ($d <= 5 && $d < $best_diff) {
[?2004l[?2004h>                 $best_diff = $d;
[?2004l[?2004h>                 $best_f = $f;
[?2004l[?2004h>                 $best_r = $r;
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     return ($best_f, $best_r, $best_diff);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Junction overhangs
[?2004l[?2004h> my $j1_oh = substr($out, 210, 4);  # ATGA: input->EGFP
[?2004l[?2004h> my $j2_oh = substr($out, 922, 4);  # AAGG: EGFP->FLAG
[?2004l[?2004h> my $j3_oh = substr($out, 1006, 4); # CAGA: FLAG->SNAP
[?2004l[?2004h> my $j4_oh = substr($out, 1551, 4); # TAAT: SNAP->input
[?2004l[?2004h> 
[?2004l[?2004h> print "Overhangs: J1=$j1_oh J2=$j2_oh J3=$j3_oh J4=$j4_oh\n";
[?2004l[?2004h> 
[?2004l[?2004h> # Verify overhangs in output
[?2004l[?2004h> for my $j ([$j1_oh,210],[$j2_oh,922],[$j3_oh,1006],[$j4_oh,1551]) {
[?2004l[?2004h>     die "Mismatch" if substr($out,$j->[1],4) ne $j->[0];
[?2004l[?2004h> }
[?2004l[?2004h> print "Overhang positions verified\n";
[?2004l[?2004h> 
[?2004l[?2004h> # Verify uniqueness
[?2004l[?2004h> my %ohu;
[?2004l[?2004h> for my $o ($j1_oh,$j2_oh,$j3_oh,$j4_oh) { die "Dup: $o" if $ohu{uc($o)}++; }
[?2004l[?2004h> print "All overhangs unique\n";
[?2004l[?2004h> 
[?2004l[?2004h> my $target = 65;
[?2004l[?2004h> my @primers;
[?2004l[?2004h> 
[?2004l[?2004h> # --- INPUT BACKBONE ---
