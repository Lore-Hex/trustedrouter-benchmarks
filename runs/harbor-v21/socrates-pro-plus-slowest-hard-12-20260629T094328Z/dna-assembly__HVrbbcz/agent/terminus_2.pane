[?2004l[?2004h>     'flag_fwd' => [$seq{flag}, 5, 'fwd'],
[?2004l[?2004h>     'flag_rev' => [$seq{flag}, 84, 'rev'],
[?2004l[?2004h>     'snap_fwd' => [$seq{snap}, 5, 'fwd'],
[?2004l[?2004h>     'snap_rev' => [$seq{snap}, 545, 'rev'],
[?2004l[?2004h> );
[?2004l[?2004h> for my $k (sort keys %ann_check) {
[?2004l[?2004h>     my ($tmpl, $pos, $dir) = @{$ann_check{$k}};
[?2004l[?2004h>     my $anneal = substr($prim{$k}, 15);
[?2004l[?2004h>     if ($dir eq 'fwd') {
