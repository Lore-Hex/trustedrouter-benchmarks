[?2004l[?2004h>         if ($ff2 && $d2 <= 5) { $flag_fwd = $ff2; $flag_rev = $fr2; }
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> die "No valid FLAG primers" unless $flag_fwd && $flag_rev;
[?2004l[?2004h> print "Fwd: $flag_fwd->{seq} Tm=$flag_fwd->{tm} len=$flag_fwd->{len}\n";
[?2004l[?2004h> print "Rev: $flag_rev->{seq} Tm=$flag_rev->{tm} len=$flag_rev->{len}\n";
[?2004l[?2004h> print "Tm diff: ", abs($flag_fwd->{tm}-$flag_rev->{tm}), "\n";
[?2004l[?2004h> 
