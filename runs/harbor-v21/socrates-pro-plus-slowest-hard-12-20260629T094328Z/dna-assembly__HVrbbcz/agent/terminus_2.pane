[?2004l[?2004h>     my $body = substr($s, 14);  # after cgcgGGTCTCA + 4nt overhang
[?2004l[?2004h>     if ($body =~ /GGTCTC/ || $body =~ /GAGACC/) {
[?2004l[?2004h>         print "WARNING: BsaI site in $p->{name}!\n";
[?2004l[?2004h>     }
[?2004l[?2004h>     # Verify primer structure
[?2004l[?2004h>     my $spacer = substr($s, 0, 4);
