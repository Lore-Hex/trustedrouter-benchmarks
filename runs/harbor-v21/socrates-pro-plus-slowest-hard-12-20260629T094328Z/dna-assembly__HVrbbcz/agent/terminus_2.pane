[?2004l[?2004h> use strict; use warnings;
[?2004l[?2004h> 
[?2004l[?2004h> my %seq; my $name;
[?2004l[?2004h> open(F,"sequences.fasta"); while(<F>){chomp; if(/^>(\S+)/){$name=$1;next;} $seq{$name}.=uc($_);} close F;
[?2004l[?2004h> sub rc { my $s=uc(shift); $s=reverse($s); $s=~tr/ACGT/TGCA/; return $s; }
[?2004l[?2004h> 
[?2004l[?2004h> my %prim; my $pn;
[?2004l[?2004h> open(P,"primers.fasta"); while(<P>){chomp; if(/^>(\S+)/){$pn=$1;next;} $prim{$pn}.=uc($_);} close P;
[?2004l[?2004h> 
[?2004l[?2004h> my $out = $seq{output};
[?2004l[?2004h> 
[?2004l[?2004h> # Verify each primer structure: cgcg + GGTCTC + N + [4nt OH] + [anneal]
[?2004l[?2004h> for my $k (sort keys %prim) {
[?2004l[?2004h>     my $s = $prim{$k};
[?2004l[?2004h>     my $spacer = substr($s,0,4);
[?2004l[?2004h>     my $bsai = substr($s,4,6);
[?2004l[?2004h>     my $extra = substr($s,10,1);
[?2004l[?2004h>     my $oh = substr($s,11,4);
[?2004l[?2004h>     my $anneal = substr($s,15);
[?2004l[?2004h>     die "Bad structure $k" unless $spacer eq 'CGCG' && $bsai eq 'GGTCTC';
[?2004l[?2004h>     die "BsaI in anneal of $k" if $anneal =~ /GGTCTC/ || $anneal =~ /GAGACC/;
[?2004l[?2004h>     print "$k: OK (spacer=$spacer BsaI=$bsai n=$extra OH=$oh anneal_len=".length($anneal)." total=".length($s).")\n";
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Reconstruct assembly
[?2004l[?2004h> # Fragments after digestion (top strand, 5'->3'):
[?2004l[?2004h> # EGFP:  ATGA + EGFP[4:712] + AAGG     (J1 to J2)
[?2004l[?2004h> # FLAG:  AAGG + FLAG[5:85] + CAGA      (J2 to J3)
[?2004l[?2004h> # SNAP:  CAGA + SNAP[5:546] + TAAT     (J3 to J4)
[?2004l[?2004h> # BACKBONE: TAAT + input[691:2727] + input[0:210] + ATGA  (J4 to J1)
[?2004l[?2004h> 
[?2004l[?2004h> my $egfp_frag = substr($seq{egfp}, 0, 712) . 'AAGG';  # EGFP[0:712] + J2 OH
[?2004l[?2004h> # Actually the fragment is: J1_OH + EGFP[4:712] + J2_OH
[?2004l[?2004h> # But J1_OH = EGFP[0:4] = ATGA, so: EGFP[0:4] + EGFP[4:712] + AAGG = EGFP[0:712] + AAGG
[?2004l[?2004h> 
[?2004l[?2004h> my $flag_frag = 'AAGG' . substr($seq{flag}, 5, 80) . 'CAGA';  # J2_OH + FLAG[5:85] + J3_OH
[?2004l[?2004h> my $snap_frag = 'CAGA' . substr($seq{snap}, 5, 541) . 'TAAT';  # J3_OH + SNAP[5:546] + J4_OH
[?2004l[?2004h> 
[?2004l[?2004h> my $backbone_frag = 'TAAT' . substr($seq{input}, 691) . substr($seq{input}, 0, 210) . 'ATGA';
[?2004l[?2004h> 
[?2004l[?2004h> print "\nFragment sizes:\n";
[?2004l[?2004h> print "EGFP: ", length($egfp_frag), "\n";
[?2004l[?2004h> print "FLAG: ", length($flag_frag), "\n";
[?2004l[?2004h> print "SNAP: ", length($snap_frag), "\n";
[?2004l[?2004h> print "BACKBONE: ", length($backbone_frag), "\n";
[?2004l[?2004h> 
[?2004l[?2004h> # Assemble by overlapping overhangs:
[?2004l[?2004h> # EGFP ends with AAGG, FLAG starts with AAGG -> overlap
[?2004l[?2004h> # FLAG ends with CAGA, SNAP starts with CAGA -> overlap  
[?2004l[?2004h> # SNAP ends with TAAT, BACKBONE starts with TAAT -> overlap
[?2004l[?2004h> # BACKBONE ends with ATGA, EGFP starts with ATGA -> overlap (circular)
[?2004l[?2004h> 
[?2004l[?2004h> my $assembled = substr($egfp_frag, 0, -4)  # EGFP without last 4 (AAGG)
[?2004l[?2004h>               . substr($flag_frag, 0, -4)   # FLAG without last 4 (CAGA)
[?2004l[?2004h>               . substr($snap_frag, 0, -4)   # SNAP without last 4 (TAAT)
[?2004l[?2004h>               . substr($backbone_frag, 0, -4);  # BACKBONE without last 4 (ATGA)
[?2004l[?2004h> 
[?2004l[?2004h> print "\nAssembled length: ", length($assembled), " vs output ", length($out), "\n";
[?2004l[?2004h> 
[?2004l[?2004h> # The assembled sequence should be a rotation of the output
[?2004l[?2004h> # Starting at position 210 (J1)
[?2004l[?2004h> my $rotated = substr($out, 210) . substr($out, 0, 210);
[?2004l[?2004h> 
[?2004l[?2004h> if ($assembled eq $rotated) {
[?2004l[?2004h>     print "\n*** ASSEMBLY VERIFIED: Exact match with output! ***\n";
[?2004l[?2004h> } else {
[?2004l[?2004h>     # Find first mismatch
[?2004l[?2004h>     for my $i (0..length($assembled)-1) {
[?2004l[?2004h>         if (substr($assembled,$i,1) ne substr($rotated,$i,1)) {
[?2004l[?2004h>             print "Mismatch at position $i: got ", substr($assembled,$i,1), " expected ", substr($rotated,$i,1), "\n";
[?2004l[?2004h>             print "Assembled context: ", substr($assembled, $i>10?$i-10:0, 20), "\n";
[?2004l[?2004h>             print "Expected context:  ", substr($rotated, $i>10?$i-10:0, 20), "\n";
[?2004l[?2004h>             last;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Also verify each annealing region maps to correct template
[?2004l[?2004h> print "\nAnnealing verification:\n";
[?2004l[?2004h> my %ann_check = (
