Sending keys: ['cat > /app/pipeline_parallel.py << \'ENDOFFILE\'\nimport torch\nimport torch.distributed as dist\nimport torch.nn.functional as F\n\n\ndef train_step_pipeline_afab(model, inputs, targets, device, dtype):\n    """\n    Runs one training step using pipeline parallelism with AFAB scheduling.\n    \n    Args:\n        model: LlamaForCausalLM instance\n        inputs: list of microbatch input ID tensors\n        targets: list of microbatch target ID tensors  \n        device: torch device\n        dtype: torch dtype\n    """\n    rank = dist.get_rank()\n    world_size = dist.get_world_size()\n    num_microbatches = len(inputs)\n    \n    # Partition transformer layers across ranks\n    all_layers = list(model.model.layers)\n    num_layers = len(all_layers)\n    layers_per_rank = num_layers // world_size\n    remainder = num_layers % world_size\n    \n    # Calculate layer range for this rank (roughly balanced)\n    start_idx = rank * layers_per_rank + min(rank, remainder)\n    if rank < remainder:\n        end_idx = start_idx + layers_per_rank + 1\n    else:\n        end_idx = start_idx + layers_per_rank\n    my_layers = all_layers[start_idx:end_idx]\n    \n    # Components per rank:\n    # Rank 0: embed_tokens + first partition of layers\n    # Last rank: last partition of layers + norm + lm_head\n    # Others: just their partition of layers\n    \n    is_first_rank = (rank == 0)\n    is_last_rank = (rank == world_size - 1)\n    \n    # Storage for AFAB\n    saved_inputs = []   # Input to our layer block for each microbatch\n    saved_outputs = []  # Output from our layer block for each microbatch\n    \n    # ============ FORWARD PHASE ============\n    for mb_idx in range(num_microbatches):\n        input_ids = inputs[mb_idx].to(device=device, dtype=torch.long)\n        target_ids = targets[mb_idx].to(device=device, dtype=torch.long)\n        \n        if is_first_rank:\n            # Embed tokens\n            hidden_states = model.model.embed_tokens(input_ids)\n            hidden_states = hidden_states.to(device=device, dtype=dtype)\n        else:\n            # Receive hidden states from previous rank\n            # Need to know the shape: [mb_size, seq_len, hidden_size]\n            # We\'ll use a metadata exchange first\n            recv_shape = torch.zeros(3, dtype=torch.long, device=device)\n            dist.recv(recv_shape, src=rank - 1)\n            hidden_states = torch.empty(\n                recv_shape.tolist(), device=device, dtype=dtype\n            )\n            dist.recv(hidden_states, src=rank - 1)\n            hidden_states = hidden_states.detach().requires_grad_(True)\n        \n        # Save input for backward\n        saved_input = hidden_states\n        \n        # Forward through this rank\'s layers\n        for layer in my_layers:\n            hidden_states = layer(hidden_states)[0]  # layer returns (output,)\n        \n        if is_last_rank:\n            # Apply final norm and LM head\n            hidden_states = model.model.norm(hidden_states)\n            logits = model.lm_head(hidden_states.to(model.lm_head.weight.dtype))\n            logits = logits.float()\n            \n            # Compute loss for this microbatch\n            loss = F.cross_entropy(\n                logits.view(-1, logits.size(-1)),\n                target_ids.view(-1)\n            )\n            \n            if mb_idx == 0:\n                total_loss = loss / num_microbatches\n            else:\n                total_loss = total_loss + loss / num_microbatches\n            \n            # Save for backward\n            saved_inputs.append(saved_input.detach().requires_grad_(True) if not saved_input.requires_grad else saved_input)\n            saved_outputs.append(hidden_states)\n        else:\n            # Send hidden states to next rank\n            out_tensor = hidden_states.contiguous()\n            # Send shape first\n            shape_tensor = torch.tensor(list(out_tensor.shape), dtype=torch.long, device=device)\n            dist.send(shape_tensor, dst=rank + 1)\n            dist.send(out_tensor.to(dtype), dst=rank + 1)\n            \n            # Save for backward\n            saved_inputs.append(saved_input)\n            saved_outputs.append(out_tensor)\n    \n    # ============ BACKWARD PHASE ============\n    for mb_idx in range(num_microbatches):\n        if is_last_rank:\n            # Backward from loss\n            total_loss.backward(\n                retain_graph=(mb_idx < num_microbatches - 1)\n            )\n            # Get gradient w.r.t. our input for this microbatch\n            input_grad = saved_inputs[mb_idx].grad\n            if not is_first_rank and input_grad is not None:\n                # Send gradient to previous rank\n                shape_tensor = torch.tensor(list(input_grad.shape), dtype=torch.long, device=device)\n                dist.send(shape_tensor, dst=rank - 1)\n                dist.send(input_grad.to(dtype), dst=rank - 1)\n        else:\n            if is_first_rank:\n                # Receive gradient from next rank\n                recv_shape = torch.zeros(3, dtype=torch.long, device=device)\n                dist.recv(recv_shape, src=rank + 1)\n                grad_output = torch.empty(recv_shape.tolist(), device=device, dtype=dtype)\n                dist.recv(grad_output, src=rank + 1)\n            else:\n                # Receive gradient from next rank\n                recv_shape = torch.zeros(3, dtype=torch.long, device=device)\n                dist.recv(recv_shape, src=rank + 1)\n                grad_output = torch.empty(recv_shape.tolist(), device=device, dtype=dtype)\n                dist.recv(grad_output, src=rank + 1)\n            \n            # Backward through our layers\n            saved_outputs[mb_idx].backward(grad_output)\n            \n            if not is_first_rank:\n                # Send gradient to previous rank\n                input_grad = saved_inputs[mb_idx].grad\n                if input_grad 