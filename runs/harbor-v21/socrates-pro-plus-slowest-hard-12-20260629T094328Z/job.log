Sending keys: ['python3 << \'EOF\'\nimport urllib.request\nimport json\n\n# Get all FPbase proteins\nurl = \'https://www.fpbase.org/api/proteins/?format=json\'\nreq = urllib.request.Request(url, headers={\'User-Agent\': \'Mozilla/5.0\'})\nresp = urllib.request.urlopen(req, timeout=60)\ndata = json.loads(resp.read())\n\nprint(f"Total proteins: {len(data)}")\n\npdb_ids = [\'2IB5\', \'4KGE\', \'4Q7T\', \'1KFD\', \'5JZL\', \'6AA7\', \'3ADF\', \'5WJ2\', \'3M22\', \'2H5Q\', \n           \'3MGF\', \'5Y01\', \'2VZX\', \'4CQH\', \'1YZW\', \'2CHA\', \'3KZY\', \'1AK4\', \'5P21\', \'1H6R\']\n\n# Find proteins with ex_max near 505 or em_max near 610\ndonors = []  # excitation ~505nm\nacceptors = []  # emission ~610nm\n\nfor p in data:\n    for state in p.get(\'states\', []):\n        ex = state.get(\'ex_max\')\n        em = state.get(\'em_max\')\n        pdbs = p.get(\'pdb\') or []\n        pdbs_upper = [x.upper() for x in pdbs]\n        if ex and abs(ex - 505) <= 3:\n            matched = [x for x in pdbs_upper if x in pdb_ids]\n            donors.append((p[\'name\'], ex, em, pdbs, matched))\n        if em and abs(em - 610) <= 3:\n            matched = [x for x in pdbs_upper if x in pdb_ids]\n            acceptors.append((p[\'name\'], ex, em, pdbs, matched))\n\nprint("\\nPotential donors (ex ~505nm):")\nfor d in donors:\n    m = " *** MATCH ***" if d[4] else ""\n    print(f"  {d[0]}: ex={d[1]}, em={d[2]}, pdb={d[3]}{m}")\n\nprint("\\nPotential acceptors (em ~610nm):")\nfor a in acceptors:\n    m = " *** MATCH ***" if a[4] else ""\n    print(f"  {a[0]}: ex={a[1]}, em={a[2]}, pdb={a[3]}{m}")\nEOF\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
