Sending keys: ['cat > /app/task_file/scripts/optimizer.py << \'PYEOF\'\n#!/usr/bin/env python3\nimport json, math, os, sys\nfrom collections import defaultdict\nsys.path.insert(0, os.path.dirname(__file__))\nfrom cost_model import CostModel, CostConsts, align, HEADS, HIDDEN\n\ndef load_requests(path):\n    reqs = {}\n    with open(path) as f:\n        for line in f:\n            r = json.loads(line)\n            reqs[r[\'request_id\']] = r\n    return reqs\n\ndef build_plan(reqs, shapes, gen_tol_frac=0.10, gen_tol_abs=8, max_batch=64):\n    """Build plan. shapes sorted ascending.\n    gen_tol: within a sub-batch, gen_len won\'t exceed min by more than tolerance.\n    """\n    shape_groups = defaultdict(list)\n    for rid, r in reqs.items():\n        s = align(r[\'prompt_len\'], 64)\n        assigned = None\n        for sh in shapes:\n            if sh >= s:\n                assigned = sh\n                break\n        if assigned is None:\n            assigned = shapes[-1]\n        shape_groups[assigned].append((rid, s, r[\'gen_len\']))\n\n    plan = []\n    bc = 0\n    for shape_val in sorted(shape_groups.keys()):\n        group = sorted(shape_groups[shape_val], key=lambda x: x[2])  # by gen_len\n        # greedy sub-batch by gen_len closeness\n        cur = []\n        cur_min = None\n        for item in group:\n            g = item[2]\n            if not cur:\n                cur = [item]; cur_min = g\n            else:\n                gmax = max(item[2], max(x[2] for x in cur))\n                # tolerance: allow gmax up to cur_min*(1+frac) or cur_min+abs\n                limit = max(cur_min*(1+gen_tol_frac), cur_min+gen_tol_abs)\n                if gmax <= limit and len(cur) < max_batch:\n                    cur.append(item)\n                else:\n                    bc += 1\n                    bid = f"b-{bc:04d}"\n                    for rid2,s2,g2 in cur:\n                        plan.append({\'request_id\':rid2,\'batch_id\':bid,\'shape\':{\'seq_align\':shape_val,\'heads_align\':HEADS,\'hidden_align\':HIDDEN}})\n                    cur=[item]; cur_min=g\n        if cur:\n            bc += 1\n            bid = f"b-{bc:04d}"\n            for rid2,s2,g2 in cur:\n                plan.append({\'request_id\':rid2,\'batch_id\':bid,\'shape\':{\'seq_align\':shape_val,\'heads_align\':HEADS,\'hidden_align\':HIDDEN}})\n    return plan\n\ndef evaluate(reqs, plan, label=""):\n    cm = CostModel(64)\n    m = cm.plan_metrics(reqs, plan)\n    shapes = set((p[\'shape\'][\'seq_align\'],p[\'shape\'][\'heads_align\'],p[\'shape\'][\'hidden_align\']) for p in plan)\n    nb = len(set(p[\'batch_id\'] for p in plan))\n    print(f"{label}: cost={m[\'cost\']:.4e} pad={m[\'pad_ratio\']:.4f} p95={m[\'p95_latency_ms\']:.4e} seq={m[\'sequential_timecost\']:.4e} shapes={len(shapes)} batches={nb}")\n    return m, shapes\n\nif __name__ == \'__main__\':\n    root = os.path.dirname(os.path.dirname(__file__))\n    reqs1 = load_requests(os.path.join(root,\'input_data\',\'requests_bucket_1.jsonl\'))\n    reqs2 = load_requests(os.path.join(root,\'input_data\',\'requests_bucket_2.jsonl\'))\n\n    # B1 needs many shapes for the tail (up to 2048). Shapes shared across buckets, max 8.\n    # Use shapes: 64,128,256,384,512,640 for low, plus larger for B1 tail\n    shapes = [64,128,256,384,512,640,1280,2048]\n\n    for frac, ab, mb in [(0.10,8,64),(0.05,4,64),(0.15,16,64),(0.10,8,32)]:\n        plan1 = build_plan(reqs1, shapes, frac, ab, mb)\n        plan2 = build_plan(reqs2, shapes, frac, ab, mb)\n        print(f"--- frac={frac} abs={ab} maxb={mb} ---")\n        evaluate(reqs1, plan1, "B1")\n        evaluate(reqs2, plan2, "B2")\nPYEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
