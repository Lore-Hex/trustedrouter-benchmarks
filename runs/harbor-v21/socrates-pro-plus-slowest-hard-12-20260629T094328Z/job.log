ore digit expansion)\nadd(r'^(\\S+) w (\\S+) (\\S+) \\d+ \\d+$', r'\\1 \\2 \\3')\nadd(r' (\\S)3$', r' \\1x')  # EP rank 3 -> x\nadd(r' (\\S)6$', r' \\1y')  # EP rank 6 -> y\nadd('/', '')\nfor i in range(8, 0, -1): add(str(i), '_' * i)\nadd(r'^', 'G')\nprint('Phase1:', len(rules))\nPYEOF\n"] min_timeout_sec: 0.3 max_timeout_sec: 180.0
