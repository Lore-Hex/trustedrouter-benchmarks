Sending keys: ["cat > /tmp/read_vga_text.py << 'PYEOF'\nimport subprocess, struct\n\n# Read VGA text memory via QEMU monitor\n# Text mode: 80x25 characters, each 2 bytes (char + attribute)\n# Address: 0xb8000\n\n# Use socat to send xp command\nimport socket\n\ndef send_monitor(cmd):\n    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)\n    sock.connect('/tmp/qemu-monitor.sock')\n    sock.recv(4096)  # prompt\n    sock.send((cmd + '\\n').encode())\n    import time\n    time.sleep(0.5)\n    result = b''\n    while True:\n        try:\n            sock.settimeout(1)\n            chunk = sock.recv(4096)\n            if not chunk:\n                break\n            result += chunk\n        except:\n            break\n    sock.close()\n    return result.decode('utf-8', errors='replace')\n\n# Read 80*25*2 = 4000 bytes from 0xb8000\n# xp command: xp /4000xb 0xb8000\nresult = send_monitor('xp /4000xb 0xb8000')\nprint(result[:500])\n\n# Parse the text\nlines = []\nfor line in result.split('\\n'):\n    if ':' in line and '0x' in line:\n        lines.append(line)\n\nprint(f'\\nGot {len(lines)} lines of memory dump')\n\n# Parse hex dump\nchars = []\nfor line in lines:\n    # Format: 0000000b8000: 0x00 0x07 0x00 0x07 ...\n    parts = line.split(':')\n    if len(parts) >= 2:\n        hex_vals = parts[1].strip().split(' ')\n        for h in hex_vals:\n            h = h.strip()\n            if h.startswith('0x'):\n                chars.append(int(h, 16))\n\n# Extract characters (every other byte is the character, the other is attribute)\ntext_lines = []\nfor row in range(25):\n    line = ''\n    for col in range(80):\n        idx = (row * 80 + col) * 2\n        if idx < len(chars):\n            ch = chars[idx]\n            if 32 <= ch < 127:\n                line += chr(ch)\n            else:\n                line += '.'\n    text_lines.append(line.rstrip())\n\nprint('\\n=== VGA Text Screen ===')\nfor i, line in enumerate(text_lines):\n    if line.strip():\n        print(f'{i:2d}: {line}')\nPYEOF\npython3 /tmp/read_vga_text.py\n"] min_timeout_sec: 10.0 max_timeout_sec: 180.0
