ev_cands) {\n            my $d = abs($f->{tm}-$r->{tm});\n            if ($d < $best_d) { $best_d=$d; $inp_fwd=$f; $inp_rev=$r; }\n        }\n    }\n    print "Adjusted backbone pair diff: $best_d\\n";\n}\n\nprint "Input fwd anneal: $inp_fwd->{seq} Tm=$inp_fwd->{tm}\\n";\nprint "Input rev anneal: $inp_rev->{seq} Tm=$inp_rev->{tm}\\n";\n\nmy $inp_fwd_primer = "cgcg" . "ggtctc" . "a" . lc($j4_oh) . $inp_fwd->{seq};\nmy $inp_rev_primer = "cgcg" . "ggtctc" . "a" . lc(rc($j1_oh)) . $inp_rev->{seq};\n\n# --- EGFP ---\n# Fwd: anneals starting at EGFP[4] (after J1 overhang EGFP[0:4])\n# Rev: anneals ending at EGFP[711] (last nt before J2 overhang at EGFP[712])\nmy $egfp_fwd = best_anneal_fwd($egfp, 4, $target);\nmy $egfp_rev = best_anneal_rev($egfp, 711, $target);\n\nprint "\\nEGFP fwd anneal: $egfp_fwd->{seq} Tm=$egfp_fwd->{tm}\\n";\nprint "EGFP rev anneal: $egfp_rev->{seq} Tm=$egfp_rev->{tm}\\n";\nprint "EGFP Tm diff: ", abs($egfp_fwd->{tm}-$egfp_rev->{tm}), "\\n";\n\nmy $egfp_fwd_primer = "cgcg" . "ggtctc" . "a" . lc($j1_oh) . $egfp_fwd->{seq};\nmy $egfp_rev_primer = "cgcg" . "ggtctc" . "a" . lc(rc($j2_oh)) . $egfp_rev->{seq};\n\n# --- FLAG ---\n# Fwd: anneals starting at FLAG[5] (after J2 overhang FLAG[3:5])\n# Rev: anneals ending at FLAG[84] (last nt before J3 overhang at FLAG[85])\nmy $flag_fwd = best_anneal_fwd($flag, 5, $target);\nmy $flag_rev = best_anneal_rev($flag, 84, $target);\n\nprint "\\nFLAG fwd anneal: $flag_fwd->{seq} Tm=$flag_fwd->{tm}\\n";\nprint "FLAG rev anneal: $flag_rev->{seq} Tm=$flag_rev->{tm}\\n";\nprint "FLAG Tm diff: ", abs($flag_fwd->{tm}-$flag_rev->{tm}), "\\n";\n\nmy $flag_fwd_primer = "cgcg" . "ggtctc" . "a" . lc($j2_oh) . $flag_fwd->{seq};\nmy $flag_rev_primer = "cgcg" . "ggtctc" . "a" . lc(rc($j3_oh)) . $flag_rev->{seq};\n\n# --- SNAP ---\n# Fwd: anneals starting at SNAP[5] (after J3 overhang SNAP[3:5])\n# Rev: anneals ending at SNAP[545] (last nt before J4 overhang at SNAP[546])\nmy $snap_fwd = best_anneal_fwd($snap, 5, $target);\nmy $snap_rev = best_anneal_rev($snap, 545, $target);\n\nprint "\\nSNAP fwd anneal: $snap_fwd->{seq} Tm=$snap_fwd->{tm}\\n";\nprint "SNAP rev anneal: $snap_rev->{seq} Tm=$snap_rev->{tm}\\n";\nprint "SNAP Tm diff: ", abs($snap_fwd->{tm}-$snap_rev->{tm}), "\\n";\n\nmy $snap_fwd_primer = "cgcg" . "ggtctc" . "a" . lc($j3_oh) . $snap_fwd->{seq};\nmy $snap_rev_primer = "cgcg" . "ggtctc" . "a" . lc(rc($j4_oh)) . $snap_rev->{seq};\n\n# Write output\nopen(OUT, ">primers.fasta") or die;\nprint OUT ">input_fwd\\n$inp_fwd_primer\\n";\nprint OUT ">input_rev\\n$inp_rev_primer\\n";\nprint OUT ">egfp_fwd\\n$egfp_fwd_primer\\n";\nprint OUT ">egfp_rev\\n$egfp_rev_primer\\n";\nprint OUT ">flag_fwd\\n$flag_fwd_primer\\n";\nprint OUT ">flag_rev\\n$flag_rev_primer\\n";\nprint OUT ">snap_fwd\\n$snap_fwd_primer\\n";\nprint OUT ">snap_rev\\n$snap_rev_primer\\n";\nclose OUT;\n\nprint "\\nPrimers written to primers.fasta\\n";\nENDSCRIPT\nperl design2.pl 2>&1\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
