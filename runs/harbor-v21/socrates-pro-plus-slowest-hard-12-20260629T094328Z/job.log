seq})};\n\n# --- SNAP ---\nprint "\\n=== SNAP ===\\n";\nmy $snap_fwd = best_anneal_fwd($snap, 5, $target);\nmy $snap_rev = best_anneal_rev($snap, 545, $target);\n\nif ($snap_fwd && $snap_rev) {\n    my $sd = abs($snap_fwd->{tm} - $snap_rev->{tm});\n    if ($sd > 5) {\n        print "SNAP Tm diff $sd > 5, trying to find better pair...\\n";\n        my ($sf2, $sr2, $d2) = find_best_pair($snap, 5, 545, $target);\n        if ($sf2 && $d2 <= 5) { $snap_fwd = $sf2; $snap_rev = $sr2; }\n    }\n}\ndie "No valid SNAP primers" unless $snap_fwd && $snap_rev;\nprint "Fwd: $snap_fwd->{seq} Tm=$snap_fwd->{tm} len=$snap_fwd->{len}\\n";\nprint "Rev: $snap_rev->{seq} Tm=$snap_rev->{tm} len=$snap_rev->{len}\\n";\nprint "Tm diff: ", abs($snap_fwd->{tm}-$snap_rev->{tm}), "\\n";\n\npush @primers, {name=>\'snap_fwd\', seq=>lc("cgcgGGTCTCA" . $j3_oh . $snap_fwd->{seq})};\npush @primers, {name=>\'snap_rev\', seq=>lc("cgcgGGTCTCA" . rc($j4_oh) . $snap_rev->{seq})};\n\n# === VALIDATION ===\nprint "\\n=== VALIDATION ===\\n";\nfor my $p (@primers) {\n    my $s = uc($p->{seq});\n    # Check no BsaI site in the middle of the primer\n    my $body = substr($s, 14);  # after cgcgGGTCTCA + 4nt overhang\n    if ($body =~ /GGTCTC/ || $body =~ /GAGACC/) {\n        print "WARNING: BsaI site in $p->{name}!\\n";\n    }\n    # Verify primer structure\n    my $spacer = substr($s, 0, 4);\n    my $bsai = substr($s, 4, 6);\n    my $extra = substr($s, 10, 1);\n    my $oh = substr($s, 11, 4);\n    my $anneal = substr($s, 15);\n    print "$p->{name}: spacer=$spacer BsaI=$bsai extra=$extra OH=$oh anneal_len=".length($anneal)." full_len=".length($s)."\\n";\n}\n\n# Write output\nopen(OUT, ">primers.fasta") or die;\nfor my $p (@primers) {\n    print OUT ">", $p->{name}, "\\n", $p->{seq}, "\\n";\n}\nclose OUT;\nprint "\\nPrimers written to primers.fasta\\n";\nENDSCRIPT\nperl design_final.pl 2>&1\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
