hape\'][\'heads_align\'], p[\'shape\'][\'hidden_align\']))\n    print(f\'Unique shapes: {len(shapes)}\')\n    print(f\'Number of batches: {len(batches)}\')\n    print()\n\n# Check total unique shapes across both buckets\nall_shapes = set()\nfor bucket in [\'1\', \'2\']:\n    with open(f\'output_data/plan_b{bucket}.jsonl\') as f:\n        for line in f:\n            p = json.loads(line)\n            all_shapes.add((p[\'shape\'][\'seq_align\'], p[\'shape\'][\'heads_align\'], p[\'shape\'][\'hidden_align\']))\nprint(f\'Total unique shapes across both buckets: {len(all_shapes)}\')\nprint(f\'Shapes: {sorted(all_shapes)}\')\nassert len(all_shapes) <= 8, f\'Too many shapes: {len(all_shapes)}\'\nprint(\'All constraints satisfied!\')\n"\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
