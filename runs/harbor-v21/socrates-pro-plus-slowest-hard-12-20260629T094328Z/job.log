Sending keys: ["cat > /tmp/fix_vm.py << 'PYEOF'\nimport re\n\nwith open('/app/vm.js', 'r') as f:\n    content = f.read()\n\n# Fix lw function\nold_lw = '''  lw(rt, offset, base) {\n        // LW rt,offset(base) - Load Word\n        const addr = (this.registers[base] + offset) >>> 0; // Force 32-bit unsigned\n        if (addr & 0x3) {\n            throw new Error(`Unaligned word access at 0x${addr.toString(16)}`);\n        }\n        this.registers[rt] = this.memory[addr] || 0;\n    }'''\n\nnew_lw = '''  lw(rt, offset, base) {\n        // LW rt,offset(base) - Load Word\n        const addr = (this.registers[base] + offset) >>> 0; // Force 32-bit unsigned\n        if (addr & 0x3) {\n            // Handle unaligned load\n            let result = 0;\n            for (let i = 0; i < 4; i++) {\n                const currentAddr = addr + i;\n                const wordAddr = currentAddr & ~0x3;\n                const byteOffset = currentAddr & 0x3;\n                const word = this.memory[wordAddr] || 0;\n                const byte = (word >> (byteOffset * 8)) & 0xFF;\n                result |= (byte << (i * 8));\n            }\n            this.registers[rt] = result;\n        } else {\n            this.registers[rt] = this.memory[addr] || 0;\n        }\n    }'''\n\ncontent = content.replace(old_lw, new_lw)\n\n# Fix sw function\nold_sw = '''  sw(rt, offset, base) {\n        // SW rt,offset(base) - Store Word\n        const addr = (this.registers[base] + offset) >>> 0; // Force 32-bit unsigned\n        if (addr & 0x3) {\n            throw new Error(`Unaligned word access at 0x${addr.toString(16)}`);\n        }\n        this.memory[addr] = this.registers[rt];\n    }'''\n\nnew_sw = '''  sw(rt, offset, base) {\n        // SW rt,offset(base) - Store Word\n        const addr = (this.registers[base] + offset) >>> 0; // Force 32-bit unsigned\n        if (addr & 0x3) {\n            // Handle unaligned store\n            for (let i = 0; i < 4; i++) {\n                const currentAddr = addr + i;\n                const wordAddr = currentAddr & ~0x3;\n                const byteOffset = currentAddr & 0x3;\n                const byte = (this.registers[rt] >> (i * 8)) & 0xFF;\n                const word = this.memory[wordAddr] || 0;\n                const byteMask = 0xFF << (byteOffset * 8);\n                this.memory[wordAddr] = (word & ~byteMask) | (byte << (byteOffset * 8));\n            }\n        } else {\n            this.memory[addr] = this.registers[rt];\n        }\n    }'''\n\ncontent = content.replace(old_sw, new_sw)\n\nwith open('/app/vm.js', 'w') as f:\n    f.write(content)\nprint('VM updated for unaligned accesses')\nPYEOF\n"] min_timeout_sec: 0.5 max_timeout_sec: 180.0
