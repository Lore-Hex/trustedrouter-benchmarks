6) . substr($out,1551,length($out)-1551) . substr($out,0,210);\nprint "\\nReconstructed length: ", length($recon), " vs output ", length($out), "\\n";\n# This is output rotated to start at 210\nmy $rotated = substr($out,210) . substr($out,0,210);\nif ($recon eq $rotated) { print "Reconstruction matches rotated output: OK\\n"; } else { print "Reconstruction MISMATCH\\n"; }\n\nprint "\\nAll checks done.\\n";\nENDSCRIPT\nperl verify.pl 2>&1\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
