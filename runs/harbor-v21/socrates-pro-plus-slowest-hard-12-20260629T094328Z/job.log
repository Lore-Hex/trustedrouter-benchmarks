Sending keys: ['cat > /app/task_file/scripts/optimizer.py << \'PYEOF\'\n#!/usr/bin/env python3\nimport json, math, os, sys\nfrom collections import defaultdict\nsys.path.insert(0, os.path.dirname(__file__))\nfrom cost_model import CostModel, CostConsts, align, HEADS, HIDDEN\n\ndef load_requests(path):\n    reqs = {}\n    with open(path) as f:\n        for line in f:\n            r = json.loads(line)\n            reqs[r[\'request_id\']] = r\n    return reqs\n\ndef analyze_bucket(reqs):\n    """Print analysis of request distribution."""\n    aligned_counts = defaultdict(int)\n    for r in reqs.values():\n        s = align(r[\'prompt_len\'], 64)\n        aligned_counts[s] += 1\n    return dict(aligned_counts)\n\ndef build_plan(reqs, shapes, max_batch_size=None):\n    """Build optimized plan for a set of requests.\n    shapes: list of seq_align values (sorted ascending)\n    """\n    # Assign each request to smallest shape >= its aligned prompt\n    shape_groups = defaultdict(list)  # shape -> list of (request_id, aligned_prompt, gen_len)\n    for rid, r in reqs.items():\n        s = align(r[\'prompt_len\'], 64)\n        assigned = None\n        for sh in shapes:\n            if sh >= s:\n                assigned = sh\n                break\n        if assigned is None:\n            assigned = shapes[-1]  # fallback\n        shape_groups[assigned].append((rid, s, r[\'gen_len\']))\n    \n    plan = []\n    batch_counter = 0\n    \n    for shape_val in sorted(shape_groups.keys()):\n        group = shape_groups[shape_val]\n        # Sort by aligned_prompt first, then by gen_len\n        group.sort(key=lambda x: (x[1], x[2]))\n        \n        # Sub-batch: group by aligned_prompt, then by gen_len ranges\n        # First group by aligned_prompt\n        prompt_subgroups = defaultdict(list)\n        for rid, s, g in group:\n            prompt_subgroups[s].append((rid, s, g))\n        \n        for s_val in sorted(prompt_subgroups.keys()):\n            subgroup = prompt_subgroups[s_val]\n            subgroup.sort(key=lambda x: x[2])  # sort by gen_len\n            \n            # Create sub-batches with tight gen_len ranges\n            # Strategy: for each aligned_prompt group, create sub-batches\n            # where gen_len values are close together\n            current_batch = []\n            current_gmax = 0\n            \n            for item in subgroup:\n                rid, s, g = item\n                if not current_batch:\n                    current_batch.append(item)\n                    current_gmax = g\n                else:\n                    new_gmax = max(current_gmax, g)\n                    # Check if adding this request would increase G_max significantly\n                    # The decode cost increase is roughly:\n                    # old_cost = len(current_batch) * S^2 * current_gmax\n                    # new_cost = (len(current_batch)+1) * S^2 * new_gmax\n                    # overhead_saved = 10M (if we merge vs separate)\n                    \n                    # Simple heuristic: allow if G_max increase is small relative to batch size\n                    # or if the batch is still small\n                    \n                    # For high S, be more aggressive about splitting\n                    if s_val >= 1024:\n                        max_g_ratio = 1.2  # very tight\n                        max_batch = 4\n                    elif s_val >= 512:\n                        max_g_ratio = 1.3\n                        max_batch = 8\n                    elif s_val >= 256:\n                        max_g_ratio = 1.5\n                        max_batch = 16\n                    else:\n                        max_g_ratio = 2.0\n                        max_batch = 32\n                    \n                    if max_batch_size:\n                        max_batch = min(max_batch, max_batch_size)\n                    \n                    g_ratio = new_gmax / max(current_gmax, 1)\n                    if len(current_batch) >= max_batch or (g_ratio > max_g_ratio and len(current_batch) >= 2):\n                        # Flush current batch\n                        batch_counter += 1\n                        bid = f"b-{batch_counter:04d}"\n                        for rid2, s2, g2 in current_batch:\n                            plan.append({\n                                \'request_id\': rid2,\n                                \'batch_id\': bid,\n                                \'shape\': {\'seq_align\': shape_val, \'heads_align\': HEADS, \'hidden_align\': HIDDEN}\n                            })\n                        current_batch = [item]\n                        current_gmax = g\n                    else:\n                        current_batch.append(item)\n                        current_gmax = new_gmax\n            \n            # Flush remaining\n            if current_batch:\n                batch_counter += 1\n                bid = f"b-{batch_counter:04d}"\n                for rid2, s2, g2 in current_batch:\n                    plan.append({\n                        \'request_id\': rid2,\n                        \'batch_id\': bid,\n                        \'shape\': {\'seq_align\': shape_val, \'heads_align\': HEADS, \'hidden_align\': HIDDEN}\n                    })\n    \n    return plan\n\ndef evaluate_plan(reqs, plan, label=""):\n    cm = CostModel(64)\n    metrics = cm.plan_metrics(reqs, plan)\n    shapes = set()\n    for p in plan:\n        sh = p[\'shape\']\n        shapes.add((sh[\'seq_align\'], sh[\'heads_align\'], sh[\'hidden_align\']))\n    \n    latencies = metrics.get(\'latencies\', metrics.get(\'per_request_latency\', []))\n    if isinstance(latencies, list) and latencies:\n        lat_sorted = sorted(latencies)\n        p95 = lat_sorted[int(len(lat_sorted)*0.95)]\n    else:\n        p95 = 0\n    \n    print(f"{label}:")\n    print(f"  Cost: {metrics[\'cost\']:.4e}")\n    print(f"  Pad ratio: {metrics.get(\'pad_ratio\', metrics.get(\'pad_tokens\',0)/max(metrics.get(\'real_tokens\',1),1)):.4f}")\n    print(f"  P95 latency: {p95:.4e}")\n    if \'sequential_timecost_ms\' in metrics:\n        print(f"  Sequential timecost: {metrics[\'sequential_timecost_ms\']:.4e}")\n    print(f"  Unique shapes: {len(shapes)}")\n    print(f"  Batches: {len(set(p[\'batch_id\'] for p in plan))}")\n    return metrics, shapes\n\nif __name__ == \'__main__\':\n    root = os.path.dirname(os.path.dirname(__file__))\n    reqs1 = load_requests(os.path.join(root, \'input_data\', \'requests_bucket_1.jsonl\'))\n    reqs2 = load_requests(os.path.join(root, \'input_data\', \'requests_bucket_2.jsonl\'))\n    \n    print(f"Bucket 1: {len(reqs1)} requests")\n    print(f"Bucket 2: {len(reqs2)} requests")\n    \n    ac1 = analyze_bucket(reqs1)\n    ac2 = analyze_bucket(reqs2)\n    print(f"\\nBucket 1 aligned prompt distribution: {dict(sorted(ac1.items()))}")\n    print(f"\\nBucket 2 aligned prompt distribution: {dict(sorted(ac2.items()))}")\n    \n    # Try different shape combinations\n    # Need 8 shapes total across both buckets\n    # Key shapes needed: must cover range 64 to 2048 for b1, 64 to 704 for b2\n    \n    shape_options = [\n        [64, 128, 192, 320, 448, 640, 1408, 2048],\n        [64, 128, 192, 320, 512, 704, 1408, 2048],\n        [64, 128, 192, 320, 448, 640, 1088, 2048],\n        [64, 128, 192, 320, 448, 704, 1408, 2048],\n        [64, 128, 256, 384, 512, 704, 1408, 2048],\n        [64, 128, 192, 320, 512, 640, 1408, 2048],\n    ]\n    \n    best_cost = float(\'inf\')\n    best_shapes = None\n    \n    for shapes in shape_options:\n        plan1 = build_plan(reqs1, shapes)\n        plan2 = build_plan(reqs2, shapes)\n        m1, s1 = evaluate_plan(reqs1, plan1, f"Shapes {shapes} - B1")\n        m2, s2 = evaluate_plan(reqs2, plan2, f"Shapes {shapes} - B2")\n        total = m1[\'cost\'] + m2[\'cost\']\n        print(f"  Total cost: {total:.4e}\\n")\n        if total < best_cost:\n            best_cost = total\n            best_shapes = shapes\n    \n    print(f"\\nBest shapes: {best_shapes} with cost {best_cost:.4e}")\nPYEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
