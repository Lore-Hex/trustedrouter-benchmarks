ere black pawn is)\n    for dc in (-1, 1):\n        sc = col + dc\n        if 0 <= sc < 8:\n            src = IDX(3, sc)  # rank 5, adjacent file\n            ep_match = f + 'y'\n            # Need to also constrain EP field to match\n            # Use a custom approach: add EP constraint\n            pass  # handle below\nprint('  (EP deferred)')\n\n# Knights\nNOFF = [(-2,-1),(-2,1),(-1,-2),(-1,2),(1,-2),(1,2),(2,-1),(2,1)]\nfor row in range(8):\n    for col in range(8):\n        s = IDX(row, col)\n        for dr, dc in NOFF:\n            nr, nc = row+dr, col+dc\n            if 0<=nr<8 and 0<=nc<8:\n                bld({s:'n',IDX(nr,nc):'[a-z_]'}, {s:'_',IDX(nr,nc):'n'}, cr=cr_for(s,IDX(nr,nc)))\nprint('  Knights:', len(rules))\n\n# Bishop (sliding)\nBDIR = [(-1,-1),(-1,1),(1,-1),(1,1)]\nfor row in range(8):\n    for col in range(8):\n        s = IDX(row, col)\n        for dr, dc in BDIR:\n            btw = []\n            for dist in range(1, 8):\n                nr, nc = row+dr*dist, col+dc*dist\n                if not (0<=nr<8 and 0<=nc<8): break\n                d = IDX(nr, nc)\n                bld({s:'b', d:'[a-z_]'} | {b:'_' for b in btw},\n                    {s:'_', d:'b'}, cr=cr_for(s,d))\n                btw.append(d)\nprint('  Bishops:', len(rules))\n\n# Rook (sliding)\nRDIR = [(-1,0),(1,0),(0,-1),(0,1)]\nfor row in range(8):\n    for col in range(8):\n        s = IDX(row, col)\n        for dr, dc in RDIR:\n            btw = []\n            for dist in range(1, 8):\n                nr, nc = row+dr*dist, col+dc*dist\n                if not (0<=nr<8 and 0<=nc<8): break\n                d = IDX(nr, nc)\n                bld({s:'r', d:'[a-z_]'} | {b:'_' for b in btw},\n                    {s:'_', d:'r'}, cr=cr_for(s,d))\n                btw.append(d)\nprint('  Rooks:', len(rules))\n\n# Queen (sliding)\nQDIR = BDIR + RDIR\nfor row in range(8):\n    for col in range(8):\n        s = IDX(row, col)\n        for dr, dc in QDIR:\n            btw = []\n            f