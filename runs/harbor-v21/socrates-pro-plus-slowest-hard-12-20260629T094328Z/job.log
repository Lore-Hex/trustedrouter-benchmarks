Sending keys: ['cat > /app/jump_analyzer.py << \'PYEOF\'\nimport sys\nimport cv2\nimport numpy as np\nimport toml\n\ndef analyze_jump(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        print(f"Error: Cannot open video {video_path}", file=sys.stderr)\n        sys.exit(1)\n\n    # Read the first frame as background (no runner)\n    ret, bg_frame = cap.read()\n    if not ret:\n        print("Error: Cannot read first frame", file=sys.stderr)\n        sys.exit(1)\n    \n    bg_gray = cv2.cvtColor(bg_frame, cv2.COLOR_BGR2GRAY)\n    bg_gray = cv2.GaussianBlur(bg_gray, (21, 21), 0)\n\n    # Store athlete position data per frame\n    # We track: bottom_y (feet position in image coords, lower value = higher position)\n    frame_data = []  # list of (frame_number, bottom_y, center_x, area)\n\n    frame_idx = 0\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        frame_idx += 1\n\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (21, 21), 0)\n\n        # Compute absolute difference from background\n        diff = cv2.absdiff(bg_gray, gray)\n        _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)\n\n        # Morphological operations to clean up\n        kernel = np.ones((5, 5), np.uint8)\n        thresh = cv2.dilate(thresh, kernel, iterations=2)\n        thresh = cv2.erode(thresh, kernel, iterations=1)\n\n        contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n\n        # Find the largest contour with sufficient area (the athlete)\n        best_contour = None\n        best_area = 0\n        for c in contours:\n            area = cv2.contourArea(c)\n            if area > best_area and area > 3000:\n                best_area = area\n                best_contour = c\n\n        if best_contour is not None:\n            x, y, w, h = cv2.boundingRect(best_contour)\n            bottom_y = y + h\n            center_x = x + w // 2\n            frame_data.append((frame_idx, bottom_y, center_x, best_area))\n        else:\n            frame_data.append((frame_idx, None, None, None))\n\n    cap.release()\n\n    # Extract frames where athlete is detected\n    detected = [(f, by, cx, a) for f, by, cx, a in frame_data if by is not None]\n    \n    if not detected:\n        print("Error: No athlete detected in video", file=sys.stderr)\n        sys.exit(1)\n\n    # Find the peak of the jump (minimum bottom_y = highest position)\n    min_bottom_y = min(by for _, by, _, _ in detected)\n    peak_frame = [f for f, by, _, _ in detected if by == min_bottom_y][0]\n\n    # Compute ground level from running frames\n    # The ground level is roughly the median of all bottom_y values\n    # Since most frames show running (not jumping), median approximates ground level\n    all_bottom_y = [by for _, by, _, _ in detected]\n    ground_level = np.median(all_bottom_y)\n\n    # Set threshold: if bottom_y is below this, athlete is in the air\n    # threshold is between ground level and peak\n    threshold = ground_level - 0.35 * (ground_level - min_bottom_y)\n\n    # Find takeoff frame: last frame before/at peak where bottom_y is above threshold\n    # (i.e., athlete is still on the ground)\n    takeoff_frame = None\n    for f, by, cx, a in sorted(detected, key=lambda x: x[0]):\n        if f > peak_frame:\n            break\n        if by > threshold:\n            takeoff_frame = f\n        else:\n            # Once we\'re below threshold, we\'ve found the jump has started\n            if takeoff_frame is not None:\n                break\n\n    # Find landing frame: first frame after peak where bottom_y is back above threshold\n    land_frame = None\n    for f, by, cx, a in sorted(detected, key=lambda x: x[0]):\n        if f <= peak_frame:\n            continue\n        if by > threshold:\n            land_frame = f\n            break\n\n    if takeoff_frame is None or land_frame is None:\n        print("Error: Could not determine takeoff or landing frame", file=sys.stderr)\n        sys.exit(1)\n\n    return takeoff_frame, land_frame\n\n\ndef main():\n    if len(sys.argv) < 2:\n        print("Usage: python3 jump_analyzer.py <video.mp4>", file=sys.stderr)\n        sys.exit(1)\n\n    video_path = sys.argv[1]\n    takeoff, landing = analyze_jump(video_path)\n\n    result = {\n        "jump_takeoff_frame_number": takeoff,\n        "jump_land_frame_number": landing\n    }\n\n    output_path = "/app/output.toml"\n    with open(output_path, "w") as f:\n        toml.dump(result, f)\n\n    print(f"Takeoff frame: {takeoff}")\n    print(f"Landing frame: {landing}")\n    print(f"Output written to {output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
