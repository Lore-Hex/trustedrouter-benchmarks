Sending keys: ['cat > /app/build.py << \'PYEOF\'\nimport random\n\nrandom.seed(42)\n\n# Codon table - multiple codons per amino acid with varying GC content\ncodon_table = {\n    \'A\': [\'GCT\',\'GCC\',\'GCA\',\'GCG\'],\n    \'R\': [\'CGT\',\'CGC\',\'CGA\',\'CGG\',\'AGA\',\'AGG\'],\n    \'N\': [\'AAT\',\'AAC\'],\n    \'D\': [\'GAT\',\'GAC\'],\n    \'C\': [\'TGT\',\'TGC\'],\n    \'Q\': [\'CAA\',\'CAG\'],\n    \'E\': [\'GAA\',\'GAG\'],\n    \'G\': [\'GGT\',\'GGC\',\'GGA\',\'GGG\'],\n    \'H\': [\'CAT\',\'CAC\'],\n    \'I\': [\'ATT\',\'ATC\',\'ATA\'],\n    \'L\': [\'TTA\',\'TTG\',\'CTT\',\'CTC\',\'CTA\',\'CTG\'],\n    \'K\': [\'AAA\',\'AAG\'],\n    \'M\': [\'ATG\'],\n    \'F\': [\'TTT\',\'TTC\'],\n    \'P\': [\'CCT\',\'CCC\',\'CCA\',\'CCG\'],\n    \'S\': [\'TCT\',\'TCC\',\'TCA\',\'TCG\',\'AGT\',\'AGC\'],\n    \'T\': [\'ACT\',\'ACC\',\'ACA\',\'ACG\'],\n    \'W\': [\'TGG\'],\n    \'Y\': [\'TAT\',\'TAC\'],\n    \'V\': [\'GTT\',\'GTC\',\'GTA\',\'GTG\'],\n}\n\ndef gc(s):\n    return (s.count(\'G\')+s.count(\'C\'))/len(s) if s else 0\n\n# Protein components\nflag = "DYKDDDDK"\nclover_pdb = "MGSSHHHHHHSSGENLYFQGHMVSKGEELFTGVVPILVELDGDVNGHKFSVRGEGEGDATNGKLTLKFICTTGKLPVPWPTLVTTFGYGVACFSRYPDHMKQHDFFKSAMPEGYVQERTISFKDDGTYKTRAEVKFEGDTLVNRIELKGIDFKEDGNILGHKLEYNFNSHNVYITADKQKNGIKANFKIRHNVEDGSVQLADHYQQNTPIGDGPVLLPDNHYLSHQSALSKDPNEKRDHMVLLEFVTAAGITHGMDELYK"\nclover = clover_pdb[1:]\ndhfr = "ISLIAALAVDRVIGMENAMPWNLPADLAWFKRNTLNKPVIMGRHTWESIGRPLPGRKNIILSSQPGTDDRVTWVKSVDEAIAACGDVPEIMVIGGGRVYEQFLPKAQKLYLTHIDAEVEGDTHFPDYEPDDWESVFSEFHDADAQNSHSYCFEILERR"\nmcherry_pdb = "MVSKGEEDNMAIIKEFMRFKVHMEGSVNGHEFEIEGEGEGRPYEGTQTAKLKVTKGGPLPFAWDILSPQFMYGSKAYVKHPADIPDYLKLSFPEGFKWERVMNFEDGGVVTVTQDSSLQDGEFIYKVKLRGTNFPSDGPVMQKKTMGWEASSERMYPEDGALKGEIKQRLKLKDGGHYDAEVKTTYKAKKPVQLPGAYNVNIKLDITSHNEDYTIVEQYERAEGRHSTGGMDELYK"\nmcherry = mcherry_pdb[1:]\nsnap = "GPGSDKDCEMKRTTLDSPLGKLELSGCEQGLHEIIFLGKGTSAADAVEVPAPAAVLGGPEPLMQATAWLNAYFHQPEAIEEFPVPALHHPVFQQESFTRQVLWKLLKVVKFGEVISYSHLAALAGNPAATAAVKTALSGNPVPILIPCHRVVQGDLDVGGYEGGLAVKEWLLAHEGHRLGKR"\ngs = "GGSGGSGGSG"\n\nprotein = flag + gs + clover + gs + dhfr + gs + mcherry + gs + snap\nprint(f"Protein length: {len(protein)}")\n\n# Codon optimization with GC window constraint\n# Greedy: for each AA, choose codon that keeps running GC balanced toward 50%\ndef optimize(protein, attempts=2000):\n    best = None\n    for attempt in range(attempts):\n        dna = []\n        for aa in protein:\n            codons = codon_table[aa]\n            # Score codons by how they keep recent window GC near 0.5\n            recent = \'\'.join(dna)[-47:]\n            def score(c):\n                w = (recent + c)[-50:]\n                return abs(gc(w) - 0.5)\n            # Add randomness\n            scored = sorted(codons, key=lambda c: score(c) + random.random()*0.05)\n            dna.append(scored[0])\n        seq = \'\'.join(dna)\n        # Validate GC windows\n        ok = True\n        for i in range(len(seq)-49):\n            w = seq[i:i+50]\n            g = gc(w)\n            if g < 0.30 or g > 0.70:\n                ok = False\n                break\n        if ok:\n            return seq\n        if best is None:\n            best = seq\n    return best\n\nseq = optimize(protein)\n\n# Validate\ndef validate(seq):\n    bad = []\n    for i in range(len(seq)-49):\n        w = seq[i:i+50]\n        g = gc(w)\n        if g < 0.30 or g > 0.70:\n            bad.append((i, g))\n    return bad\n\nbad = validate(seq)\nprint(f"DNA length: {len(seq)}")\nprint(f"Bad windows: {len(bad)}")\nif bad:\n    print("First bad:", bad[:5])\nprint(f"Overall GC: {gc(seq):.3f}")\n\n# Verify translation\ncodon2aa = {}\nfor aa, cs in codon_table.items():\n    for c in cs:\n        codon2aa[c] = aa\ntrans = \'\'.join(codon2aa[seq[i:i+3]] for i in range(0, len(seq), 3))\nprint(f"Translation matches: {trans == protein}")\n\nif not bad and trans == protein:\n    with open(\'/app/gblock.txt\', \'w\') as f:\n        f.write(seq)\n    print("WROTE gblock.txt")\nelse:\n    print("NOT WRITTEN - issues remain")\nPYEOF\npython3 /app/build.py\n'] min_timeout_sec: 30.0 max_timeout_sec: 180.0
