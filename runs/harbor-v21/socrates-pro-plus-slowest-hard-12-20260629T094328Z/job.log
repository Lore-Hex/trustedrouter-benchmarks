\':bid,\'shape\':{\'seq_align\':shape_val,\'heads_align\':HEADS,\'hidden_align\':HIDDEN}})\n    return plan\n\ndef evaluate(reqs, plan, label=""):\n    cm = CostModel(64)\n    m = cm.plan_metrics(reqs, plan)\n    shapes = set((p[\'shape\'][\'seq_align\'],p[\'shape\'][\'heads_align\'],p[\'shape\'][\'hidden_align\']) for p in plan)\n    nb = len(set(p[\'batch_id\'] for p in plan))\n    return m, len(shapes), nb\n\nif __name__ == \'__main__\':\n    root = os.path.dirname(os.path.dirname(__file__))\n    reqs1 = load_requests(os.path.join(root,\'input_data\',\'requests_bucket_1.jsonl\'))\n    reqs2 = load_requests(os.path.join(root,\'input_data\',\'requests_bucket_2.jsonl\'))\n\n    # Candidate shape sets (must be multiples of 64, sorted, max 8)\n    candidates = [\n        [64,128,256,448,704,1088,1472,2048],\n        [64,128,192,384,640,1088,1472,2048],\n        [64,128,192,384,640,1024,1408,2048],\n        [64,128,192,320,448,704,1152,2048],\n        [64,128,192,320,448,704,1088,2048],\n        [64,128,192,320,448,704,1024,2048],\n        [64,128,192,320,448,704,1024,1600],\n        [64,128,192,320,448,704,1152,1792],\n        [64,128,192,320,448,704,1280,2048],\n    ]\n    best = None\n    for shapes in candidates:\n        for frac, ab in [(0.05,4), (0.03,3), (0.02,2), (0.10,8)]:\n            plan1 = build_plan(reqs1, shapes, frac, ab, 64)\n            plan2 = build_plan(reqs2, shapes, frac, ab, 64)\n            m1, s1, nb1 = evaluate(reqs1, plan1)\n            m2, s2, nb2 = evaluate(reqs2, plan2)\n            ok1 = (m1[\'cost\'] < 3.0e11 and m1[\'pad_ratio\'] < 0.055 and m1[\'p95_latency_ms\'] < 2.1e6 and m1[\'sequential_timecost\'] < 2.7e8)\n            ok2 = (m2[\'cost\'] < 4.8e10 and m2[\'pad_ratio\'] < 0.15 and m2[\'p95_latency_ms\'] < 2.1e5 and m2[\'sequential_timecost\'] < 3.2e7)\n            score = m1[\'cost\'] + m2[\'cost\']\n            if best is None or (ok1 and ok2 and score < best[\'score\']) or (not best[\'ok\'] and (ok1 and ok2)):\n                b