rint "BACKBONE: ", length($backbone_frag), "\\n";\n\n# Assemble by overlapping overhangs:\n# EGFP ends with AAGG, FLAG starts with AAGG -> overlap\n# FLAG ends with CAGA, SNAP starts with CAGA -> overlap  \n# SNAP ends with TAAT, BACKBONE starts with TAAT -> overlap\n# BACKBONE ends with ATGA, EGFP starts with ATGA -> overlap (circular)\n\nmy $assembled = substr($egfp_frag, 0, -4)  # EGFP without last 4 (AAGG)\n              . substr($flag_frag, 0, -4)   # FLAG without last 4 (CAGA)\n              . substr($snap_frag, 0, -4)   # SNAP without last 4 (TAAT)\n              . substr($backbone_frag, 0, -4);  # BACKBONE without last 4 (ATGA)\n\nprint "\\nAssembled length: ", length($assembled), " vs output ", length($out), "\\n";\n\n# The assembled sequence should be a rotation of the output\n# Starting at position 210 (J1)\nmy $rotated = substr($out, 210) . substr($out, 0, 210);\n\nif ($assembled eq $rotated) {\n    print "\\n*** ASSEMBLY VERIFIED: Exact match with output! ***\\n";\n} else {\n    # Find first mismatch\n    for my $i (0..length($assembled)-1) {\n        if (substr($assembled,$i,1) ne substr($rotated,$i,1)) {\n            print "Mismatch at position $i: got ", substr($assembled,$i,1), " expected ", substr($rotated,$i,1), "\\n";\n            print "Assembled context: ", substr($assembled, $i>10?$i-10:0, 20), "\\n";\n            print "Expected context:  ", substr($rotated, $i>10?$i-10:0, 20), "\\n";\n            last;\n        }\n    }\n}\n\n# Also verify each annealing region maps to correct template\nprint "\\nAnnealing verification:\\n";\nmy %ann_check = (\n    \'input_fwd\' => [$seq{input}, 691, \'fwd\'],\n    \'input_rev\' => [$seq{input}, 209, \'rev\'],\n    \'egfp_fwd\' => [$seq{egfp}, 4, \'fwd\'],\n    \'egfp_rev\' => [$seq{egfp}, 711, \'rev\'],\n    \'flag_fwd\' => [$seq{flag}, 5, \'fwd\'],\n    \'flag_rev\' => [$seq{flag}, 84, \'rev\'],\n    \'snap_fwd\' => [$seq{snap}, 5, \'fwd\'],\n    \'snap_rev\' => [$seq{snap}, 545, \'rev\'],\n);\nfor my $k (sort keys %ann_check) {\n    my ($tmpl, $pos, $dir) = @{$ann_check{$k}};\n    my $anneal = substr($prim{$k}, 15);\n    if ($dir eq \'fwd\') {\n        my $expected = substr($tmpl, $pos, length($anneal));\n        if (uc($anneal) eq uc($expected)) {\n            print "$k: fwd anneal matches template[$pos:".($pos+length($anneal))."] OK\\n";\n        } else {\n            print "$k: MISMATCH! Primer=$anneal Expected=$expected\\n";\n        }\n    } else {\n        my $expected_rc = rc(substr($tmpl, $pos - length($anneal) + 1, length($anneal)));\n        if (uc($anneal) eq uc($expected_rc)) {\n            print "$k: rev anneal (RC) matches template[".($pos-length($anneal)+1).":".($pos+1)."] OK\\n";\n        } else {\n            print "$k: MISMATCH! Primer=$anneal Expected_RC=$expected_rc\\n";\n        }\n    }\n}\nEOF\nperl final_check.pl 2>&1\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
