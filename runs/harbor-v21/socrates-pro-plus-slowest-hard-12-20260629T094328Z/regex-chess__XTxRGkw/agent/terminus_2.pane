[?2004l[?2004h>     for t, v, gi, _ in entries:
[?2004l[?2004h>         bp += '(.{%d})' % v if t == 'g' else '(%s)' % v
[?2004l[?2004h>     gb = ''.join('\\' + str(gi) for _, _, gi, _ in entries)
[?2004l[?2004h>     db = ''
[?2004l[?2004h>     for t, v, gi, bpos in entries:
