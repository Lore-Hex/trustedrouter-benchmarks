[?2004l[?2004h>         gr = 'G' + gb + ' \\' + str(cg) + ' \\' + str(eg)
[?2004l[?2004h>         dr = 'D' + db + ' ' + dc + ' ' + new_ep
[?2004l[?2004h>         add(pat, gr + '\\n' + dr)
