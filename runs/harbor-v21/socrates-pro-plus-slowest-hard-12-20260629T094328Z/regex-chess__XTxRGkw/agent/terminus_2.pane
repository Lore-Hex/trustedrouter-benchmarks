[?2004l[?2004h> # pos_new: {pos: literal_replacement_char}
[?2004l[?2004h> # Positions not in pos_new get backreferenced
[?2004l[?2004h> def build_rule(pos_chars, pos_new, new_ep='-'):
[?2004l[?2004h>     all_p = sorted(set(pos_chars) | set(pos_new))
[?2004l[?2004h>     prev = 0
[?2004l[?2004h>     gs = []
[?2004l[?2004h>     gid = 0
[?2004l[?2004h>     for sp in all_p:
[?2004l[?2004h>         gap = sp - prev
[?2004l[?2004h>         if gap > 0:
[?2004l[?2004h>             gid += 1
[?2004l[?2004h>             gs.append(('g', gap, gid))
[?2004l[?2004h>         gid += 1
[?2004l[?2004h>         ch = pos_chars.get(sp, '.')
[?2004l[?2004h>         gs.append(('c', ch, gid))
[?2004l[?2004h>         prev = sp + 1
[?2004l[?2004h>     tail = 64 - prev
[?2004l[?2004h>     if tail > 0:
[?2004l[?2004h>         gid += 1
[?2004l[?2004h>         gs.append(('g', tail, gid))
[?2004l[?2004h>     cg, eg = gid + 1, gid + 2
[?2004l[?2004h>     bp = ''
[?2004l[?2004h>     for t, v, gi in gs:
[?2004l[?2004h>         bp += '(.{%d})' % v if t == 'g' else '(%s)' % v
[?2004l[?2004h>     gb = ''.join('\\' + str(gi) for _, _, gi in gs)
[?2004l[?2004h>     db = ''
[?2004l[?2004h>     for t, v, gi in gs:
[?2004l[?2004h>         if gi in [x[2] for x in gs if x[0] == 'c']:
[?2004l[?2004h>             pos = 0
[?2004l[?2004h>             cnt = 0
[?2004l[?2004h>             for t2, v2, gi2 in gs:
[?2004l[?2004h>                 if t2 == 'g':
[?2004l[?2004h>                     cnt += v2
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     if gi2 == gi:
[?2004l[?2004h>                         pos = cnt
[?2004l[?2004h>                         break
[?2004l[?2004h>                     cnt += 1
[?2004l[?2004h>             if pos in pos_new:
[?2004l[?2004h>                 db += pos_new[pos]
[?2004l[?2004h>             else:
[?2004l[?2004h>                 db += '\\' + str(gi)
[?2004l[?2004h>         else:
[?2004l[?2004h>             db += '\\' + str(gi)
[?2004l[?2004h>     pat = '(?m)^G' + bp + ' (\\S+) (\\S+)$'
[?2004l[?2004h>     gr = 'G' + gb + ' \\' + str(cg) + ' \\' + str(eg)
[?2004l[?2004h>     dr = 'D' + db + ' \\' + str(cg) + ' ' + new_ep
[?2004l[?2004h>     add(pat, gr + '\\n' + dr)
[?2004l[?2004h> 
