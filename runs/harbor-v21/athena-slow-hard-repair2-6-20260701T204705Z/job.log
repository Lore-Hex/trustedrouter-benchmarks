Sending keys: ["cat > /app/train_fasttext.py <<'PY'\nimport pandas as pd\nimport fasttext\nimport os\nimport re\n\ndef clean(text):\n    text = str(text)\n    text = text.replace('\\n', ' ').replace('\\r', ' ').replace('\\t', ' ')\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text.lower()\n\nprint('Loading data...')\ntrain = pd.read_parquet('/app/data/train-00000-of-00001.parquet')\ntest = pd.read_parquet('/app/data/test-00000-of-00001.parquet')\n\nprint('Writing fasttext format files...')\nwith open('/tmp/train_ft.txt', 'w') as f:\n    for label, text in zip(train['label'], train['text']):\n        f.write(f'__label__{int(label)} {clean(text)}\\n')\nwith open('/tmp/test_ft.txt', 'w') as f:\n    for label, text in zip(test['label'], test['text']):\n        f.write(f'__label__{int(label)} {clean(text)}\\n')\n\nprint('Training model...')\nmodel = fasttext.train_supervised(\n    input='/tmp/train_ft.txt',\n    epoch=25,\n    lr=1.0,\n    wordNgrams=2,\n    dim=100,\n    bucket=500000,\n    minCount=2,\n    loss='softmax',\n    thread=4,\n    verbose=2,\n)\n\nprint('Evaluating full model...')\nn, p, r = model.test('/tmp/test_ft.txt')\nprint(f'Full model: n={n}, precision={p:.4f}, recall={r:.4f}')\n\nprint('Quantizing model...')\nmodel.quantize(input='/tmp/train_ft.txt', retrain=True, qnorm=True, cutoff=100000, epoch=15, lr=1.0, thread=4)\n\nprint('Evaluating quantized model...')\nn, p, r = model.test('/tmp/test_ft.txt')\nprint(f'Quantized model: n={n}, precision={p:.4f}, recall={r:.4f}')\n\nprint('Saving model...')\nmodel.save_model('/app/model.bin')\nsize = os.path.getsize('/app/model.bin') / (1024*1024)\nprint(f'Model size: {size:.2f} MB')\nprint(f'Accuracy: {p:.4f}')\nif size < 150 and p >= 0.62:\n    print('SUCCESS: model meets constraints')\nelse:\n    print('WARNING: model may not meet constraints')\nPY\npython3 /app/train_fasttext.py\n"] min_timeout_sec: 60.0 max_timeout_sec: 180.0
