Sending keys: ["python3 - <<'PY'\nimport re,struct\n# decode rodata\nbase=None; data=bytearray()\nfor line in open('/tmp/rodata.txt'):\n    m=re.match(r'\\s*([0-9a-f]+)\\s+(.+)', line)\n    if not m: continue\n    addr=int(m.group(1),16)\n    if base is None: base=addr\n    for p in m.group(2).split():\n        if re.fullmatch(r'[0-9a-f]{8}', p):\n            data.extend(bytes.fromhex(p))\n        else: break\ndef fval(a):\n    off=a-base\n    if 0<=off and off+4<=len(data):\n        return struct.unpack('<f',data[off:off+4])[0]\n    return None\n# parse main.asm to find vector_create calls and nearby constant loads\nlines=open('/tmp/main.asm').read().splitlines()\nfor i,line in enumerate(lines):\n    if 'vector_create' in line and 'call' in line:\n        # look back up to 8 lines for movss/mov with constants or stack refs\n        ctx=[]\n        for j in range(max(0,i-8),i+1):\n            l=lines[j]\n            refs=re.findall(r'# ([0-9a-f]+)', l)\n            vals=[fval(int(r,16)) for r in refs if fval(int(r,16)) is not None]\n            ctx.append((j+1,l.split('#')[0].strip(),vals))\n        print(f'--- vector_create at line {i+1} ---')\n        for ln,txt,vals in ctx:\n            print(f'  {ln}: {txt}  vals={vals}')\nPY\n"] min_timeout_sec: 0.1 max_timeout_sec: 180.0
