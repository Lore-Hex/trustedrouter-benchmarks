Sending keys: ['python3 - <<\'PY\'\nimport re,struct\n# build rodata map\nbase=None; data=bytearray()\nfor line in open(\'/tmp/rodata.txt\'):\n    m=re.match(r\'\\s*([0-9a-f]+)\\s+((?:[0-9a-f]{2}\\s)+)\',line)\n    if not m: continue\n    if base is None: base=int(m.group(1),16)\n    data.extend(int(x,16) for x in m.group(2).split())\ndef decode(addr,size=4):\n    off=addr-base\n    if 0<=off and off+size<=len(data):\n        b=data[off:off+size]\n        if size==4:\n            f=struct.unpack(\'<f\',b)[0]\n            i=struct.unpack(\'<I\',b)[0]\n            s=data[off:off+16].split(b\'\\0\')[0]\n            t=\'\'\n            if len(s)>=2 and all(32<=c<127 for c in s): t=\' str="\'+s.decode(\'latin1\')+\'"\'\n            return f\'{f:.9g} u={i:#010x}{t}\'\n        return b.hex()\n    return \'out_of_range\'\nasm=open(\'/tmp/orig.asm\').read()\nfuncs=[\'vector_create\',\'vector_add\',\'vector_subtract\',\'vector_multiply\',\'vector_dot\',\'vector_length\',\'vector_normalize\',\'ray_create\',\'ray_at\',\'sky_color\',\'plane_intersect\',\'sphere_intersect\',\'is_in_shadow\',\'trace\',\'main\',\'write_image\',\'allocate_image\',\'free_image\']\nfor fn in funcs:\n    m=re.search(rf\'<{fn}>:\\n(.*?)\\n\\n\', asm, re.S)\n    if not m: \n        print(fn,\'not found\'); continue\n    body=m.group(1)\n    refs=sorted(set(int(x,16) for x in re.findall(r\'# ([0-9a-f]+) <\', body)))\n    # also rip comments with addresses not symbol\n    refs2=sorted(set(int(x,16) for x in re.findall(r\'# ([0-9a-f]+)$\', body, re.M)))\n    print(f\'===== {fn} lines={body.count(chr(10))} refs={len(refs2)} =====\')\n    for a in refs2:\n        print(f\'  {a:#06x}: {decode(a)}\')\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
