[?2004l[?2004h>     f.readline(); f.readline(); f.readline()
[?2004l[?2004h>     for line in f: vals.extend(map(int,line.split()))
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3; return (vals[i],vals[i+1],vals[i+2])
[?2004l[?2004h> # find first non-sky row by scanning center column
[?2004l[?2004h> for y in range(h):
[?2004l[?2004h>     r,g,b=px(w//2,y)
[?2004l[?2004h>     if not (b==255 and r<g<b):
[?2004l[?2004h>         print('center horizon/non-sky at y',y,'color',px(w//2,y)); break
[?2004l[?2004h> for y in range(h):
[?2004l[?2004h>     if all(px(x,y)[2]!=255 for x in range(0,w,20)):
[?2004l[?2004h>         print('all sampled no pure blue at y',y); break
[?2004l[?2004h> # find non-plane/sphere bounding boxes by color categories
[?2004l[?2004h> def cat(c):
[?2004l[?2004h>     r,g,b=c
[?2004l[?2004h>     if b==255 and r<=g<b: return 'sky'
[?2004l[?2004h>     if r==g==b and (r==152 or r==67 or r==20 or r==46): return 'plane'
[?2004l[?2004h>     if r==51 and g==10 and b==10: return 'sphere?'
[?2004l[?2004h>     return 'other'
[?2004l[?2004h> for name in ['sphere?','other']:
[?2004l[?2004h>     xs=[]; ys=[]
[?2004l[?2004h>     for y in range(0,h,5):
[?2004l[?2004h>         for x in range(0,w,5):
[?2004l[?2004h>             c=px(x,y)
[?2004l[?2004h>             if cat(c)==name:
[?2004l[?2004h>                 xs.append(x); ys.append(y)
[?2004l[?2004h>     if xs:
[?2004l[?2004h>         print(name,'bbox approx',min(xs),min(ys),max(xs),max(ys),'count',len(xs))
[?2004l[?2004h>         for y in range(min(ys),max(ys)+1,max(1,(max(ys)-min(ys))//8)):
[?2004l[?2004h>             row=[]
[?2004l[?2004h>             for x in range(min(xs),max(xs)+1,max(1,(max(xs)-min(xs))//8)):
[?2004l[?2004h>                 row.append(px(x,y))
[?2004l[?2004h>             print(' row',y,row)
