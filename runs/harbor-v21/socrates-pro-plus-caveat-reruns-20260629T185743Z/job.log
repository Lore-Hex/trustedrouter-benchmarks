Sending keys: ['cat > /app/compress.py << \'PYEOF\'\n#!/usr/bin/env python3\nimport sys\nfrom collections import defaultdict\n\ndef main():\n    with open(\'/app/data.txt\', \'rb\') as f:\n        data = f.read()\n    n = len(data)\n    print(f"Input size: {n}", file=sys.stderr)\n\n    low = 0\n    range_val = 1\n    scale_count = 0\n    cc = {}\n\n    def put_bit(bit, ctx):\n        nonlocal low, range_val, scale_count\n        while range_val < 255:\n            range_val *= 255\n            low *= 255\n            scale_count += 1\n        c0 = cc.get((ctx, 0), 0)\n        c1 = cc.get((ctx, 1), 0)\n        split = range_val * (c0 + 1) // (c0 + c1 + 2)\n        if bit:\n            low += split\n            range_val -= split\n        else:\n            range_val = split\n        cc[(ctx, bit)] = cc.get((ctx, bit), 0) + 1\n\n    def put_integer(value, initial_tmp, ctx_base):\n        result_ans = value + (1 << initial_tmp)\n        T = result_ans.bit_length()\n        ctx_scaled = ctx_base * 99\n        for tmp_val in range(initial_tmp + 1, T):\n            put_bit(0, tmp_val + ctx_scaled)\n        put_bit(1, T + ctx_scaled)\n        data_bits = T - 1\n        for i in range(data_bits):\n            bv = (result_ans >> (data_bits - 1 - i)) & 1\n            put_bit(bv, ctx_scaled)\n\n    # LZ77 parse\n    operations = []\n    pos = 0\n    hash_map = defaultdict(list)\n    while pos < n:\n        best_dist = 0\n        best_len = 0\n        if pos + 1 < n:\n            key = (data[pos], data[pos+1])\n            candidates = hash_map[key]\n            limit = min(len(candidates), 200)\n            for idx in range(limit - 1, -1, -1):\n                prev_pos = candidates[idx]\n                dist = pos - prev_pos\n                if dist > 65535: continue\n                length = 0\n                while pos + length < n:\n                    if data[prev_pos + (length % dist)] == data[pos + length]:\n                        length += 1\n                        if length >= 2000: break\n                    else:\n                        break\n                if length > best_len:\n                    best_len = length\n                    best_dist = dist\n                    if best_len >= 50: break\n            hash_map[key].append(pos)\n        if best_len >= 2:\n            operations.append((\'match\', best_dist, best_len))\n            for i in range(1, best_len):\n                if pos + i + 1 < n:\n                    hash_map[(data[pos+i], data[pos+i+1])].append(pos+i)\n            pos += best_len\n        else:\n            operations.append((\'literal\', data[pos]))\n            pos += 1\n\n    total_ops = len(operations)\n    print(f"Total operations: {total_ops}", file=sys.stderr)\n\n    put_integer(total_ops, 9, 0)\n    for op in operations:\n        if op[0] == \'match\':\n            _, dist, length = op\n            put_bit(1, 1)\n            put_integer(dist - 1, 5, 2)\n            put_integer(length - 1, 2, 3)\n        else:\n            _, bv = op\n            put_bit(0, 1)\n            if bv < 128:\n                sign, value = 0, bv\n            else:\n                sign, value = 1, 256 - bv\n            put_bit(sign, 8)\n            put_integer(value, 4, 9)\n\n    print(f"scale_count: {scale_count}", file=sys.stderr)\n\n    digits = []\n    temp = low\n    for _ in range(scale_count):\n        digits.append(int(temp % 255))\n        temp //= 255\n    digits.reverse()\n    assert temp == 0, f"Remaining: {temp}"\n\n    output = bytes([d + 1 for d in digits])\n    with open(\'/app/data.comp\', \'wb\') as f:\n        f.write(output)\n    print(f"Output size: {len(output)} bytes", file=sys.stderr)\n    if len(output) <= 2500:\n        print("OK: within 2500 byte limit.", file=sys.stderr)\n    else:\n        print("WARNING: exceeds 2500 bytes!", file=sys.stderr)\n\nmain()\nPYEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
