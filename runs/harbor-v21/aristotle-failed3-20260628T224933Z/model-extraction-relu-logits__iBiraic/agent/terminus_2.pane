[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Theory:
[?2004l[?2004h> # f(t*e_j) = sum_i A2[i] * ReLU(A1[i,j]*t + b1[i]) + b2
[?2004l[?2004h> # For neuron i along direction j:
[?2004l[?2004h> #   breakpoint t_i_j = -b1[i] / A1[i,j]
[?2004l[?2004h> #   slope change at breakpoint: Δ_i_j = A2[i] * A1[i,j]
[?2004l[?2004h> #   invariant: t_i_j * Δ_i_j = -b1[i] * A2[i]  (constant per neuron)
[?2004l[?2004h> # 
[?2004l[?2004h> # So |t * Δ| clusters by neuron.
[?2004l[?2004h> # Then A1[i,j] = -b1[i] / t_i_j, so A1[i,j] ∝ -1/t_i_j (since b1[i] is same for all j for this neuron)
