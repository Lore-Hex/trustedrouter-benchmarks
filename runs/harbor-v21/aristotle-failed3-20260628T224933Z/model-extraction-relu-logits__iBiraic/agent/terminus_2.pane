[?2004l[?2004h>     
[?2004l[?2004h>     # Merge nearby peaks
[?2004l[?2004h>     if len(peak_indices) == 0:
[?2004l[?2004h>         return []
[?2004l[?2004h>     
[?2004l[?2004h>     merged = [peak_indices[0]]
[?2004l[?2004h>     for idx in peak_indices[1:]:
[?2004l[?2004h>         if idx - merged[-1] > 5:  # More than 5 grid points apart
[?2004l[?2004h>             merged.append(idx)
[?2004l[?2004h>     
[?2004l[?2004h>     breakpoints = []
