  [?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Recover A1 by probing f(t*e_j) along basis directions
[?2004l[?2004h> # 
[?2004l)
 [?2004h> # Method:
[?2004l[?2004h> # 1. For each basis direction e_j, find breakpoints of g(t) = f(t*e_j)
[?2004l[?2004h> # 2. For each breakpoint, compute gradient of f just before and after
[?2004ln[?2004h> # 3. The difference in gradients equals ±A2[i] * A1[i,:] for some neuron i
[?2004l[?2004h> # 4. Collect all these gradient-difference vectors and cluster them
[?2004li[?2004h> # 5. Each cluster corresponds to a row of A1 (up to scaling)
[?2004l[?2004h> 
[?2004l [?2004h> def num_grad(x):
[?2004lalg.norm([?2004h>     """Compute gradient of f at point x using central differences."""
[?2004l[?2004h>     h = 1e-6
[?2004l[?2004h>     grad = np.zeros(10)
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         x_plus = x.copy()
[?2004l[?2004h>         x_plus[j] += h
[?2004l[?2004h>         x_minus = x.copy()
[?2004l[?2004h>         x_minus[j] -= h
[?2004l[?2004h>         grad[j] = (forward(x_plus) - forward(x_minus)) / (2 * h)
[?2004l[?2004h>     return grad
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=10000):
[?2004l[?2004h>     """Find breakpoints along basis direction j."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(changes)
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 1e-5
[?2004l[?2004h>     significant = np.where(abs_changes > threshold)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     breakpoints = []
[?2004l[?2004h>     i = 0
[?2004l[?2004h>     while i < len(significant):
[?2004l[?2004h>         idx = significant[i]
[?2004l[?2004h>         if idx + 1 < len(changes) and abs_changes[idx+1] > threshold and np.sign(changes[idx]) == np.sign(changes[idx+1]):
[?2004l[?2004h>             c0 = changes[idx]
[?2004l[?2004h>             c1 = changes[idx+1]
[?2004l[?2004h>             total_change = c0 + c1
[?2004l[?2004h>             if abs(total_change) > 1e-10:
[?2004l[?2004h>                 t_break = t_vals[idx+1] + dt * c0 / total_change
[?2004l[?2004h>                 delta = total_change
[?2004l[?2004h>                 breakpoints.append((t_break, delta))
[?2004l[?2004h>                 i += 2
[?2004l[?2004h>                 continue
[?2004l[?2004h>         i += 1
[?2004l[?2004h>     return breakpoints
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     # Collect all row recovery vectors from breakpoints
[?2004l[?2004h>     # Each is proportional to a row of A1
[?2004l[?2004h>     row_vectors = []
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         
[?2004l[?2004h>         e_j = np.zeros(10)
[?2004l[?2004h>         e_j[j] = 1.0
[?2004l[?2004h>         
[?2004l[?2004h>         for t_star, delta in bps:
[?2004l[?2004h>             # Point just before and after the breakpoint
[?2004l[?2004h>             eps = 1e-5 * max(1.0, abs(t_star))
[?2004l[?2004h>             x_before = e_j * (t_star - eps)
[?2004l[?2004h>             x_after = e_j * (t_star + eps)
[?2004l[?2004h>             
[?2004l[?2004h>             g_before = num_grad(x_before)
[?2004l[?2004h>             g_after = num_grad(x_after)
[?2004l[?2004h>             
[?2004l[?2004h>             diff = g_after - g_before
[?2004l[?2004h>             
[?2004l[?2004h>             # diff is proportional to a row of A1
[?2004l[?2004h>             norm = np.linalg.norm(diff)
[?2004l[?2004h>             if norm > 1e-10:
[?2004l[?2004h>                 row_vectors.append(diff / norm)
[?2004l[?2004h>                 print(f"    t={t_star:+.10f}, Δ={delta:+.8f}, row_vec_norm={norm:.6f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal row vectors collected: {len(row_vectors)}")
[?2004l[?2004h>     
[?2004l[?2004h>     if len(row_vectors) < 20:
[?2004l[?2004h>         print("ERROR: Not enough vectors.")
[?2004l[?2004h>         # Try with smaller threshold?
[?2004l[?2004h>         return None
[?2004l[?2004h>     
[?2004l[?2004h>     # Cluster the row vectors
[?2004l[?2004h>     # Each neuron should contribute multiple vectors (one per direction with non-zero A1)
[?2004l[?2004h>     # We need to find the unique directions
[?2004l[?2004h>     
[?2004l[?2004h>     # Use hierarchical clustering: for each pair of vectors, compute |dot product|
[?2004l[?2004h>     # If |v1·v2| > 0.99, they belong to the same neuron
[?2004l[?2004h>     
[?2004l[?2004h>     vecs = np.array(row_vectors)
[?2004l[?2004h>     n = len(vecs)
[?2004l[?2004h>     
[?2004l[?2004h>     # Group by correlation
[?2004l[?2004h>     used = set()
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(n):
[?2004l[?2004h>         if i in used:
[?2004l[?2004h>             continue
[?2004l[?2004h>         cluster = [i]
[?2004l[?2004h>         used.add(i)
[?2004l[?2004h>         for j in range(i+1, n):
[?2004l[?2004h>             if j not in used:
[?2004l[?2004h>                 # Check correlation with all members of current cluster
[?2004l[?2004h>                 corr = np.min([abs(np.dot(vecs[i], vecs[k])) for k in cluster])
[?2004l[?2004h>                 if corr > 0.99 and abs(np.dot(vecs[i], vecs[j])) > 0.99:
[?2004l[?2004h>                     cluster.append(j)
[?2004l[?2004h>                     used.add(j)
[?2004l[?2004h>         clusters.append(cluster)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nFound {len(clusters)} clusters (expecting 20 neurons)")
[?2004l[?2004h>     
[?2004l[?2004h>     # Build recovered A1 from clusters
[?2004l[?2004h>     # For each cluster, the average direction gives the row (up to scaling)
[?2004l[?2004h>     A1_recovered = np.zeros((len(clusters), 10))
[?2004l[?2004h>     
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         # Average the vectors in this cluster
[?2004l[?2004h>         avg_vec = np.mean([vecs[i] for i in cluster], axis=0)
[?2004l[?2004h>         # Normalize
[?2004l[?2004h>         norm = np.linalg.norm(avg_vec)
[?2004l[?2004h>         if norm > 0:
[?2004l[?2004h>             A1_recovered[k, :] = avg_vec / norm
[?2004l[?2004h>         print(f"  Cluster {k}: size={len(cluster)}")
[?2004l[?2004h>     
[?2004l[?2004h>     return A1_recovered
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     A1_stolen = recover_A1()
[?2004l[?2004h>     if A1_stolen is not None and A1_stolen.shape[0] > 0:
[?2004l[?2004h>         np.save('/app/stolen_A1.npy', A1_stolen)
[?2004l[?2004h>         print(f"\nSaved stolen A1 to /app/stolen_A1.npy")
[?2004l[?2004h>         print(f"Shape: {A1_stolen.shape}")
