[?2004l[?2004h>     # they will be very extreme outliers
[?2004l[?2004h>     
[?2004l
  [?2004h>     # Find local maxima in d2_abs that are above 99th percentile
[?2004l[?2004h>     # But adaptively: look for the top K peaks where K is around 20
[?2004l[?2004h>     
[?2004l  [?2004h>     # Let's find ALL local maxima first
