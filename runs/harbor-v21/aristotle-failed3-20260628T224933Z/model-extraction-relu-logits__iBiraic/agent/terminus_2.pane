[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Recover A1 by probing f(t*e_j) along basis directions
[?2004l[?2004h> # 
[?2004l[?2004h> # For each direction j, find breakpoints of g(t) = f(t*e_j)
[?2004l[?2004h> # Each breakpoint corresponds to a neuron i, with:
[?2004l[?2004h> #   Location: t_i_j = -b1[i] / A1[i,j]
[?2004l[?2004h> #   Slope change: Δ_i_j = A2[i] * |A1[i,j]|
[?2004l[?2004h> #   Invariant: |t * Δ| = |b1[i] * A2[i]| (constant per neuron)
[?2004l[?2004h> # 
[?2004l[?2004h> # Therefore A1[i,j] ∝ -1/t_i_j
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=10000):
[?2004l[?2004h>     """Find breakpoints along basis direction j."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(changes)
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 1e-5
[?2004l[?2004h>     significant = np.where(abs_changes > threshold)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     breakpoints = []
[?2004l[?2004h>     i = 0
[?2004l[?2004h>     while i < len(significant):
[?2004l[?2004h>         idx = significant[i]
[?2004l[?2004h>         if idx + 1 < len(changes) and abs_changes[idx+1] > threshold and np.sign(changes[idx]) == np.sign(changes[idx+1]):
[?2004l[?2004h>             c0 = changes[idx]
[?2004l[?2004h>             c1 = changes[idx+1]
[?2004l[?2004h>             total_change = c0 + c1
[?2004l[?2004h>             if abs(total_change) > 1e-10:
[?2004l[?2004h>                 t_break = t_vals[idx+1] + dt * c0 / total_change
[?2004l[?2004h>                 delta = total_change
[?2004l[?2004h>                 breakpoints.append((t_break, delta))
[?2004l[?2004h>                 i += 2
[?2004l[?2004h>                 continue
[?2004l[?2004h>         i += 1
[?2004l[?2004h>     return breakpoints
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     # Collect breakpoints per direction
[?2004l[?2004h>     all_breakpoints = []  # list of (direction, t, delta)
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         for t, delta in bps:
[?2004l[?2004h>             all_breakpoints.append((j, t, delta))
[?2004l[?2004h>             print(f"    t={t:+.10f}, Δ={delta:+.10f}, |t*Δ|={abs(t*delta):.10f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal breakpoints: {len(all_breakpoints)}")
[?2004l[?2004h>     
[?2004l[?2004h>     if len(all_breakpoints) < 20:
[?2004l[?2004h>         print("ERROR: Not enough breakpoints.")
[?2004l[?2004h>         return None
[?2004ll[?2004h>     
[?2004lA1[?2004h>     # Build array with (direction, t, delta, |t*Δ|, -1/t)
[?2004l[?2004h>     bp_array = np.array([
[?2004l[?2004h>         (j, t, delta, abs(t*delta), -1.0/t if abs(t) > 1e-10 else 0.0)
[?2004l[?2004h>         for j, t, delta in all_breakpoints
[?2004l[?2004h>     ])
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by |t*Δ|
[?2004l[?2004h>     sorted_order = np.argsort(bp_array[:, 3])
[?2004l[?2004h>     sorted_bps = bp_array[sorted_order]
[?2004l[?2004h>     
[?2004l[?2004h>     print("\nSorted |t*Δ|:")
[?2004l[?2004h>     for bp in sorted_bps:
[?2004l[?2004h>         print(f"  dir={int(bp[0]):d}, |t*Δ|={bp[3]:.10f}, -1/t={bp[4]:+.8f}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Build a similarity graph:
[?2004l[?2004h>     # Two breakpoints from different directions belong to the same neuron if
[?2004l[?2004h>     # their |t*Δ| values are close (within 5%)
[?2004l[?2004h>     # AND their directions are different (a neuron can only have one breakpoint per direction)
[?2004l[?2004h>     
[?2004l[?2004h>     n = len(sorted_bps)
[?2004l[?2004h>     # Adjacency matrix: pairs that could belong to same neuron
[?2004l[?2004h>     adj = np.zeros((n, n), dtype=bool)
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(n):
[?2004l[?2004h>         for j in range(i+1, n):
[?2004l[?2004h>             di = int(sorted_bps[i, 0])
[?2004l[?2004h>             dj = int(sorted_bps[j, 0])
[?2004l[?2004h>             if di == dj:
[?2004l[?2004h>                 continue  # Same direction, different breakpoints -> different neurons
[?2004l[?2004h>             
[?2004l[?2004h>             inv_i = sorted_bps[i, 3]
[?2004l[?2004h>             inv_j = sorted_bps[j, 3]
[?2004l[?2004h>             abs_max = max(inv_i, inv_j)
[?2004l[?2004h>             if abs_max > 1e-6:
[?2004l[?2004h>                 rel_diff = abs(inv_i - inv_j) / abs_max
[?2004l[?2004h>                 if rel_diff < 0.05:  # Within 5%
[?2004l[?2004h>                     adj[i, j] = adj[j, i] = True
[?2004l[?2004h>     
[?2004l[?2004h>     # Find connected components in this graph
[?2004l[?2004h>     # But since this is a bipartite-like matching (each neuron appears at most once per direction),
[?2004l[?2004h>     # we can use a greedy clustering approach
[?2004l[?2004h>     
[?2004l[?2004h>     # For each breakpoint, find all other breakpoints it's connected to
[?2004l[?2004h>     # Then merge overlapping groups
[?2004l[?2004h>     used = set()
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(n):
[?2004l[?2004h>         if i in used:
[?2004l[?2004h>             continue
[?2004l[?2004h>         cluster = [i]
[?2004l[?2004h>         used.add(i)
[?2004l[?2004h>         
[?2004l[?2004h>         # Find all nodes connected to this cluster
[?2004l[?2004h>         changed = True
[?2004l[?2004h>         while changed:
[?2004l[?2004h>             changed = False
[?2004l[?2004h>             for j in range(n):
[?2004l[?2004h>                 if j not in used:
[?2004l[?2004h>                     # Check if j is connected to any member of the cluster
[?2004l[?2004h>                     for k in cluster:
[?2004l[?2004h>                         if adj[j, k]:
[?2004l[?2004h>                             cluster.append(j)
[?2004l[?2004h>                             used.add(j)
[?2004l[?2004h>                             changed = True
[?2004l[?2004h>                             break
[?2004l[?2004h>         clusters.append(cluster)
[?2004l[?2004h>     
[?2004l[?2004h>     # Now each cluster should correspond to a neuron
[?2004l[?2004h>     # But a cluster may contain multiple breakpoints from the same direction.
[?2004l[?2004h>     # That would imply the same neuron has multiple breakpoints in that direction, which is impossible.
[?2004l[?2004h>     # Let's check and filter
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nRaw clusters: {len(clusters)}")
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         dirs = [int(sorted_bps[i, 0]) for i in cluster]
[?2004l[?2004h>         print(f"  Cluster {k}: size={len(cluster)}, dirs={sorted(set(dirs))}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Filter clusters: keep only those with at least 2 unique directions (reliable)
[?2004l[?2004h>     clusters = [c for c in clusters if len(set(int(sorted_bps[i, 0]) for i in c)) >= 2]
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nAfter filtering: {len(clusters)} clusters")
[?2004l[?2004h>     
[?2004l[?2004h>     # Build recovered A1
[?2004l[?2004h>     A1_recovered = np.zeros((len(clusters), 10))
[?2004l[?2004h>     
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         print(f"\nCluster {k} (size {len(cluster)}):")
[?2004l[?2004h>         row = np.zeros(10)
[?2004l[?2004h>         for i in cluster:
[?2004l[?2004h>             bp = sorted_bps[i]
[?2004l[?2004h>             j = int(bp[0])
[?2004l[?2004h>             val = bp[4]
[?2004l[?2004h>             # If multiple breakpoints for same direction (shouldn't happen), average them
[?2004l[?2004h>             if row[j] == 0:
[?2004l[?2004h>                 row[j] = val
[?2004l[?2004h>             else:
[?2004l[?2004h>                 row[j] = (row[j] + val) / 2
[?2004l[?2004h>             print(f"  dir={j}, t={bp[1]:+.10f}, -1/t={val:+.8f}")
[?2004l[?2004h>         
[?2004l[?2004h>         norm = np.linalg.norm(row)
[?2004l[?2004h>         if norm > 0:
[?2004l[?2004h>             row = row / norm
[?2004l[?2004h>         A1_recovered[k, :] = row
[?2004l[?2004h>     
[?2004l[?2004h>     return A1_recovered
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     A1_stolen = recover_A1()
[?2004l[?2004h>     if A1_stolen is not None and A1_stolen.shape[0] > 0:
[?2004l[?2004h>         np.save('/app/stolen_A1.npy', A1_stolen)
[?2004l[?2004h>         print(f"\nSaved stolen A1 to /app/stolen_A1.npy")
[?2004l[?2004h>         print(f"Shape: {A1_stolen.shape}")
[?2004l[?2004h>         print("Stolen A1 (rows normalized):")
[?2004l[?2004h>         np.set_printoptions(precision=6, suppress=True, linewidth=200)
[?2004l[?2004h>         print(A1_stolen)
[?2004l[?2004h>         print("\nDone!")
[?2004l[?2004h>     else:
[?2004l[?2004h>         print("Failed to recover A1")
