[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward, A1, b1, A2
[?2004l[?2004h> 
[?2004l[?2004h> # True invariants per neuron
[?2004l[?2004h> print('True invariants (-b1[i]*A2[i]):')
[?2004l[?2004h> true_inv = np.array([-b1[i] * A2[0,i] for i in range(20)])
[?2004l[?2004h> for i, v in enumerate(true_inv):
[?2004l[?2004h>     print(f'  Neuron {i}: {v:+.8f}')
[?2004l[?2004h> 
[?2004l[?2004h> print()
[?2004l[?2004h> 
[?2004l[?2004h> # Now let's use a finer grid to detect breakpoints
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=20000):
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     slope_changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(slope_changes)
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 1e-5
[?2004l[?2004h>     candidates = []
[?2004l[?2004h>     for i in range(1, len(abs_changes) - 1):
[?2004l[?2004h>         if abs_changes[i] > threshold and abs_changes[i] >= abs_changes[i-1] and abs_changes[i] >= abs_changes[i+1]:
[?2004l[?2004h>             t_approx = (t_vals[i+1] + t_vals[i+2]) / 2
[?2004l[?2004h>             delta_slope = slope_changes[i]
[?2004l[?2004h>             candidates.append((t_approx, delta_slope, abs_changes[i]))
[?2004l[?2004h>     
[?2004l[?2004h>     candidates.sort(key=lambda x: -abs(x[1]))
[?2004l[?2004h>     candidates = candidates[:25]
[?2004l[?2004h>     candidates.sort(key=lambda x: x[0])
[?2004l[?2004h>     
[?2004l[?2004h>     result = []
[?2004l[?2004h>     for bp in candidates:
[?2004l[?2004h>         t = bp[0]
[?2004l[?2004h>         if not result or abs(t - result[-1][0]) > 0.001:
[?2004l[?2004h>             result.append((bp[0], bp[1]))
[?2004l[?2004h>     return result
[?2004l[?2004h> 
[?2004l[?2004h> # Test on direction 0 with fine grid
[?2004l[?2004h> bps = find_breakpoints_1d(0, num_samples=20000)
[?2004l[?2004h> print(f'\nDirection 0 detected breakpoints (fine grid):')
[?2004l[?2004h> for t, d in bps:
[?2004l[?2004h>     inv = t * d
[?2004l[?2004h>     print(f'  t={t:+.8f}, Δ={d:+.8f}, t*Δ={inv:+.8f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Compare with true
[?2004l[?2004h> print('\nTrue breakpoints for direction 0:')
[?2004l[?2004h> for i in range(20):
[?2004l[?2004h>     if abs(A1[i,0]) > 1e-10:
[?2004l[?2004h>         t = -b1[i] / A1[i,0]
[?2004l[?2004h>         if abs(t) <= 5:
[?2004l[?2004h>             d = A2[0,i] * A1[i,0]
[?2004l[?2004h>             inv = t * d
[?2004l[?2004h>             print(f'  Neuron {i}: t={t:+.8f}, Δ={d:+.8f}, t*Δ={inv:+.8f}')
[?2004l[?2004h> "
