[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     all_breakpoints = []  # list of (direction, t, delta)
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         for t, delta in bps:
[?2004l[?2004h>             all_breakpoints.append((j, t, delta))
[?2004l[?2004h>             print(f"    t={t:+.8f}, Δ={delta:+.8f}, t*Δ={t*delta:+.8f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal breakpoints collected: {len(all_breakpoints)}")
[?2004l[?2004h>     
[?2004l[?2004h>     if len(all_breakpoints) < 20:
[?2004l[?2004h>         print("ERROR: Not enough breakpoints found")
[?2004l[?2004h>         # Try with more samples?
[?2004l[?2004h>         return None
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute invariants
[?2004l[?2004h>     bp_array = np.array([(j, t, delta, t*delta) for j, t, delta in all_breakpoints])
[?2004l[?2004h>     
[?2004l[?2004h>     # Cluster by |t*delta|
[?2004l[?2004h>     invariants = np.abs(bp_array[:, 3])
[?2004l[?2004h>     
[?2004l[?2004h>     # Use hierarchical clustering based on distance
[?2004l[?2004h>     # Create distance matrix: |inv_i - inv_j|
[?2004l[?2004h>     n = len(invariants)
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by invariant
[?2004l[?2004h>     sorted_order = np.argsort(invariants)
[?2004l[?2004h>     sorted_inv = invariants[sorted_order]
[?2004l[?2004h>     
[?2004l[?2004h>     # Find gaps
[?2004l[?2004h>     gaps = np.diff(sorted_inv)
[?2004l[?2004h>     # We expect 20 groups, but some may be missing
[?2004l[?2004h>     # Use a threshold: if gap > median_gap * 3, it's a split
[?2004l[?2004h>     median_gap = np.median(gaps)
[?2004l[?2004h>     gap_threshold = max(median_gap * 3, 1e-7)
[?2004l[?2004h>     
[?2004l[?2004h>     split_indices = [0]
[?2004l[?2004h>     for i in range(len(gaps)):
[?2004l[?2004h>         if gaps[i] > gap_threshold:
[?2004l[?2004h>             split_indices.append(i + 1)
[?2004l[?2004h>     split_indices.append(len(sorted_inv))
[?2004l[?2004h>     
[?2004l[?2004h>     # Build clusters
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     for k in range(len(split_indices) - 1):
[?2004l[?2004h>         start, end = split_indices[k], split_indices[k+1]
[?2004l[?2004h>         if end - start < 2:
[?2004l[?2004h>             continue  # Skip isolated points (noise)
[?2004l[?2004h>         cluster_indices = sorted_order[start:end]
[?2004l[?2004h>         cluster = []
[?2004l[?2004h>         for idx in cluster_indices:
[?2004l[?2004h>             j, t, delta, inv = bp_array[idx]
[?2004l[?2004h>             cluster.append((int(j), float(t), float(delta)))
[?2004l[?2004h>         clusters.append(cluster)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nFound {len(clusters)} clusters (expecting 20 neurons)")
[?2004l[?2004h>     
[?2004l[?2004h>     # For each cluster, recover the corresponding row of A1
[?2004l[?2004h>     # A1[i,j] ∝ -1/t_i_j (since A1[i,j] = -b1[i]/t_i_j and b1[i] is constant)
[?2004l[?2004h>     
[?2004l[?2004h>     A1_recovered = np.zeros((len(clusters), 10))
[?2004l[?2004h>     
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         print(f"\nCluster {k} (size {len(cluster)}):")
[?2004l[?2004h>         row = np.zeros(10)
[?2004l[?2004h>         for j, t, delta in cluster:
[?2004l[?2004h>             if abs(t) > 1e-10:
[?2004l[?2004h>                 # A1[i,j] ∝ -1/t
[?2004l[?2004h>                 row[int(j)] = -1.0 / t
[?2004l[?2004h>                 print(f"  dir={j}, t={t:+.8f}, Δ={delta:+.8f}, val={-1.0/t:+.8f}")
[?2004l[?2004h>         
[?2004l[?2004h>         # Normalize row (since we only care about direction/ratios)
[?2004l[?2004h>         norm = np.linalg.norm(row)
[?2004l[?2004h>         if norm > 0:
[?2004l[?2004h>             row = row / norm
[?2004l[?2004h>         A1_recovered[k, :] = row
[?2004l[?2004h>     
[?2004l[?2004h>     return A1_recovered
[?2004l[?2004h> 
