[?2004l   [?2004h>     slopes[0] = (f_vals[1] - f_vals[0]) / dt
[?2004l[?2004h>     slopes[-1] = (f_vals[-1] - f_vals[-2]) / dt
[?2004l[?2004h>     
[?2004l val=[?2004h>     # Detect jumps in slope: look for large second derivative
[?2004ll[?2004h>     d2 = np.diff(slopes) / dt
[?2004l)[?2004h>     
[?2004l
    [?2004h>     # Find candidate breakpoints where |d2| is large
[?2004l[?2004h>     # The slope jumps are localized spikes in d2
[?2004led[[?2004h>     d2_abs = np.abs(d2)
[?2004lret[?2004h>     
[?2004lrn A[?2004h>     # Adaptive threshold: use median + some multiple of MAD
[?2004lec[?2004h>     median_d2 = np.median(d2_abs)
[?2004l[?2004h>     mad = np.median(np.abs(d2_abs - median_d2))
[?2004ls[?2004h>     threshold = median_d2 + 5 * mad
[?2004l[?2004h>     
[?2004ln A1 [?2004h>     # Find peaks in d2_abs
[?2004l  [?2004h>     peak_indices = []
[?2004l: {A[?2004h>     for i in range(1, len(d2_abs) - 1):
[?2004l [?2004h>         if d2_abs[i] > threshold and d2_abs[i] > d2_abs[i-1] and d2_abs[i] > d2_abs[i+1]:
