[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import A1
[?2004l[?2004h> 
[?2004l[?2004h> stolen = np.load('/app/stolen_A1.npy')
[?2004l[?2004h> print('Stolen shape:', stolen.shape)
[?2004l[?2004h> print('Actual A1 shape:', A1.shape)
[?2004l[?2004h> 
[?2004l[?2004h> # Normalize rows
[?2004l[?2004h> stolen_norm = stolen / (np.linalg.norm(stolen, axis=1, keepdims=True) + 1e-30)
[?2004l[?2004h> actual_norm = A1 / (np.linalg.norm(A1, axis=1, keepdims=True) + 1e-30)
[?2004l[?2004h> 
[?2004l[?2004h> # Correlation matrix
[?2004l[?2004h> corr = np.abs(stolen_norm @ actual_norm.T)
[?2004l[?2004h> print('\nBest match per stolen row:')
[?2004l[?2004h> used_actual = set()
[?2004l[?2004h> for i in range(stolen.shape[0]):
[?2004l[?2004h>     best_j = np.argmax(corr[i])
[?2004l[?2004h>     print(f'  Stolen {i} -> Actual {best_j}: {corr[i,best_j]:.6f}')
[?2004l[?2004h> 
[?2004l[?2004h> print('\nUnmatched actual rows:')
[?2004l[?2004h> matched = set(np.argmax(corr, axis=1))
[?2004l[?2004h> for j in range(A1.shape[0]):
[?2004l[?2004h>     if j not in matched:
[?2004l[?2004h>         print(f'  Actual row {j} unmatched')
[?2004l[?2004h> 
[?2004l[?2004h> high_conf = sum(1 for i in range(stolen.shape[0]) if np.max(corr[i]) > 0.99)
[?2004l[?2004h> print(f'\nHigh confidence rows (corr > 0.99): {high_conf}/{stolen.shape[0]}')
[?2004l[?2004h> 
[?2004l[?2004h> # Also compute best possible matching score
[?2004l[?2004h> from scipy.optimize import linear_sum_assignment
[?2004l[?2004h> # Use negative correlation as cost (since we want to maximize)
[?2004l[?2004h> cost = -corr
[?2004l[?2004h> row_ind, col_ind = linear_sum_assignment(cost)
[?2004l[?2004h> total_corr = -cost[row_ind, col_ind].sum()
[?2004l[?2004h> print(f'Total sum of best matches: {total_corr:.4f}')
[?2004l[?2004h> print(f'Average best match: {total_corr/stolen.shape[0]:.4f}')
