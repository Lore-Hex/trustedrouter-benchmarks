[?2004l[?2004h> #   invariant: t_i_j * Δ_i_j = -b1[i] * A2[i]  (constant per neuron!)
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, num_samples=5000, search_range=5.0):
[?2004l[?2004h>     """Find breakpoints along basis direction j using coarse-to-fine search."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     
[?2004l[?2004h>     # Step 1: Evaluate at many points
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     
[?2004l[?2004h>     # Step 2: Compute discrete second derivative (which should be zero except at breakpoints)
