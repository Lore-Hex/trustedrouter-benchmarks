[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Recover A1 by probing f(t*e_j) along basis directions
[?2004l[?2004h> # f(t*e_j) = sum_i A2[i] * ReLU(A1[i,j]*t + b1[i]) + b2
[?2004l[?2004h> # 
[?2004l[?2004h> # Breakpoint at t_i_j = -b1[i] / A1[i,j]
[?2004l[?2004h> # Slope change Δ_i_j = A2[i] * |A1[i,j]|
[?2004l[?2004h> # |t * Δ| = |b1[i] * A2[i]| (constant per neuron)
[?2004l[?2004h> # A1[i,j] ∝ -1/t_i_j
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=10000):
[?2004l[?2004h>     """Find breakpoints along basis direction j."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(changes)
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 1e-5
[?2004l[?2004h>     significant = np.where(abs_changes > threshold)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     breakpoints = []
[?2004l[?2004h>     i = 0
[?2004l[?2004h>     while i < len(significant):
[?2004l[?2004h>         idx = significant[i]
[?2004l[?2004h>         if idx + 1 < len(changes) and abs_changes[idx+1] > threshold and np.sign(changes[idx]) == np.sign(changes[idx+1]):
[?2004l[?2004h>             c0 = changes[idx]
[?2004l[?2004h>             c1 = changes[idx+1]
[?2004l[?2004h>             total_change = c0 + c1
[?2004l[?2004h>             if abs(total_change) > 1e-10:
[?2004l[?2004h>                 t_break = t_vals[idx+1] + dt * c0 / total_change
[?2004l[?2004h>                 delta = total_change
[?2004l[?2004h>                 breakpoints.append((t_break, delta))
[?2004l[?2004h>                 i += 2
[?2004l[?2004h>                 continue
[?2004l[?2004h>         i += 1
[?2004l[?2004h>     return breakpoints
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     # Collect breakpoints for all directions
[?2004l[?2004h>     all_breakpoints = []
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         for t, delta in bps:
[?2004l[?2004h>             all_breakpoints.append((j, t, delta))
[?2004l[?2004h>             print(f"    t={t:+.10f}, Δ={delta:+.10f}, |t*Δ|={abs(t*delta):.10f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal breakpoints: {len(all_breakpoints)}")
[?2004l[?2004h>     
