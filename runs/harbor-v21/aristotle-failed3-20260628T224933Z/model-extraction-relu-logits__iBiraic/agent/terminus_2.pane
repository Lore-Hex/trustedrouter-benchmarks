[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Recover A1 by probing f(t*e_j) along basis directions
[?2004l[?2004h> # Breakpoint at t_i_j = -b1[i] / A1[i,j]
[?2004l[?2004h> # Slope change Δ_i_j = A2[i] * A1[i,j]
[?2004l[?2004h> # Invariant: t_i_j * Δ_i_j = -b1[i] * A2[i] (constant per neuron)
[?2004l[?2004h> # So A1[i,j] = -b1[i] / t_i_j, thus A1[i,j] ∝ -1/t_i_j
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=5000):
[?2004l[?2004h>     """Find breakpoints along basis direction j."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     
[?2004l[?2004h>     # Evaluate forward
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     
[?2004l[?2004h>     # Forward differences (slope between consecutive points)
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     
[?2004l[?2004h>     # Differences of consecutive slopes (detects slope changes)
[?2004l[?2004h>     slope_changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(slope_changes)
[?2004l[?2004h>     
[?2004l     [?2004h>     # Find peaks in abs_changes
[?2004l[?2004h>     # Use adaptive threshold: find the largest changes
[?2004lta:+.8f[?2004h>     # Sort all abs_changes and look for a knee point
[?2004l[?2004h>     sorted_changes = np.sort(abs_changes)
[?2004l[?2004h>     
[?2004l     [?2004h>     # We expect at most 20 breakpoints per direction.
[?2004l[?2004h>     # Let's find the top K candidates where K is at most 25.
[?2004l1_[?2004h>     # Use a threshold that separates signal from noise.
[?2004l[?2004h>     # The typical noise level is the median of small changes.
[?2004l[?2004h>     # Real breakpoints should be outliers.
[?2004l[?2004h>     
[?2004l[?2004h>     # Use percentile-based threshold: find where values drop significantly
[?2004l[?2004h>     # by looking at the ratio of consecutive sorted values
[?2004l[?2004h>     if len(sorted_changes) > 10:
[?2004l[?2004h>         # Find the cutoff point
[?2004l[?2004h>         # Real signals have abs_changes > 0.001 typically
[?2004l[?2004h>         # Noise is much smaller
[?2004l[?2004h>         threshold = 0.0005  # Fixed threshold based on expected Δ magnitude
[?2004l[?2004h>     else:
[?2004l[?2004h>         threshold = 0.0
[?2004l[?2004h>     
[?2004l[?2004h>     candidates = []
[?2004l[?2004h>     for i in range(1, len(abs_changes) - 1):
[?2004l[?2004h>         if abs_changes[i] > threshold and abs_changes[i] >= abs_changes[i-1] and abs_changes[i] >= abs_changes[i+1]:
[?2004l[?2004h>             # Local maximum above threshold
[?2004l[?2004h>             # The breakpoint lies between t_vals[i+1] and t_vals[i+2]
[?2004l[?2004h>             # The center of the slope change is at i+1 in terms of intervals
[?2004l[?2004h>             # So the breakpoint is near t_vals[i+1]
[?2004l[?2004h>             t_approx = (t_vals[i+1] + t_vals[i+2]) / 2
[?2004l[?2004h>             delta_slope = slope_changes[i]
[?2004l[?2004h>             candidates.append((t_approx, delta_slope, abs_changes[i]))
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by magnitude of slope change (largest first)
[?2004l[?2004h>     candidates.sort(key=lambda x: -abs(x[1]))
[?2004l[?2004h>     
[?2004l[?2004h>     # Keep top candidates (at most 25, but should be ~20)
[?2004l[?2004h>     max_candidates = 25
[?2004l[?2004h>     candidates = candidates[:max_candidates]
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by t value
[?2004l[?2004h>     candidates.sort(key=lambda x: x[0])
[?2004l[?2004h>     
[?2004l[?2004h>     # Remove duplicates (points too close)
[?2004l[?2004h>     result = []
[?2004l[?2004h>     for bp in candidates:
[?2004l[?2004h>         t = bp[0]
[?2004l[?2004h>         if not result or abs(t - result[-1][0]) > 0.001:
[?2004l[?2004h>             result.append((bp[0], bp[1]))
[?2004l[?2004h>     
[?2004l[?2004h>     return result
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     all_breakpoints = []  # list of (direction, t, delta)
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         for t, delta in bps:
[?2004l[?2004h>             all_breakpoints.append((j, t, delta))
[?2004l[?2004h>             print(f"    t={t:+.8f}, Δ={delta:+.8f}, t*Δ={t*delta:+.8f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal breakpoints collected: {len(all_breakpoints)}")
[?2004l[?2004h>     
[?2004l[?2004h>     if len(all_breakpoints) < 20:
[?2004l[?2004h>         print("ERROR: Not enough breakpoints found.")
[?2004l[?2004h>         return None
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute invariants
[?2004l[?2004h>     bp_array = np.array([(j, t, delta, t*delta) for j, t, delta in all_breakpoints])
[?2004l[?2004h>     
[?2004l[?2004h>     # Cluster by t*delta value (constant per neuron)
[?2004l[?2004h>     invariants = bp_array[:, 3]
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by invariant
[?2004l[?2004h>     sorted_order = np.argsort(invariants)
[?2004l[?2004h>     sorted_bps = bp_array[sorted_order]
[?2004l[?2004h>     
[?2004l[?2004h>     # Greedy clustering with adaptive tolerance
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     current = [sorted_bps[0]]
[?2004l[?2004h>     
[?2004l[?2004h>     for k in range(1, len(sorted_bps)):
[?2004l[?2004h>         prev_val = sorted_bps[k-1, 3]
[?2004l[?2004h>         curr_val = sorted_bps[k, 3]
[?2004l[?2004h>         
[?2004l[?2004h>         abs_max = max(abs(prev_val), abs(curr_val))
[?2004l[?2004h>         tol = max(0.005 * abs_max, 1e-7)
[?2004l[?2004h>         
[?2004l[?2004h>         if abs(curr_val - prev_val) > tol:
[?2004l[?2004h>             clusters.append(current)
[?2004l[?2004h>             current = [sorted_bps[k]]
[?2004l[?2004h>         else:
[?2004l[?2004h>             current.append(sorted_bps[k])
[?2004l[?2004h>     
[?2004l[?2004h>     if len(current) > 0:
[?2004l[?2004h>         clusters.append(current)
[?2004l[?2004h>     
[?2004l[?2004h>     # Keep only clusters with at least 2 directions
[?2004l[?2004h>     clusters = [c for c in clusters if len(c) >= 2]
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nFound {len(clusters)} clusters (expecting 20 neurons)")
[?2004l[?2004h>     
[?2004l[?2004h>     # Build recovered A1
[?2004l[?2004h>     A1_recovered = np.zeros((len(clusters), 10))
[?2004l[?2004h>     
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         print(f"\nCluster {k} (size {len(cluster)}):")
[?2004l[?2004h>         row = np.zeros(10)
[?2004l[?2004h>         for bp in cluster:
[?2004l[?2004h>             j = int(bp[0])
[?2004l[?2004h>             t = bp[1]
[?2004l[?2004h>             delta = bp[2]
[?2004l[?2004h>             if abs(t) > 1e-10:
[?2004l[?2004h>                 # A1[i,j] ∝ -1/t
[?2004l[?2004h>                 row[j] = -1.0 / t
[?2004l[?2004h>                 print(f"  dir={j}, t={t:+.8f}, Δ={delta:+.8f}, val={-1.0/t:+.8f}")
[?2004l[?2004h>         
[?2004l[?2004h>         norm = np.linalg.norm(row)
[?2004l[?2004h>         if norm > 0:
[?2004l[?2004h>             row = row / norm
[?2004l[?2004h>         A1_recovered[k, :] = row
[?2004l[?2004h>     
[?2004l[?2004h>     return A1_recovered
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
[?2004l[?2004h>     A1_stolen = recover_A1()
[?2004l[?2004h>     if A1_stolen is not None and A1_stolen.shape[0] > 0:
[?2004l[?2004h>         np.save('/app/stolen_A1.npy', A1_stolen)
[?2004l[?2004h>         print(f"\nSaved stolen A1 to /app/stolen_A1.npy")
[?2004l[?2004h>         print(f"Shape: {A1_stolen.shape}")
[?2004l[?2004h>         print("Stolen A1 (rows normalized):")
[?2004l[?2004h>         np.set_printoptions(precision=6, suppress=True)
