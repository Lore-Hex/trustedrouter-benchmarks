[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> # Recover A1 by probing f(t*e_j) along basis directions
[?2004l[?2004h> 
[?2004l[?2004h> def find_breakpoints_1d(j, search_range=5.0, num_samples=20000):
[?2004l[?2004h>     """Find breakpoints along basis direction j with high resolution."""
[?2004l[?2004h>     e_j = np.zeros(10)
[?2004l[?2004h>     e_j[j] = 1.0
[?2004l[?2004h>     t_vals = np.linspace(-search_range, search_range, num_samples)
[?2004l[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l[?2004h>     forward_slopes = (f_vals[1:] - f_vals[:-1]) / dt
[?2004l[?2004h>     changes = np.diff(forward_slopes)
[?2004l[?2004h>     abs_changes = np.abs(changes)
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 1e-5
[?2004l[?2004h>     significant = np.where(abs_changes > threshold)[0]
[?2004l[?2004h>     
[?2004l[?2004h>     breakpoints = []
[?2004l[?2004h>     i = 0
[?2004l[?2004h>     while i < len(significant):
[?2004l[?2004h>         idx = significant[i]
[?2004l[?2004h>         if idx + 1 < len(changes) and abs_changes[idx+1] > threshold and np.sign(changes[idx]) == np.sign(changes[idx+1]):
[?2004l[?2004h>             c0 = changes[idx]
[?2004l[?2004h>             c1 = changes[idx+1]
[?2004l[?2004h>             total_change = c0 + c1
[?2004l[?2004h>             if abs(total_change) > 1e-10:
[?2004l[?2004h>                 t_break = t_vals[idx+1] + dt * c0 / total_change
[?2004l[?2004h>                 delta = total_change
[?2004l[?2004h>                 breakpoints.append((t_break, delta))
[?2004l[?2004h>                 i += 2
[?2004l[?2004h>                 continue
[?2004l[?2004h>         i += 1
[?2004l[?2004h>     return breakpoints
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def recover_A1():
[?2004l[?2004h>     """Recover A1 matrix using only forward() queries."""
[?2004l[?2004h>     
[?2004l[?2004h>     all_breakpoints = []
[?2004l[?2004h>     
[?2004l[?2004h>     for j in range(10):
[?2004l[?2004h>         print(f"Probing direction {j}...")
[?2004l[?2004h>         bps = find_breakpoints_1d(j)
[?2004l[?2004h>         print(f"  Found {len(bps)} breakpoints")
[?2004l[?2004h>         for t, delta in bps:
[?2004l[?2004h>             all_breakpoints.append((j, t, delta))
[?2004l[?2004h>             print(f"    t={t:+.8f}, Δ={delta:+.8f}, |t*Δ|={abs(t*delta):.8f}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nTotal breakpoints: {len(all_breakpoints)}")
[?2004l[?2004h>     
[?2004l[?2004h>     if len(all_breakpoints) < 20:
[?2004l[?2004h>         print("ERROR: Not enough breakpoints.")
[?2004l[?2004h>         return None
[?2004l[?2004h>     
[?2004l[?2004h>     # Build array with (direction, t, delta, |t*Δ|, -1/t)
[?2004l[?2004h>     bp_array = np.array([
[?2004l[?2004h>         (j, t, delta, abs(t*delta), -1.0/t if abs(t) > 1e-10 else 0.0)
[?2004l[?2004h>         for j, t, delta in all_breakpoints
[?2004l[?2004h>     ])
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by |t*Δ|
[?2004l[?2004h>     sorted_order = np.argsort(bp_array[:, 3])
[?2004l[?2004h>     sorted_bps = bp_array[sorted_order]
[?2004l[?2004h>     
[?2004l[?2004h>     print("\nSorted |t*Δ|:")
[?2004l[?2004h>     for bp in sorted_bps:
[?2004l[?2004h>         print(f"  dir={int(bp[0]):d}, |t*Δ|={bp[3]:.10f}, -1/t={bp[4]:+.8f}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Clustering: we expect ~20 clusters. Use the fact that the invariants
[?2004l[?2004h>     # should be close to multiples of some base values, but let's just use
[?2004l[?2004h>     # a simple threshold that separates clusters
[?2004l[?2004h>     
[?2004l[?2004h>     vals = sorted_bps[:, 3]
[?2004l[?2004h>     n = len(vals)
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute differences between consecutive sorted invariants
[?2004l[?2004h>     diffs = np.diff(vals)
[?2004l[?2004h>     
[?2004l[?2004h>     # Use a threshold of 10% of the value (since close neurons can differ by as little as 1.09x)
[?2004l[?2004h>     thresholds = np.maximum(0.08 * vals[:-1], 1e-6)
[?2004l[?2004h>     
[?2004l[?2004h>     # Find split points
[?2004l[?2004h>     split_indices = [0]
[?2004l[?2004h>     for i in range(len(diffs)):
[?2004l[?2004h>         if diffs[i] > thresholds[i]:
[?2004l[?2004h>             split_indices.append(i + 1)
[?2004l[?2004h>     split_indices.append(n)
[?2004l[?2004h>     
[?2004l[?2004h>     # Create clusters
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     for k in range(len(split_indices) - 1):
[?2004l[?2004h>         start, end = split_indices[k], split_indices[k+1]
[?2004l[?2004h>         if end - start >= 2:
[?2004l[?2004h>             clusters.append(sorted_bps[start:end])
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nFound {len(clusters)} clusters (expecting ~20)")
[?2004l[?2004h>     
[?2004l[?2004h>     # If we have too many or too few clusters, adjust threshold
[?2004l[?2004h>     if len(clusters) > 25:
[?2004l[?2004h>         # Increase threshold
[?2004l[?2004h>         print("Too many clusters, using larger threshold")
[?2004l[?2004h>         thresholds = np.maximum(0.15 * vals[:-1], 1e-5)
[?2004l[?2004h>         split_indices = [0]
[?2004l[?2004h>         for i in range(len(diffs)):
[?2004l[?2004h>             if diffs[i] > thresholds[i]:
[?2004l[?2004h>                 split_indices.append(i + 1)
[?2004l[?2004h>         split_indices.append(n)
[?2004l[?2004h>         clusters = []
[?2004l[?2004h>         for k in range(len(split_indices) - 1):
[?2004l[?2004h>             start, end = split_indices[k], split_indices[k+1]
[?2004l[?2004h>             if end - start >= 2:
[?2004l[?2004h>                 clusters.append(sorted_bps[start:end])
[?2004l[?2004h>         print(f"  After adjustment: {len(clusters)} clusters")
[?2004l[?2004h>     
[?2004l[?2004h>     # Build recovered A1
[?2004l[?2004h>     A1_recovered = np.zeros((len(clusters), 10))
[?2004l[?2004h>     
[?2004l[?2004h>     for k, cluster in enumerate(clusters):
[?2004l[?2004h>         print(f"\nCluster {k} (size {len(cluster)}):")
[?2004l[?2004h>         row = np.zeros(10)
[?2004l[?2004h>         for bp in cluster:
[?2004l[?2004h>             j = int(bp[0])
[?2004l[?2004h>             val = bp[4]
[?2004l[?2004h>             row[j] = val
[?2004l[?2004h>             print(f"  dir={j}, t={bp[1]:+.8f}, -1/t={val:+.8f}")
[?2004l[?2004h>         
[?2004l[?2004h>         norm = np.linalg.norm(row)
[?2004l[?2004h>         if norm > 0:
[?2004l[?2004h>             row = row / norm
[?2004l[?2004h>         A1_recovered[k, :] = row
[?2004l[?2004h>     
[?2004l[?2004h>     return A1_recovered
[?2004l[?2004h> 
