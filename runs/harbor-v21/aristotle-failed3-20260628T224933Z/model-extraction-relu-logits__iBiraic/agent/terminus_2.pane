[?2004l[?2004h> def find_breakpoints_1d(j):
[?2004len[?2004h>     """Find all breakpoints along basis direction j."""
[?2004l#[?2004h>     e_j = np.zeros(10)
[?2004lo[?2004h>     e_j[j] = 1.0
[?2004ln[?2004h>     
[?2004lding [?2004h>     # Step 1: Coarse scan to find approximate locations
[?2004l[?2004h>     # Use a wide range and enough points
[?2004l [?2004h>     t_vals = np.linspace(-5.0, 5.0, 20001)
[?2004l 1[?2004h>     f_vals = np.array([forward(e_j * t) for t in t_vals])
[?2004l   [?2004h>     
[?2004l  pri[?2004h>     dt = t_vals[1] - t_vals[0]
[?2004l[?2004h>     
[?2004lluste[?2004h>     # Compute slope (derivative) via central difference
[?2004l[?2004h>     slopes = np.zeros_like(f_vals)
