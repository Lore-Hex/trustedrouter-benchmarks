[?2004l[?2004h> b=open('/app/image.ppm','rb').read().split()
[?2004l[?2004h> w=int(b[1]); h=int(b[2])
[?2004l[?2004h> vals=list(map(int,b[4:]))
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3; return (vals[i],vals[i+1],vals[i+2])
[?2004l[?2004h> # Object: for each y, find left and right edges of non-sky/non-checker
[?2004l[?2004h> print('OBJECT EDGES')
[?2004l[?2004h> for y in range(830,1425,1):
[?2004l[?2004h>     left=w; right=-1; col=None
[?2004l[?2004h>     for x in range(0,w):
[?2004l[?2004h>         c=px(x,y)
[?2004l[?2004h>         is_sky = y<900 and c[2]==255
[?2004l[?2004h>         is_chk = c in [(67,67,67),(152,152,152)]
[?2004l[?2004h>         if not is_sky and not is_chk:
[?2004l[?2004h>             if x<left: left=x; col=c
[?2004l[?2004h>             if x>right: right=x
[?2004l[?2004h>     if right>=0:
[?2004l[?2004h>         print(y,left,right,col)
