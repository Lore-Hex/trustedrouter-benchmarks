[?2004hroot@93a3337995c6:/app# python3 - <<'PY'
[?2004l[?2004h> b=open('/app/image.ppm','rb').read().split()
[?2004l[?2004h> w=int(b[1]); h=int(b[2])
[?2004l[?2004h> vals=list(map(int,b[4:]))
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3; return (vals[i],vals[i+1],vals[i+2])
[?2004l[?2004h> # Object scan: for y=830..1430, print x ranges of non-checker/non-sky colors
[?2004l[?2004h> print('OBJECT vertical slices')
[?2004l[?2004h> for y in range(830,1431,5):
[?2004l[?2004h>     segs=[]
[?2004l[?2004h>     x=0
[?2004l[?2004h>     while x<w:
[?2004l[?2004h>         c=px(x,y)
[?2004l[?2004h>         if c not in [(67,67,67),(152,152,152)] or y<900:
[?2004l[?2004h>             # mark non-checker or sky
[?2004l[?2004h>             if y<900 and c[2]==255:
[?2004l[?2004h>                 x+=1; continue
[?2004l[?2004h>             s=x
[?2004l[?2004h>             while x<w and (px(x,y) not in [(67,67,67),(152,152,152)] or (y<900 and px(x,y)[2]!=255)):
[?2004l[?2004h>                 x+=1
[?2004l[?2004h>             segs.append((s,x-1,px(s,y)))
[?2004l[?2004h>         else:
[?2004l[?2004h>             x+=1
[?2004l[?2004h>     if segs:
[?2004l[?2004h>         print(y,[(s,e,c) for s,e,c in segs][:8])
[?2004l[?2004h> PY
