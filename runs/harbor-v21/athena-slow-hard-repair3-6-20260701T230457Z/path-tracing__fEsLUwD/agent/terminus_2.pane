[?2004hroot@93a3337995c6:/app# python3 - <<'PY'
[?2004l[?2004h> b=open('/app/image.ppm','rb').read().split()
[?2004l[?2004h> w=int(b[1]); h=int(b[2])
[?2004l[?2004h> vals=list(map(int,b[4:]))
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3; return (vals[i],vals[i+1],vals[i+2])
[?2004l[?2004h> # scan for dark red (51,10,10) and dark (20,20,20)/(46,46,46) bounding boxes
[?2004l[?2004h> objs={'red':(51,10,10),'dark':(20,20,20),'gray46':(46,46,46)}
[?2004l[?2004h> for name,col in objs.items():
[?2004l[?2004h>     pts=[]
[?2004l[?2004h>     for y in range(0,h,1):
[?2004l[?2004h>         for x in range(0,w,1):
[?2004l[?2004h>             if px(x,y)==col:
[?2004l[?2004h>                 pts.append((x,y))
[?2004l[?2004h>     if pts:
[?2004l[?2004h>         xs=[p[0] for p in pts]; ys=[p[1] for p in pts]
[?2004l[?2004h>         print(name,col,'count',len(pts),'x',min(xs),max(xs),'y',min(ys),max(ys))
[?2004l[?2004h>     else:
[?2004l[?2004h>         print(name,col,'none')
[?2004l[?2004h> PY
[?2004lred (51, 10, 10) count 87726 x 1016 1361 y 837 1177
dark (20, 20, 20) count 71402 x 491 1279 y 1151 1421
gray46 (46, 46, 46) count 51604 x 478 1265 y 1158 1411
