[?2004hroot@93a3337995c6:/app# python3 - <<'PY'
[?2004l[?2004h> import re,struct
[?2004l[?2004h> with open('/app/orig','rb') as f:
[?2004l[?2004h>     binb=f.read()
[?2004l[?2004h> rodata={}
[?2004l[?2004h> for off in range(0x3000,0x31b0,4):
[?2004l[?2004h>     val=struct.unpack('<f',binb[off:off+4])[0]
[?2004l[?2004h>     rodata[off]=val
[?2004l[?2004h> lines=open('/tmp/orig_intel.asm').read().split('\n')
[?2004l[?2004h> funcs={'sphere_intersect':(0x16c4,0x19e5),'plane_intersect':(0x19e5,0x1b4d),'sky_color':(0x1b4d,0x1c8d),'is_in_shadow':(0x1c8d,0x1d5c),'trace':(0x1d5c,0x2203),,'main':(0x2530,0x2c30)}
[?2004l[?2004h> for name,(s,e) in funcs.items():
[?2004l[?2004h>     out=[]
[?2004l[?2004h>     for l in lines:
[?2004l[?2004h>         m=re.match(r'\s*([0-9a-f]+):',l)
[?2004l[?2004h>         if not m or not (s<=int(m.group(1),16)<e): continue
[?2004l[?2004h>         m2=re.search(r'# ([0-9a-f]+)',l)
[?2004l[?2004h>         if m2:
[?2004l[?2004h>             addr=int(m2.group(1),16)
[?2004l[?2004h>             if addr in rodata:
[?2004l[?2004h>                 l=l+f'  ;; {rodata[addr]}'
[?2004l[?2004h>         out.append(l)
[?2004l[?2004h>     open(f'/tmp/{name}_fix.txt','w').write('\n'.join(out))
[?2004l[?2004h>     print(name,len(out))
[?2004l[?2004h> PY
