[?2004hroot@93a3337995c6:/app# python3 - <<'PY'
[?2004l[?2004h> b=open('/app/image.ppm','rb').read().split()
[?2004l[?2004h> w=int(b[1]); h=int(b[2])
[?2004l[?2004h> vals=list(map(int,b[4:]))
[?2004l[?2004h> def px(x,y):
[?2004l[?2004h>     i=(y*w+x)*3; return (vals[i],vals[i+1],vals[i+2])
[?2004l[?2004h> # Checkerboard: for each y from 900 to 1799, find tile size by counting color changes in x
[?2004l[?2004h> print('CHECKER tile analysis')
[?2004l[?2004h> for y in range(900,1800,10):
[?2004l[?2004h>     changes=0
[?2004l[?2004h>     first=px(0,y)[0]
[?2004l[?2004h>     cur=first
[?2004l[?2004h>     for x in range(1,w):
[?2004l[?2004h>         v=px(x,y)[0]
[?2004l[?2004h>         if v!=cur:
[?2004l[?2004h>             changes+=1; cur=v
[?2004l[?2004h>     # tile size ~ w/(changes+1)
[?2004l[?2004h>     print(y,first,changes,w//(changes+1) if changes>0 else w,px(0,y),px(w//2,y))
[?2004l[?2004h> PY
