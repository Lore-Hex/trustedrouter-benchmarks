Sending keys: ['cat > /app/image.c <<\'EOF\'\n#include <stdio.h>\n#include <math.h>\ntypedef struct{float x,y,z;}V;\nV v3(float a,float b,float c){V v={a,b,c};return v;}\nV add(V a,V b){return v3(a.x+b.x,a.y+b.y,a.z+b.z);}\nV sub(V a,V b){return v3(a.x-b.x,a.y-b.y,a.z-b.z);}\nV mul(V a,float s){return v3(a.x*s,a.y*s,a.z*s);}\nfloat dot(V a,V b){return a.x*b.x+a.y*b.y+a.z*b.z;}\nV nrm(V a){return mul(a,1.f/sqrtf(dot(a,a)));}\nint sp(V o,V d,V c,float r,float*t,V*p,V*n){\n V oc=sub(o,c);float a=dot(d,d),b=2*dot(oc,d),e=dot(oc,oc)-r*r,ds=b*b-4*a*e;\n if(ds<=0)return 0;float sq=sqrtf(ds),t1=(-b-sq)/(2*a);\n if(t1>=0.001f){*t=t1;*p=add(o,mul(d,t1));*n=nrm(sub(*p,c));return 1;}\n float t2=(-b+sq)/(2*a);\n if(t2>=0.001f){*t=t2;*p=add(o,mul(d,t2));*n=nrm(sub(*p,c));return 1;}\n return 0;\n}\nint shd(V o,V d,V c,float r){\n V oc=sub(o,c);float a=dot(d,d),b=2*dot(oc,d),e=dot(oc,oc)-r*r,ds=b*b-4*a*e;\n if(ds<=0)return 0;float sq=sqrtf(ds),t1=(-b-sq)/(2*a);\n if(t1>=0.001f)return 1;float t2=(-b+sq)/(2*a);return t2>=0.001f;\n}\nint main(){\n int W=2400,H=1800,i,j;\n V o={0,0,0},sc={0,-0.5f,-5};float sr=1,vh=2,vw=2.f*W/H;\n V h={vw,0,0},v={0,vh,0},ll={-vw/2,-vh/2,-1};\n V ld=nrm(v3(1,1,-1));float py=-1.5f;\n FILE*f=fopen("reconstructed.ppm","w");\n fprintf(f,"P3\\n%d %d\\n255\\n",W,H);\n for(i=0;i<H;i++)for(j=0;j<W;j++){\n  float u=(float)j/(W-1),vv=(float)i/(H-1);\n  V d=nrm(add(add(ll,mul(h,u)),mul(v,1-vv)));\n  float st,pt;V spp,sn,pp,pn;int s,ph=0;\n  s=sp(o,d,sc,sr,&st,&spp,&sn);\n  if(fabsf(d.y)<1.f){float t=(py-o.y)/d.y;if(t>=0.001f){ph=1;pt=t;pp=add(o,mul(d,t));pn=v3(0,1,0);}}\n  V cl;\n  if(s&&(!ph||st<=pt)){\n   V so=add(spp,mul(sn,0.001f));\n   int sh=shd(so,ld,sc,sr);\n   float it=fmaxf(0,dot(sn,ld));if(sh)it=0;\n   cl=mul(v3(1,0.2f,0.2f),0.2f+0.8f*it);\n  }else if(ph){\n   V so=add(pp,mul(pn,0.001f));\n   int sh=shd(so,ld,sc,sr);\n   float it=fmaxf(0,dot(pn,ld));if(sh)it=0;\n   int ck=((int)floorf(pp.x)+(int)floorf(pp.z))&1;\n   cl=mul(ck==0?v3(0.9f,0.9f,0.9f):v3(0.4f,0.4f,0.4f),0.2f+0.8f*it);\n  }else{\n   float t=0.5f*(d.y+1);\n   cl=add(mul(v3(1,1,1),1-t),mul(v3(0.5f,0.7f,1),t));\n  }\n  fprintf(f,"%d %d %d\\n",(int)(cl.x*255.99f),(int)(cl.y*255.99f),(int)(cl.z*255.99f));\n }\n fclose(f);\n return 0;\n}\nEOF\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
