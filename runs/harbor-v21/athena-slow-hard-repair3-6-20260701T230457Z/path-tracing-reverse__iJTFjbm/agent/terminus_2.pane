[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { float x,y,z; } Vec;
[?2004l[?2004h> 
[?2004l[?2004h> static Vec vadd(Vec a, Vec b){return (Vec){a.x+b.x,a.y+b.y,a.z+b.z};}
[?2004l[?2004h> static Vec vsub(Vec a, Vec b){return (Vec){a.x-b.x,a.y-b.y,a.z-b.z};}
[?2004l[?2004h> static Vec vmul(Vec a, float s){return (Vec){a.x*s,a.y*s,a.z*s};}
[?2004l[?2004h> static float vdot(Vec a, Vec b){return a.x*b.x+a.y*b.y+a.z*b.z;}
[?2004l[?2004h> static Vec vnorm(Vec a){float l=sqrtf(vdot(a,a));return (Vec){a.x/l,a.y/l,a.z/l};}
[?2004l[?2004h> static Vec vneg(Vec a){return (Vec){-a.x,-a.y,-a.z};}
[?2004l[?2004h> 
[?2004l[?2004h> int sphere_hit(Vec ro, Vec rd, Vec c, float r, float *t){
[?2004l[?2004h>     Vec oc=vsub(ro,c);
[?2004l[?2004h>     float b=vdot(oc,rd), cc=vdot(oc,oc)-r*r, d=b*b-cc;
[?2004l[?2004h>     if(d<0) return 0;
[?2004l[?2004h>     float s=sqrtf(d), t0=-b-s;
[?2004l[?2004h>     if(t0<0.001f) t0=-b+s;
[?2004l[?2004h>     if(t0<0.001f) return 0;
[?2004l[?2004h>     *t=t0; return 1;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> int main(){
[?2004l[?2004h>     int W=800,H=600;
[?2004l[?2004h>     fprintf(stderr,"Creating high-resolution image: %dx%d\n",W,H);
[?2004l[?2004h>     fputs("This will be downsampled with ffmpeg after rendering",stderr);
[?2004l[?2004h>     Vec ldir=vnorm((Vec){1,1,-1});
[?2004l[?2004h>     Vec sc=(Vec){0,-0.5f,-5}; float sr=1.0f;
[?2004l[?2004h>     float *img=malloc(W*H*3*sizeof(float));
[?2004l[?2004h>     fputs("Rendering high-resolution image...",stderr);
[?2004l[?2004h>     for(int j=0;j<H;j++){
[?2004l[?2004h>         fprintf(stderr,"Progress: %.1f%%\n",(float)j*100.0f/H);
[?2004l[?2004h>         for(int i=0;i<W;i++){
[?2004l[?2004h>             float u=(float)i/799.0f*8.0f/3.0f-4.0f/3.0f;
[?2004l[?2004h>             float v=2.0f*(1.0f-(float)j/599.0f)-1.0f;
[?2004l[?2004h>             Vec rd=vnorm((Vec){u,v,-1});
[?2004l[?2004h>             Vec ro=(Vec){0,0,0};
[?2004l[?2004h>             float t;
[?2004l[?2004h>             Vec col;
[?2004l[?2004h>             if(sphere_hit(ro,rd,sc,sr,&t)){
[?2004l[?2004h>                 Vec p=vadd(ro,vmul(rd,t));
[?2004l[?2004h>                 Vec n=vnorm(vsub(p,sc));
[?2004l[?2004h>                 float diff=fmaxf(0.0f,vdot(n,ldir));
[?2004l[?2004h>                 // shadow check
[?2004l[?2004h>                 Vec so=vadd(p,vmul(n,0.001f));
[?2004l[?2004h>                 float st;
[?2004l[?2004h>                 int in_shadow=sphere_hit(so,ldir,sc,sr,&st);
[?2004l[?2004h>                 if(in_shadow) diff=0;
[?2004l[?2004h>                 float amb=0.2f, dif=0.8f;
[?2004l[?2004h>                 float intensity=amb+dif*diff;
[?2004l[?2004h>                 col=(Vec){intensity*1.0f,intensity*0.2f,intensity*0.2f};
[?2004l[?2004h>             } else {
[?2004l[?2004h>                 // check plane y=-1.5
[?2004l[?2004h>                 if(fabsf(rd.y)>0.0001f){
[?2004l[?2004h>                     float tp=(-1.5f-ro.y)/rd.y;
[?2004l[?2004h>                     if(tp>0.001f){
[?2004l[?2004h>                         Vec p=vadd(ro,vmul(rd,tp));
[?2004l[?2004h>                         // checkerboard
[?2004l[?2004h>                         int c=(int)(p.x+p.z);
[?2004l[?2004h>                         float cv=(c%2==0)?0.9f:0.4f;
[?2004l[?2004h>                         Vec n=(Vec){0,1,0};
[?2004l[?2004h>                         float diff=fmaxf(0.0f,vdot(n,ldir));
[?2004l[?2004h>                         Vec so=vadd(p,vmul(n,0.001f));
[?2004l[?2004h>                         float st;
[?2004l[?2004h>                         if(sphere_hit(so,ldir,sc,sr,&st)) diff=0;
[?2004l[?2004h>                         float intensity=0.2f+0.8f*diff;
[?2004l[?2004h>                         col=(Vec){intensity*cv,intensity*cv,intensity*cv};
[?2004l[?2004h>                     } else {
[?2004l[?2004h>                         // sky
[?2004l[?2004h>                         float t2=0.5f*(rd.y+1.0f);
[?2004l[?2004h>                         col=(Vec){(1.0f-t2)*1.0f+t2*0.5f,(1.0f-t2)*1.0f+t2*0.7f,1.0f};
[?2004l[?2004h>                     }
[?2004l[?2004h>                 } else {
[?2004l[?2004h>                     // sky
[?2004l[?2004h>                     float t2=0.5f*(rd.y+1.0f);
[?2004l[?2004h>                     col=(Vec){(1.0f-t2)*1.0f+t2*0.5f,(1.0f-t2)*1.0f+t2*0.7f,1.0f};
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             img[(j*W+i)*3+0]=col.x;
[?2004l[?2004h>             img[(j*W+i)*3+1]=col.y;
[?2004l[?2004h>             img[(j*W+i)*3+2]=col.z;
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fputs("Rendering complete\n",stderr);
[?2004l[?2004h>     FILE *f=fopen("image.ppm","w");
[?2004l[?2004h>     if(!f){fprintf(stderr,"Error: Could not open file %s for writing\n","image.ppm");return 1;}
[?2004l[?2004h>     fprintf(f,"P3\n%d %d\n255\n",W,H);
[?2004l[?2004h>     for(int j=0;j<H;j++){
[?2004l[?2004h>         for(int i=0;i<W;i++){
[?2004l[?2004h>             int r=(int)(img[(j*W+i)*3+0]*255.99f);
[?2004l[?2004h>             int g=(int)(img[(j*W+i)*3+1]*255.99f);
[?2004l[?2004h>             int b=(int)(img[(j*W+i)*3+2]*255.99f);
[?2004l[?2004h>             fprintf(f,"%d %d %d\n",r,g,b);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     fprintf(stderr,"Wrote image to image.ppm\nDone.\n");
[?2004l[?2004h>     free(img);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
