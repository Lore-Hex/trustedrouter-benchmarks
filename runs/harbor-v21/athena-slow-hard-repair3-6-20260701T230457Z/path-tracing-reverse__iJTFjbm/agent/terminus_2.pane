[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> typedef struct{float x,y,z;}Vec;
[?2004l[?2004h> static float ss(float x){float r;__asm__("sqrtss %1,%0":"=x"(r):"x"(x));return r;}
[?2004l[?2004h> static Vec va(Vec a,Vec b){return(Vec){a.x+b.x,a.y+b.y,a.z+b.z};}
[?2004l[?2004h> static Vec vs(Vec a,Vec b){return(Vec){a.x-b.x,a.y-b.y,a.z-b.z};}
[?2004l[?2004h> static Vec vm(Vec a,float s){return(Vec){a.x*s,a.y*s,a.z*s};}
[?2004l[?2004h> static float vd(Vec a,Vec b){return a.x*b.x+a.y*b.y+a.z*b.z;}
[?2004l[?2004h> static Vec vn(Vec a){float l=ss(vd(a,a));return(Vec){a.x/l,a.y/l,a.z/l};}
[?2004l[?2004h> static Vec vrn(Vec a){float l=ss((a.z*a.z+a.y*a.y)+a.x*a.x);return(Vec){a.x/l,a.y/l,a.z/l};}
[?2004l[?2004h> int sh(Vec ro,Vec rd,Vec c,float r,float*t){
