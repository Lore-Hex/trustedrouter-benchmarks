 = (x - 1200) / 1200.0\n    dy = y / 900.0\n    pred_r = 146 + 13*dx*dx + 45*dy\n    pred_g = 190 + 7*dx*dx + 27*dy\n    print(f"({x},{y}): actual=({r},{g},{b}), pred=({pred_r:.0f},{pred_g:.0f},255)")\nEOF\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
