[0]*dir_local_n[0] + cy[0]*dir_local_n[1] + cz[0]*dir_local_n[2],\n    cx[1]*dir_local_n[0] + cy[1]*dir_local_n[1] + cz[1]*dir_local_n[2],\n    cx[2]*dir_local_n[0] + cy[2]*dir_local_n[1] + cz[2]*dir_local_n[2]\n)\nprint(f"  world dir: {dir_world}")\n# Dot with up (0,1,0) = dir_world.y\ndot_up = dir_world[1]\nprint(f"  dot with up: {dot_up:.4f}")\n# Actual colors at (0,0)\ni = 0\nprint(f"  actual RGB: ({p[i]},{p[i+1]},{p[i+2]})")\n\n# At (1200,0):\nu = (1200 - w/2) / (w/2) * (w/h)\nv = -(0 - h/2) / (h/2)\ndir_local = (u, v, -1.0)\nlen_d = math.sqrt(dir_local[0]**2 + dir_local[1]**2 + dir_local[2]**2)\ndir_local_n = (dir_local[0]/len_d, dir_local[1]/len_d, dir_local[2]/len_d)\ndir_world = (\n    cx[0]*dir_local_n[0] + cy[0]*dir_local_n[1] + cz[0]*dir_local_n[2],\n    cx[1]*dir_local_n[0] + cy[1]*dir_local_n[1] + cz[1]*dir_local_n[2],\n    cx[2]*dir_local_n[0] + cy[2]*dir_local_n[1] + cz[2]*dir_local_n[2]\n)\ndot_up = dir_world[1]\nprint(f"\\nAt (1200,0):")\nprint(f"  dot with up: {dot_up:.4f}")\ni = (0*w+1200)*3\nprint(f"  actual RGB: ({p[i]},{p[i+1]},{p[i+2]})")\n\n# At (0,899) just before horizon:\nu = (0 - w/2) / (w/2) * (w/h)\nv = -(899 - h/2) / (h/2)\ndir_local = (u, v, -1.0)\nlen_d = math.sqrt(dir_local[0]**2 + dir_local[1]**2 + dir_local[2]**2)\ndir_local_n = (dir_local[0]/len_d, dir_local[1]/len_d, dir_local[2]/len_d)\ndir_world = (\n    cx[0]*dir_local_n[0] + cy[0]*dir_local_n[1] + cz[0]*dir_local_n[2],\n    cx[1]*dir_local_n[0] + cy[1]*dir_local_n[1] + cz[1]*dir_local_n[2],\n    cx[2]*dir_local_n[0] + cy[2]*dir_local_n[1] + cz[2]*dir_local_n[2]\n)\ndot_up = dir_world[1]\nprint(f"\\nAt (0,899):")\nprint(f"  dot with up: {dot_up:.4f}")\ni = (899*w+0)*3\nprint(f"  actual RGB: ({p[i]},{p[i+1]},{p[i+2]})")\nEOF\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
