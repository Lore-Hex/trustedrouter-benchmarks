Sending keys: ['cd /app && python3 -c "\nimport math\n\n# Let\'s check if the floor pattern could be generated with a different formula\n# instead of (floor(X*freq) + floor(Z*freq)) & 1\n\nwith open(\'/app/image.ppm\') as f:\n    next(f); wh=next(f).split(); w,h=int(wh[0]),int(wh[1]); next(f)\n    ref = list(map(int, f.read().split()))\n\nfov=900.0; d=1.5; freq=1.0\n\n# Test different formulas\nformulas = [\n    (\'ADD\', lambda ix, iz, inv: (ix + iz + inv) & 1),\n    (\'XOR\', lambda ix, iz, inv: (ix ^ iz + inv) & 1),\n    (\'IX_ONLY\', lambda ix, iz, inv: (ix + inv) & 1),\n    (\'IZ_ONLY\', lambda ix, iz, inv: (iz + inv) & 1),\n    (\'IX_IZ_ADD\', lambda ix, iz, inv: (ix + iz) & 1),\n]\n\nfor name, formula in formulas:\n    best = 0\n    best_p = None\n    for xoff in [-1.0, -0.5, 0, 0.5, 1.0]:\n        for zoff in [-1.0, -0.5, 0, 0.5, 1.0]:\n            for inv in [0, 1]:\n                m = t = 0\n                for y in range(910, 1400, 30):\n                    dy = -(y - 900) / fov\n                    if dy >= 0: continue\n                    Z = d / (-dy)\n                    for x in range(0, 1000, 30):\n                        i = (y*w + x)*3\n                        r = ref[i]\n                        if r not in (67, 152): continue\n                        actual = 1 if r == 152 else 0\n                        X = (x - 1200) * Z / fov\n                        ix = int(math.floor(X * freq + xoff))\n                        iz = int(math.floor(Z * freq + zoff))\n                        pred = formula(ix, iz, inv)\n                        if pred == actual: m += 1\n                        t += 1\n                acc = m / t if t > 0 else 0\n                if acc > best:\n                    best = acc\n                    best_p = (xoff, zoff, inv)\n    print(f\'{name}: best={100*best:.2f}% with xoff={best_p[0]}, zoff={best_p[1]}, inv={best_p[2]}\')\n"\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
