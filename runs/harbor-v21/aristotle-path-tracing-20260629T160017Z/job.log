d = (ix + iz + inv) & 1\n            \n            if pred == actual:\n                matches += 1\n            total += 1\n    \n    return matches / total if total > 0 else 0\n\nprint("Testing various floor formulas...")\nbest = 0\nbest_p = None\n\n# Test d values around 0.75 and 1.5\nfor d in [i/100.0 for i in range(50, 200)]:\n    for T in [i/100.0 for i in range(20, 150)]:  # tile size\n        freq = 1.0 / T\n        # We know d * freq should be around 1.5\n        for xoff in [-0.5, -0.25, 0, 0.25, 0.5]:\n            for zoff in [-0.5, -0.25, 0, 0.25, 0.5]:\n                for inv in [0, 1]:\n                    acc = test_floor(d, T, xoff, zoff, inv)\n                    if acc > best:\n                        best = acc\n                        best_p = (d, T, freq, xoff, zoff, inv)\n                        if best > 0.95:\n                            print(f"Found: d={d:.2f}, T={T:.2f}, freq={freq:.2f}, xoff={xoff:.2f}, zoff={zoff:.2f}, inv={inv}: {100*acc:.2f}%")\n\nif best_p:\n    print(f"\\nBest: d={best_p[0]:.2f}, T={best_p[1]:.2f}, freq={best_p[2]:.2f}, xoff={best_p[3]:.2f}, zoff={best_p[4]:.2f}, inv={best_p[5]}: {100*best:.2f}%")\nEOF\n'] min_timeout_sec: 30.0 max_timeout_sec: 180.0
