tion\n            Vec oc = sub(cam, sp);\n            double a = dot(wdir, wdir);\n            double bb = 2 * dot(oc, wdir);\n            double c = dot(oc, oc) - sr * sr;\n            double disc = bb*bb - 4*a*c;\n            \n            if (disc > 0) {\n                double t = (-bb - sqrt(disc)) / (2 * a);\n                if (t > 0.001) {\n                    Vec pt = add(cam, mul(wdir, t));\n                    Vec n = norm(sub(pt, sp));\n                    Vec L = norm(sub(lp, pt));\n                    double diff = dot(n, L);\n                    if (diff < 0) diff = 0;\n                    \n                    Vec V = mul(wdir, -1);\n                    Vec Hv = norm(add(L, V));\n                    double spec = dot(n, Hv);\n                    if (spec < 0) spec = 0;\n                    spec = pow(spec, 20);\n                    \n                    r = clamp(sc.x * (0.2 + 0.8 * diff) * 255 + spec * 200);\n                    g = clamp(sc.y * (0.2 + 0.8 * diff) * 255 + spec * 40);\n                    b = clamp(sc.z * (0.2 + 0.8 * diff) * 255 + spec * 40);\n                    hit = 1;\n                }\n            }\n            \n            if (!hit && wdir.y < 0) {\n                // Ground plane\n                double t = -(cam.y - ground_y) / wdir.y;\n                if (t > 0) {\n                    Vec pt = add(cam, mul(wdir, t));\n                    \n                    // Checkerboard\n                    int ix = (int)(floor(pt.x * 2.0));\n                    int iz = (int)(floor(pt.z * 2.0));\n                    double col = ((ix + iz) & 1) ? 152.0 : 67.0;\n                    \n                    // Shadow\n                    Vec L = norm(sub(lp, pt));\n                    Vec oc2 = sub(pt, sp);\n                    double sa = dot(L, L);\n                    double sb = 2 * dot(oc2, L);\n                    double sc_ = dot(oc2, oc2) - sr * sr;\n                    double sd = sb*sb - 4*sa*sc_;\n                    if (sd >