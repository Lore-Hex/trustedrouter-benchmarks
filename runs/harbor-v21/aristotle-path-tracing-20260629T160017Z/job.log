ation:")\n    for px, py, expected_color in test_points:\n        dy = -(py - 900) / fov\n        Z = d / (-dy)\n        X = (px - 1200) * Z / fov\n        ix = int(math.floor(X * freq + best_p[0]))\n        iz = int(math.floor(Z * freq + best_p[1]))\n        pred = (ix + iz + best_p[2]) & 1\n        pred_color = 152 if pred else 67\n        match = "OK" if pred_color == expected_color else "FAIL"\n        print(f"  ({px},{py}): expected={\'W\' if expected_color==152 else \'B\'}, pred={\'W\' if pred_color==152 else \'B\'} {match}")\nEOF\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
