 + dz0*dz0)\nndx, ndy, ndz = dx0/n0, dy0/n0, dz0/n0\n\n# Tangent condition: (dot(oc, dir))^2 - dot(oc, oc) + R^2 = 0\ndot_oc_dir = oc_x*ndx + oc_y*ndy + oc_z*ndz\ndisc = dot_oc_dir**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\nprint(f"\\nTangent condition at top: disc = {disc:.6f} (should be 0)")\n\n# Let\'s find the correct Zs by solving the tangent equation\n# We\'ll search for Zs that makes disc = 0\nprint("\\nSearching for correct Zs...")\nbest_z = None\nbest_err = 1e10\nfor z in [i/1000.0 for i in range(-8000, -1000)]:\n    Zs = z / 1.0\n    Xs = 21 * Zs / fov\n    Ys = H - 47 * Zs / fov\n    R = 138 * (-Zs) / fov\n    \n    oc_x = Xs\n    oc_y = Ys - H\n    oc_z = Zs\n    dx0, dy0, dz0 = 0, -(809 - 900)/fov, -1\n    n0 = math.sqrt(dx0*dx0 + dy0*dy0 + dz0*dz0)\n    ndx, ndy, ndz = dx0/n0, dy0/n0, dz0/n0\n    dot_oc_dir = oc_x*ndx + oc_y*ndy + oc_z*ndz\n    disc = dot_oc_dir**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\n    \n    if abs(disc) < best_err:\n        best_err = abs(disc)\n        best_z = (Zs, Xs, Ys, R, disc)\n\nprint(f"Best: Zs={best_z[0]:.6f}, Xs={best_z[1]:.6f}, Ys={best_z[2]:.6f}, R={best_z[3]:.6f}")\nprint(f"  disc = {best_z[4]:.10f}")\n\n# Check left edge tangent with these parameters\nZs, Xs, Ys, R = best_z[0], best_z[1], best_z[2], best_z[3]\noc_x = Xs\noc_y = Ys - H\noc_z = Zs\n\n# Left edge (1041, 900)\ndx1, dy1, dz1 = (1041 - 1200)/fov, 0, -1\nn1 = math.sqrt(dx1*dx1 + dy1*dy1 + dz1*dz1)\nndx1, ndy1, ndz1 = dx1/n1, dy1/n1, dz1/n1\ndot_oc_dir1 = oc_x*ndx1 + oc_y*ndy1 + oc_z*ndz1\ndisc_left = dot_oc_dir1**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\nprint(f"Left edge tangent disc = {disc_left:.6f} (should be 0)")\n\n# Right edge (1317, 900)\ndx2, dy2, dz2 = (1317 - 1200)/fov, 0, -1\nn2 = math.sqrt(dx2*dx2 + dy2*dy2 + dz2*dz2)\nndx2, ndy2, ndz2 = dx2/n2, dy2/n2, dz2/n2\ndot_oc_dir2 = oc_x*ndx2 + oc_y*ndy2 + oc_z*ndz2\ndisc_right = dot_oc_dir2**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\nprint(f"Right edge tangent disc = {disc_right:.6f} (should be 0)")