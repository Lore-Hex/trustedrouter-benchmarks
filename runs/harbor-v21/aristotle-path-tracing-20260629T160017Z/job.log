  best_params = (Xs, Ys, Zs, R, disc_top, disc_left, disc_right)\n\nprint(f"\\nBest parameters:")\nprint(f"  Xs = {best_params[0]:.6f}")\nprint(f"  Ys = {best_params[1]:.6f}")\nprint(f"  Zs = {best_params[2]:.6f}")\nprint(f"  R  = {best_params[3]:.6f}")\nprint(f"  disc_top   = {best_params[4]:.6f}")\nprint(f"  disc_left  = {best_params[5]:.6f}")\nprint(f"  disc_right = {best_params[6]:.6f}")\n\n# Now refine around the best\nXs_b, Ys_b, Zs_b, R_b = best_params[0], best_params[1], best_params[2], best_params[3]\n\nbest_err2 = 1e10\nbest2 = None\n\nfor Xs in [Xs_b + i/10000.0 for i in range(-50, 50)]:\n    for Ys in [Ys_b + i/10000.0 for i in range(-50, 50)]:\n        for Zs in [Zs_b + i/10000.0 for i in range(-50, 50)]:\n            for R in [R_b + i/10000.0 for i in range(-50, 50)]:\n                oc_x = Xs\n                oc_y = Ys - H\n                oc_z = Zs\n                \n                dot_top = oc_x*t_dx + oc_y*t_dy + oc_z*t_dz\n                disc_top = dot_top**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\n                \n                dot_left = oc_x*l_dx + oc_y*l_dy + oc_z*l_dz\n                disc_left = dot_left**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\n                \n                dot_right = oc_x*r_dx + oc_y*r_dy + oc_z*r_dz\n                disc_right = dot_right**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2\n                \n                err = abs(disc_top) + abs(disc_left) + abs(disc_right)\n                if err < best_err2:\n                    best_err2 = err\n                    best2 = (Xs, Ys, Zs, R, disc_top, disc_left, disc_right)\n\nprint(f"\\nRefined parameters:")\nprint(f"  Xs = {best2[0]:.6f}")\nprint(f"  Ys = {best2[1]:.6f}")\nprint(f"  Zs = {best2[2]:.6f}")\nprint(f"  R  = {best2[3]:.6f}")\nprint(f"  disc_top   = {best2[4]:.10f}")\nprint(f"  disc_left  = {best2[5]:.10f}")\nprint(f"  disc_right = {best2[6]:.10f}")\n\n# Also predict the screen-space positions\nXs, Ys, Zs, R = best2[0], best2[1], best2[2], best2[3]\n# Center projection\nx_center = 1200 + fov * Xs / (-Zs)\ny_center = 900 + fov * (Ys - H) / (-Zs)\napp_R = fov * R / (-Zs)\nprint(f"\\nProjected center: ({x_center:.1f}, {y_center:.1f})")\nprint(f"Apparent radius: {app_R:.1f}")\nprint(f"Top: y={y_center - app_R:.1f} (expected 809)")\nprint(f"Left: x={x_center - app_R:.1f} (expected 1041)")\nprint(f"Right: x={x_center + app_R:.1f} (expected 1317)")\nEOF\n'] min_timeout_sec: 30.0 max_timeout_sec: 180.0
