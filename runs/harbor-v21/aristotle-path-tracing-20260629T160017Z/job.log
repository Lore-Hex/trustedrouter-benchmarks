              double diff = dot(n, L);\n                    if (diff < 0) diff = 0;\n                    \n                    Vec V = mul(dir, -1);\n                    Vec Hv = norm(add(L, V));\n                    double spec = dot(n, Hv);\n                    if (spec < 0) spec = 0;\n                    spec = pow(spec, 20);\n                    \n                    // Red sphere\n                    r = clamp((0.2 + 0.8 * diff) * 255 + spec * 200);\n                    g = clamp((0.2 + 0.8 * diff) * 51 + spec * 40);\n                    b = clamp((0.2 + 0.8 * diff) * 51 + spec * 40);\n                    hit = 1;\n                }\n            }\n            \n            if (!hit && dir.y < 0) {\n                // Ground plane at y = -0.5 (below camera)\n                double t = -(cam_y - (-0.5)) / dir.y;\n                if (t > 0) {\n                    Vec pt = add(v(0, cam_y, 0), mul(dir, t));\n                    int ix = (int)(floor(pt.x * 2.0) + 1000);\n                    int iz = (int)(floor(pt.z * 2.0) + 1000);\n                    double col = ((ix + iz) & 1) ? 152.0 : 67.0;\n                    \n                    // Simple shadow\n                    Vec L = norm(sub(lp, pt));\n                    Vec oc2 = sub(pt, sp);\n                    double sa = dot(L, L);\n                    double sb = 2 * dot(oc2, L);\n                    double sc = dot(oc2, oc2) - sr * sr;\n                    double sd = sb*sb - 4*sa*sc;\n                    if (sd > 0) {\n                        double st = (-sb - sqrt(sd)) / (2 * sa);\n                        if (st > 0.001) col *= 0.4;\n                    }\n                    \n                    r = g = b = clamp(col);\n                    hit = 1;\n                }\n            }\n            \n            if (!hit) {\n                // Sky\n                double ndy = dir.y;\n                double max_ndy = 0.7071067811865475;  // ndy at top center\n                if (ndy > max_ndy) ndy = max_ndy;\n                if (ndy < 0) ndy = 0;\n                double t = ndy / max_ndy;\n                r = clamp(191 - 45 * t);\n                g = clamp(217 - 27 * t);\n                b = 255;\n            }\n            \n            fprintf(f, "%d %d %d\\n", (int)r, (int)g, (int)b);\n        }\n    }\n    \n    fclose(f);\n    return 0;\n}\nENDCODE\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
