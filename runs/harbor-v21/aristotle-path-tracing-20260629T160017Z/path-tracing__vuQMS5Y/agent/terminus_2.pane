[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check the actual sphere position by looking at the center of the sphere
[?2004l[?2004h> # The sphere's center (in screen coordinates) can be found by finding the point
[?2004l[?2004h> # where the sphere's width is maximum (at the equator)
[?2004l[?2004h> 
[?2004l[?2004h> print("Finding sphere center from silhouette...")
[?2004l[?2004h> max_width = 0
[?2004l[?2004h> max_y = 0
[?2004l[?2004h> center_x_at_max = 0
[?2004l[?2004h> 
[?2004l[?2004h> for y in range(800, 1300):
[?2004l[?2004h>     left = None
[?2004l[?2004h>     right = None
[?2004l[?2004h>     for x in range(1000, 1400):
[?2004l[?2004h>         i = (y*2400 + x)*3
[?2004l[?2004h>         r, g, b = ref[i], ref[i+1], ref[i+2]
[?2004l[?2004h>         # Check if it's sphere (not sky, not floor)
[?2004l[?2004h>         if not (r > 100 and g > 100 and b > 200) and not (r == g == b and r in [67, 152]):
[?2004l[?2004h>             if left is None:
[?2004l[?2004h>                 left = x
[?2004l[?2004h>             right = x
[?2004l[?2004h>     if left is not None and right is not None:
[?2004l[?2004h>         width = right - left
[?2004l[?2004h>         center_x = (left + right) / 2
[?2004l[?2004h>         if width > max_width:
[?2004l[?2004h>             max_width = width
[?2004l[?2004h>             max_y = y
[?2004l[?2004h>             center_x_at_max = center_x
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Max width at y={max_y}, width={max_width}, center_x={center_x_at_max:.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> # The apparent radius should be width/2 at the equator
[?2004l[?2004h> R_app = max_width / 2
[?2004l[?2004h> print(f"Apparent radius: {R_app:.1f}")
[?2004l[?2004h> 
[?2004l[?2004h> # The center of the sphere in screen coordinates:
[?2004l[?2004h> x_center = center_x_at_max
[?2004l[?2004h> y_center = max_y
[?2004l[?2004h> print(f"Sphere center screen: ({x_center:.1f}, {y_center:.1f})")
[?2004l[?2004h> 
[?2004l[?2004h> # Now compute the 3D sphere position from screen coordinates
[?2004l[?2004h> # x_c = 1200 + fov * Xs / (-Zs)  => Xs = (x_c - 1200) * (-Zs) / fov
[?2004l[?2004h> # y_c = 900 + fov * (Ys - H) / (-Zs) => Ys = H + (y_c - 900) * (-Zs) / fov
[?2004l[?2004h> # R_app = fov * R / (-Zs) => R = R_app * (-Zs) / fov
[?2004l[?2004h> 
[?2004l[?2004h> # We have 3 unknowns (Xs, Ys, Zs, R) and 3 equations, but we need one more constraint
[?2004l[?2004h> # Let's find Zs such that the top of sphere matches y=809
[?2004l[?2004h> # Top of sphere: y_top = y_center - R_app = 809
