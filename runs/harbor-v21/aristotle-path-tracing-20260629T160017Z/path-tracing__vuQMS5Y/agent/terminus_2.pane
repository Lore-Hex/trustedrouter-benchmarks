[?2004l[?2004h> 
[?2004l[?2004h> #define W 2400
[?2004l[?2004h> #define H 1800
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { double x, y, z; } Vec;
[?2004l[?2004h> 
[?2004l[?2004h> Vec v(double x, double y, double z) {
[?2004l[?2004h>     Vec r = {x, y, z};
[?2004l[?2004h>     return r;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double dot(Vec a, Vec b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> Vec sub(Vec a, Vec b) { return v(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> Vec add(Vec a, Vec b) { return v(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> Vec mul(Vec a, double s) { return v(a.x*s, a.y*s, a.z*s); }
[?2004l[?2004h> Vec norm(Vec a) {
[?2004l[?2004h>     double l = sqrt(dot(a,a));
[?2004l[?2004h>     return v(a.x/l, a.y/l, a.z/l);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double clamp(double x) { return x < 0 ? 0 : (x > 255 ? 255 : x); }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     FILE *f = fopen("reconstructed.ppm", "w");
[?2004l[?2004h>     fprintf(f, "P3\n%d %d\n255\n", W, H);
[?2004l[?2004h>     
[?2004l[?2004h>     double fov = 900.0;
[?2004l[?2004h>     
[?2004l[?2004h>     // Camera at (0, 1.5, 5) looking at (0, 0, 0)
[?2004l[?2004h>     Vec cam = v(0, 1.5, 5);
[?2004l[?2004h>     Vec target = v(0, 0, 0);
[?2004l[?2004h>     
[?2004l[?2004h>     // Camera basis vectors
[?2004l[?2004h>     Vec cz = norm(sub(target, cam));  // forward direction
[?2004l[?2004h>     Vec up = v(0, 1, 0);
[?2004l[?2004h>     Vec cx = norm(v(up.y*cz.z - up.z*cz.y, up.z*cz.x - up.x*cz.z, up.x*cz.y - up.y*cz.x));
[?2004l[?2004h>     Vec cy = v(cz.y*cx.z - cz.z*cx.y, cz.z*cx.x - cz.x*cx.z, cz.x*cx.y - cz.y*cx.x);
[?2004l[?2004h>     
[?2004l[?2004h>     // Sphere at (0, 0.5, 0) radius 1
[?2004l[?2004h>     Vec sp = v(0, 0.5, 0);
[?2004l[?2004h>     double sr = 1.0;
[?2004l[?2004h>     Vec sc = v(1.0, 0.2, 0.2);  // redish
[?2004l[?2004h>     
[?2004l[?2004h>     // Light
[?2004l[?2004h>     Vec lp = v(5, 5, 5);
[?2004l[?2004h>     
[?2004l[?2004h>     // Ground plane at y = 0
[?2004l[?2004h>     double ground_y = 0.0;
[?2004l[?2004h>     double d = 1.5;  // camera height - ground
[?2004l[?2004h>     double freq = 2.0;
[?2004l[?2004h>     double xoff = 0.0;
[?2004l[?2004h>     double zoff = 0.0;
[?2004l[?2004h>     int inv = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     for (int y = 0; y < H; y++) {
[?2004l[?2004h>         for (int x = 0; x < W; x++) {
[?2004l[?2004h>             // Camera space coordinates
[?2004l[?2004h>             double u = (2.0 * x / W - 1.0) * (double)W / H;
[?2004l[?2004h>             double vv = -(2.0 * y / H - 1.0);
[?2004l[?2004h>             
[?2004l[?2004h>             // Ray direction in camera space (looking along -z)
[?2004l[?2004h>             Vec dir = norm(v(u, vv, -1.0));
[?2004l[?2004h>             
[?2004l[?2004h>             // Transform to world space
