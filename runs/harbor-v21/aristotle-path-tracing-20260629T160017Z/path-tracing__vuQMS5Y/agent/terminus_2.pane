[?2004l[?2004h>                 if (t > 0) {
[?2004l[?2004h>                     Vec pt = add(v(0, cam_h, 0), mul(dir, t));
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Checkerboard with frequency 2
[?2004l[?2004h>                     int ix = (int)(floor(pt.x * 2.0 + 0.0));
[?2004l[?2004h>                     int iz = (int)(floor(pt.z * 2.0 + 0.99));
[?2004l[?2004h>                     double col = ((ix + iz + 1) & 1) ? 152.0 : 67.0;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Check sphere shadow
