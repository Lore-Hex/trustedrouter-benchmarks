[?2004l[?2004h>         r2, g2, b2 = rec[i], rec[i+1], rec[i+2]
[?2004l[?2004h>         d = (rr-r2)**2 + (gg-g2)**2 + (bb-b2)**2
[?2004l[?2004h>         if bb == 255 and rr > 100 and gg > 100:
[?2004l[?2004h>             sky_diff += d
