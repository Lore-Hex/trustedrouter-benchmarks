[?2004l[?2004h>                 if (t > 0) {
[?2004l[?2004h>                     Vec pt = add(cam_pos, mul(wdir, t));
[?2004l[?2004h>                     int ix = (int)(floor(pt.x * 2) + 1000);
[?2004l[?2004h>                     int iz = (int)(floor(pt.z * 2) + 1000);
[?2004l[?2004h>                     double col = ((ix + iz) & 1) ? 152 : 67;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Check shadow
[?2004l[?2004h>                     Vec L = norm(sub(light_pos, pt));
[?2004l[?2004h>                     // Check sphere shadow
