[?2004l[?2004h> # The zenith direction is (0, 1, 0) in world coordinates
[?2004l[?2004h> # If the camera is looking horizontally along z, then:
[?2004l[?2004h> # The camera coordinate system:
[?2004l[?2004h> # right = (1, 0, 0)
[?2004l[?2004h> # up = (0, 1, 0)
[?2004l[?2004h> # forward = (0, 0, -1)
[?2004l[?2004h> 
[?2004l[?2004h> # Then the ray direction in world coordinates is (dx, dy, dz) normalized
[?2004l[?2004h> # The dot product with zenith (0,1,0) is just dy/norm
[?2004l[?2004h> 
[?2004l[?2004h> # Let me verify this by computing the actual relationship
[?2004l[?2004h> print("\nVerifying sky color vs ray direction:")
[?2004l[?2004h> asp = w / h
[?2004l[?2004h> fov = 1.0
[?2004l[?2004h> 
[?2004l[?2004h> for y in [0, 200, 400, 600, 800]:
[?2004l[?2004h>     for x in [0, 600, 1200, 1800, 2399]:
[?2004l[?2004h>         i = (y*w + x)*3
[?2004l[?2004h>         rr, gg, bb = p[i], p[i+1], p[i+2]
[?2004l[?2004h>         if rr < 100:
[?2004l[?2004h>             continue  # sky
[?2004l[?2004h>         
[?2004l[?2004h>         u = (2.0 * x / w - 1.0) * asp
[?2004l[?2004h>         v = -(2.0 * y / h - 1.0)
[?2004l[?2004h>         
[?2004l[?2004h>         dx = u
[?2004l[?2004h>         dy = v
[?2004l[?2004h>         dz = -fov
[?2004l[?2004h>         
[?2004l[?2004h>         norm = math.sqrt(dx*dx + dy*dy + dz*dz)
[?2004l[?2004h>         ndx, ndy, ndz = dx/norm, dy/norm, dz/norm
[?2004l[?2004h>         
[?2004l[?2004h>         # In this camera model, the Y component of the world direction is ndy
[?2004l[?2004h>         # (since camera up = (0,1,0))
[?2004l[?2004h>         # The angle from vertical is acos(ndy)
[?2004l[?2004h>         # The angle from horizontal is asin(ndy)
[?2004l[?2004h>         
[?2004l[?2004h>         # Let's check: at horizon (y=900), ndy should be 0 (horizontal)
[?2004l[?2004h>         # At top (y=0), ndy should be positive (looking up)
[?2004l[?2004h>         
[?2004l[?2004h>         # Sky color model: t = 0.5 + 0.5 * ndy (where ndy is cos(theta) from zenith? No...)
[?2004l[?2004h>         # Actually if ndy is the component along the up direction:
[?2004l[?2004h>         # ndy = 1 means looking straight up
[?2004l[?2004h>         # ndy = 0 means looking horizontal
[?2004l[?2004h>         # ndy = -1 means looking straight down
[?2004l[?2004h>         
[?2004l[?2004h>         # For sky pixels (y < 900), ndy > 0 (looking up)
[?2004l[?2004h>         # Let's try: R = 146 + (191-146) * (1 - ndy) when ndy > 0
[?2004l[?2004h>         # Actually at top center (1200,0), R=146, ndy=0.707
[?2004l[?2004h>         # At left edge (0,0), R=159, ndy=0.577
[?2004l[?2004h>         # At horizon (0,899), R=191, ndy=0.194
[?2004l[?2004h>         
[?2004l[?2004h>         # Hmm, this doesn't match a simple linear model
[?2004l[?2004h>         
[?2004l[?2004h>         # Let's try: R = 146 + 45 * (1 - ndy)^x
[?2004l[?2004h>         # At (1200,0): ndy=0.707, 1-ndy=0.293, R=146 -> offset=0
[?2004l[?2004h>         # At (0,0): ndy=0.577, 1-ndy=0.423, R=159 -> offset=13
