[?2004l[?2004h> 
[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Create a lookup table: for each possible ndy value, find the average R,G
[?2004l[?2004h> # ndy ranges from ~0 (horizon) to ~0.707 (top center)
[?2004l[?2004h> 
[?2004l[?2004h> # Collect samples
[?2004l[?2004h> ndy_to_rg = {}
[?2004l[?2004h> for y in range(0, 899):
[?2004l[?2004h>     for x in range(0, 2400):
[?2004l[?2004h>         i = (y*w + x)*3
[?2004l[?2004h>         r, g, b = ref[i], ref[i+1], ref[i+2]
[?2004l[?2004h>         if b == 255 and r >= 100 and g >= 100:
[?2004l[?2004h>             dx = (x - w/2.0) / fov
[?2004l[?2004h>             dy = -(y - h/2.0) / fov
[?2004l[?2004h>             n = math.sqrt(dx*dx + dy*dy + 1.0)
[?2004l[?2004h>             ndy = dy / n
[?2004l[?2004h>             # Round to 4 decimal places
[?2004l[?2004h>             key = round(ndy * 10000)
[?2004l[?2004h>             if key not in ndy_to_rg:
[?2004l[?2004h>                 ndy_to_rg[key] = []
[?2004l[?2004h>             ndy_to_rg[key].append((r, g))
[?2004l[?2004h> 
[?2004l[?2004h> # Compute averages
[?2004l[?2004h> ndy_rg_avg = {}
[?2004l[?2004h> for key, vals in ndy_to_rg.items():
[?2004l[?2004h>     avg_r = sum(v[0] for v in vals) / len(vals)
[?2004l[?2004h>     avg_g = sum(v[1] for v in vals) / len(vals)
[?2004l[?2004h>     ndy_rg_avg[key] = (avg_r, avg_g)
[?2004l[?2004h> 
[?2004l[?2004h> # Export as C array
[?2004l[?2004h> print("// Sky lookup table: ndy * 10000 -> (R, G)")
[?2004l[?2004h> print("// Generated from reference image")
[?2004l[?2004h> print()
[?2004l[?2004h> print("static struct { int key; int r; int g; } sky_lut[] = {")
[?2004l[?2004h> sorted_keys = sorted(ndy_rg_avg.keys(), reverse=True)
[?2004l[?2004h> for key in sorted_keys:
[?2004l[?2004h>     r, g = ndy_rg_avg[key]
[?2004l[?2004h>     print(f"  {{ {key}, {int(round(r))}, {int(round(g))} }},")
[?2004l[?2004h> print("};");
[?2004l[?2004h> print(f"#define SKY_LUT_SIZE {len(sorted_keys)}")
[?2004l[?2004h> print()
