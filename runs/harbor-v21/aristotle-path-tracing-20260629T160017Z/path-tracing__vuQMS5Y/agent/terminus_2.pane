[?2004l[?2004h>     ref = list(map(int, f.read().split()))
[?2004l[?2004h> 
[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check the floor pattern at a specific y=950
[?2004l[?2004h> # and find the exact tile boundaries
[?2004l[?2004h> 
[?2004l[?2004h> print("Floor at y=950 (first 200 pixels):")
[?2004l[?2004h> row = []
[?2004l[?2004h> for x in range(0, 200):
[?2004l[?2004h>     i = (950*w + x)*3
[?2004l[?2004h>     r = ref[i]
[?2004l[?2004h>     if r == 152:
[?2004l[?2004h>         row.append("W")
[?2004l[?2004h>     elif r == 67:
[?2004l[?2004h>         row.append("B")
[?2004l[?2004h>     else:
[?2004l[?2004h>         row.append("?")
[?2004l[?2004h> print(''.join(row))
[?2004l[?2004h> 
[?2004l[?2004h> # The pattern shows: B(0-21), W(22-54), B(55-...)
[?2004l[?2004h> # First boundary at x=22 (B->W)
[?2004l[?2004h> # Second boundary at x=55 (W->B)
[?2004l[?2004h> # So first tile width = 22 (B), second tile width = 33 (W)...
[?2004l[?2004h> # But this is actually the perspective effect: tiles farther from center are smaller
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check what camera height gives this pattern
[?2004l[?2004h> # At y=950, dy = -(950-900)/fov = -50/900 = -0.05556
[?2004l[?2004h> # t = (H - G) / (-dy) = d / 0.05556
[?2004l[?2004h> # Z = t = d * 900 / 50 = 18 * d
[?2004l[?2004h> # X = (x - 1200) * Z / fov = (x-1200) * 18d / 900 = (x-1200) * d / 50
[?2004l[?2004h> 
[?2004l[?2004h> # Let's try to find d and frequency such that the pattern matches
[?2004l[?2004h> print("\nFinding floor parameters...")
[?2004l[?2004h> 
[?2004l[?2004h> # Test various (d, freq) combinations
[?2004l[?2004h> for d in [i/20.0 for i in range(10, 50)]:  # 0.5 to 2.5
[?2004l[?2004h>     for freq in [i/2.0 for i in range(1, 10)]:  # 0.5 to 5.0
[?2004l[?2004h>         # Test at multiple y values
[?2004l[?2004h>         matches = 0
[?2004l[?2004h>         total = 0
[?2004l[?2004h>         for test_y in [920, 950, 1000, 1100, 1200, 1300]:
[?2004l[?2004h>             for test_x in range(0, 500, 10):
[?2004l[?2004h>                 i = (test_y*w + test_x)*3
[?2004l[?2004h>                 r = ref[i]
[?2004l[?2004h>                 if r != 152 and r != 67:
[?2004l[?2004h>                     continue
[?2004l[?2004h>                 actual = 1 if r == 152 else 0
[?2004l[?2004h>                 
[?2004l[?2004h>                 dy = -(test_y - 900.0) / fov
[?2004l[?2004h>                 if dy >= 0:
[?2004l[?2004h>                     continue
[?2004l[?2004h>                 t = d / (-dy)
[?2004l[?2004h>                 Z = t
[?2004l[?2004h>                 X = (test_x - 1200.0) * Z / fov
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Try different offsets
[?2004l[?2004h>                 found = False
[?2004l[?2004h>                 for xoff in [i/4.0 for i in range(-4, 5)]:
[?2004l[?2004h>                     for zoff in [i/4.0 for i in range(-4, 5)]:
[?2004l[?2004h>                         for inv in [0, 1]:
[?2004l[?2004h>                             ix = int(math.floor(X * freq + xoff))
[?2004l[?2004h>                             iz = int(math.floor(Z * freq + zoff))
[?2004l[?2004h>                             pred = (ix + iz + inv) & 1
[?2004l[?2004h>                             if pred == actual:
[?2004l[?2004h>                                 found = True
[?2004l[?2004h>                                 break
[?2004l[?2004h>                         if found:
[?2004l[?2004h>                             break
[?2004l[?2004h>                     if found:
[?2004l[?2004h>                         break
[?2004l[?2004h>                 if found:
[?2004l[?2004h>                     matches += 1
[?2004l[?2004h>                 total += 1
[?2004l[?2004h>         
[?2004l[?2004h>         acc = matches / total if total > 0 else 0
[?2004l[?2004h>         if acc > 0.95:
[?2004l[?2004h>             print(f"d={d:.2f}, freq={freq:.1f}: accuracy={acc:.4f}")
[?2004l[?2004h> EOF
