[?2004l[?2004h> right_ndx, right_ndy, right_ndz = norm_dir((1317-1200)/fov, 0, -1)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Top dir: ({top_ndx:.6f}, {top_ndy:.6f}, {top_ndz:.6f})")
[?2004l[?2004h> print(f"Left dir: ({left_ndx:.6f}, {left_ndy:.6f}, {left_ndz:.6f})")
[?2004l[?2004h> print(f"Right dir: ({right_ndx:.6f}, {right_ndy:.6f}, {right_ndz:.6f})")
[?2004l[?2004h> 
[?2004l[?2004h> # For a sphere at (0, Ys, Zs) with radius R, the oc vector from camera to sphere:
[?2004l[?2004h> # oc = (0, H - Ys, -Zs)
[?2004l[?2004h> # The ray satisfies tangent condition: discriminant = 0
[?2004l[?2004h> # (dot(oc, dir))^2 - dot(oc, oc) + R^2 = 0
[?2004l[?2004h> 
[?2004l[?2004h> # Let's solve for Ys, Zs, R such that both top and left rays are tangent
[?2004l[?2004h> # We have 3 unknowns (Ys, Zs, R) and 2 equations (top tangent, left tangent)
[?2004l[?2004h> # But we also have the right tangent at y=900
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, the left and right edges at y=900 give us information about the sphere's
[?2004l[?2004h> # horizontal extent. At y=900, dy=0 (horizontal ray).
[?2004l[?2004h> # The ray at left edge is tangent to the sphere.
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find (Ys, Zs, R) that satisfy both top and left tangent conditions.
[?2004l[?2004h> 
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from scipy.optimize import fsolve
[?2004l[?2004h> 
[?2004l[?2004h> # We'll search numerically
[?2004l[?2004h> def equations(params):
[?2004l[?2004h>     Ys, Zs, R = params
[?2004l[?2004h>     oc_y = H - Ys
[?2004l[?2004h>     oc_z = -Zs
[?2004l[?2004h>     
[?2004l[?2004h>     # Top tangent condition
[?2004l[?2004h>     disc_top = (oc_y*top_ndy + oc_z*top_ndz)**2 - (oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>     
[?2004l[?2004h>     # Left tangent condition
[?2004l[?2004h>     disc_left = (oc_y*left_ndy + oc_z*left_ndz)**2 - (oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>     
[?2004l[?2004h>     return [disc_top, disc_left, 0]  # 3rd equation is just a guess
[?2004l[?2004h> 
[?2004l[?2004h> # Search numerically
[?2004l[?2004h> best_err = 1e10
[?2004l[?2004h> best_params = None
[?2004l[?2004h> 
[?2004l[?2004h> for Ys in [i/100.0 for i in range(50, 200)]:  # 0.5 to 2.0
[?2004l[?2004h>     for Zs in [i/100.0 for i in range(-500, -300)]:  # -5.0 to -3.0
[?2004l[?2004h>         for R in [i/100.0 for i in range(50, 200)]:  # 0.5 to 2.0
[?2004l[?2004h>             oc_y = H - Ys
[?2004l[?2004h>             oc_z = -Zs
[?2004l[?2004h>             disc_top = (oc_y*top_ndy + oc_z*top_ndz)**2 - (oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>             disc_left = (oc_y*left_ndy + oc_z*left_ndz)**2 - (oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>             err = abs(disc_top) + abs(disc_left)
[?2004l[?2004h>             if err < best_err:
[?2004l[?2004h>                 best_err = err
[?2004l[?2004h>                 best_params = (Ys, Zs, R, disc_top, disc_left)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nBest parameters:")
[?2004l[?2004h> print(f"  Ys = {best_params[0]:.4f}")
[?2004l[?2004h> print(f"  Zs = {best_params[1]:.4f}")
[?2004l[?2004h> print(f"  R  = {best_params[2]:.4f}")
[?2004l[?2004h> print(f"  disc_top = {best_params[3]:.6f}")
[?2004l[?2004h> print(f"  disc_left = {best_params[4]:.6f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Now let's also check the right edge tangent
[?2004l[?2004h> Ys, Zs, R, _, _ = best_params
[?2004l[?2004h> oc_y = H - Ys
[?2004l[?2004h> oc_z = -Zs
[?2004l[?2004h> disc_right = (oc_y*right_ndy + oc_z*right_ndz)**2 - (oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h> print(f"  disc_right = {disc_right:.6f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Also compute expected left/right edges
[?2004l[?2004h> # At y=900, dy=0, so the ray is (dx, 0, -1)
[?2004l[?2004h> # The tangent condition: (oc_y*0 + oc_z*ndz)^2 - (oc_y^2 + oc_z^2) + R^2 = 0
[?2004l[?2004h> # oc_z^2 * ndz^2 - (oc_y^2 + oc_z^2) + R^2 = 0
[?2004l[?2004h> # For a given dx, the ndz = -1 / sqrt(dx^2 + 1), ndx = dx / sqrt(dx^2 + 1)
[?2004l[?2004h> # So oc_z^2 / (dx^2 + 1) - (oc_y^2 + oc_z^2) + R^2 = 0
[?2004l[?2004h> # Solve for dx:
[?2004l[?2004h> # oc_z^2 / (dx^2 + 1) = oc_y^2 + oc_z^2 - R^2
[?2004l[?2004h> # dx^2 + 1 = oc_z^2 / (oc_y^2 + oc_z^2 - R^2)
[?2004l[?2004h> # dx = sqrt(oc_z^2 / (oc_y^2 + oc_z^2 - R^2) - 1)
[?2004l[?2004h> 
[?2004l[?2004h> if oc_y**2 + oc_z**2 > R**2:
