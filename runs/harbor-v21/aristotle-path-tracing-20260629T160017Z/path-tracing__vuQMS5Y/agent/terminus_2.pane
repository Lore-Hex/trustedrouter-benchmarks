[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> #define W 2400
[?2004l[?2004h> #define H 1800
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { double x, y, z; } Vec;
[?2004l[?2004h> 
[?2004l[?2004h> Vec v(double x, double y, double z) {
[?2004l[?2004h>     Vec r = {x, y, z};
[?2004l[?2004h>     return r;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double dot(Vec a, Vec b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> Vec sub(Vec a, Vec b) { return v(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> Vec add(Vec a, Vec b) { return v(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> Vec mul(Vec a, double s) { return v(a.x*s, a.y*s, a.z*s); }
[?2004l[?2004h> Vec norm(Vec a) {
[?2004l[?2004h>     double l = sqrt(dot(a,a));
[?2004l[?2004h>     return v(a.x/l, a.y/l, a.z/l);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double clamp(double x) { return x < 0 ? 0 : (x > 255 ? 255 : x); }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     FILE *f = fopen("reconstructed.ppm", "w");
[?2004l[?2004h>     fprintf(f, "P3\n%d %d\n255\n", W, H);
[?2004l[?2004h>     
[?2004l[?2004h>     double fov = 900.0;
[?2004l[?2004h>     double cam_y = 1.5;
[?2004l[?2004h>     double ground_y = 0.0;
[?2004l[?2004h>     
[?2004l[?2004h>     // Sphere parameters computed from silhouette
[?2004l[?2004h>     Vec sp = v(-0.152, 1.841, -6.522);
[?2004l[?2004h>     double sr = 1.0;
[?2004l[?2004h>     Vec sc = v(1.0, 0.2, 0.2);  // reddish
[?2004l[?2004h>     
[?2004l[?2004h>     // Light
[?2004l[?2004h>     Vec lp = v(5, 5, 5);
[?2004l[?2004h>     
[?2004l[?2004h>     // Floor checkerboard
[?2004l[?2004h>     double freq = 1.0;
[?2004l[?2004h>     double xoff = 0.0;
[?2004l[?2004h>     double zoff = 0.0;
[?2004l[?2004h>     int inv = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     for (int y = 0; y < H; y++) {
[?2004l[?2004h>         for (int x = 0; x < W; x++) {
[?2004l[?2004h>             double dx = (x - W/2.0) / fov;
[?2004l[?2004h>             double dy = -(y - H/2.0) / fov;
[?2004l[?2004h>             
[?2004l[?2004h>             Vec dir = norm(v(dx, dy, -1));
[?2004l[?2004h>             
[?2004l[?2004h>             double r, g, b;
[?2004l[?2004h>             int hit = 0;
[?2004l[?2004h>             
[?2004l[?2004h>             // Sphere intersection
[?2004l[?2004h>             Vec oc = sub(v(0, cam_y, 0), sp);
[?2004l[?2004h>             double a = dot(dir, dir);
[?2004l[?2004h>             double bb = 2 * dot(oc, dir);
[?2004l[?2004h>             double c = dot(oc, oc) - sr * sr;
[?2004l[?2004h>             double disc = bb*bb - 4*a*c;
[?2004l[?2004h>             
[?2004l[?2004h>             if (disc > 0) {
[?2004l[?2004h>                 double t = (-bb - sqrt(disc)) / (2 * a);
[?2004l[?2004h>                 if (t > 0.001) {
[?2004l[?2004h>                     Vec pt = add(v(0, cam_y, 0), mul(dir, t));
[?2004l[?2004h>                     Vec n = norm(sub(pt, sp));
[?2004l[?2004h>                     Vec L = norm(sub(lp, pt));
[?2004l[?2004h>                     double diff = dot(n, L);
[?2004l[?2004h>                     if (diff < 0) diff = 0;
[?2004l[?2004h>                     
[?2004l[?2004h>                     Vec V = mul(dir, -1);
[?2004l[?2004h>                     Vec Hv = norm(add(L, V));
[?2004l[?2004h>                     double spec = dot(n, Hv);
[?2004l[?2004h>                     if (spec < 0) spec = 0;
[?2004l[?2004h>                     spec = pow(spec, 20);
[?2004l[?2004h>                     
[?2004l[?2004h>                     r = clamp(sc.x * (0.2 + 0.8 * diff) * 255 + spec * 200);
[?2004l[?2004h>                     g = clamp(sc.y * (0.2 + 0.8 * diff) * 255 + spec * 40);
[?2004l[?2004h>                     b = clamp(sc.z * (0.2 + 0.8 * diff) * 255 + spec * 40);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit && dy < 0) {
[?2004l[?2004h>                 // Ground plane
[?2004l[?2004h>                 double t = -(cam_y - ground_y) / dy;
[?2004l[?2004h>                 if (t > 0) {
[?2004l[?2004h>                     double Z = t;
[?2004l[?2004h>                     double X = dx * t;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Checkerboard with proper offset
[?2004l[?2004h>                     // The pattern: floor(X * freq + xoff) + floor(Z * freq + zoff) + inv & 1
[?2004l[?2004h>                     int ix = (int)(floor(X * freq + xoff));
[?2004l[?2004h>                     int iz = (int)(floor(Z * freq + zoff));
[?2004l[?2004h>                     double col = ((ix + iz + inv) & 1) ? 152.0 : 67.0;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Shadow from sphere
[?2004l[?2004h>                     Vec pt = add(v(0, cam_y, 0), mul(dir, t));
[?2004l[?2004h>                     Vec L = norm(sub(lp, pt));
[?2004l[?2004h>                     Vec oc2 = sub(pt, sp);
[?2004l[?2004h>                     double sa = dot(L, L);
[?2004l[?2004h>                     double sb = 2 * dot(oc2, L);
[?2004l[?2004h>                     double sc_ = dot(oc2, oc2) - sr * sr;
[?2004l[?2004h>                     double sd = sb*sb - 4*sa*sc_;
[?2004l[?2004h>                     if (sd > 0) {
[?2004l[?2004h>                         double st = (-sb - sqrt(sd)) / (2 * sa);
[?2004l[?2004h>                         if (st > 0.001) {
[?2004l[?2004h>                             Vec sh_pt = add(pt, mul(L, st));
[?2004l[?2004h>                             Vec to_light = sub(lp, pt);
[?2004l[?2004h>                             Vec to_sh = sub(sh_pt, pt);
[?2004l[?2004h>                             if (dot(to_light, to_sh) > 0 && dot(to_sh, to_sh) < dot(to_light, to_light)) {
[?2004l[?2004h>                                 col *= 0.35;
[?2004l[?2004h>                             }
[?2004l[?2004h>                         }
[?2004l[?2004h>                     }
[?2004l[?2004h>                     
[?2004l[?2004h>                     r = g = b = clamp(col);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit) {
[?2004l[?2004h>                 // Sky
[?2004l[?2004h>                 double ndy = dir.y;
[?2004l[?2004h>                 if (ndy < 0) ndy = 0;
[?2004l[?2004h>                 if (ndy > 0.7071) ndy = 0.7071;
[?2004l[?2004h>                 r = clamp(191.5 - 64.0 * ndy);
[?2004l[?2004h>                 g = clamp(217.1 - 38.4 * ndy);
[?2004l[?2004h>                 b = 255;
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             fprintf(f, "%d %d %d\n", (int)r, (int)g, (int)b);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
[?2004l[?2004h> ENDCODE
