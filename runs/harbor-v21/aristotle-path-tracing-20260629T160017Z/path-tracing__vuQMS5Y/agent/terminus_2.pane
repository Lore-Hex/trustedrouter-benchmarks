[?2004l[?2004h> 
[?2004l[?2004h> # Test different formulas
[?2004l[?2004h> formulas = [
[?2004l[?2004h>     ('ADD', lambda ix, iz, inv: (ix + iz + inv) & 1),
[?2004l[?2004h>     ('XOR', lambda ix, iz, inv: (ix ^ iz + inv) & 1),
[?2004l[?2004h>     ('IX_ONLY', lambda ix, iz, inv: (ix + inv) & 1),
[?2004l[?2004h>     ('IZ_ONLY', lambda ix, iz, inv: (iz + inv) & 1),
[?2004l[?2004h>     ('IX_IZ_ADD', lambda ix, iz, inv: (ix + iz) & 1),
[?2004l[?2004h> ]
[?2004l[?2004h> 
[?2004l[?2004h> for name, formula in formulas:
[?2004l[?2004h>     best = 0
[?2004l[?2004h>     best_p = None
[?2004l[?2004h>     for xoff in [-1.0, -0.5, 0, 0.5, 1.0]:
[?2004l[?2004h>         for zoff in [-1.0, -0.5, 0, 0.5, 1.0]:
[?2004l[?2004h>             for inv in [0, 1]:
[?2004l[?2004h>                 m = t = 0
[?2004l[?2004h>                 for y in range(910, 1400, 30):
[?2004l[?2004h>                     dy = -(y - 900) / fov
[?2004l[?2004h>                     if dy >= 0: continue
[?2004l[?2004h>                     Z = d / (-dy)
[?2004l[?2004h>                     for x in range(0, 1000, 30):
[?2004l[?2004h>                         i = (y*w + x)*3
[?2004l[?2004h>                         r = ref[i]
[?2004l[?2004h>                         if r not in (67, 152): continue
[?2004l[?2004h>                         actual = 1 if r == 152 else 0
