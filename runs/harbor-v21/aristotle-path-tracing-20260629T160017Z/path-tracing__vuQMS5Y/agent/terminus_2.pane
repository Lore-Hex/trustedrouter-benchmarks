[?2004hroot@dcf07d044a6c:/app# cd /app && python3 << 'EOF'
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/image.ppm') as f:
[?2004l[?2004h>     next(f); wh=next(f).split(); w,h=int(wh[0]),int(wh[1]); next(f)
[?2004l[?2004h>     ref = list(map(int, f.read().split()))
[?2004l[?2004h> 
[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the exact floor parameters by matching the first boundary
[?2004l[?2004h> # at multiple y values using a least-squares approach
[?2004l[?2004h> 
[?2004l[?2004h> # The first boundary x at a given y occurs when the parity changes
[?2004l[?2004h> # parity = (floor(X*freq + xoff) + floor(Z*freq + zoff) + inv) & 1
[?2004l[?2004h> # where X = (x-1200)*d/(y-900), Z = d*fov/(y-900)
[?2004l[?2004h> # 
[?2004l[?2004h> # As x increases from 0, the first time parity changes is when X*freq + xoff crosses an integer
[?2004l[?2004h> # because Z is constant for a given y
[?2004l[?2004h> 
[?2004l[?2004h> # At the boundary x_b:
[?2004l[?2004h> # X_b * freq + xoff = k for some integer k
[?2004l[?2004h> # X_b = (k - xoff) / freq
[?2004l[?2004h> # (x_b - 1200) * d / (y - 900) = (k - xoff) / freq
[?2004l[?2004h> # x_b = 1200 + (k - xoff) * (y - 900) / (d * freq)
[?2004l[?2004h> 
[?2004l[?2004h> # So the first boundary (smallest x > 0) corresponds to:
[?2004l[?2004h> # k = ceil(xoff) or floor(xoff) depending on direction
[?2004l[?2004h> 
[?2004l[?2004h> # Let's use this to find d*freq and xoff from the boundary positions
[?2004l[?2004h> 
[?2004l[?2004h> # Collect first boundaries
[?2004l[?2004h> print("First boundary analysis:")
[?2004l[?2004h> for y in [910, 920, 930, 940, 950, 960, 970, 980, 990, 1000]:
[?2004l[?2004h>     prev = None
[?2004l[?2004h>     for x in range(0, 2400):
[?2004l[?2004h>         i = (y*w + x)*3
[?2004l[?2004h>         r = ref[i]
[?2004l[?2004h>         if r in [67, 152]:
[?2004l[?2004h>             if r != prev and prev is not None:
[?2004l[?2004h>                 print(f"y={y}: first boundary at x={x}")
[?2004l[?2004h>                 break
[?2004l[?2004h>             prev = r
[?2004l[?2004h> 
[?2004l[?2004h> # From the data:
[?2004l[?2004h> # y=920: x=11
[?2004l[?2004h> # y=950: x=22
[?2004l[?2004h> # y=1000: x=61
[?2004l[?2004h> # y=1100: x=131
[?2004l[?2004h> 
[?2004l[?2004h> # The formula: x_b = 1200 + (k - xoff) * (y - 900) / (d * freq)
[?2004l[?2004h> # Let's find d*freq and (k-xoff) by fitting
[?2004l[?2004h> 
[?2004l[?2004h> # x_b = a + b * (y - 900)
[?2004l[?2004h> # where a = 1200 (since for y=900, x_b should be at infinity, but actually the horizon is at y=900)
[?2004l[?2004h> # Actually, at y=900, the ray is horizontal and never hits the ground, so there's no floor.
[?2004l[?2004h> # The formula should be: x_b = 1200 + C * (y - 900) where C = (k - xoff) / (d * freq)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute C from each data point
[?2004l[?2004h> print("\nComputing C = (x_b - 1200) / (y - 900):")
[?2004l[?2004h> for y, x_b in [(910, 3), (920, 11), (930, 21), (940, 12), (950, 22), (960, 30), (970, 25), (980, 19), (990, 54), (1000, 61), (1050, 96), (1100, 131), (1200, 1998)]:
[?2004l[?2004h>     yy = y - 900
[?2004l[?2004h>     if yy > 0:
[?2004l[?2004h>         C = (x_b - 1200) / yy
[?2004l[?2004h>         print(f"y={y}: C = {C:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # The C values vary because of the discrete nature of floor(z). 
[?2004l[?2004h> # The actual formula is more complex because the parity depends on both X and Z.
[?2004l[?2004h> EOF
