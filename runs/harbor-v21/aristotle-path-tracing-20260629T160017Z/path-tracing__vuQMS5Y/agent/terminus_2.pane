[?2004l[?2004h> print(f"Projected center: ({x_center_proj:.1f}, {y_center_proj:.1f})")
[?2004l[?2004h> 
[?2004l[?2004h> # The sphere's apparent radius in pixels at the center:
[?2004l[?2004h> apparent_R = fov * R / (-Zs) if Zs != 0 else 0
[?2004l[?2004h> print(f"Apparent radius at center: {apparent_R:.1f} pixels")
[?2004l[?2004h> print(f"Expected top of sphere: y={y_center_proj - apparent_R:.1f} (actual: 809)")
[?2004l[?2004h> print(f"Expected left at y=900: x={x_center_proj - apparent_R:.1f} (actual: 1041)")
[?2004l[?2004h> print(f"Expected right at y=900: x={x_center_proj + apparent_R:.1f} (actual: 1317)")
[?2004l[?2004h> 
[?2004l[?2004h> # We need to adjust the sphere so that:
[?2004l[?2004h> # y_center_proj - apparent_R = 809 (top)
[?2004l[?2004h> # x_center_proj - apparent_R = 1041 (left edge at y=900)
[?2004l[?2004h> # x_center_proj + apparent_R = 1317 (right edge at y=900)
[?2004l[?2004h> 
[?2004l[?2004h> # From these three equations, we can solve for Xs, Ys, Zs, R
[?2004l[?2004h> # But it's overdetermined... Let's find the best fit
[?2004l[?2004h> 
[?2004l[?2004h> print("\nSolving for sphere parameters...")
[?2004l[?2004h> 
[?2004l[?2004h> # From top: y_center - apparent_R = 809
[?2004l[?2004h> # => 900 + 900*(Ys-H)/(-Zs) - 900*1/(-Zs) = 809
[?2004l[?2004h> # => 900*(1 - (Ys-H) - 1)/(-Zs) = 809 - 900
[?2004l[?2004h> # Actually, y_center = 900 + 900*(Ys-H)/(-Zs)
[?2004l[?2004h> # apparent_R = 900*1/(-Zs)
[?2004l[?2004h> # So y_center - apparent_R = 900 + 900*(Ys-H)/(-Zs) - 900/(-Zs)
[?2004l[?2004h> # = 900 + 900*(Ys-H-1)/(-Zs)
[?2004l[?2004h> # Setting = 809:
[?2004l[?2004h> # 900 + 900*(Ys-H-1)/(-Zs) = 809
[?2004l[?2004h> # 900*(Ys-H-1)/(-Zs) = -91
[?2004l[?2004h> # (Ys-H-1)/(-Zs) = -91/900 = -0.101111
[?2004l[?2004h> # (Ys-H-1) = 0.101111 * Zs
[?2004l[?2004h> # Ys = H + 1 + 0.101111 * Zs
[?2004l[?2004h> 
[?2004l[?2004h> # From left: x_center - apparent_R = 1041
[?2004l[?2004h> # x_center = 1200 + 900*Xs/(-Zs)
[?2004l[?2004h> # apparent_R = 900/(-Zs)
[?2004l[?2004h> # So 1200 + 900*Xs/(-Zs) - 900/(-Zs) = 1041
[?2004l[?2004h> # 900*(Xs - 1)/(-Zs) = -159
[?2004l[?2004h> # (Xs - 1)/(-Zs) = -159/900 = -0.176667
[?2004l[?2004h> # Xs - 1 = 0.176667 * Zs
[?2004l[?2004h> # Xs = 1 + 0.176667 * Zs
[?2004l[?2004h> 
[?2004l[?2004h> # From right: x_center + apparent_R = 1317
[?2004l[?2004h> # 1200 + 900*Xs/(-Zs) + 900/(-Zs) = 1317
[?2004l[?2004h> # 900*(Xs + 1)/(-Zs) = 117
[?2004l[?2004h> # (Xs + 1)/(-Zs) = 117/900 = 0.13
[?2004l[?2004h> # Xs + 1 = -0.13 * Zs
[?2004l[?2004h> # Xs = -1 - 0.13 * Zs
[?2004l[?2004h> 
[?2004l[?2004h> # Equating the two expressions for Xs:
[?2004l[?2004h> # 1 + 0.176667 * Zs = -1 - 0.13 * Zs
[?2004l[?2004h> # 0.176667 * Zs + 0.13 * Zs = -2
[?2004l[?2004h> # 0.306667 * Zs = -2
[?2004l[?2004h> # Zs = -6.5217
[?2004l[?2004h> 
[?2004l[?2004h> # Then Xs = 1 + 0.176667 * (-6.5217) = 1 - 1.152 = -0.152
[?2004l[?2004h> # And from top: Ys = H + 1 + 0.101111 * Zs = 1.5 + 1 + 0.101111 * (-6.5217) = 2.5 - 0.659 = 1.841
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Solving using left=1041 and right=1317:")
[?2004l[?2004h> print(f"  Zs = -6.5217")
[?2004l[?2004h> print(f"  Xs = -0.152")
[?2004l[?2004h> print(f"  Ys from top = {1.5 + 1 + 0.101111 * (-6.5217):.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Let's verify these values
[?2004l[?2004h> Zs_calc = -6.5217
[?2004l[?2004h> Xs_calc = -0.152
[?2004l[?2004h> Ys_from_left = 1.5 + 1 + 0.101111 * Zs_calc
[?2004l[?2004h> print(f"  Ys = {Ys_from_left:.4f}")
[?2004l[?2004h> 
[?2004l[?2004h> # Compute expected screen positions
[?2004l[?2004h> x_center = 1200 + 900 * Xs_calc / (-Zs_calc)
[?2004l[?2004h> y_center = 900 + 900 * (Ys_from_left - 1.5) / (-Zs_calc)
[?2004l[?2004h> app_R = 900 * 1.0 / (-Zs_calc)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nVerification:")
[?2004l[?2004h> print(f"  Center: ({x_center:.1f}, {y_center:.1f})")
[?2004l[?2004h> print(f"  Top: y={y_center - app_R:.1f} (expected 809)")
[?2004l[?2004h> print(f"  Left: x={x_center - app_R:.1f} (expected 1041)")
[?2004l[?2004h> print(f"  Right: x={x_center + app_R:.1f} (expected 1317)")
