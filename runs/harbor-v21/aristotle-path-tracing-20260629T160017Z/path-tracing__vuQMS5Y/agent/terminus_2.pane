[?2004l[?2004h>                     if (sd > 0) {
[?2004l[?2004h>                         double st = (-sb - sqrt(sd)) / (2 * sa);
[?2004l[?2004h>                         if (st > 0.001) {
[?2004l[?2004h>                             // Check if shadow point is between pt and light
[?2004l[?2004h>                             Vec sh_pt = add(pt, mul(L, st));
[?2004l[?2004h>                             Vec to_light = sub(lp, pt);
[?2004l[?2004h>                             Vec to_sh = sub(sh_pt, pt);
[?2004l[?2004h>                             if (dot(to_light, to_sh) > 0 && dot(to_sh, to_sh) < dot(to_light, to_light)) {
