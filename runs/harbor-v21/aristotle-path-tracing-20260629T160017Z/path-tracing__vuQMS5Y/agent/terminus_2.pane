[?2004l[?2004h>                 prev = r
[?2004l[?2004h>             else:
[?2004l[?2004h>                 current_len += 1
[?2004l[?2004h>     if current_len > 0:
[?2004l[?2004h>         lengths.append(current_len)
[?2004l[?2004h>     return lengths if lengths else [0]
