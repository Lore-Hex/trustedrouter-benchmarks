[?2004l[?2004h>     Zs = -6.5
[?2004l[?2004h>     Xs = (x_c - 1200) * (-Zs) / fov
[?2004l[?2004h>     Ys = 1.5 + (y_c - 900) * (-Zs) / fov
[?2004l[?2004h>     R = R_app * (-Zs) / fov
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nComputed sphere: Xs={Xs:.4f}, Ys={Ys:.4f}, Zs={Zs:.4f}, R={R:.4f}")
