[?2004l[?2004h> import math
[?2004l[?2004h> with open('/app/image.ppm') as f:
[?2004l[?2004h>     next(f); wh=next(f).split(); w,h=int(wh[0]),int(wh[1]); next(f)
[?2004l[?2004h>     ref = list(map(int, f.read().split()))
[?2004l[?2004h> fov=900.0; d=1.5; freq=1.0
[?2004l[?2004h> best_acc=0; best_p=None
[?2004l[?2004h> for xoff in [i/20.0 for i in range(-20,20)]:
[?2004l[?2004h>   for zoff in [i/20.0 for i in range(-20,20)]:
[?2004l[?2004h>     for inv in [0,1]:
[?2004l[?2004h>       m=t=0
[?2004l[?2004h>       for y in range(910,1400,30):
[?2004l[?2004h>         dy=-(y-900.0)/fov
[?2004l[?2004h>         if dy>=0: continue
[?2004l[?2004h>         Z=d/(-dy)
[?2004l[?2004h>         for x in range(0,2400,50):
[?2004l[?2004h>           i=(y*w+x)*3; r=ref[i]
[?2004l[?2004h>           if r not in (67,152): continue
[?2004l[?2004h>           a=1 if r==152 else 0
[?2004l[?2004h>           X=(x-1200.0)*Z/fov
[?2004l[?2004h>           ix=int(math.floor(X*freq+xoff))
[?2004l[?2004h>           iz=int(math.floor(Z*freq+zoff))
[?2004l[?2004h>           p=(ix+iz+inv)&1
[?2004l[?2004h>           if p==a: m+=1
[?2004l[?2004h>           t+=1
[?2004l[?2004h>       acc=m/t if t>0 else 0
[?2004l[?2004h>       if acc>best_acc:
[?2004l[?2004h>         best_acc=acc
[?2004l[?2004h>         best_p=(xoff,zoff,inv,m,t)
[?2004l[?2004h> print(f'Best: xoff={best_p[0]:.2f}, zoff={best_p[1]:.2f}, inv={best_p[2]}, acc={100*best_p[3]/best_p[4]:.2f}%')
[?2004l[?2004h> "
