[?2004l[?2004h> n = math.sqrt(dy*dy + 1)
[?2004l[?2004h> ndy = dy/n
[?2004l[?2004h> ndz = -1/n
[?2004l[?2004h> 
[?2004l[?2004h> def check_tangent(Zs):
[?2004l[?2004h>     Xs = -21 * (-Zs) / fov
[?2004l[?2004h>     Ys = 1.5 + 47 * (-Zs) / fov
[?2004l[?2004h>     R = 138 * (-Zs) / fov
[?2004l[?2004h>     
[?2004l[?2004h>     oc_x = Xs
[?2004l[?2004h>     oc_y = Ys - H
[?2004l[?2004h>     oc_z = Zs
[?2004l[?2004h>     
[?2004l[?2004h>     dot_oc_dir = oc_x*0 + oc_y*ndy + oc_z*ndz
[?2004l[?2004h>     disc = dot_oc_dir**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>     return disc, Xs, Ys, R
[?2004l[?2004h> 
[?2004l[?2004h> # Search for Zs that minimizes disc
[?2004l[?2004h> best_err = 1e10
[?2004l[?2004h> best_Zs = None
[?2004l[?2004h> for zi in range(-8000, -1000):
[?2004l[?2004h>     Zs = zi / 1000.0
[?2004l[?2004h>     disc, Xs, Ys, R = check_tangent(Zs)
[?2004l[?2004h>     if abs(disc) < abs(best_err):
[?2004l[?2004h>         best_err = disc
[?2004l[?2004h>         best_Zs = (Zs, Xs, Ys, R)
[?2004l[?2004h> 
[?2004l[?2004h> print(f'Best: Zs={best_Zs[0]:.4f}, Xs={best_Zs[1]:.6f}, Ys={best_Zs[2]:.6f}, R={best_Zs[3]:.6f}')
