[?2004l[?2004h>     
[?2004l[?2004h>     # Left tangent
[?2004l[?2004h>     dot_l = oc_x*l_dx + oc_y*l_dy + oc_z*l_dz
[?2004l[?2004h>     disc_l = dot_l**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>     
[?2004l[?2004h>     # Right tangent
[?2004l[?2004h>     dot_r = oc_x*r_dx + oc_y*r_dy + oc_z*r_dz
[?2004l[?2004h>     disc_r = dot_r**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>     
