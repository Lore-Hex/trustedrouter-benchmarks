[?2004l[?2004h> 
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> w,h=2400,1800
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute the exact relationship between direction and sky color
[?2004l[?2004h> # For each pixel (x,y) in sky, compute direction vector from camera
[?2004l[?2004h> # Assume camera at (0,0,0), looking towards -z
[?2004l[?2004h> # Image plane at z = -focal_length, where focal_length = ?
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute focal length from field of view
[?2004l[?2004h> # If we assume the horizon (y=900) corresponds to angle 0 (horizontal),
[?2004l[?2004h> # and top of image (y=0) corresponds to some upward angle,
[?2004l[?2004h> # then the vertical field of view covers from top to horizon
[?2004l[?2004h> 
[?2004l[?2004h> # For a pixel (x,y), the direction vector before normalization:
[?2004l[?2004h> # dx = x - w/2
[?2004l[?2004h> # dy = -(y - h/2)  (negative because y increases downward)
[?2004l[?2004h> # dz = -focal_length
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find focal_length such that horizon (y=900) corresponds to dy=0
[?2004l[?2004h> # At y=900, dy = -(900 - 900) = 0, so direction = (dx, 0, -f)
[?2004l[?2004h> # This makes sense: horizon is when direction is horizontal
[?2004l[?2004h> 
[?2004l[?2004h> # At top y=0, dy = -(0 - 900) = 900
[?2004l[?2004h> # The angle from horizontal to top is atan(900 / f)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check: at (0,0), the sky color is (159,197,255)
[?2004l[?2004h> # At (1200,0) it's (146,190,255)
[?2004l[?2004h> # The difference is due to dx component
[?2004l[?2004h> 
[?2004l[?2004h> # Let me compute the exact sky color function by checking correlation with direction
[?2004l[?2004h> 
[?2004l[?2004h> # First, let's find the focal length by examining how tile width changes with y
[?2004l[?2004h> # For perspective projection of ground plane, the screen y coordinate of a point 
[?2004l[?2004h> # at distance Z along the ground is: y = fy * (camera_height / Z) + horizon
[?2004l[?2004h> # So tile width (which corresponds to physical tile size / Z) is proportional to 1/(y - 900)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check if width = K / (y - 900)
[?2004l[?2004h> print("Testing width = K / (y - 900):")
[?2004l[?2004h> for y in [920, 950, 1000, 1100, 1200, 1300]:
[?2004l[?2004h>     prev=None
[?2004l[?2004h>     boundaries=[]
[?2004l[?2004h>     for x in range(0, 2400):
[?2004l[?2004h>         i=(y*w+x)*3
[?2004l[?2004h>         c=(p[i],p[i+1],p[i+2])
[?2004l[?2004h>         if c!=prev and prev is not None:
[?2004l[?2004h>             boundaries.append(x)
[?2004l[?2004h>             if len(boundaries)>=3:
[?2004l[?2004h>                 break
[?2004l[?2004h>         prev=c
[?2004l[?2004h>     if len(boundaries)>=2:
[?2004l[?2004h>         w_=boundaries[1]-boundaries[0]
[?2004l[?2004h>         # Try width = K / (y - 900)
[?2004l[?2004h>         K = w_ * (y - 900)
[?2004l[?2004h>         print(f"y={y}: width={w_}, K={K:.1f}, predicted K={(y-900)*w_}")
[?2004l[?2004h> 
[?2004l[?2004h> # K should be constant if it's simple perspective
[?2004l[?2004h> # But it's not constant - K increases with (y-900)^2
[?2004l[?2004h> # This means width ~ (y-900)^2? No, width increases linearly with y
