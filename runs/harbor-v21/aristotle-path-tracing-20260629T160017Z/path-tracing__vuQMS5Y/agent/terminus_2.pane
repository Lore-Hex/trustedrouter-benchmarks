[?2004l[?2004h>     print(f"\ny={y}: center R={r_center}")
[?2004l[?2004h>     for x in range(0, 2401, 200):
[?2004l[?2004h>         i = (y*w + x)*3
[?2004l[?2004h>         r = p[i]
