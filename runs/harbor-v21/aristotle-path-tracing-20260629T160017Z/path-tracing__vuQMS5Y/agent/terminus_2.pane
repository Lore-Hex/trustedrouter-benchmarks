[?2004hroot@dcf07d044a6c:/app# cd /app && python3 << 'EOF'
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/image.ppm') as f:
[?2004l[?2004h>     next(f); wh=next(f).split(); w,h=int(wh[0]),int(wh[1]); next(f)
[?2004l[?2004h>     ref = list(map(int, f.read().split()))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check if the image is a mathematical function of (x, y) directly
[?2004l[?2004h> # rather than a 3D scene
[?2004l[?2004h> 
[?2004l[?2004h> # Sky: R = 191.5 - 64.0 * ndy where ndy = dy/sqrt(dx^2 + dy^2 + 1)
[?2004l[?2004h> # This is a function of (x, y) directly!
[?2004l[?2004h> 
[?2004l[?2004h> # Floor: colors (67,67,67) and (152,152,152) with checkerboard pattern
[?2004l[?2004h> # The checkerboard pattern at pixel (x,y) depends on world coordinates (X, Z)
[?2004l[?2004h> # which are functions of (x, y):
[?2004l[?2004h> # X = (x - 1200) * d / (y - 900)
[?2004l[?2004h> # Z = d * fov / (y - 900)
[?2004l[?2004h> 
[?2004l[?2004h> # Sphere: the sphere color at pixel (x,y) depends on the intersection point
[?2004l[?2004h> # which is also a function of (x, y)
[?2004l[?2004h> 
[?2004l[?2004h> # So the entire image is a deterministic function of pixel coordinates (x, y)
[?2004l[?2004h> # The sky is already perfectly modeled.
[?2004l[?2004h> # The floor is a checkerboard of X and Z.
[?2004l[?2004h> # The sphere requires ray-sphere intersection.
[?2004l[?2004h> 
