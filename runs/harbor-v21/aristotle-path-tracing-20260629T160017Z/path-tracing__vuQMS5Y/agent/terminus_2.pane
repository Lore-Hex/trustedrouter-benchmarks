[?2004l[?2004h>     print(f"y={y}: first few lengths: {lens[:8]}")
[?2004l[?2004h> 
[?2004l[?2004h> # The tile lengths vary because of perspective. At a given y, the tile width is:
[?2004l[?2004h> # width = T * (y - 900) / d where T = 1/freq
