[?2004l[?2004h> # dy = 0
[?2004l[?2004h> # dz = -1
[?2004l[?2004h> 
[?2004l[?2004h> # Normalized directions:
[?2004l[?2004h> def norm_dir(dx, dy, dz):
[?2004l[?2004h>     n = math.sqrt(dx*dx + dy*dy + dz*dz)
[?2004l[?2004h>     return dx/n, dy/n, dz/n
[?2004l[?2004h> 
[?2004l[?2004h> top_ndx, top_ndy, top_ndz = norm_dir(0, -(809 - 900)/fov, -1)
