[?2004l[?2004h>         
[?2004l[?2004h>         offset = rr - 146
[?2004l[?2004h>         one_minus_ndy = 1 - ndy
[?2004l[?2004h>         print(f"({x},{y}): ndy={ndy:.4f}, 1-ndy={one_minus_ndy:.4f}, R={rr}, offset={offset}")
