[?2004l[?2004h>         if r<100:  # not sky
[?2004l[?2004h>             continue
[?2004l[?2004h>         dx = (x - w/2) / (w/2)
[?2004l[?2004h>         dy = -(y - h/2) / (h/2)
[?2004l[?2004h>         dz = -1.0
[?2004l[?2004h>         norm = math.sqrt(dx*dx + dy*dy + dz*dz)
[?2004l[?2004h>         ndy = dy/norm  # Y component of normalized direction
[?2004l[?2004h>         # Zenith angle from vertical (0 = straight up, pi/2 = horizontal)
[?2004l[?2004h>         cos_zenith = abs(ndy)  # Actually dot with (0,1,0) = ndy
[?2004l[?2004h>         # But if looking down, we want -ndy for upward looking
[?2004l[?2004h>         print(f"({x},{y}): R={r}, G={g}, ndy={ndy:.4f}")
