[?2004l[?2004h>     ix = int(math.floor(px * 2.0 + 0.0))
[?2004l[?2004h>     iz = int(math.floor(pz * 2.0 + 0.99))
[?2004l[?2004h>     col = ((ix + iz + 1) & 1)
[?2004l[?2004h>     print("W" if col else "B", end=" ")
[?2004l[?2004h> print()
[?2004l[?2004h> 
