[?2004l[?2004h>                     g = clamp(sc.y * (0.2 + 0.6 * diff) * 255 + spec * 20);
[?2004l[?2004h>                     b = clamp(sc.z * (0.2 + 0.6 * diff) * 255 + spec * 20);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit && dy < 0) {
[?2004l[?2004h>                 double t = -(cam_y - ground_y) / dy;
