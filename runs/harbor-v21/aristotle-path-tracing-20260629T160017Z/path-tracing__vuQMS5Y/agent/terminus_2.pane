[?2004l[?2004h>                         if (sh_t > 0.001) {
[?2004l[?2004h>                             col *= 0.3; // shadow
[?2004l[?2004h>                         }
[?2004l[?2004h>                     }
[?2004l[?2004h>                     
[?2004l[?2004h>                     r = g = b = clamp(col);
[?2004l[?2004h>                     fprintf(f, "%d %d %d\n", (int)r, (int)g, (int)b);
[?2004l[?2004h>                     continue;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             // Sky
[?2004l[?2004h>             double t = 0.5 + 0.5 * wdir.y;
[?2004l[?2004h>             double sky_r = 146 + (191 - 146) * (1 - t);
[?2004l[?2004h>             double sky_g = 190 + (217 - 190) * (1 - t);
