[?2004l[?2004h>                         ix = int(math.floor(X * freq + xoff))
[?2004l[?2004h>                         iz = int(math.floor(Z * freq + zoff))
[?2004l[?2004h>                         pred = formula(ix, iz, inv)
[?2004l[?2004h>                         if pred == actual: m += 1
[?2004l[?2004h>                         t += 1
[?2004l[?2004h>                 acc = m / t if t > 0 else 0
[?2004l[?2004h>                 if acc > best:
[?2004l[?2004h>                     best = acc
[?2004l[?2004h>                     best_p = (xoff, zoff, inv)
[?2004l[?2004h>     print(f'{name}: best={100*best:.2f}% with xoff={best_p[0]}, zoff={best_p[1]}, inv={best_p[2]}')
