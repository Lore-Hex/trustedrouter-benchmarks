[?2004l[?2004h> typedef struct { double x, y, z; } Vec;
[?2004l[?2004h> 
[?2004l[?2004h> Vec vec(double x, double y, double z) {
[?2004l[?2004h>     Vec v = {x, y, z};
[?2004l[?2004h>     return v;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double dot(Vec a, Vec b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> Vec sub(Vec a, Vec b) { return vec(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> Vec add(Vec a, Vec b) { return vec(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> Vec mul(Vec a, double s) { return vec(a.x*s, a.y*s, a.z*s); }
[?2004l[?2004h> Vec normalize(Vec v) {
[?2004l[?2004h>     double len = sqrt(dot(v,v));
