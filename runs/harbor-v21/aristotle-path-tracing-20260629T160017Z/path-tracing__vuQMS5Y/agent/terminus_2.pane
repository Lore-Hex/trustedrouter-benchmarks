[?2004l[?2004h> 
[?2004l[?2004h> # The floor tile width at a given y is proportional to (y - horizon_y)
[?2004l[?2004h> # From earlier: width = 0.667 * (y - 900)
[?2004l[?2004h> # 
[?2004l[?2004h> # For perspective projection of ground plane at y=-0.5 (camera height H):
[?2004l[?2004h> # Let camera be at (0, H, 0), looking along -z.
[?2004l[?2004h> # The image plane is at z = -f (focal length).
[?2004l[?2004h> # A point on the ground (X, -0.5, Z) projects to:
[?2004l[?2004h> #   x_screen = f * X / Z + w/2
[?2004l[?2004h> #   y_screen = f * (H - (-0.5)) / Z + h/2 = f * (H + 0.5) / Z + h/2
[?2004l[?2004h> # 
[?2004l[?2004h> # So Z = f * (H + 0.5) / (y_screen - h/2)
[?2004l[?2004h> # And tile width on screen = f * (tile_size / Z) = tile_size * (y_screen - h/2) / (H + 0.5)
[?2004l[?2004h> # 
[?2004l[?2004h> # From data: width / (y - 900) ≈ 0.667
[?2004l[?2004h> # So tile_size / (H + 0.5) ≈ 0.667
[?2004l[?2004h> # 
[?2004l[?2004h> # If tile_size = 0.5 (since we used freq=2), then:
[?2004l[?2004h> # H + 0.5 = 0.5 / 0.667 = 0.75, so H = 0.25
[?2004l[?2004h> # But the camera height might be different
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the focal length f by considering the field of view
[?2004l[?2004h> # At y=0 (top of image), the direction's y-component is:
[?2004l[?2004h> # dy = -(0 - h/2) / fov = 900 / fov
[?2004l[?2004h> # The normalized y-component = 900 / sqrt((dx)^2 + (900)^2 + fov^2)
[?2004l[?2004h> # At x=w/2 (x=1200), dx=0, so ndy = 900 / sqrt(900^2 + fov^2)
[?2004l[?2004h> # From data: at (1200,0), ndy = 0.7071
[?2004l[?2004h> # So 900 / sqrt(900^2 + fov^2) = 0.7071
[?2004l[?2004h> # 900^2 / (900^2 + fov^2) = 0.5
[?2004l[?2004h> # 2 * 900^2 = 900^2 + fov^2
[?2004l[?2004h> # fov^2 = 900^2
[?2004l[?2004h> # fov = 900
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Focal length fov = 900 pixels")
[?2004l[?2004h> 
[?2004l[?2004h> # Now, the camera height H determines the horizon position.
[?2004l[?2004h> # If camera is at height H above the ground plane (which is at y=0), 
[?2004l[?2004h> # then the horizon is at the same height as the camera's eye level.
[?2004l[?2004h> # The horizon in the image is at y = h/2 = 900 (center of image).
[?2004l[?2004h> # This means the camera is looking horizontally, and the ground is at some y < 0.
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, if the camera is at (0, H, 0) looking at (0, 0, -infinity),
[?2004l[?2004h> # then the horizon is at y = h/2 = 900.
[?2004l[?2004h> # The ground plane is at y = 0 (or some value below camera).
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the ground plane height by examining the floor at the bottom of the image
[?2004l[?2004h> # At the bottom (y=1799), the closest point on the ground is where the ray hits the ground.
[?2004l[?2004h> # The ray direction at bottom center (1200, 1799):
[?2004l[?2004h> # dy = -(1799 - 900) / 900 = -0.9989
[?2004l[?2004h> # dx = 0
[?2004l[?2004h> # So dir = (0, -0.9989, -1) normalized = (0, -0.7071, -0.7071)
[?2004l[?2004h> # The ray starts at camera (0, H, 0).
[?2004l[?2004h> # The ground plane equation: y = ground_y
[?2004l[?2004h> # t = (camera_y - ground_y) / (-dir.y)
[?2004l[?2004h> # The point on ground: Z = camera_z + dir.z * t = 0 + (-0.7071) * t
[?2004l[?2004h> # The horizontal distance from camera: sqrt(X^2 + Z^2)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's determine the checkerboard frequency by matching the pattern at y=1000
[?2004l[?2004h> print("\nAnalyzing floor pattern to find camera height...")
[?2004l[?2004h> 
[?2004l[?2004h> # At y=1000, the tile width is about 67 pixels
[?2004l[?2004h> # width = tile_size * (y - 900) / (H + 0.5)? No wait, the ground might be at different height
[?2004l[?2004h> 
[?2004l[?2004h> # Let's just try different camera heights and see which gives the correct sphere position
[?2004l[?2004h> 
[?2004l[?2004h> # The sphere top is at y=809 at x=1200
[?2004l[?2004h> # The sphere appears above the horizon, so it's physically above the ground
