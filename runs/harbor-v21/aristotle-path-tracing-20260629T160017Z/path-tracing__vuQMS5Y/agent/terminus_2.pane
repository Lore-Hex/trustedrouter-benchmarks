[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the sphere center and radius by examining boundaries
[?2004l[?2004h> # Top of sphere: y=809 at x=1200 (where it meets the sky)
[?2004l[?2004h> # Left edge at y=900: x=1041
[?2004l[?2004h> # Right edge at y=900: x=1317
[?2004l[?2004h> # Bottom of sphere (where shadow/floor meets): 
