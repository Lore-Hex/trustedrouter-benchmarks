[?2004l[?2004h> # Center x = 1179, R_app = 138
[?2004l[?2004h> 
[?2004l[?2004h> # The sphere center projection:
[?2004l[?2004h> x_c = 1179.0
[?2004l[?2004h> y_c = 809 + 138.0  # = 947
[?2004l[?2004h> 
[?2004l[?2004h> # For a given Zs:
[?2004l[?2004h> # Xs = (x_c - 1200) * (-Zs) / fov = -21 * (-Zs) / 900
[?2004l[?2004h> # Ys = H + (y_c - 900) * (-Zs) / fov = 1.5 + 47 * (-Zs) / 900
[?2004l[?2004h> # R = R_app * (-Zs) / fov = 138 * (-Zs) / 900
[?2004l[?2004h> 
[?2004l[?2004h> # We need to find Zs such that the top ray is tangent
[?2004l[?2004h> # At top (1200, 809): ray = (0, 0.100598, -0.994927)
