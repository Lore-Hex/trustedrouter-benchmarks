[?2004hroot@dcf07d044a6c:/app# python3 << 'EOF'
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> with open('/app/image.ppm') as f:
[?2004l[?2004h>     next(f); wh=next(f).split(); w,h=int(wh[0]),int(wh[1]); next(f)
[?2004l[?2004h>     ref = list(map(int, f.read().split()))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute the exact sky formula by examining the relationship
[?2004l[?2004h> # between the pixel's vertical angle and the R,G values
[?2004l[?2004h> 
[?2004l[?2004h> # The sky color at a pixel depends ONLY on the y-component of the ray direction
[?2004l[?2004h> # Let's verify this by checking that pixels with same ndy have same color
[?2004l[?2004h> 
[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Check if pixels with same ndy have same R
[?2004l[?2004h> print("Checking consistency: pixels with same ndy should have same R")
[?2004l[?2004h> # Find pairs of pixels with similar ndy
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> ndy_map = defaultdict(list)
[?2004l[?2004h> for y in range(0, 899, 10):
[?2004l[?2004h>     for x in range(0, 2400, 10):
[?2004l[?2004h>         i = (y*w + x)*3
[?2004l[?2004h>         r, g, b = ref[i], ref[i+1], ref[i+2]
[?2004l[?2004h>         if b == 255 and r >= 100:
[?2004l[?2004h>             dx = (x - w/2.0) / fov
[?2004l[?2004h>             dy = -(y - h/2.0) / fov
[?2004l[?2004h>             n = math.sqrt(dx*dx + dy*dy + 1.0)
[?2004l[?2004h>             ndy = dy / n
[?2004l[?2004h>             ndy_rounded = round(ndy * 100)  # to 2 decimal places
[?2004l[?2004h>             ndy_map[ndy_rounded].append((r, g, x, y))
[?2004l[?2004h> 
[?2004l[?2004h> # Check consistency
[?2004l[?2004h> print("Checking some ndy values:")
[?2004l[?2004h> for ndy_key in sorted(ndy_map.keys(), reverse=True)[:10]:
[?2004l[?2004h>     vals = ndy_map[ndy_key]
[?2004l[?2004h>     avg_r = sum(v[0] for v in vals) / len(vals)
[?2004l[?2004h>     avg_g = sum(v[1] for v in vals) / len(vals)
[?2004l[?2004h>     min_r = min(v[0] for v in vals)
[?2004l[?2004h>     max_r = max(v[0] for v in vals)
[?2004l[?2004h>     print(f"ndy~{ndy_key/100:.2f}: avg_R={avg_r:.1f}, avg_G={avg_g:.1f}, range_R=[{min_r},{max_r}], count={len(vals)}")
[?2004l[?2004h>     if len(vals) > 1:
[?2004l[?2004h>         # Check if any difference
[?2004l[?2004h>         diff_r = max(v[0] for v in vals) - min(v[0] for v in vals)
[?2004l[?2004h>         if diff_r > 2:
[?2004l[?2004h>             print(f"  WARNING: R varies by {diff_r}!")
[?2004l[?2004h> EOF
