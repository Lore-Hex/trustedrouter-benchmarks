[?2004l[?2004h> 
[?2004l[?2004h> # Solve for floor parameters using the first boundary positions
[?2004l[?2004h> # At y=920: first boundary at x=11 (W->B)
[?2004l[?2004h> # At y=950: first boundary at x=22 (B->W)
[?2004l[?2004h> # At y=1000: first boundary at x=61 (W->B)
[?2004l[?2004h> # At y=1100: first boundary at x=131 (W->B)
