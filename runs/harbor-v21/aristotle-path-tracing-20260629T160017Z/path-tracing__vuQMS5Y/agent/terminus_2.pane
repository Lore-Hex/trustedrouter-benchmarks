[?2004l[?2004h> right_x, right_y = 1317, 900
[?2004l[?2004h> 
[?2004l[?2004h> # Ray directions at these points (normalized)
[?2004l[?2004h> def get_dir(x, y):
[?2004l[?2004h>     dx = (x - 1200) / fov
[?2004l[?2004h>     dy = -(y - 900) / fov
[?2004l[?2004h>     n = math.sqrt(dx*dx + dy*dy + 1)
[?2004l[?2004h>     return dx/n, dy/n, -1/n
[?2004l[?2004h> 
