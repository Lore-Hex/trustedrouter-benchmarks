[?2004l[?2004h> import math
[?2004l[?2004h> # Quick verification of sphere parameters
[?2004l[?2004h> # From silhouette: center at (1179, 947), R_app=138
[?2004l[?2004h> # With d=1.5, freq=1.0:
[?2004l[?2004h> # x_c = 1200 + 900*Xs/(-Zs) = 1179 => Xs = -21*(-Zs)/900
[?2004l[?2004h> # y_c = 900 + 900*(Ys-1.5)/(-Zs) = 947 => Ys = 1.5 + 47*(-Zs)/900
[?2004l[?2004h> # R_app = 900*R/(-Zs) = 138 => R = 138*(-Zs)/900
[?2004l[?2004h> # Tangent at top: (dot(oc,dir))^2 = dot(oc,oc) - R^2
[?2004l[?2004h> # Using Zs = -6.522:
[?2004l[?2004h> Zs = -6.522
[?2004l[?2004h> Xs = -21*(-Zs)/900
[?2004l[?2004h> Ys = 1.5 + 47*(-Zs)/900
[?2004l[?2004h> R = 138*(-Zs)/900
[?2004l[?2004h> print(f'Xs={Xs:.6f}, Ys={Ys:.6f}, Zs={Zs:.6f}, R={R:.6f}')
[?2004l[?2004h> # Check tangent at top
[?2004l[?2004h> fov=900.0; H=1.5
[?2004l[?2004h> dx,dy,dz=0,-(809-900)/fov,-1
[?2004l[?2004h> n=math.sqrt(dx*dx+dy*dy+dz*dz)
[?2004l[?2004h> ndx,ndy,ndz=dx/n,dy/n,dz/n
[?2004l[?2004h> oc=(Xs,Ys-H,Zs)
[?2004l[?2004h> dot=oc[0]*ndx+oc[1]*ndy+oc[2]*ndz
[?2004l[?2004h> disc=dot*dot-(oc[0]**2+oc[1]**2+oc[2]**2)+R**2
[?2004l[?2004h> print(f'Top tangent disc={disc:.10f} (should be 0)')
[?2004l[?2004h> "
