[?2004hroot@dcf07d044a6c:/app# python3 << 'EOF'
[?2004l[?2004h> with open('/app/image.ppm') as f:
[?2004l[?2004h>     hdr1 = next(f)
[?2004l[?2004h>     hdr2 = next(f).split()
[?2004l[?2004h>     w,h = int(hdr2[0]), int(hdr2[1])
[?2004l[?2004h>     next(f)  # maxval
[?2004l[?2004h>     
[?2004l[?2004h>     # Sample first row (sky)
[?2004l[?2004h>     row0 = [next(f).strip().split() for _ in range(w)]
[?2004l[?2004h>     print("Row 0 samples:", *row0[:5], "...", *row0[w//2-2:w//2+2], "...", *row0[-5:])
[?2004l[?2004h>     
[?2004l[?2004h>     # Read beyond first row - let's sample specific rows efficiently
[?2004l[?2004h>     import sys
[?2004l[?2004h>     line_num = w
[?2004l[?2004h>     sample_rows = [0, h//4, h//2, 3*h//4, h-1]
[?2004l[?2004h>     for target_row in sample_rows:
[?2004l[?2004h>         if target_row == 0:
[?2004l[?2004h>             pixels = row0
[?2004l[?2004h>         else:
[?2004l[?2004h>             # Skip to target row
[?2004l[?2004h>             for _ in range(line_num, target_row * w):
[?2004l[?2004h>                 next(f)
[?2004l[?2004h>             line_num = target_row * w
[?2004l[?2004h>             pixels = [next(f).strip().split() for _ in range(w)]
[?2004l[?2004h>             line_num += w
[?2004l[?2004h>         # Sample: left edge, center, right edge
[?2004l[?2004h>         left = pixels[0]
[?2004l[?2004h>         center = pixels[w//2]
[?2004l[?2004h>         right = pixels[w-1]
[?2004l[?2004h>         print(f"Row {target_row}: left={left} center={center} right={right}")
