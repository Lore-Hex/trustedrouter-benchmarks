[?2004l[?2004h> dx = (1041-1200)/fov
[?2004l[?2004h> n = math.sqrt(dx*dx + 0 + 1)
[?2004l[?2004h> ndx = dx/n
[?2004l[?2004h> ndz = -1/n
[?2004l[?2004h> 
[?2004l[?2004h> oc_x = Xs
[?2004l[?2004h> oc_y = Ys - H
[?2004l[?2004h> oc_z = Zs
[?2004l[?2004h> dot_oc_dir = oc_x*ndx + oc_y*0 + oc_z*ndz
[?2004l[?2004h> disc_left = dot_oc_dir**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h> print(f'Left tangent disc = {disc_left:.6f}')
[?2004l[?2004h> 
[?2004l[?2004h> # Right edge (1317, 900):
[?2004l[?2004h> dx = (1317-1200)/fov
[?2004l[?2004h> n = math.sqrt(dx*dx + 0 + 1)
[?2004l[?2004h> ndx = dx/n
[?2004l[?2004h> ndz = -1/n
[?2004l[?2004h> dot_oc_dir = oc_x*ndx + oc_y*0 + oc_z*ndz
[?2004l[?2004h> disc_right = dot_oc_dir**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
