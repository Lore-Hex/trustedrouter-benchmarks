[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> #define W 2400
[?2004l[?2004h> #define H 1800
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { double x, y, z; } Vec;
[?2004l[?2004h> 
[?2004l[?2004h> Vec v(double x, double y, double z) {
[?2004l[?2004h>     Vec r = {x, y, z};
[?2004l[?2004h>     return r;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double dot(Vec a, Vec b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> Vec sub(Vec a, Vec b) { return v(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> Vec add(Vec a, Vec b) { return v(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> Vec mul(Vec a, double s) { return v(a.x*s, a.y*s, a.z*s); }
[?2004l[?2004h> Vec norm(Vec a) {
[?2004l[?2004h>     double l = sqrt(dot(a,a));
[?2004l[?2004h>     return v(a.x/l, a.y/l, a.z/l);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> double clamp(double x) { return x < 0 ? 0 : (x > 255 ? 255 : x); }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     FILE *f = fopen("reconstructed.ppm", "w");
[?2004l[?2004h>     fprintf(f, "P3\n%d %d\n255\n", W, H);
[?2004l[?2004h>     
[?2004l[?2004h>     double fov = 900.0;
[?2004l[?2004h>     double cam_y = 1.5;
[?2004l[?2004h>     double ground_y = 0.0;
[?2004l[?2004h>     double d = cam_y - ground_y;
[?2004l[?2004h>     
[?2004l[?2004h>     // Sphere parameters (adjusted to match silhouette)
[?2004l[?2004h>     Vec sp = v(-0.152, 1.841, -6.522);
[?2004l[?2004h>     double sr = 1.0;
[?2004l[?2004h>     Vec sc = v(1.0, 0.2, 0.2);
[?2004l[?2004h>     
[?2004l[?2004h>     // Light
[?2004l[?2004h>     Vec lp = v(5, 5, 5);
[?2004l[?2004h>     
[?2004l[?2004h>     // Floor checkerboard
[?2004l[?2004h>     double freq = 1.0;
[?2004l[?2004h>     double xoff = -1.0;
[?2004l[?2004h>     double zoff = -1.0;
[?2004l[?2004h>     int inv = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     for (int y = 0; y < H; y++) {
[?2004l[?2004h>         for (int x = 0; x < W; x++) {
[?2004l[?2004h>             double dx = (x - W/2.0) / fov;
[?2004l[?2004h>             double dy = -(y - H/2.0) / fov;
[?2004l[?2004h>             
[?2004l[?2004h>             Vec dir = norm(v(dx, dy, -1));
[?2004l[?2004h>             
[?2004l[?2004h>             double r, g, b;
[?2004l[?2004h>             int hit = 0;
[?2004l[?2004h>             
[?2004l[?2004h>             // Sphere intersection
[?2004l[?2004h>             Vec oc = sub(v(0, cam_y, 0), sp);
[?2004l[?2004h>             double a = dot(dir, dir);
[?2004l[?2004h>             double bb = 2 * dot(oc, dir);
[?2004l[?2004h>             double c = dot(oc, oc) - sr * sr;
[?2004l[?2004h>             double disc = bb*bb - 4*a*c;
[?2004l[?2004h>             
