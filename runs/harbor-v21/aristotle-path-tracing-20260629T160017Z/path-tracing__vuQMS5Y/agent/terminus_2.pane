[?2004l[?2004h> # Let's compute the exact sky formula
[?2004l[?2004h> # The sky gradient R seems to follow: R = base_R + fx(x) + fy(y)
[?2004l[?2004h> # Where base_R at (1200,0) = 146
[?2004l[?2004h> # fx(x) is 0 at x=1200, increases to 13 at edges (x=0 or x=2399)
[?2004l[?2004h> # fy(y) is 0 at y=0, increases to 45 at y=899 (horizon: 191 - 146 = 45)
[?2004l[?2004h> 
[?2004l[?2004h> # But the fx(x) seems to decrease as y increases (the gradient flattens)
[?2004l[?2004h> # Let's check: at y=0, edge offset = 13; at y=800, edge offset = 3
[?2004l[?2004h> # So fx(x,y) = fx0(x) * (1 - y/900) maybe?
[?2004l[?2004h> 
[?2004l[?2004h> # Let's extract the x-profile at each y and see how it changes
[?2004l[?2004h> print("X-profile at various y (R value vs distance from center):")
[?2004l[?2004h> for y in [0, 200, 400, 600, 800]:
[?2004l[?2004h>     i_center = (y*w + 1200)*3
[?2004l[?2004h>     r_center = p[i_center]
[?2004l[?2004h>     if r_center < 100:
