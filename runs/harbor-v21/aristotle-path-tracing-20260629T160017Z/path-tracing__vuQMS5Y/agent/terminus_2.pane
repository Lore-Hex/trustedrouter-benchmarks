[?2004l00*matches/tot[?2004h> # Let's check the exact camera model by looking at the sphere and floor together
[?2004l[?2004h> # The sphere top is at y=809, center is around x=1199.5
[?2004l[?2004h> # The floor tile width at y=1000 is 67 pixels
[?2004l[?2004h> 
[?2004l[?2004h> # Let me check if the camera is looking at the origin from (0, 1.5, 5)
[?2004l[?2004h> # as in the classic "Ray Tracing in One Weekend"
[?2004l[?2004h> 
[?2004l[?2004h> # For this camera, the camera coordinate system:
[?2004l[?2004h> cz = (0-0, 0-1.5, 0-5)  # target - eye
[?2004l[?2004h> cz_len = math.sqrt(0 + 2.25 + 25)  # sqrt(27.25)
[?2004l[?2004h> print(f"cz length = {cz_len}")
[?2004l[?2004h> # cz = (0, -1.5/5.219, -5/5.219) = (0, -0.287, -0.958)
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, the camera looks along -z in camera space
[?2004l[?2004h> # The world direction for pixel (x,y) is:
[?2004l[?2004h> # dir = cx * u + cy * v + cz * (-fov)
[?2004l[?2004h> # where u = (x - w/2)/fov, v = -(y - h/2)/fov
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check if the ndy we computed matches this model
[?2004l[?2004h> # ndy = dir.y = cx.y * u + cy.y * v + cz.y * (-1)
[?2004l[?2004h> # 
[?2004l[?2004h> # With our camera at (0, 1.5, 5) looking at (0, 0, 0):
[?2004l[?2004h> # cz = (0, -0.287, -0.958)
[?2004l[?2004h> # cy = (0, 0.958, -0.287)
[?2004l[?2004h> # cx = (1, 0, 0)
[?2004l[?2004h> 
[?2004l[?2004h> # For a pixel (x,y):
[?2004l[?2004h> # u = (x - 1200) / 900
[?2004l[?2004h> # v = -(y - 900) / 900
[?2004l[?2004h> # 
[?2004l[?2004h> # dir = cx*u + cy*v + cz*(-1)
[?2004l[?2004h> # dir.x = 1*u + 0*v + 0*(-1) = u
[?2004l[?2004h> # dir.y = 0*u + 0.958*v + (-0.287)*(-1) = 0.958*v + 0.287
[?2004l[?2004h> # dir.z = 0*u + (-0.287)*v + (-0.958)*(-1) = -0.287*v + 0.958
[?2004l[?2004h> 
[?2004l[?2004h> # At (1200, 0): u=0, v=1 (since y=0, v = -(0-900)/900 = 1)
[?2004l[?2004h> # dir.y = 0.958*1 + 0.287 = 1.245
[?2004l[?2004h> # dir.z = -0.287*1 + 0.958 = 0.671
[?2004l[?2004h> # norm = sqrt(0 + 1.245^2 + 0.671^2) = sqrt(1.550 + 0.450) = sqrt(2.0) = 1.414
[?2004l[?2004h> # ndy = 1.245 / 1.414 = 0.880
[?2004l[?2004h> 
[?2004l[?2004h> # But earlier we computed ndy = 0.707 for (1200, 0)
[?2004l[?2004h> # So this camera model doesn't match!
[?2004l[?2004h> 
[?2004l[?2004h> # Let's find the correct camera model
[?2004l[?2004h> # We know ndy at (1200, 0) = 0.7071
[?2004l[?2004h> # ndy at (0, 0) = 0.5145
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, the relationship might be:
[?2004l[?2004h> # ndy = v / sqrt(u^2 + v^2 + 1)  (if camera is looking along -z, up=y)
[?2004l[?2004h> # At (1200, 0): u=0, v=-(-900)/900 = 1
[?2004l[?2004h> # ndy = 1 / sqrt(0 + 1 + 1) = 1 / 1.414 = 0.7071 ✓
[?2004l[?2004h> # At (0, 0): u=-1200/900 = -1.333, v=1
[?2004l[?2004h> # ndy = 1 / sqrt(1.778 + 1 + 1) = 1 / sqrt(3.778) = 1 / 1.944 = 0.5145 ✓
[?2004l[?2004h> 
[?2004l[?2004h> # So the camera model IS simply looking along -z with up=y!
[?2004l[?2004h> # No transformation needed - the world space is the same as camera space!
[?2004l[?2004h> 
[?2004l[?2004h> print("Camera model: looking along -z, up = y")
[?2004l[?2004h> print("World space = camera space")
[?2004l[?2004h> print("This means the camera is at origin looking along -z")
[?2004l[?2004h> 
[?2004l[?2004h> # But then where is the ground?
[?2004l[?2004h> # The horizon is at y=900 (center of image)
[?2004l[?2004h> # If the camera is at height H above the ground, looking horizontally,
[?2004l[?2004h> # then the horizon is at the same height as the camera
[?2004l[?2004h> # The ground extends downward from the horizon
[?2004l[?2004h> 
[?2004l[?2004h> # For a ray through pixel (x,y):
[?2004l[?2004h> # dir = (dx, dy, -1) where dx=(x-1200)/900, dy=-(y-900)/900
[?2004l[?2004h> # The ray hits the ground at y = G (ground level)
[?2004l[?2004h> # Camera is at (0, H, 0) where H is the camera height
[?2004l[?2004h> # 
[?2004l[?2004h> # t = (G - H) / dir.y = (G - H) / dy
[?2004l[?2004h> # At the horizon (y=900), dy=0, so the ground is at infinity
[?2004l[?2004h> # For y > 900, dy < 0, looking down
[?2004l[?2004h> 
[?2004l[?2004h> # The world X coordinate: X = cam.x + t * dir.x = 0 + t * dx
[?2004l[?2004h> # The world Z coordinate: Z = cam.z + t * dir.z = 0 + t * (-1) = -t
[?2004l[?2004h> 
[?2004l[?2004h> # So Z = (H - G) / (-dy) = (H - G) * 900 / (y - 900)
[?2004l[?2004h> # X = (x - 1200) / 900 * Z = (x - 1200) * (H - G) / (y - 900)
[?2004l[?2004h> 
[?2004l[?2004h> # The tile width at screen is: width = T * (y - 900) / (H - G)
[?2004l[?2004h> # From observation: width / (y - 900) = 0.667
[?2004l[?2004h> # So T / (H - G) = 0.667
[?2004l[?2004h> 
[?2004l[?2004h> # If T = 0.5, H - G = 0.75
[?2004l[?2004h> # If T = 1.0, H - G = 1.5
[?2004l[?2004h> 
[?2004l[?2004h> print("\nLet's test both possibilities:")
[?2004l[?2004h> 
[?2004l[?2004h> for d in [0.75, 1.5]:
[?2004l[?2004h>     T = 0.5 if d == 0.75 else 1.0
[?2004l[?2004h>     print(f"\nd = H - G = {d}, T = {T}:")
[?2004l[?2004h>     
[?2004l[?2004h>     # Test a few floor pixels
[?2004l[?2004h>     matches = 0
[?2004l[?2004h>     total = 0
[?2004l[?2004h>     for y in [950, 1000, 1100, 1200, 1300]:
[?2004l[?2004h>         for x in range(0, 2400, 50):
[?2004l[?2004h>             i = (y*w + x)*3
[?2004l[?2004h>             r, g, b = ref[i], ref[i+1], ref[i+2]
[?2004l[?2004h>             if r == g == b and r in [67, 152]:
[?2004l[?2004h>                 actual = 1 if r == 152 else 0
[?2004l[?2004h>                 dy = -(y - h/2.0) / fov
[?2004l[?2004h>                 Z = d / (-dy)
[?2004l[?2004h>                 X = (x - w/2.0) * Z / fov
[?2004l[?2004h>                 ix = int(math.floor(X / T))
[?2004l[?2004h>                 iz = int(math.floor(Z / T))
[?2004l[?2004h>                 pred = (ix + iz) & 1
[?2004l[?2004h>                 if pred == actual:
[?2004l[?2004h>                     matches += 1
[?2004l[?2004h>                 total += 1
[?2004l[?2004h>     print(f"  Accuracy: {matches}/{total} = {100*matches/total:.2f}%")
[?2004l[?2004h> EOF
