[?2004l[?2004h> l_dx, l_dy, l_dz = get_dir(left_x, left_y)
[?2004l[?2004h> r_dx, r_dy, r_dz = get_dir(right_x, right_y)
[?2004l[?2004h> 
[?2004l[?2004h> print("Ray directions:")
