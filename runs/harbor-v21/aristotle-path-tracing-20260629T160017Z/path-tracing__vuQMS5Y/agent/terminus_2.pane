[?2004l[?2004h> print(f"  Right:  ({r_dx:.6f}, {r_dy:.6f}, {r_dz:.6f})")
[?2004l[?2004h> 
[?2004l[?2004h> # For each silhouette point, the ray is tangent to the sphere.
[?2004l[?2004h> # For a sphere at (Xs, Ys, Zs) with radius R:
[?2004l[?2004h> # oc = (Xs, Ys - H, Zs)  (vector from camera to sphere center)
[?2004l[?2004h> # Tangent condition: (dot(oc, dir))^2 = dot(oc, oc) - R^2
[?2004l[?2004h> 
[?2004l[?2004h> # Let's search for the sphere parameters that minimize the tangent errors
[?2004l[?2004h> print("\nSearching for sphere parameters...")
[?2004l[?2004h> 
[?2004l[?2004h> best_err = 1e10
[?2004l[?2004h> best = None
[?2004l[?2004h> 
[?2004l[?2004h> # The sphere center projects to:
