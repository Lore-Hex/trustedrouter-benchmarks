[?2004l[?2004h> # Actually: y = y_horizon + f * H / Z
[?2004l[?2004h> # So Z = f * H / (y - y_horizon)
[?2004l[?2004h> # Tile width in image = f * (tile_size / Z) = f * tile_size * (y - y_horizon) / (f * H) = tile_size * (y - y_horizon) / H
[?2004l[?2004h> # So tile_width = (tile_size / H) * (y - y_horizon)
[?2004l[?2004h> 
