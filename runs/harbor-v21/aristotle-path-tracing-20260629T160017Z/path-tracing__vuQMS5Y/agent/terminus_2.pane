[?2004l[?2004h> # The left edge at y=900 is at x=1041
[?2004l[?2004h> # The right edge at y=900 is at x=1317
[?2004l[?2004h> 
[?2004l[?2004h> # At the top (1200, 809): the ray direction is tangent to the sphere
[?2004l[?2004h> # dx = 0
[?2004l[?2004h> # dy = -(809 - 900) / fov = 91 / 900 = 0.101111
[?2004l[?2004h> # dz = -1
[?2004l[?2004h> 
[?2004l[?2004h> # At left edge (1041, 900): 
