[?2004l[?2004h> # y_c = 900 + fov * (Ys - H) / (-Zs)
[?2004l[?2004h> # R_app = fov * R / (-Zs)
[?2004l[?2004h> 
[?2004l[?2004h> # From silhouette: x_c = 1179, R_app = 138, y_c = 809 + 138 = 947
[?2004l[?2004h> # So Xs = (1179-1200) * (-Zs) / 900 = -21 * (-Zs) / 900
[?2004l[?2004h> # Ys = H + (947-900) * (-Zs) / 900 = 1.5 + 47 * (-Zs) / 900
[?2004l[?2004h> # R = 138 * (-Zs) / 900
[?2004l[?2004h> 
[?2004l[?2004h> # We need to find Zs that makes the top ray tangent
[?2004l[?2004h> 
[?2004l[?2004h> for zi in range(-8000, -1000):
