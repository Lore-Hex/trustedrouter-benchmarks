[?2004l[?2004h> def get_silhouette_radius_at_y(y_screen, Xs, Ys, Zs, R):
[?2004l[?2004h>     """Return the radius of the sphere silhouette at a given y_screen.
[?2004l[?2004h>     This is found by solving the tangent condition for x_screen at fixed y_screen.
[?2004l[?2004h>     """
