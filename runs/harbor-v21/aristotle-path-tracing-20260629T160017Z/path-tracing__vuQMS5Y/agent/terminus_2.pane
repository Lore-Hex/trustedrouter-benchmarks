[?2004l[?2004h>                     r = g = b = clamp(col);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit) {
[?2004l[?2004h>                 // Sky - function of vertical angle
