[?2004l[?2004h> # color = sky_color + (horizon_color - sky_color) * (1 - cos(theta))^n
[?2004l[?2004h> # where theta is the angle from zenith
[?2004l[?2004h> 
[?2004l[?2004h> # For a simple gradient sky used in many ray tracers:
[?2004l[?2004h> # t = 0.5 + 0.5 * dir.y  (where dir.y is the Y component of normalized ray direction)
[?2004l[?2004h> # color = (1-t) * sky_color + t * horizon_color
[?2004l[?2004h> 
[?2004l[?2004h> # Let's check this hypothesis
