[?2004l[?2004h>     p=list(map(int,data))
[?2004l[?2004h> 
[?2004l[?2004h> # Let's compute the exact sky formula
[?2004l[?2004h> # Normalize coordinates: x in [-1, 1], y in [-1, 1]
[?2004l[?2004h> # But the sky only occupies top 900 rows
[?2004l[?2004h> 
[?2004l[?2004h> print("Computing normalized coordinates and RGB values:")
[?2004l[?2004h> # Sample a grid
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> # The horizon is at y=900, so the sky is y in [0, 899]
[?2004l[?2004h> # The gradient seems symmetric
[?2004l[?2004h> 
[?2004l[?2004h> # Check if R and G follow a simple function of angle from vertical
[?2004l[?2004h> # Let's compute direction vectors: assume perspective camera at origin looking along -z
[?2004l[?2004h> # with field of view covering the image
[?2004l[?2004h> 
[?2004l[?2004h> # Actually, let's just check if the sky color is a function of (x, y) position
[?2004l[?2004h> # by checking if values are consistent across different (x,y) with same direction
[?2004l[?2004h> 
[?2004l[?2004h> # For a given pixel (x,y), compute direction in 3D: 
[?2004l[?2004h> # Assume camera at (0,0,0), looking towards -z, with up = y
[?2004l[?2004h> # Image plane is at z = -1, size w x h
[?2004l[?2004h> # Then direction = (x - w/2, -(y - h/2), -focal_length)
[?2004l[?2004h> 
[?2004l[?2004h> w=2400
[?2004l[?2004h> h=1800
[?2004l[?2004h> # Let's check if sky R is a function of the direction vector's Y component
[?2004l[?2004h> print("\nChecking if R is function of vertical angle only (y=0, varying x):")
[?2004l[?2004h> for x in range(0, 2401, 200):
[?2004l[?2004h>     i=(0*w+x)*3
[?2004l[?2004h>     r,g,b=p[i],p[i+1],p[i+2]
[?2004l[?2004h>     # Compute direction
[?2004l[?2004h>     dx = (x - w/2) / (w/2)  # normalized to [-1, 1]
[?2004l[?2004h>     dy = -(0 - h/2) / (h/2)  # normalized to [-1, 1]
[?2004l[?2004h>     dz = -1.0  # assume focal length = 1
[?2004l[?2004h>     # Normalize
[?2004l[?2004h>     norm = math.sqrt(dx*dx + dy*dy + dz*dz)
[?2004l[?2004h>     ndx, ndy, ndz = dx/norm, dy/norm, dz/norm
[?2004l[?2004h>     # The zenith angle: angle from up vector (0,1,0)
[?2004l[?2004h>     cos_zenith = ndy  # dot with (0,1,0)
[?2004l[?2004h>     print(f"x={x}: R={r}, G={g}, cos_zenith={cos_zenith:.4f}")
