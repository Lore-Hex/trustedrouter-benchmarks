[?2004l[?2004h>                          cx.y*dir.x + cy.y*dir.y + cz.y*dir.z,
[?2004l[?2004h>                          cx.z*dir.x + cy.z*dir.y + cz.z*dir.z);
[?2004l[?2004h>             
[?2004l[?2004h>             double r, g, b;
[?2004l[?2004h>             int hit = 0;
[?2004l[?2004h>             
[?2004l[?2004h>             // Sphere intersection
[?2004l[?2004h>             Vec oc = sub(cam, sp);
[?2004l[?2004h>             double a = dot(wdir, wdir);
[?2004l[?2004h>             double bb = 2 * dot(oc, wdir);
[?2004l[?2004h>             double c = dot(oc, oc) - sr * sr;
[?2004l[?2004h>             double disc = bb*bb - 4*a*c;
[?2004l[?2004h>             
[?2004l[?2004h>             if (disc > 0) {
[?2004l[?2004h>                 double t = (-bb - sqrt(disc)) / (2 * a);
[?2004l[?2004h>                 if (t > 0.001) {
[?2004l[?2004h>                     Vec pt = add(cam, mul(wdir, t));
[?2004l[?2004h>                     Vec n = norm(sub(pt, sp));
[?2004l[?2004h>                     Vec L = norm(sub(lp, pt));
[?2004l[?2004h>                     double diff = dot(n, L);
[?2004l[?2004h>                     if (diff < 0) diff = 0;
[?2004l[?2004h>                     
[?2004l[?2004h>                     Vec V = mul(wdir, -1);
[?2004l[?2004h>                     Vec Hv = norm(add(L, V));
[?2004l[?2004h>                     double spec = dot(n, Hv);
[?2004l[?2004h>                     if (spec < 0) spec = 0;
[?2004l[?2004h>                     spec = pow(spec, 20);
[?2004l[?2004h>                     
[?2004l[?2004h>                     r = clamp(sc.x * (0.2 + 0.8 * diff) * 255 + spec * 200);
[?2004l[?2004h>                     g = clamp(sc.y * (0.2 + 0.8 * diff) * 255 + spec * 40);
[?2004l[?2004h>                     b = clamp(sc.z * (0.2 + 0.8 * diff) * 255 + spec * 40);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit && wdir.y < 0) {
[?2004l[?2004h>                 // Ground plane intersection
[?2004l[?2004h>                 double t = -(cam.y - ground_y) / wdir.y;
[?2004l[?2004h>                 if (t > 0) {
[?2004l[?2004h>                     Vec pt = add(cam, mul(wdir, t));
[?2004l[?2004h>                     double Z = pt.z;  // distance along ground
[?2004l[?2004h>                     double X = pt.x;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Checkerboard
[?2004l[?2004h>                     int ix = (int)(floor(X * freq + xoff));
[?2004l[?2004h>                     int iz = (int)(floor(Z * freq + zoff));
[?2004l[?2004h>                     double col = ((ix + iz + inv) & 1) ? 152.0 : 67.0;
[?2004l[?2004h>                     
[?2004l[?2004h>                     // Shadow
[?2004l[?2004h>                     Vec L = norm(sub(lp, pt));
[?2004l[?2004h>                     Vec oc2 = sub(pt, sp);
[?2004l[?2004h>                     double sa = dot(L, L);
[?2004l[?2004h>                     double sb = 2 * dot(oc2, L);
[?2004l[?2004h>                     double sc_ = dot(oc2, oc2) - sr * sr;
[?2004l[?2004h>                     double sd = sb*sb - 4*sa*sc_;
[?2004l[?2004h>                     if (sd > 0) {
[?2004l[?2004h>                         double st = (-sb - sqrt(sd)) / (2 * sa);
[?2004l[?2004h>                         if (st > 0.001) {
[?2004l[?2004h>                             col *= 0.35;
[?2004l[?2004h>                         }
[?2004l[?2004h>                     }
[?2004l[?2004h>                     
[?2004l[?2004h>                     r = g = b = clamp(col);
[?2004l[?2004h>                     hit = 1;
[?2004l[?2004h>                 }
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             if (!hit) {
[?2004l[?2004h>                 // Sky
[?2004l[?2004h>                 double ndy = wdir.y;
[?2004l[?2004h>                 if (ndy < 0) ndy = 0;
[?2004l[?2004h>                 if (ndy > 0.7071) ndy = 0.7071;
[?2004l[?2004h>                 r = clamp(191.5 - 64.0 * ndy);
[?2004l[?2004h>                 g = clamp(217.1 - 38.4 * ndy);
[?2004l[?2004h>                 b = 255;
[?2004l[?2004h>             }
[?2004l[?2004h>             
[?2004l[?2004h>             fprintf(f, "%d %d %d\n", (int)r, (int)g, (int)b);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
[?2004l[?2004h> ENDCODE
