[?2004l[?2004h>     Xs = -21 * (-Zs) / 900
[?2004l[?2004h>     Ys = 1.5 + 47 * (-Zs) / 900
[?2004l[?2004h>     R = 138 * (-Zs) / 900
[?2004l[?2004h>     
[?2004l[?2004h>     oc_x = Xs
[?2004l[?2004h>     oc_y = Ys - H
[?2004l[?2004h>     oc_z = Zs
[?2004l[?2004h>     
