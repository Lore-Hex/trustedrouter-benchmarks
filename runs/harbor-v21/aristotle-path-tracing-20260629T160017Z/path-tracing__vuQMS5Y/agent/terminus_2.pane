[?2004hroot@dcf07d044a6c:/app# python3 << 'EOF'
[?2004l[?2004h> import math
[?2004l[?2004h> 
[?2004l[?2004h> H = 1.5  # camera height
[?2004l[?2004h> fov = 900.0
[?2004l[?2004h> 
[?2004l[?2004h> # Compute normalized ray directions for the three silhouette points
[?2004l[?2004h> def get_ray(x_screen, y_screen):
[?2004l[?2004h>     dx = (x_screen - 1200) / fov
[?2004l[?2004h>     dy = -(y_screen - 900) / fov
[?2004l[?2004h>     n = math.sqrt(dx*dx + dy*dy + 1.0)
[?2004l[?2004h>     return dx/n, dy/n, -1/n
[?2004l[?2004h> 
[?2004l[?2004h> t_dx, t_dy, t_dz = get_ray(1200, 809)  # top
[?2004l[?2004h> l_dx, l_dy, l_dz = get_ray(1041, 900)  # left
[?2004l[?2004h> r_dx, r_dy, r_dz = get_ray(1317, 900)  # right
[?2004l[?2004h> 
[?2004l[?2004h> print("Ray directions:")
[?2004l[?2004h> print(f"  Top:    ({t_dx:.6f}, {t_dy:.6f}, {t_dz:.6f})")
[?2004l[?2004h> print(f"  Left:   ({l_dx:.6f}, {l_dy:.6f}, {l_dz:.6f})")
[?2004l[?2004h> print(f"  Right:  ({r_dx:.6f}, {r_dy:.6f}, {r_dz:.6f})")
[?2004l[?2004h> 
[?2004l[?2004h> # For a sphere at (Xs, Ys, Zs) with radius R, the tangent condition is:
[?2004l[?2004h> # dot(oc, dir)^2 = dot(oc, oc) - R^2
[?2004l[?2004h> # where oc = (Xs, Ys - H, Zs)
[?2004l[?2004h> 
[?2004l[?2004h> # Let's search for the best sphere parameters
[?2004l[?2004h> best_err = 1e10
[?2004l[?2004h> best_params = None
[?2004l[?2004h> 
[?2004l[?2004h> for Xs in [i/1000.0 for i in range(-500, 500)]:  # -0.5 to 0.5
[?2004l[?2004h>     for Ys in [i/100.0 for i in range(150, 250)]:  # 1.5 to 2.5
[?2004l[?2004h>         for Zs in [i/100.0 for i in range(-700, -300)]:  # -7.0 to -3.0
[?2004l[?2004h>             for R in [i/100.0 for i in range(50, 150)]:  # 0.5 to 1.5
[?2004l[?2004h>                 oc_x = Xs
[?2004l[?2004h>                 oc_y = Ys - H
[?2004l[?2004h>                 oc_z = Zs
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Top
[?2004l[?2004h>                 dot_top = oc_x*t_dx + oc_y*t_dy + oc_z*t_dz
[?2004l[?2004h>                 disc_top = dot_top**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Left
[?2004l[?2004h>                 dot_left = oc_x*l_dx + oc_y*l_dy + oc_z*l_dz
[?2004l[?2004h>                 disc_left = dot_left**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Right
[?2004l[?2004h>                 dot_right = oc_x*r_dx + oc_y*r_dy + oc_z*r_dz
[?2004l[?2004h>                 disc_right = dot_right**2 - (oc_x**2 + oc_y**2 + oc_z**2) + R**2
[?2004l[?2004h>                 
[?2004l[?2004h>                 err = abs(disc_top) + abs(disc_left) + abs(disc_right)
[?2004l[?2004h>                 if err < best_err:
[?2004l[?2004h>                     best_err = err
[?2004l[?2004h>                     best_params = (Xs, Ys, Zs, R, disc_top, disc_left, disc_right)
[?2004l[?2004h> 
[?2004l[?2004h> print(f"\nBest parameters:")
[?2004l[?2004h> print(f"  Xs = {best_params[0]:.6f}")
[?2004l[?2004h> print(f"  Ys = {best_params[1]:.6f}")
[?2004l[?2004h> print(f"  Zs = {best_params[2]:.6f}")
