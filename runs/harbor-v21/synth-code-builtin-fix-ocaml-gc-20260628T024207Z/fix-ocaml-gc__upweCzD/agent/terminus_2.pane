    44	/* Initial MARKED, UNMARKED, and GARBAGE values; any permutation would work */
    45	struct global_heap_state caml_global_heap_state = {
    46	  0 << HEADER_COLOR_SHIFT,
    47	  1 << HEADER_COLOR_SHIFT,
    48	  2 << HEADER_COLOR_SHIFT,
