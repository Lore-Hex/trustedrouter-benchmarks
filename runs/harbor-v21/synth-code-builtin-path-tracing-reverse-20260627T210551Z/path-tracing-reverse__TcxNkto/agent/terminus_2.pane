from pathlib import Path
import struct
raw=Path('/app/mystery').read_bytes()
secs=[('.rodata',0x480000,0x80000,0x1c314),('.data.rel.ro',0x4a6f80,0xa5f80,0x3fc8),('.data',0x4ab0c0,0xaa0c0,0x1a00)]
def fo(va):
    for n,addr,off,size in secs:
        if addr<=va<addr+size:
            return off+(va-addr)
    return None
for va in [0x485a58,0x485a60,0x485a68,0x485a70,0x485a78,0x485a80,0x485a88,0x485a90,0x485a98,0x485aa0,0x485ab0,0x485ab8,0x485ac0,0x485ac8,0x485ad0,0x485ad8,0x485adc,0x485ae0]:
    f=fo(va)
    if f is not None and f+16<=len(raw):
        b=raw[f:f+16]
        print(f'{va:#010x} {b.hex()} {struct.unpack("<4f",b)}')
    else:
        print(f'{va:#010x} unmapped')
PY
