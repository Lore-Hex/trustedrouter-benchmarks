[?2004hroot@e24cbc52c951:/app# python3 - > /tmp/consts.txt <<'PY'
[?2004l[?2004h> from pathlib import Path
[?2004l[?2004h> import struct, re
[?2004l[?2004h> raw = Path('/app/mystery').read_bytes()
[?2004l[?2004h> text = Path('/tmp/main_dis.txt').read_text()
[?2004l[?2004h> # Parse ELF64 section headers for VA->file offset mapping.
[?2004l[?2004h> e_shoff = struct.unpack_from('<Q', raw, 0x28)[0]
[?2004l[?2004h> e_shentsize = struct.unpack_from('<H', raw, 0x3a)[0]
[?2004l[?2004h> e_shnum = struct.unpack_from('<H', raw, 0x3c)[0]
[?2004l[?2004h> e_shstrndx = struct.unpack_from('<H', raw, 0x3e)[0]
[?2004l[?2004h> strtab_off = struct.unpack_from('<Q', raw, e_shoff + e_shstrndx*e_shentsize + 0x18)[0]
[?2004l[?2004h> sections = []
[?2004l[?2004h> for i in range(e_shnum):
[?2004l[?2004h>     off = e_shoff + i*e_shentsize
[?2004l[?2004h>     name_off = struct.unpack_from('<I', raw, off)[0]
[?2004l[?2004h>     sh_addr = struct.unpack_from('<Q', raw, off+0x10)[0]
[?2004l[?2004h>     sh_offset = struct.unpack_from('<Q', raw, off+0x18)[0]
[?2004l[?2004h>     sh_size = struct.unpack_from('<Q', raw, off+0x20)[0]
[?2004l[?2004h>     name = raw[strtab_off+name_off:raw.index(b'\0', strtab_off+name_off)].decode()
[?2004l[?2004h>     sections.append((name, sh_addr, sh_offset, sh_size))
[?2004l[?2004h> 
[?2004l[?2004h> def fileoff(va):
[?2004l[?2004h>     for name, addr, off, size in sections:
[?2004l[?2004h>         if addr <= va < addr + size:
[?2004l[?2004h>             return off + (va - addr)
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> addrs = {}
[?2004l[?2004h> for line in text.splitlines():
[?2004l[?2004h>     if '#' not in line:
[?2004l[?2004h>         continue
[?2004l[?2004h>     comment = line.split('#', 1)[1]
[?2004l[?2004h>     for m in re.finditer(r'([0-9a-fA-F]{6,8})\s+<([^>]+)>', comment):
[?2004l[?2004h>         a = int(m.group(1), 16)
[?2004l[?2004h>         n = m.group(2)
[?2004l[?2004h>         addrs[a] = n
[?2004l[?2004h> 
[?2004l[?2004h> mapped = []
[?2004l[?2004h> for a in sorted(addrs):
[?2004l[?2004h>     fo = fileoff(a)
[?2004l[?2004h>     if fo is not None and fo + 16 <= len(raw):
[?2004l[?2004h>         b = raw[fo:fo+16]
[?2004l[?2004h>         mapped.append((a, addrs[a], b.hex(), struct.unpack('<4f', b)))
[?2004l[?2004h> print(f'Found {len(addrs)} comments, {len(mapped)} mapped')
[?2004l[?2004h> for a, n, h, fl in mapped:
[?2004l[?2004h>     print(f'{a:#010x} {n:36s} {h} {fl}')
[?2004l[?2004h> PY
