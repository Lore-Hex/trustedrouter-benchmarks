[?2004hroot@e24cbc52c951:/app# python3 - <<'PY'
[?2004l[?2004h> from pathlib import Path
[?2004l[?2004h> data=Path('/tmp/original.ppm').read_text().split()
[?2004l[?2004h> w=800;h=600;vals=list(map(int,data[4:]))
[?2004l[?2004h> def px(x,y): return (vals[(y*w+x)*3],vals[(y*w+x)*3+1],vals[(y*w+x)*3+2])
[?2004l[?2004h> for y in range(0,600,30):
[?2004l[?2004h>     print('row',y,[px(x,y) for x in range(0,800,50)])
[?2004l[?2004h> print('col 400 y295..330')
[?2004l[?2004h> for y in range(295,330):
[?2004l[?2004h>     print(y, px(400,y))
[?2004l[?2004h> print('boundary map y250..360')
[?2004l[?2004h> for y in range(250,360,5):
[?2004l[?2004h>     line=[]
[?2004l[?2004h>     for x in range(280,520,10):
[?2004l[?2004h>         r,g,b=px(x,y)
[?2004l[?2004h>         if (r,g,b)==(51,10,10): line.append('#')
[?2004l[?2004h>         elif b==255 and r>100: line.append('.')
[?2004l[?2004h>         else: line.append('?')
[?2004l[?2004h>     print(y,''.join(line))
[?2004l[?2004h> print('checker x0..40 y300..315')
[?2004l[?2004h> for y in range(300,316):
[?2004l[?2004h>     print(y,[px(x,y) for x in range(0,40)])
[?2004l[?2004h> inside=[]
[?2004l[?2004h> for y in range(h):
[?2004l[?2004h>     for x in range(w):
[?2004l[?2004h>         if px(x,y)==(51,10,10): inside.append((x,y))
[?2004l[?2004h> if inside:
[?2004l[?2004h>     xs=[x for x,y in inside]; ys=[y for x,y in inside]
[?2004l[?2004h>     print('red bbox',min(xs),max(xs),min(ys),max(ys),'count',len(inside))
[?2004l[?2004h>     for y in range(min(ys),max(ys)+1,10):
[?2004l[?2004h>         xs2=[x for x in range(w) if px(x,y)==(51,10,10)]
[?2004l[?2004h>         if xs2: print(y,min(xs2),max(xs2),len(xs2))
