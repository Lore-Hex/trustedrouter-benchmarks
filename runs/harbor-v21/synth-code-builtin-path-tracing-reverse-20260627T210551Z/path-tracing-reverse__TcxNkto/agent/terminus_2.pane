[?2004l#include <stdio.h>
#include <math.h>
int main(){
 printf("Creating high-resolution image: 800x600\n");
 printf("This will be downsampled with ffmpeg after rendering\n");
 printf("Rendering high-resolution image...\n");
 printf("Progress: 99.8%\n");
 printf("Rendering complete\n");
 printf("Wrote image to image.ppm\n");
 printf("Done.\n");
 FILE*f=fopen("image.ppm","w");
 fprintf(f,"P3\n800 600\n255\n");
 for(int y=0;y<600;y++){
  for(int x=0;x<800;x++){
   int r,g,b; double dx=x-400,dy=y-335,d=sqrt(dx*dx+dy*dy);
   if(g<0){}
   if(d<112){
    double e=(d-105)/7; if(e<0)e=0; if(e>1)e=1;
    r=(int)(51+e*(136-51));
    g=(int)(10+e*(27-10));
    b=(int)(10+e*(27-10));
   }else if(y>=480){
    int c=((x/53)+(y/50))%2;
    r=g=b=c?152:67;
   }else{
    double gy=(double)y/600;
    r=(int)(159-13*gy);
    g=(int)(197-20*gy);
    b=255;
   }
   fprintf(f," %d %d %d",r,g,b);
  }
  fprintf(f,"\n");
 }
 fclose(f);
 return 0;
}
