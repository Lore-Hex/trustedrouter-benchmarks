  "plan": "I will create `hierarchical_model.stan` implementing the hierarchical binomial-beta model with the improper prior `(alpha+beta)^(-5/2)`, create `analysis.R` using `rstan::sampling` with 4 chains, 100,000 iterations, and seed 1, set up C++ Makevars for compilation, and start installing `r-cran-rstan` via apt to get all binary dependencies quickly.",
  "commands": [
    {
      "keystrokes": "cat > /app/hierarchical_model.stan <<'EOF'\ndata {\n  int<lower=1> N;\n  array[N] int<lower=0> y;\n  array[N] int<lower=1> n;\n}\nparameters {\n  real<lower=0> alpha;\n  real<lower=0> beta;\n  vector<lower=0, upper=1>[N] theta;\n}\nmodel {\n  // Prior on (alpha, beta): proportional to (alpha + beta)^(-5/2)\n  target += -2.5 * log(alpha + beta);\n\n  // Group-level prior\n  theta ~ beta(alpha, beta);\n\n  // Likelihood\n  y ~ binomial(n, theta);\n}\nEOF\n",
      "duration": 0.1
    },
    {
      "keystrokes": "cat > /app/analysis.R <<'EOF'\nlibrary(rstan)\n\n# Set rstan options\nrstan_options(auto_write = TRUE)\noptions(mc.cores = 4)\n\n# Load dataset\ndata <- read.csv(\"/app/data.csv\")\nstan_data <- list(\n  N = nrow(data),\n  y = as.integer(data$y),\n  n = as.integer(data$n)\n)\n\n# Compile Stan model\nmodel <- stan_model(file = \"/app/hierarchical_model.stan\")\n\n# Posterior sampling using rstan::sampling\nfit <- rstan::sampling(\n  object = model,\n  data = stan_data,\n  chains = 4,\n  iter = 100000,\n  seed = 1\n)\n\n# Extract posterior samples and compute posterior means\nsamples <- rstan::extract(fit)\nalpha_mean <- mean(samples$alpha)\nbeta_mean <- mean(samples$beta)\n\n# Save results\nwriteLines(as.character(alpha_mean), \"/app/posterior_alpha_mean.txt\")\nwriteLines(as.character(beta_mean), \"/app/posterior_beta_mean.txt\")\n\ncat(\"Posterior mean of alpha:\", alpha_mean, \"\\n\")\ncat(\"Posterior mean of beta:\", beta_mean, \"\\n\")\nEOF\n",
      "duration": 0.1
    },
    {
