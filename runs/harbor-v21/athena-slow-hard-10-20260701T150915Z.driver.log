[tr-stream call-0006] start model=trustedrouter/athena base_url=https://api.trustedrouter.com/v1
[tr-stream call-0006:trustedrouter/athena] {
  "analysis": "The partial correlation analysis clearly reveals the 6-edge DAG. Conditioning on U, only Y-D (r=0.32) and R-M (r=0.25) remain significant among non-U pairs; Y-R, Y-M, R-D, D-M are not significant. U connects to all four other nodes. For directionality: U has no parents (given), Y→D (D before Y alphabetically, so D is child of Y), and R→M (M before R alphabetically, so M is child of R). Now we need to save the DAG, learn a Gaussian BN via OLS regression, intervene on Y (set Y=0.0), save intervened DAG, and sample 10k points.",
  "plan": "Write a pure Python script that: (1) saves learned_dag.csv with 6 edges, (2) fits OLS linear regressions for each node given its parents, (3) saves intervened_dag.csv with edges into Y removed, (4) samples 10k points from the intervened BN in topological order with Y set to 0.0 (tiny variance 1e-8), and (5) saves final_bn_sample.csv with original column names.",
  "commands": [
    {
      "keystrokes": "python3 - <<'PY'\nimport csv, math, random\n\n# ---- Read data ----\ndata = []\nwith open('/app/bn_sample_10k.csv') as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    for row in reader:\n        data.append([float(x) for x in row])\n\nidx = {h: i for i, h in enumerate(header)}\nn = len(data)\n\n# ---- DAG edges: (to, from) meaning from -> to ----\nedges = [\n    ('Y', 'U'),  # U -> Y\n    ('R', 'U'),  # U -> R\n    ('D', 'U'),  # U -> D\n    ('M', 'U'),  # U -> M\n    ('D', 'Y'),  # Y -> D\n    ('M', 'R'),  # R -> M\n]\n\n# ---- Save learned_dag.csv ----\nwith open('/app/learned_dag.csv', 'w') as f:\n    f.write('to,from\\n')\n    for to, frm in edges:\n        f.write(f'{to},{frm}\\n')\nprint('Saved /app/learned_dag.csv')\n\n# ---- Build parents map ----\nparents = {h: [] for h in header}\nfor to, frm in edges:\n    parents[to].append(frm)\n\n# ---- OLS regression utilities ----\ndef mat_inv(m):\n    size = len(m)\n    aug = [row[:] + [1.0 if i == j else 0.0 for j in range(size)] for i, row in enumerate(m)]\n    for col in range(size):\n        piv = max(range(col, size), key=lambda r: abs(aug[r][col]))\n        aug[col], aug[piv] = aug[piv], aug[col]\n        pv = aug[col][col]\n        if abs(pv) < 1e-14:\n            raise ValueError('singular')\n        for j in range(2 * size):\n            aug[col][j] /= pv\n        for r in range(size):\n            if r != col:\n                factor = aug[r][col]\n                for j in range(2 * size):\n                    aug[r][j] -= factor * aug[col][j]\n    return [row[size:] for row in aug]\n\ndef mat_vec(m, v):\n    return [sum(m[i][j] * v[j] for j in range(len(v))) for i in range(len(m))]\n\ndef fit_ols(node, par_nodes):\n    if not par_nodes:\n        col = [r[idx[node]] for r in data]\n        mean = sum(col) / n\n        var = sum((v - mean) ** 2 for v in col) / n\n        return {'intercept': mean, 'coefs': {}, 'var': var}\n    p = len(par_nodes)\n    XtX = [[0.0] * (p + 1) for _ in range(p + 1)]\n    Xty = [0.0] * (p + 1)\n    for r in data:\n        xrow = [1.0] + [r[idx[x]] for x in par_nodes]\n        yval = r[idx[node]]\n        for i in range(p + 1):\n            Xty[i] += xrow[i] * yval\n            for j in range(p + 1):\n                XtX[i][j] += xrow[i] * xrow[j]\n    for i in range(p + 1):\n        for j in range(p + 1):\n            XtX[i][j] /= n\n        Xty[i] /= n\n    inv = mat_inv(XtX)\n    beta = mat_vec(inv, Xty)\n    ss = 0.0\n    for r in data:\n        pred = beta[0]\n        for j in range(p):\n            pred += beta[j + 1] * r[idx[par_nodes[j]]]\n        ss += (r[idx[node]] - pred) ** 2\n    var = ss / n\n    return {\n        'intercept': beta[0],\n        'coefs': {par_nodes[j]: beta[j + 1] for j in range(p)},\n        'var': var\n    }\n\n# ---- Fit BN parameters ----\nparams = {}\nfor node in header:\n    params[node] = fit_ols(node, parents[node])\n    p = params[node]\n    print(f\"{node}: parents={parents[node]} intercept={p['intercept']:.4f} coefs={p['coefs']} var={p['var']:.4f}\")\n\n# ---- Intervened DAG: remove edges into Y ----\nintervened_edges = [(to, frm) for (to, frm) in edges if to != 'Y']\nwith open('/app/intervened_dag.csv', 'w') as f:\n    f.write('to,from\\n')\n    for to, frm in intervened_edges:\n        f.write(f'{to},{frm}\\n')\nprint('Saved /app/intervened_dag.csv')\n\n# ---- Sample 10k from intervened BN ----\n# Intervention: Y = 0.0 with tiny variance (10e-9 = 1e-8)\nintervene_var = 1e-8\nintervene_std = math.sqrt(intervene_var)\n\ntopo_order = ['U', 'Y', 'R', 'D', 'M']\nrandom.seed(42)\n\nsamples = []\nfor _ in range(n):\n    vals = {}\n    for node in topo_order:\n        if node == 'Y':\n            vals[node] = random.gauss(0.0, intervene_std)\n        else:\n            p = params[node]\n            mean = p['intercept']\n            for parent in parents[node]:\n                mean += p['coefs'][parent] * vals[parent]\n            vals[node] = random.gauss(mean, math.sqrt(p['var']))\n    samples.append([vals[h] for h in header])\n\nwith open('/app/final_bn_sample.csv', 'w') as f:\n    f.write(','.join(f'\"{h}\"' for h in header) + '\\n')\n    for s in samples:\n        f.write(','.join(str(v) for v in s) + '\\n')\nprint('Saved /app/final_bn_sample.csv')\nprint('Done!')\nPY\n",
      "duration": 1.0
    }
  ]
}
