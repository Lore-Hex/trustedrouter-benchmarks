[tr-stream call-0005] start model=trustedrouter/athena base_url=https://api.trustedrouter.com/v1
[tr-stream call-0005:trustedrouter/athena] {
  "analysis": "We have the data summary and correlation matrix. Variables are U, Y, R, D, M. U has no parents and there are 6 edges total. The correlation matrix shows U correlates with all variables, and there are correlations among all pairs. To recover the DAG, we need partial correlations / conditional independence tests to identify direct dependencies versus indirect ones.",
  "plan": "Compute partial correlations conditioned on subsets (especially U, and combinations of other variables) using pure Python. This will help identify which edges are direct and which correlations are induced by common causes or chains. Then infer the 6-edge DAG.",
  "commands": [
    {
      "keystrokes": "python3 - <<'PY'\nimport csv, math\nfrom itertools import combinations\n\ndata=[]\nwith open('/app/bn_sample_10k.csv') as f:\n    reader=csv.reader(f)\n    header=next(reader)\n    for row in reader:\n        data.append([float(x) for x in row])\n\nn=len(data)\nk=len(header)\nidx={h:i for i,h in enumerate(header)}\nmeans=[sum(r[i] for r in data)/n for i in range(k)]\n\n# covariance matrix\ncov=[[0.0]*k for _ in range(k)]\nfor r in data:\n    for i in range(k):\n        for j in range(i,k):\n            cov[i][j]+=(r[i]-means[i])*(r[j]-means[j])\nfor i in range(k):\n    for j in range(k):\n        if j<i:\n            cov[i][j]=cov[j][i]\n        else:\n            cov[i][j]/=n\n\ndef mat_inv(m):\n    size=len(m)\n    aug=[row[:]+[1.0 if i==j else 0.0 for j in range(size)] for i,row in enumerate(m)]\n    for col in range(size):\n        piv=max(range(col,size), key=lambda r: abs(aug[r][col]))\n        aug[col],aug[piv]=aug[piv],aug[col]\n        pv=aug[col][col]\n        if abs(pv)<1e-12: raise ValueError('singular')\n        for j in range(2*size):\n            aug[col][j]/=pv\n        for r in range(size):\n            if r!=col:\n                factor=aug[r][col]\n                for j in range(2*size):\n                    aug[r][j]-=factor*aug[col][j]\n    return [row[size:] for row in aug]\n\ndef partial_corr(a,b,cond):\n    cols=[idx[a],idx[b]]+[idx[c] for c in cond]\n    sub=[[cov[i][j] for j in cols] for i in cols]\n    inv=mat_inv(sub)\n    pa=-inv[0][1]/math.sqrt(inv[0][0]*inv[1][1])\n    return pa\n\nnodes=['U','Y','R','D','M']\nprint('Pairwise correlations:')\nfor a,b in combinations(nodes,2):\n    print(f'{a}-{b}: {cov[idx[a]][idx[b]]/math.sqrt(cov[idx[a]][idx[a]]*cov[idx[b]][idx[b]]):.4f}')\n\nprint('\\nPartial corr given U:')\nfor a,b in combinations(['Y','R','D','M'],2):\n    print(f'{a}-{b}|U: {partial_corr(a,b,[\"U\"]):.4f}')\n\nprint('\\nPartial corr given U and each other node:')\nfor a,b in combinations(['Y','R','D','M'],2):\n    others=[x for x in ['Y','R','D','M'] if x not in (a,b)]\n    for c in others:\n        print(f'{a}-{b}|U,{c}: {partial_corr(a,b,[\"U\",c]):.4f}')\n\nprint('\\nPartial corr given all other nodes (full partial):')\nfor a,b in combinations(nodes,2):\n    cond=[x for x in nodes if x not in (a,b)]\n    print(f'{a}-{b}|{\" \".join(cond)}: {partial_corr(a,b,cond):.4f}')\n\n# Fisher z-test p-values approx\nfrom statistics import NormalDist\ndef z_test(r,n,cond_size):\n    z=0.5*math.log((1+r+1e-15)/(1-r+1e-15))*math.sqrt(n-cond_size-3)\n    p=2*(1-NormalDist().cdf(abs(z)))\n    return p\n\nprint('\\nFisher z p-values for partial corr given U:')\nfor a,b in combinations(['Y','R','D','M'],2):\n    r=partial_corr(a,b,['U'])\n    print(f'{a}-{b}|U: r={r:.4f} p={z_test(r,n,1):.2e}')\n\nprint('\\nFull partial p-values:')\nfor a,b in combinations(nodes,2):\n    cond=[x for x in nodes if x not in (a,b)]\n    r=partial_corr(a,b,cond)\n    print(f'{a}-{b}|{\" \".join(cond)}: r={r:.4f} p={z_test(r,n,len(cond)):.2e}')\nPY\n",
      "duration": 1.0
    }
  ]
}
