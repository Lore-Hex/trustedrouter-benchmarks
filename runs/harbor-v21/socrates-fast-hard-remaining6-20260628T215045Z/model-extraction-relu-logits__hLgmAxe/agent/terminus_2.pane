[?2004hroot@5c1e470db76f:/app# cat <<'PY' > /app/steal.py
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> import forward
[?2004l[?2004h> 
[?2004l[?2004h> def grad(x, eps=1e-6):
[?2004l[?2004h>     base = forward.forward(x)
[?2004l[?2004h>     g = np.zeros_like(x)
[?2004l[?2004h>     for i in range(len(x)):
[?2004l[?2004h>         dx = np.zeros_like(x)
[?2004l[?2004h>         dx[i] = eps
[?2004l[?2004h>         g[i] = (forward.forward(x + dx) - base) / eps
[?2004l[?2004h>     return g
[?2004l[?2004h> 
[?2004l[?2004h> # Use a large positive input to ensure all ReLU units are active.
[?2004l[?2004h> # The gradient will be proportional to A2 @ A1, which is sufficient up to scaling.
[?2004l[?2004h> x = np.full(10, 10.0)
[?2004l[?2004h> A1_est = grad(x).reshape(1, -1)
[?2004l[?2004h> np.save('/app/stolen_A1.npy', A1_est)
[?2004l[?2004h> PY
