Sending keys: ['cat > /app/steal.py << \'ENDSCRIPT\'\nimport numpy as np\nfrom forward import forward\n\ninput_dim = 10\n\ndef numerical_gradient(x, eps=1e-4):\n    grad = np.zeros(len(x))\n    f0 = forward(x)\n    for i in range(len(x)):\n        e = np.zeros(len(x))\n        e[i] = eps\n        grad[i] = (forward(x + e) - f0) / eps\n    return grad\n\ndef find_single_neuron_gradients(num_directions=500, scales_per_dir=60):\n    found_rows = []  # List of (gradient_direction, gradient_vector)\n    \n    for d_idx in range(num_directions):\n        d = np.random.randn(input_dim)\n        d = d / np.linalg.norm(d)\n        \n        # Sweep from origin outward in both directions\n        for sign in [1, -1]:\n            grads = []\n            scale_list = np.linspace(0.5, 12, scales_per_dir)\n            \n            for scale in scale_list:\n                x = sign * d * scale\n                g = numerical_gradient(x)\n                grads.append((scale, g))\n            \n            # Find intervals where gradient direction is constant\n            i = 0\n            while i < len(grads) - 1:\n                s1, g1 = grads[i]\n                g1_norm = np.linalg.norm(g1)\n                if g1_norm < 1e-6:\n                    i += 1\n                    continue\n                \n                # Find how far this gradient direction extends\n                j = i + 1\n                while j < len(grads):\n                    s2, g2 = grads[j]\n                    g2_norm = np.linalg.norm(g2)\n                    if g2_norm < 1e-6:\n                        break\n                    cos_sim = np.dot(g1, g2) / (g1_norm * g2_norm)\n                    if cos_sim < 0.98:  # Direction changed\n                        break\n                    j += 1\n                \n                # We need at least 3 consecutive same-direction gradients\n                if j - i >= 3:\n                    # Average the gradients in this interval\n                    avg_grad = np.mean([g for _, g in grads[i:j]], axis=0)\n                    avg_dir = avg_grad / np.linalg.norm(avg_grad)\n                    \n                    # Check if this direction is new\n                    is_new = True\n                    for existing_dir, _ in found_rows:\n                        if abs(np.dot(avg_dir, existing_dir)) > 0.95:\n                            is_new = False\n                            break\n                    \n                    if is_new:\n                        found_rows.append((avg_dir, avg_grad))\n                \n                i = j  # Move to next segment\n        \n        if d_idx % 50 == 0:\n            print(f"  Direction {d_idx}/{num_directions}, found {len(found_rows)} rows so far")\n        \n        if len(found_rows) >= 25:\n            break\n    \n    return found_rows\n\ndef main():\n    np.random.seed(42)\n    \n    print("Searching for single-neuron activation regions...")\n    found = find_single_neuron_gradients(num_directions=2000, scales_per_dir=80)\n    print(f"Found {len(found)} candidate A1 rows")\n    \n    if len(found) < 20:\n        print("Trying with more directions...")\n        found2 = find_single_neuron_gradients(num_directions=5000, scales_per_dir=100)\n        for d, g in found2:\n            is_new = True\n            for existing_d, _ in found:\n                if abs(np.dot(d, existing_d)) > 0.95:\n                    is_new = False\n                    break\n            if is_new:\n                found.append((d, g))\n        print(f"Total: {len(found)} candidate A1 rows")\n    \n    # Take top 20 or as many as we have\n    A1 = np.array([g for _, g in found[:20]])\n    \n    print(f"Final A1 shape: {A1.shape}")\n    np.save(\'/app/stolen_A1.npy\', A1)\n    print("Saved A1 to /app/stolen_A1.npy")\n    print("\\nReconstructed A1:")\n    print(A1)\n\nif __name__ == "__main__":\n    main()\nENDSCRIPT\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
