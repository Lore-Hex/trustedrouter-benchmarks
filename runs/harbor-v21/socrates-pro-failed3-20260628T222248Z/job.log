Sending keys: ['cat > /app/steal.py << \'ENDSCRIPT\'\nimport numpy as np\nfrom forward import forward\n\ninput_dim = 10\n\ndef numerical_gradient(x, eps=1e-5):\n    grad = np.zeros(len(x))\n    f0 = forward(x)\n    for i in range(len(x)):\n        e = np.zeros(len(x))\n        e[i] = eps\n        grad[i] = (forward(x + e) - f0) / eps\n    return grad\n\ndef extract_rows_from_line(x0, direction, num_steps=200, step_size=0.05):\n    """Sweep along a line and extract gradient changes at neuron boundaries."""\n    rows = []\n    \n    prev_grad = numerical_gradient(x0)\n    \n    for i in range(1, num_steps):\n        x = x0 + direction * i * step_size\n        curr_grad = numerical_gradient(x)\n        \n        diff = curr_grad - prev_grad\n        diff_norm = np.linalg.norm(diff)\n        \n        # A significant gradient change means a neuron flipped\n        if diff_norm > 1e-4:\n            # Normalize to get direction\n            diff_dir = diff / diff_norm\n            rows.append(diff_dir)\n        \n        prev_grad = curr_grad\n    \n    return rows\n\ndef cluster_rows(all_rows, threshold=0.95):\n    """Cluster row directions, keeping both + and - as same (up to sign)."""\n    clusters = []  # List of (representative_direction, [all_rows_in_cluster])\n    \n    for row in all_rows:\n        assigned = False\n        for c_idx in range(len(clusters)):\n            rep = clusters[c_idx][0]\n            # Check both positive and negative alignment\n            if abs(np.dot(row, rep)) > threshold:\n                clusters[c_idx][1].append(row)\n                assigned = True\n                break\n        if not assigned:\n            clusters.append((row, [row]))\n    \n    return clusters\n\ndef main():\n    np.random.seed(42)\n    \n    all_rows = []\n    \n    print("Sweeping along random lines to find neuron boundaries...")\n    num_lines = 500\n    \n    for line_idx in range(num_lines):\n        # Random starting point and direction\n        x0 = np.random.randn(input_dim) * 3\n        direction = np.random.randn(input_dim)\n        direction = direction / np.linalg.norm(direction)\n        \n        rows = extract_rows_from_line(x0, direction, num_steps=300, step_size=0.02)\n        all_rows.extend(rows)\n        \n        if line_idx % 100 == 0:\n            print(f"  Line {line_idx}/{num_lines}, total rows: {len(all_rows)}")\n    \n    print(f"Total gradient differences found: {len(all_rows)}")\n    \n    # Cluster the rows\n    print("Clustering...")\n    clusters = cluster_rows(all_rows, threshold=0.90)\n    print(f"Found {len(clusters)} clusters")\n    \n    # For each cluster, average the rows to get better estimate\n    A1_rows = []\n    for rep, members in sorted(clusters, key=lambda c: len(c[1]), reverse=True):\n        avg = np.mean(members, axis=0)\n        avg_dir = avg / np.linalg.norm(avg)\n        A1_rows.append(avg)\n    \n    A1 = np.array(A1_rows[:20])\n    print(f"Final A1 shape: {A1.shape}")\n    \n    np.save(\'/app/stolen_A1.npy\', A1)\n    print("Saved A1 to /app/stolen_A1.npy")\n    print("\\nReconstructed A1:")\n    print(A1)\n\nif __name__ == "__main__":\n    main()\nENDSCRIPT\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
