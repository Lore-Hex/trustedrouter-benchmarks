[?2004l[?2004h>         d = np.random.randn(input_dim)
[?2004l[?2004h>         d = d / np.linalg.norm(d)
[?2004l[?2004h>         
[?2004l[?2004h>         # Find a point along this direction that gives a gradient
[?2004l[?2004h>         best_grad = None
[?2004l[?2004h>         best_grad_norm = 0
[?2004l[?2004h>         
[?2004l[?2004h>         for scale in np.linspace(0.1, 10, 50):
[?2004l[?2004h>             x = d * scale
[?2004l[?2004h>             grad = numerical_gradient(x)
[?2004l[?2004h>             grad_norm = np.linalg.norm(grad)
[?2004l[?2004h>             
[?2004l[?2004h>             if grad_norm > best_grad_norm:
[?2004l[?2004h>                 best_grad_norm = grad_norm
[?2004l[?2004h>                 best_grad = grad
[?2004l[?2004h>         
[?2004l[?2004h>         # Also try negative direction
[?2004l[?2004h>         for scale in np.linspace(0.1, 10, 50):
[?2004l[?2004h>             x = -d * scale
[?2004l[?2004h>             grad = numerical_gradient(x)
[?2004l[?2004h>             grad_norm = np.linalg.norm(grad)
[?2004l[?2004h>             
[?2004l[?2004h>             if grad_norm > best_grad_norm:
[?2004l[?2004h>                 best_grad_norm = grad_norm
[?2004l[?2004h>                 best_grad = -grad  # Flip to keep direction consistent
[?2004l[?2004h>         
[?2004l[?2004h>         if best_grad is not None and np.linalg.norm(best_grad) > 1e-3:
[?2004l[?2004h>             A1_candidates.append(best_grad)
[?2004l[?2004h>     
[?2004l[?2004h>     # Deduplicate by direction
[?2004l[?2004h>     unique_A1 = []
