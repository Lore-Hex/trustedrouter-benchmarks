[?2004l[?2004h>     selected = []
[?2004l[?2004h>     for idx in idx_sorted[:50]:
[?2004l[?2004h>         grad = gradients[idx]
[?2004l[?2004h>         is_unique = True
[?2004l[?2004h>         for existing in selected:
[?2004l[?2004h>             cos_sim = abs(np.dot(grad/np.linalg.norm(grad), existing/np.linalg.norm(existing)))
[?2004l[?2004h>             if cos_sim > threshold:
