[?2004l[?2004h> def extract_basis_with_pca(gradients, n_components=20):
[?2004l[?2004h>     """Use PCA to extract basis vectors from gradients"""
[?2004l[?2004h>     # Center the data
[?2004l[?2004h>     centered = gradients - np.mean(gradients, axis=0)
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute covariance matrix
[?2004l[?2004h>     cov = np.cov(centered.T)
[?2004l[?2004h>     
