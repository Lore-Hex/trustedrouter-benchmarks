[?2004l[?2004h> def extract_A1_basis(gradients, n_neurons=20):
[?2004l[?2004h>     """Extract A1 rows from gradients using a basis approach"""
[?2004l[?2004h>     # All gradients are linear combinations of A1 rows
[?2004l[?2004h>     # We want to find the A1 rows themselves
[?2004l[?2004h>     
[?2004l[?2004h>     # Use SVD to understand the space
