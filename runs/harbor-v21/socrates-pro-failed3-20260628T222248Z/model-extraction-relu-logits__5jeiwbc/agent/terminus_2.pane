[?2004l[?2004h>             grads = []
[?2004l[?2004h>             scale_list = np.linspace(0.5, 12, scales_per_dir)
[?2004l[?2004h>             
[?2004l[?2004h>             for scale in scale_list:
[?2004l[?2004h>                 x = sign * d * scale
[?2004l[?2004h>                 g = numerical_gradient(x)
[?2004l[?2004h>                 grads.append((scale, g))
[?2004l[?2004h>             
[?2004l[?2004h>             # Find intervals where gradient direction is constant
[?2004l[?2004h>             i = 0
[?2004l[?2004h>             while i < len(grads) - 1:
[?2004l[?2004h>                 s1, g1 = grads[i]
[?2004l[?2004h>                 g1_norm = np.linalg.norm(g1)
[?2004l[?2004h>                 if g1_norm < 1e-6:
[?2004l[?2004h>                     i += 1
[?2004l[?2004h>                     continue
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Find how far this gradient direction extends
[?2004l[?2004h>                 j = i + 1
[?2004l[?2004h>                 while j < len(grads):
[?2004l[?2004h>                     s2, g2 = grads[j]
[?2004l[?2004h>                     g2_norm = np.linalg.norm(g2)
[?2004l[?2004h>                     if g2_norm < 1e-6:
[?2004l[?2004h>                         break
[?2004l[?2004h>                     cos_sim = np.dot(g1, g2) / (g1_norm * g2_norm)
[?2004l[?2004h>                     if cos_sim < 0.98:  # Direction changed
[?2004l[?2004h>                         break
[?2004l[?2004h>                     j += 1
[?2004l[?2004h>                 
[?2004l[?2004h>                 # We need at least 3 consecutive same-direction gradients
[?2004l[?2004h>                 if j - i >= 3:
[?2004l[?2004h>                     # Average the gradients in this interval
[?2004l[?2004h>                     avg_grad = np.mean([g for _, g in grads[i:j]], axis=0)
[?2004l[?2004h>                     avg_dir = avg_grad / np.linalg.norm(avg_grad)
[?2004l[?2004h>                     
[?2004l[?2004h>                     # Check if this direction is new
[?2004l[?2004h>                     is_new = True
[?2004l[?2004h>                     for existing_dir, _ in found_rows:
[?2004l[?2004h>                         if abs(np.dot(avg_dir, existing_dir)) > 0.95:
[?2004l[?2004h>                             is_new = False
[?2004l[?2004h>                             break
[?2004l[?2004h>                     
[?2004l[?2004h>                     if is_new:
[?2004l[?2004h>                         found_rows.append((avg_dir, avg_grad))
[?2004l[?2004h>                 
[?2004l[?2004h>                 i = j  # Move to next segment
[?2004l[?2004h>         
[?2004l[?2004h>         if d_idx % 50 == 0:
[?2004l[?2004h>             print(f"  Direction {d_idx}/{num_directions}, found {len(found_rows)} rows so far")
[?2004l[?2004h>         
[?2004l[?2004h>         if len(found_rows) >= 25:
[?2004l[?2004h>             break
[?2004l[?2004h>     
[?2004l[?2004h>     return found_rows
[?2004l[?2004h> 
