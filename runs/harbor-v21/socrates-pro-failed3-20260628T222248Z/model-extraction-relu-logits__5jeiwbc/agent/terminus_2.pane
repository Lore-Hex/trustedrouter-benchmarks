[?2004l[?2004h> def extract_neurons_via_extremal_gradients(num_samples=10000):
[?2004l[?2004h>     """Find extremal gradient directions - these often correspond to single neurons"""
[?2004l[?2004h>     gradients = collect_gradients(num_samples)
[?2004l[?2004h>     
[?2004l[?2004h>     # Normalize all gradients
[?2004l[?2004h>     normalized = np.array([g / np.linalg.norm(g) for g in gradients])
[?2004l[?2004h>     
[?2004l[?2004h>     # For each gradient, find how many others are similar
[?2004l[?2004h>     unique_directions = []
[?2004l[?2004h>     direction_counts = []
[?2004l[?2004h>     
[?2004l[?2004h>     threshold = 0.9  # Cosine similarity threshold
[?2004l[?2004h>     
[?2004l[?2004h>     for i, grad in enumerate(normalized):
[?2004l[?2004h>         similar_count = np.sum([np.dot(grad, g) > threshold for g in normalized])
[?2004l[?2004h>         direction_counts.append(similar_count)
