[?2004l[?2004h> import numpy as np
[?2004l[?2004h> from forward import forward
[?2004l[?2004h> 
[?2004l[?2004h> input_dim = 10
[?2004l[?2004h> 
[?2004l[?2004h> def numerical_gradient(x, eps=1e-5):
[?2004l[?2004h>     grad = np.zeros(len(x))
[?2004l[?2004h>     f0 = forward(x)
[?2004l[?2004h>     for i in range(len(x)):
[?2004l[?2004h>         e = np.zeros(len(x))
[?2004l[?2004h>         e[i] = eps
[?2004l[?2004h>         grad[i] = (forward(x + e) - f0) / eps
[?2004l[?2004h>     return grad
[?2004l[?2004h> 
[?2004l[?2004h> def extract_rows_from_line(x0, direction, num_steps=200, step_size=0.05):
[?2004l[?2004h>     """Sweep along a line and extract gradient changes at neuron boundaries."""
[?2004l[?2004h>     rows = []
[?2004l[?2004h>     
[?2004l[?2004h>     prev_grad = numerical_gradient(x0)
[?2004l[?2004h>     
[?2004l[?2004h>     for i in range(1, num_steps):
[?2004l[?2004h>         x = x0 + direction * i * step_size
[?2004l[?2004h>         curr_grad = numerical_gradient(x)
[?2004l[?2004h>         
[?2004l[?2004h>         diff = curr_grad - prev_grad
[?2004l[?2004h>         diff_norm = np.linalg.norm(diff)
[?2004l[?2004h>         
[?2004l[?2004h>         # A significant gradient change means a neuron flipped
[?2004l[?2004h>         if diff_norm > 1e-4:
[?2004l[?2004h>             # Normalize to get direction
[?2004l[?2004h>             diff_dir = diff / diff_norm
[?2004l[?2004h>             rows.append(diff_dir)
[?2004l[?2004h>         
[?2004l[?2004h>         prev_grad = curr_grad
[?2004l[?2004h>     
[?2004l[?2004h>     return rows
[?2004l[?2004h> 
[?2004l[?2004h> def cluster_rows(all_rows, threshold=0.95):
[?2004l[?2004h>     """Cluster row directions, keeping both + and - as same (up to sign)."""
[?2004l[?2004h>     clusters = []  # List of (representative_direction, [all_rows_in_cluster])
[?2004l[?2004h>     
[?2004l[?2004h>     for row in all_rows:
[?2004l[?2004h>         assigned = False
[?2004l[?2004h>         for c_idx in range(len(clusters)):
[?2004l[?2004h>             rep = clusters[c_idx][0]
[?2004l[?2004h>             # Check both positive and negative alignment
[?2004l[?2004h>             if abs(np.dot(row, rep)) > threshold:
[?2004l[?2004h>                 clusters[c_idx][1].append(row)
[?2004l[?2004h>                 assigned = True
[?2004l[?2004h>                 break
[?2004l[?2004h>         if not assigned:
[?2004l[?2004h>             clusters.append((row, [row]))
[?2004l[?2004h>     
[?2004l[?2004h>     return clusters
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     np.random.seed(42)
[?2004l[?2004h>     
[?2004l[?2004h>     all_rows = []
[?2004l[?2004h>     
[?2004l[?2004h>     print("Sweeping along random lines to find neuron boundaries...")
[?2004l[?2004h>     num_lines = 500
[?2004l[?2004h>     
[?2004l[?2004h>     for line_idx in range(num_lines):
[?2004l[?2004h>         # Random starting point and direction
[?2004l[?2004h>         x0 = np.random.randn(input_dim) * 3
[?2004l[?2004h>         direction = np.random.randn(input_dim)
[?2004l[?2004h>         direction = direction / np.linalg.norm(direction)
[?2004l[?2004h>         
[?2004l[?2004h>         rows = extract_rows_from_line(x0, direction, num_steps=300, step_size=0.02)
[?2004l[?2004h>         all_rows.extend(rows)
[?2004l[?2004h>         
[?2004l[?2004h>         if line_idx % 100 == 0:
[?2004l[?2004h>             print(f"  Line {line_idx}/{num_lines}, total rows: {len(all_rows)}")
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Total gradient differences found: {len(all_rows)}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Cluster the rows
[?2004l[?2004h>     print("Clustering...")
[?2004l[?2004h>     clusters = cluster_rows(all_rows, threshold=0.90)
[?2004l[?2004h>     print(f"Found {len(clusters)} clusters")
[?2004l[?2004h>     
[?2004l[?2004h>     # For each cluster, average the rows to get better estimate
[?2004l[?2004h>     A1_rows = []
[?2004l[?2004h>     for rep, members in sorted(clusters, key=lambda c: len(c[1]), reverse=True):
[?2004l[?2004h>         avg = np.mean(members, axis=0)
[?2004l[?2004h>         avg_dir = avg / np.linalg.norm(avg)
[?2004l[?2004h>         A1_rows.append(avg)
[?2004l[?2004h>     
[?2004l[?2004h>     A1 = np.array(A1_rows[:20])
[?2004l[?2004h>     print(f"Final A1 shape: {A1.shape}")
[?2004l[?2004h>     
[?2004l[?2004h>     np.save('/app/stolen_A1.npy', A1)
