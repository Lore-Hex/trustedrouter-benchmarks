[?2004l[?2004h>     print("Performing SVD to find basis of gradient space...")
[?2004l[?2004h>     U, S, Vt = np.linalg.svd(gradients, full_matrices=False)
[?2004l[?2004h>     
[?2004l[?2004h>     # The rank tells us the dimension of the active subspace
[?2004l[?2004h>     rank = np.sum(S > S[0] * 0.001)
[?2004l[?2004h>     print(f"Effective rank: {rank}")
