[?2004l[?2004h> def spectral_basis_extraction(gradients, n_basis=20):
[?2004l[?2004h>     """Use spectral methods to find the basis of the gradient space"""
[?2004l[?2004h>     # The gradients lie in the span of A1 rows
[?2004l[?2004h>     # We need to find the basis of this span
[?2004l[?2004h>     
[?2004l[?2004h>     # Stack gradients as rows
[?2004l[?2004h>     G = gradients  # shape: (n_samples, input_dim)
[?2004l[?2004h>     
[?2004l[?2004h>     # Perform SVD
[?2004l[?2004h>     U, S, Vt = np.linalg.svd(G, full_matrices=False)
[?2004l[?2004h>     
[?2004l[?2004h>     # The right singular vectors V (rows of Vt) form a basis
[?2004l[?2004h>     # We need to find which combination of these gives us the actual A1 rows
[?2004l[?2004h>     
[?2004l[?2004h>     # The A1 rows are in the row space of G
[?2004l[?2004h>     return Vt[:n_basis]
[?2004l[?2004h> 
[?2004l[?2004h> def reconstruct_A1():
[?2004l[?2004h>     """Main reconstruction algorithm"""
