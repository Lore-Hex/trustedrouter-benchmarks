[?2004l[?2004h> def greedy_cluster(vectors, sim_thresh=0.95):
[?2004l[?2004h>     """Greedy clustering: find high-similarity groups."""
[?2004l[?2004h>     X = vectors.copy()
[?2004l[?2004h>     n = X.shape[0]
[?2004l[?2004h>     assigned = np.zeros(n, dtype=bool)
[?2004l[?2004h>     clusters = []
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute pairwise absolute dot products
[?2004l[?2004h>     dot_matrix = X @ X.T
[?2004l[?2004h>     
[?2004l[?2004h>     for _ in range(N_NEURONS):
[?2004l[?2004h>         # Find unassigned point with most neighbors
[?2004l[?2004h>         best_seed = -1
[?2004l[?2004h>         best_count = -1
[?2004l[?2004h>         for i in range(n):
[?2004l[?2004h>             if not assigned[i]:
[?2004l[?2004h>                 count = 0
[?2004l[?2004h>                 for j in range(n):
[?2004l[?2004h>                     if not assigned[j]:
[?2004l[?2004h>                         if abs(dot_matrix[i, j]) > sim_thresh:
[?2004l[?2004h>                             count += 1
[?2004l[?2004h>                 if count > best_count:
[?2004l[?2004h>                     best_count = count
[?2004l[?2004h>                     best_seed = i
[?2004l[?2004h>         
[?2004l[?2004h>         if best_seed == -1 or best_count < 2:
[?2004l[?2004h>             break
[?2004l[?2004h>         
[?2004l[?2004h>         # Form cluster
[?2004l[?2004h>         cluster = []
[?2004l[?2004h>         for j in range(n):
[?2004l[?2004h>             if not assigned[j] and abs(dot_matrix[best_seed, j]) > sim_thresh:
[?2004l[?2004h>                 cluster.append(j)
[?2004l[?2004h>                 assigned[j] = True
[?2004l[?2004h>         clusters.append(cluster)
[?2004l[?2004h>     
[?2004l[?2004h>     return clusters, dot_matrix
[?2004l[?2004h> 
