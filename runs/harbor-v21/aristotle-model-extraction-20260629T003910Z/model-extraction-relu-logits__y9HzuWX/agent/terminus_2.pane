[?2004l [?2004h> def refine_breakpoint(v, t_approx):
[?2004l[?2004h>     """Refine breakpoint using binary search on second derivative peak.
[?2004l[?2004h>     Returns (t_refined, jump_vector) where jump = grad_right - grad_left."""
[?2004l[?2004h>     # Find the exact t where pre-activation of some neuron = 0
[?2004l[?2004h>     # We look for where the gradient (along v direction) changes
[?2004l[?2004h>     
[?2004l[?2004h>     def g(t):
[?2004l[?2004h>         return forward(t * v)
[?2004l[?2004h>     
[?2004l[?2004h>     # Binary search for maximum of second derivative
[?2004l[?2004h>     lo = t_approx - 0.005
[?2004l[?2004h>     hi = t_approx + 0.005
[?2004l[?2004h>     
[?2004l[?2004h>     for _ in range(40):
[?2004l[?2004h>         mid = (lo + hi) / 2
[?2004l[?2004h>         # Compute second derivative numerically at mid
[?2004l[?2004h>         eps_t = 1e-6
[?2004l[?2004h>         g_mid_lo = g(mid - eps_t)
[?2004l[?2004h>         g_mid = g(mid)
[?2004l[?2004h>         g_mid_hi = g(mid + eps_t)
[?2004l[?2004h>         d1_lo = (g_mid - g_mid_lo) / eps_t
[?2004l[?2004h>         d1_hi = (g_mid_hi - g_mid) / eps_t
[?2004l[?2004h>         d2 = (d1_hi - d1_lo) / eps_t
[?2004l[?2004h>         
[?2004l[?2004h>         # Check second derivative at lo and mid to see if peak is between
[?2004l[?2004h>         g_lo_lo = g(lo - eps_t)
[?2004l[?2004h>         g_lo = g(lo)
[?2004l[?2004h>         g_lo_hi = g(lo + eps_t)
[?2004l[?2004h>         d1_lo_lo = (g_lo - g_lo_lo) / eps_t
[?2004l[?2004h>         d1_lo_hi = (g_lo_hi - g_lo) / eps_t
[?2004l[?2004h>         d2_lo = (d1_lo_hi - d1_lo_lo) / eps_t
[?2004l[?2004h>         
[?2004l[?2004h>         if d2_lo * d2 < 0:
[?2004l[?2004h>             # Peak is between lo and mid
[?2004l[?2004h>             hi = mid
[?2004l[?2004h>         else:
[?2004l[?2004h>             lo = mid
[?2004l[?2004h>     
[?2004l[?2004h>     t_refined = (lo + hi) / 2
[?2004l[?2004h>     
[?2004l[?2004h>     # Compute gradient on each side
[?2004l[?2004h>     delta = 1e-4
[?2004l[?2004h>     g_left = grad((t_refined - delta) * v)
[?2004l[?2004h>     g_right = grad((t_refined + delta) * v)
[?2004l[?2004h>     jump = g_right - g_left
[?2004l[?2004h>     
[?2004l[?2004h>     return t_refined, jump
