[?2004l[?2004h> def solve_for_w(cluster, observations):
[?2004l[?2004h>     """Given a cluster of observations (same neuron), solve for w = A2_i * A1_i.
[?2004l[?2004h>     
[?2004l[?2004h>     Each observation: v is direction, t is breakpoint, jump is scalar jump.
[?2004l[?2004h>     We have: w · v = jump  (since jump = A2_i * (A1_i · v) = w · v)
[?2004l[?2004h>     
[?2004l[?2004h>     But also t * (A1_i · v) + b1_i = 0  => A1_i · v = -b1_i / t
[?2004l[?2004h>     So jump = A2_i * (-b1_i / t) = -A2_i * b1_i / t = c / t where c = -A2_i * b1_i = t * jump
[?2004l[?2004h>     
[?2004l[?2004h>     So indeed, for a correctly matched cluster, w · v = jump.
[?2004l[?2004h>     
[?2004l[?2004h>     We set up a linear system: V @ w = jumps where V is (n x 10) matrix of direction vectors, jumps is n-vector.
[?2004l[?2004h>     """
[?2004l[?2004h>     vs = []
[?2004l[?2004h>     js = []
[?2004l[?2004h>     for idx in cluster:
[?2004l[?2004h>         v, t, jump = observations[idx]
[?2004l[?2004h>         vs.append(v)
[?2004l[?2004h>         js.append(jump)
[?2004l[?2004h>     
[?2004l[?2004h>     V = np.array(vs)
[?2004l[?2004h>     b = np.array(js)
[?2004l[?2004h>     
[?2004l[?2004h>     # Solve least squares
[?2004l[?2004h>     w, residuals, rank, s = np.linalg.lstsq(V, b, rcond=None)
[?2004l[?2004h>     return w
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     print("Collecting 1D observations...")
[?2004l[?2004h>     obs = collect_observations(num_dirs=10000)
[?2004l[?2004h>     print(f"Total observations: {len(obs)}")
[?2004l[?2004h>     
[?2004l[?2004h>     np.save('/app/obs.npy', np.array([(v, t, j) for (v, t, j) in obs], dtype=object))
[?2004l[?2004h>     
[?2004l[?2004h>     print("Clustering by invariant c = t*jump...")
[?2004l[?2004h>     clusters = cluster_by_invariant(obs, eps=0.04)
[?2004l[?2004h>     print(f"Found {len(clusters)} clusters with >=5 members")
[?2004l[?2004h>     
[?2004l[?2004h>     for i, cl in enumerate(clusters[:25]):
