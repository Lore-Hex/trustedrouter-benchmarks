[?2004l[?2004h> def collect_jumps(num_lines=3000):
[?2004l[?2004h>     rng = np.random.default_rng(12345)
[?2004l[?2004h>     vectors = []  # Store unit vectors only
[?2004l[?2004h>     
[?2004l[?2004h>     for li in range(num_lines):
[?2004l[?2004h>         v = rng.standard_normal(INPUT_DIM)
[?2004l[?2004h>         v = v / (np.linalg.norm(v) + 1e-12)
[?2004l[?2004h>         
[?2004l[?2004h>         bps = find_breakpoints(v)
[?2004l[?2004h>         for t0 in bps:
[?2004l[?2004h>             # Use multiple deltas to handle noise
[?2004l[?2004h>             for delta in [2e-4, 5e-4, 8e-4]:
[?2004l[?2004h>                 x_left = (t0 - delta) * v
[?2004l[?2004h>                 x_right = (t0 + delta) * v
[?2004l[?2004h>                 g_left = grad(x_left)
[?2004l[?2004h>                 g_right = grad(x_right)
[?2004l[?2004h>                 jump = g_right - g_left
[?2004l[?2004h>                 nrm = np.linalg.norm(jump)
[?2004l[?2004h>                 if nrm > 1e-5:
[?2004l[?2004h>                     vectors.append(jump / nrm)
[?2004l[?2004h>                     break
[?2004l[?2004h>         
[?2004l[?2004h>         if (li + 1) % 1000 == 0:
