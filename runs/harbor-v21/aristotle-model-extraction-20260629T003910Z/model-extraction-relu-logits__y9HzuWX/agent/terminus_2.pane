[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def cluster_signed(vectors, k=N_NEURONS, restarts=8, iters=200, seed=0):
[?2004l[?2004h>     """Sign-invariant spherical k-means: distance is min(||c-v||, ||c+v||)."""
[?2004l[?2004h>     rng = np.random.default_rng(seed)
[?2004l[?2004h>     X = vectors / (np.linalg.norm(vectors, axis=1, keepdims=True) + 1e-12)
[?2004l[?2004h>     n = X.shape[0]
[?2004l[?2004h> 
[?2004l[?2004h>     best_inertia = np.inf
[?2004l[?2004h>     best_centroids = None
[?2004l[?2004h> 
[?2004l[?2004h>     for r in range(restarts):
[?2004l[?2004h>         centroids = X[rng.choice(n, k, replace=False)].copy()
[?2004l[?2004h> 
[?2004l[?2004h>         for it in range(iters):
[?2004l[?2004h>             # Assignment
[?2004l[?2004h>             # dist_pos[i,j] = ||X[i] - centroids[j]||^2 = 2 - 2*X[i].centroids[j]
[?2004l[?2004h>             # dist_neg[i,j] = ||X[i] + centroids[j]||^2 = 2 + 2*X[i].centroids[j]
[?2004l[?2004h>             dots = X @ centroids.T
[?2004l[?2004h>             dist_pos = 2.0 - 2.0 * dots
[?2004l[?2004h>             dist_neg = 2.0 + 2.0 * dots
[?2004l[?2004h>             min_dists = np.minimum(dist_pos, dist_neg)
[?2004l[?2004h>             labels = np.argmin(min_dists, axis=1)
[?2004l[?2004h> 
[?2004l[?2004h>             # Update
[?2004l[?2004h>             new_centroids = np.zeros((k, INPUT_DIM))
[?2004l[?2004h>             for j in range(k):
[?2004l[?2004h>                 members = X[labels == j]
[?2004l[?2004h>                 if len(members) == 0:
[?2004l[?2004h>                     new_centroids[j] = X[rng.integers(n)]
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     # Align signs to the first member
[?2004l[?2004h>                     ref = members[0]
[?2004l[?2004h>                     aligned = members.copy()
[?2004l[?2004h>                     flips = np.dot(members, ref) < 0
[?2004l[?2004h>                     aligned[flips] *= -1.0
[?2004l[?2004h>                     c = aligned.mean(axis=0)
[?2004l[?2004h>                     norm = np.linalg.norm(c)
[?2004l[?2004h>                     new_centroids[j] = c / norm if norm > 1e-12 else ref
[?2004l[?2004h> 
[?2004l[?2004h>             if np.allclose(new_centroids, centroids, atol=1e-8, rtol=0):
[?2004l[?2004h>                 centroids = new_centroids
[?2004l[?2004h>                 break
[?2004l[?2004h>             centroids = new_centroids
[?2004l[?2004h> 
[?2004l[?2004h>         dots = X @ centroids.T
[?2004l[?2004h>         inertia = np.minimum(2.0 - 2.0 * dots, 2.0 + 2.0 * dots).sum()
[?2004l[?2004h>         if inertia < best_inertia:
[?2004l[?2004h>             best_inertia = inertia
[?2004l[?2004h>             best_centroids = centroids.copy()
[?2004l[?2004h> 
[?2004l[?2004h>     return best_centroids, best_inertia
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def representative_magnitudes(vectors, centroids):
[?2004l[?2004h>     """For each centroid, take the median norm of assigned raw vectors."""
[?2004l[?2004h>     X = vectors / (np.linalg.norm(vectors, axis=1, keepdims=True) + 1e-12)
[?2004l[?2004h>     raw_norms = np.linalg.norm(vectors, axis=1)
[?2004l[?2004h>     dots = X @ centroids.T
[?2004l[?2004h>     dist_pos = 2.0 - 2.0 * dots
[?2004l[?2004h>     dist_neg = 2.0 + 2.0 * dots
[?2004l[?2004h>     labels = np.argmin(np.minimum(dist_pos, dist_neg), axis=1)
[?2004l[?2004h> 
[?2004l[?2004h>     mags = np.zeros(centroids.shape[0])
[?2004l[?2004h>     for j in range(centroids.shape[0]):
[?2004l[?2004h>         assigned = raw_norms[labels == j]
[?2004l[?2004h>         mags[j] = np.median(assigned) if len(assigned) > 0 else 0.0
[?2004l[?2004h>     return mags
[?2004l[?2004h> 
