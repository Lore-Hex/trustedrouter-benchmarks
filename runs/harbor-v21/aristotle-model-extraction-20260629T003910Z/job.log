breakpoints\n        bps = find_breakpoints(v, num_samples=samples_per_dir)\n        \n        for bp in bps:\n            # Refine and get gradient jump\n            try:\n                t_refined, jump, _, _ = refine_breakpoint(v, bp)\n                # Normalize the jump vector (sign doesn\'t matter, we just need direction)\n                if np.linalg.norm(jump) > 1e-8:\n                    # Store both the vector and its negative (to handle sign ambiguity later)\n                    all_vectors.append(jump)\n            except:\n                pass\n    \n    return np.array(all_vectors)\n\ndef cluster_vectors(vectors, n_clusters=20, n_iter=100):\n    """Cluster vectors into n_clusters groups using k-means with cosine similarity."""\n    if len(vectors) == 0:\n        return None\n    \n    # Normalize vectors\n    norms = np.linalg.norm(vectors, axis=1, keepdims=True)\n    norms[norms == 0] = 1\n    vectors_normalized = vectors / norms\n    \n    # Also store signs: we can flip sign of vectors since scaling ambiguity\n    # For k-means we need direction, not orientation\n    \n    # Initialize with random vectors\n    n = len(vectors)\n    indices = np.random.choice(n, n_clusters, replace=False)\n    centroids = vectors_normalized[indices].copy()\n    \n    for iteration in range(n_iter):\n        # Assign each point to nearest centroid (by cosine similarity)\n        # We need to handle sign: distance = min(|c - v|, |c + v|)\n        assignments = []\n        for v in vectors_normalized:\n            # Compute distances to all centroids\n            dists_pos = np.linalg.norm(centroids - v.reshape(1, -1), axis=1)\n            dists_neg = np.linalg.norm(centroids + v.reshape(1, -1), axis=1)\n            dists = np.minimum(dists_pos, dists_neg)\n            assignments.append(np.argmin(dists))\n        assignments = np.array(assignments)\n        \n        # Update centroids\n        new_centroids = []\n        for k in range(n_clusters):\n            mask =