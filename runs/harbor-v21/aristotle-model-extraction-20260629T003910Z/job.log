   if s < 1e-10:\n        return np.eye(3) if c > 0 else -np.eye(3)\n    Vx = np.array([[0, -v[2], v[1]], [v[2], 0, -v[0]], [-v[1], v[0], 0]])\n    return np.eye(3) + Vx + Vx @ Vx * (1 - c) / (s * s)\n\n\ndef align_to_ref(members, ref):\n    """Align signs of all members to match ref orientation."""\n    for i in range(len(members)):\n        if np.dot(members[i], ref) < 0:\n            members[i] = -members[i]\n    return members\n\n\ndef spherical_kmeans(X, k, restarts=20, max_iter=200):\n    """Sign-invariant spherical k-means."""\n    n, d = X.shape\n    best_inertia = np.inf\n    best_centroids = None\n    \n    for r in range(restarts):\n        # Initialize: pick k furthest vectors\n        idx = np.random.randint(n)\n        centroids = [X[idx]]\n        for _ in range(1, k):\n            dists = np.array([\n                min(np.linalg.norm(X[j] - c)**2, np.linalg.norm(X[j] + c)**2)\n                for j in range(n)\n                for c in centroids\n            ]).reshape(n, -1).min(axis=1)\n            # Actually just pick furthest from existing centroids\n            min_d = np.full(n, np.inf)\n            for c in centroids:\n                d_pos = np.sum((X - c)**2, axis=1)\n                d_neg = np.sum((X + c)**2, axis=1)\n                min_d = np.minimum(min_d, np.minimum(d_pos, d_neg))\n            idx = np.argmax(min_d)\n            centroids.append(X[idx])\n        centroids = np.array(centroids)\n        \n        for it in range(max_iter):\n            dots = X @ centroids.T\n            dists = np.minimum(2.0 - 2.0*dots, 2.0 + 2.0*dots)\n            labels = np.argmin(dists, axis=1)\n            \n            new_centroids = []\n            for j in range(k):\n                mask = labels == j\n                if mask.sum() == 0:\n                    new_centroids.append(X[np.random.randint(n)])\n                else:\n                    m = X[mask].copy()\n                    ref = m[0]\n                    for i in range(len(m)):\n