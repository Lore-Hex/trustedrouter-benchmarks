= 1e-3\n            g_left = grad((t0 - delta) * v, eps=1e-6)\n            g_right = grad((t0 + delta) * v, eps=1e-6)\n            jump = g_right - g_left\n            norm = np.linalg.norm(jump)\n            if norm > 1e-6:\n                vectors.append(jump)\n\n    return np.array(vectors)\n\n\ndef cluster_signed(vectors, k=N_NEURONS, restarts=8, iters=200, seed=0):\n    """Sign-invariant spherical k-means: distance is min(||c-v||, ||c+v||)."""\n    rng = np.random.default_rng(seed)\n    X = vectors / (np.linalg.norm(vectors, axis=1, keepdims=True) + 1e-12)\n    n = X.shape[0]\n\n    best_inertia = np.inf\n    best_centroids = None\n\n    for r in range(restarts):\n        centroids = X[rng.choice(n, k, replace=False)].copy()\n\n        for it in range(iters):\n            # Assignment\n            # dist_pos[i,j] = ||X[i] - centroids[j]||^2 = 2 - 2*X[i].centroids[j]\n            # dist_neg[i,j] = ||X[i] + centroids[j]||^2 = 2 + 2*X[i].centroids[j]\n            dots = X @ centroids.T\n            dist_pos = 2.0 - 2.0 * dots\n            dist_neg = 2.0 + 2.0 * dots\n            min_dists = np.minimum(dist_pos, dist_neg)\n            labels = np.argmin(min_dists, axis=1)\n\n            # Update\n            new_centroids = np.zeros((k, INPUT_DIM))\n            for j in range(k):\n                members = X[labels == j]\n                if len(members) == 0:\n                    new_centroids[j] = X[rng.integers(n)]\n                else:\n                    # Align signs to the first member\n                    ref = members[0]\n                    aligned = members.copy()\n                    flips = np.dot(members, ref) < 0\n                    aligned[flips] *= -1.0\n                    c = aligned.mean(axis=0)\n                    norm = np.linalg.norm(c)\n                    new_centroids[j] = c / norm if norm > 1e-12 else ref\n\n            if np.allclose(new_centroids, centroids, atol=1e-8, rtol=0):\n                centroids = new_centroids\n            