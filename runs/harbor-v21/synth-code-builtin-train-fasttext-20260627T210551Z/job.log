Sending keys: ['cat > /app/work/final_train.sh <<\'SCRIPT\'\n#!/bin/bash\nset -u\nFSTEXT=/opt/fastText/fasttext\nTRAIN=/app/work/train.txt\nTEST=/app/work/test.txt\nBASE=/app/work/model_final\nFINAL=/app/model.bin\nMAX_SIZE=150000000\nQUANT_TRIGGER=135000000\nMIN_ACC=0.62\nSEED=42\n\necho "=== final_train.sh start $(date -Iseconds) ==="\n\n# Kill stray fasttext supervised processes\nfor p in /proc/[0-9]*; do\n  cmd=$(tr \'\\0\' \' \' < "$p/cmdline" 2>/dev/null)\n  case "$cmd" in\n    *fasttext*) echo "killing ${p##*/}: $cmd"; kill -KILL "${p##*/}" 2>/dev/null || true;;\n  esac\ndone\nsleep 2\n\n# Clean stale artifacts\nrm -f "$BASE".bin "$BASE".vec "$BASE".ftz /app/work/train_final.log /app/work/train_final.pid /app/work/eval_final.txt /app/work/quantize_final.log /app/work/model_final_quant.ftz\nrm -f /app/work/model_aut2.bin /app/work/model_aut2.vec /app/work/model_aut2.ftz /app/work/autotune2.log /app/work/autotune2.pid /app/work/eval_aut2.txt\nrm -f "$FINAL"\n\necho "=== Data check ==="\nwc -l "$TRAIN" "$TEST"\ndf -h /app /app/work | tail -5\n\necho "=== Training supervised model ==="\nnohup "$FSTEXT" supervised \\\n  -input "$TRAIN" \\\n  -output "$BASE" \\\n  -dim 100 \\\n  -epoch 25 \\\n  -lr 0.7 \\\n  -wordNgrams 2 \\\n  -minn 3 \\\n  -maxn 5 \\\n  -bucket 200000 \\\n  -minCount 2 \\\n  -loss softmax \\\n  -thread "$(nproc)" \\\n  -seed "$SEED" \\\n  > /app/work/train_final.log 2>&1 &\ntrain_pid=$!\necho "$train_pid" > /app/work/train_final.pid\necho "train_pid=$train_pid"\n\n# Poll for completion up to 25 minutes\nfor i in $(seq 1 50); do\n  if [ -d "/proc/$train_pid" ]; then status=running; else status=finished; fi\n  size=$(stat -c %s "$BASE.bin" 2>/dev/null || echo 0)\n  printf \'(%s/50) status=%s bin_size=%s \' "$i" "$status" "$size"\n  tail -1 /app/work/train_final.log 2>/dev/null || true\n  if [ "$status" = finished ] && [ "$size" -gt 0 ]; then echo \'training_done\'; break; fi\n  if [ "$status" = finished ] && [ "$size" -eq 0 ]; then echo \'training_finished_no_model\'; break; fi\n  sleep 30\ndone\n\nif [ ! -s "$BASE.bin" ]; then\n  echo "ERROR: no valid raw model produced"\n  tail -40 /app/work/train_final.log 2>/dev/null || true\n  exit 1\nfi\n\nrm -f "$BASE.vec"\nRAW_SIZE=$(stat -c %s "$BASE.bin")\necho "raw_model_size=$RAW_SIZE"\n\necho "=== Evaluating raw model ==="\n"$FSTEXT" test "$BASE.bin" "$TEST" 2>&1 | tee /app/work/eval_final.txt\nRAW_ACC=$(awk \'/^P@1/ {print $3+0}\' /app/work/eval_final.txt 2>/dev/null || echo 0)\necho "raw_accuracy=$RAW_ACC"\n\nif [ "$RAW_SIZE" -lt "$MAX_SIZE" ] && awk -v min="$MIN_ACC" \'/^P@1/ {exit !($3+0 >= min)}\' /app/work/eval_final.txt; then\n  cp "$BASE.bin" "$FINAL"\n  echo "copied raw model to $FINAL"\nelse\n  echo "raw model not acceptable; raw_size=$RAW_SIZE raw_accuracy=$RAW_ACC"\n  if [ "$RAW_SIZE" -gt "$QUANT_TRIGGER" ] || ! awk -v min="$MIN_ACC" \'/^P@1/ {exit !($3+0 >= min)}\' /app/work/eval_final.txt; then\n    echo "=== Quantizing with retrain ==="\n    "$FSTEXT" quantize \\\n      -input "$BASE.bin" \\\n      -output "$BASE" \\\n      -qnorm -retrain -cutoff 100000 \\\n      -thread "$(nproc)" \\\n      > /app/work/quantize_final.log 2>&1\n    echo "quantize_exit=$?"\n    tail -30 /app/work/quantize_final.log 2>/dev/null || true\n    if [ ! -s "$BASE.ftz" ]; then\n      echo "ERROR: quantization did not produce $BASE.ftz"\n      exit 1\n    fi\n    QUANT_SIZE=$(stat -c %s "$BASE.ftz")\n    echo "quantized_size=$QUANT_SIZE"\n    echo "=== Evaluating quantized model ==="\n    "$FSTEXT" test "$BASE.ftz" "$TEST" 2>&1 | tee /app/work/eval_final.txt\n    QUANT_ACC=$(awk \'/^P@1/ {print $3+0}\' /app/work/eval_final.txt 2>/dev/null || echo 0)\n    echo "quantized_accuracy=$QUANT_ACC"\n    if [ "$QUANT_SIZE" -lt "$MAX_SIZE" ] && awk -v min="$MIN_ACC" \'/^P@1/ {exit !($3+0 >= min)}\' /app/work/eval_final.txt; then\n      cp "$BASE.ftz" "$FINAL"\n      echo "copied quantized model to $FINAL"\n    else\n      echo "ERROR: quantized model not acceptable; quantized_size=$QUANT_SIZE quantized_accuracy=$QUANT_ACC"\n      exit 1\n    fi\n  else\n    echo "ERROR: raw model failed accuracy but is not large enough for quantization fallback"\n    exit 1\n  fi\nfi\n\necho "=== Final verification ==="\nls -lh "$FINAL"\necho "final_size_bytes=$(stat -c %s "$FINAL")"\n"$FSTEXT" test "$FINAL" "$TEST" 2>&1 | tee /app/work/eval_final_check.txt\necho "=== final_train.sh done $(date -Iseconds) ==="\nSCRIPT\nchmod +x /app/work/final_train.sh\n/app/work/final_train.sh\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
