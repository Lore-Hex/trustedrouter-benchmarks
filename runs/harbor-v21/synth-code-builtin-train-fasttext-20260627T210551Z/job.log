Sending keys: ['cat > /app/work/wait_eval_copy.sh <<\'SCRIPT\'\n#!/bin/bash\nset -u\nPIDFILE=/app/work/autotune2.pid\nLOGFILE=/app/work/autotune2.log\nMODEL_BIN=/app/work/model_aut2.bin\nMODEL_FTZ=/app/work/model_aut2.ftz\nTESTFILE=/app/work/test.txt\nFINAL=/app/model.bin\nMAX_WAITS=30\nWAIT_INTERVAL=30\nMAX_SIZE=150000000\nMIN_ACC=0.62\n\necho "=== Waiting for autotune to finish ==="\nfor i in $(seq 1 "$MAX_WAITS"); do\n  pid=$(cat "$PIDFILE" 2>/dev/null || true)\n  if [ -n "$pid" ] && [ -d "/proc/$pid" ]; then\n    printf \'(%s/%s) pid=%s running; \' "$i" "$MAX_WAITS" "$pid"\n    tail -1 "$LOGFILE" 2>/dev/null || true\n    sleep "$WAIT_INTERVAL"\n    continue\n  fi\n  if [ -s "$MODEL_BIN" ] || [ -s "$MODEL_FTZ" ]; then\n    echo "autotune finished and model file exists"\n    break\n  fi\n  printf \'(%s/%s) finished but no model file; \' "$i" "$MAX_WAITS"\n  tail -1 "$LOGFILE" 2>/dev/null || true\n  sleep "$WAIT_INTERVAL"\ndone\n\necho "=== Autotune log tail ==="\ntail -40 "$LOGFILE" 2>/dev/null || true\n\necho "=== Clean/check model files ==="\nrm -f /app/work/model_aut2.vec\nls -lh /app/work/model_aut2.* 2>/dev/null || echo \'No model files found\'\n\nif [ -s "$MODEL_BIN" ]; then\n  MODEL="$MODEL_BIN"\nelif [ -s "$MODEL_FTZ" ]; then\n  MODEL="$MODEL_FTZ"\nelse\n  echo \'No valid autotune model produced; fallback needed\'\n  exit 1\nfi\n\nSIZE=$(stat -c %s "$MODEL")\necho "Selected model: $MODEL size=$SIZE bytes"\n\necho "=== Evaluate local test accuracy ==="\n/opt/fastText/fasttext test "$MODEL" "$TESTFILE" 2>&1 | tee /app/work/eval_aut2.txt || echo \'test failed\'\n\necho "=== Parse accuracy ==="\nawk -v min="$MIN_ACC" \'/^P@1/ {acc=$3+0; print "parsed_accuracy="acc; if (acc >= min && acc > 0) {print "accuracy_ok"; exit 0} else {print "accuracy_too_low"; exit 1}}\' /app/work/eval_aut2.txt\ncode=$?  # In bash, this captures the awk exit code.\n\necho "=== Copy to /app/model.bin if size and accuracy OK ==="\nif [ "$SIZE" -lt "$MAX_SIZE" ]; then\n  if [ -s /app/work/eval_aut2.txt ] && awk -v min="$MIN_ACC" \'/^P@1/ {acc=$3+0; if (acc >= min && acc > 0) {exit 0} else {exit 1}}\' /app/work/eval_aut2.txt; then\n    cp "$MODEL" "$FINAL"\n    echo "copied to $FINAL"\n    ls -lh "$FINAL"\n    echo "final_size_bytes=$(stat -c %s "$FINAL")"\n    echo "FINAL_OK"\n  else\n    echo "accuracy below $MIN_ACC; not copying"\n    echo "AUTOTUNE_ACCURACY_TOO_LOW"\n  fi\nelse\n  echo "model size $SIZE >= $MAX_SIZE; not copying"\n  echo "AUTOTUNE_SIZE_TOO_LARGE"\nfi\nSCRIPT\nchmod +x /app/work/wait_eval_copy.sh\n/app/work/wait_eval_copy.sh\n'] min_timeout_sec: 60 max_timeout_sec: 180.0
