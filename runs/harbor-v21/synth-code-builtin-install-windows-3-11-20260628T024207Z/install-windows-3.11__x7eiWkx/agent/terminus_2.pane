import urllib.request, http.client, base64, os
print('--- HTTP ---')
for url in ['http://localhost:80/vnc.html','http://localhost:80/','http://localhost:6080/']:
    try:
        r=urllib.request.urlopen(url, timeout=3)
        print(url, r.status, r.getheader('Content-Type'), len(r.read(300)))
    except Exception as e:
        print(url, 'ERROR', repr(e))
print('--- WEBSOCKET UPGRADE ---')
try:
    conn=http.client.HTTPConnection('localhost', 80, timeout=5)
    key=base64.b64encode(os.urandom(16)).decode()
    conn.putrequest('GET', '/websockify')
    conn.putheader('Host','localhost')
    conn.putheader('Upgrade','websocket')
    conn.putheader('Connection','Upgrade')
    conn.putheader('Sec-WebSocket-Key', key)
    conn.putheader('Sec-WebSocket-Version','13')
    conn.endheaders()
    r=conn.getresponse()
    print('websocket', r.status, r.reason, 'upgrade', r.getheader('Upgrade'), 'connection', r.getheader('Connection'), 'accept', r.getheader('Sec-WebSocket-Accept'))
    print('body', r.read(120))
    conn.close()
except Exception as e:
    print('websocket ERROR', repr(e))
PY
cat > /tmp/qemu_boot_probe.py <<'PY'
import socket, time, os, sys
sock_path='/tmp/qemu-monitor.sock'
out1='/tmp/win311_boot1.ppm'
s=socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(15)
s.connect(sock_path)
time.sleep(0.2)
print('BANNER:', s.recv(4096).decode(errors='replace').strip())
for cmd in [b'info status\n', b'screendump '+out1.encode()+b'\n']:
    s.sendall(cmd)
    time.sleep(3)
    print('---', cmd.decode().strip())
    print(s.recv(8192).decode(errors='replace').strip())
for cmd in [b'sendkey ret\n', b'sendkey ret\n', b'sendkey w\n', b'sendkey i\n', b'sendkey n\n', b'sendkey ret\n']:
    s.sendall(cmd)
    time.sleep(0.8)
    print('CMD', cmd.decode().strip())
    print(s.recv(8192).decode(errors='replace').strip())
print('Waiting 45s for Windows to load...')
time.sleep(45)
out2='/tmp/win311_boot2.ppm'
s.sendall(b'screendump '+out2.encode()+b'\n')
time.sleep(4)
print('--- screendump2')
print(s.recv(8192).decode(errors='replace').strip())
s.close()
for p in [out1, out2]:
    print('exists', p, os.path.exists(p), 'size', os.path.getsize(p) if os.path.exists(p) else 0)
    if os.path.exists(p) and os.path.getsize(p)>0:
        with open(p,'rb') as f:
            print('header:', f.read(32))
PY
timeout 90 python3 /tmp/qemu_boot_probe.py
python3 - <<'PY'
from collections import Counter
for p in ['/tmp/win311_boot1.ppm','/tmp/win311_boot2.ppm']:
    print('FILE', p)
    try:
        with open(p,'rb') as f:
            magic=f.readline().strip(); dims=f.readline().strip().split(); maxv=f.readline().strip()
            w,h=map(int,dims); data=f.read()
        pixels=len(data)//3
        c=Counter(); nonblack=0; rsum=gsum=bsum=0
        for i in range(0,len(data),3):
            r,g,b=data[i],data[i+1],data[i+2]
            c[(r,g,b)]+=1
            rsum+=r; gsum+=g; bsum+=b
            if (r,g,b)!=(0,0,0): nonblack+=1
        print(' size',w,h,'pixels',pixels,'unique_colors',len(c),'nonblack_pixels',nonblack)
        print(' avg_rgb', round(rsum/max(1,pixels),2), round(gsum/max(1,pixels),2), round(bsum/max(1,pixels),2))
        print(' top15', c.most_common(15))
        for name,color in [('teal',(0,128,128)),('white',(255,255,255)),('gray192',(192,192,192)),('gray128',(128,128,128)),('green',(0,128,0)),('blue',(0,0,255)),('red',(255,0,0))]:
            print(' ',name, c.get(color,0))
    except Exception as e:
        print(' ERROR', repr(e))
