cat > /tmp/qemu_boot_probe.py <<'PY'
import socket, time, os
sock_path='/tmp/qemu-monitor.sock'
out1='/tmp/win311_boot1.ppm'
s=socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(15)
s.connect(sock_path)
time.sleep(0.2)
print('BANNER:', s.recv(4096).decode(errors='replace').strip())
for cmd in [b'info status\n', b'screendump '+out1.encode()+b'\n']:
    s.sendall(cmd)
    time.sleep(3)
    print('---', cmd.decode().strip())
    print(s.recv(8192).decode(errors='replace').strip())
s.close()
print('exists', os.path.exists(out1), 'size', os.path.getsize(out1) if os.path.exists(out1) else 0)
if os.path.exists(out1) and os.path.getsize(out1)>0:
    with open(out1,'rb') as f:
        print('header:', f.read(32))
