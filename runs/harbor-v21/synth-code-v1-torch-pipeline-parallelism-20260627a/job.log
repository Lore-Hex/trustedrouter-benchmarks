Sending keys: ['cat > /app/pipeline_parallel.py <<\'PY\'\n"""Pipeline parallel training for Hugging Face LLaMA models using PyTorch.\n\nThis module implements an all-forward-all-backward (AFAB) pipeline parallel\ntraining step for ``transformers.LlamaForCausalLM``.  Communication between\npipeline stages uses ``torch.distributed.P2POp``.\n"""\n\nfrom typing import List, Optional, Tuple\n\nimport torch\nimport torch.distributed as dist\n\n\ndef _partition_layers(num_layers: int, world_size: int) -> List[Tuple[int, int]]:\n    """Return ``(start, end)`` layer indices for each rank in a roughly balanced way."""\n    base = num_layers // world_size\n    rem = num_layers % world_size\n    partitions: List[Tuple[int, int]] = []\n    start = 0\n    for rank in range(world_size):\n        count = base + (1 if rank < rem else 0)\n        end = start + count\n        partitions.append((start, end))\n        start = end\n    return partitions\n\n\ndef _decoder_layer_kwargs(layer, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]) -> dict:\n    """Build kwargs for LlamaDecoderLayer across transformers versions."""\n    kwargs: dict = {}\n    try:\n        import inspect\n\n        params = set(inspect.signature(layer.forward).parameters.keys())\n        if "position_ids" in params:\n            kwargs["position_ids"] = position_ids\n        if "position_embeddings" in params and rotary_emb is not None:\n            kwargs["position_embeddings"] = rotary_emb\n    except Exception:\n        kwargs["position_ids"] = position_ids\n        if rotary_emb is not None:\n            kwargs["position_embeddings"] = rotary_emb\n    return kwargs\n\n\ndef _get_rotary_emb(model, hidden_states: torch.Tensor, position_ids: torch.Tensor) -> Optional[Tuple[torch.Tensor, torch.Tensor]]:\n    """Return rotary embeddings from the model if available."""\n    model_ref = getattr(model, "model", model)\n    rotary_emb_mod = getattr(model_ref, "rotary_emb", None)\n    if rotary_emb_mod is None:\n        return None\n    try:\n        with torch.no_grad():\n            return rotary_emb_mod(hidden_states, position_ids)\n    except Exception:\n        return None\n\n\ndef _run_layers(model, start: int, end: int, hidden_states: torch.Tensor, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]) -> torch.Tensor:\n    """Run ``model.layers[start:end]`` and return output hidden states."""\n    out = hidden_states\n    for layer in model.layers[start:end]:\n        kwargs = _decoder_layer_kwargs(layer, position_ids, rotary_emb)\n        layer_out = layer(out, **kwargs)\n        if isinstance(layer_out, (tuple, list)):\n            out = layer_out[0]\n        else:\n            out = layer_out\n    return out\n\n\ndef _recv_hidden(microbatch_size: int, seq_len: int, hidden_size: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:\n    """Allocate a non-leaf hidden-state tensor for receiving from a peer."""\n    return torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype).requires_grad_(True)\n\n\ndef _send_tensor(tensor: torch.Tensor, peer: int) -> None:\n    """Send a tensor to ``peer`` using a P2POp and wait for completion."""\n    op = dist.P2POp(dist.isend, tensor, peer)\n    op.wait()\n\n\ndef _recv_tensor(tensor: torch.Tensor, peer: int) -> None:\n    """Receive a tensor from ``peer`` using a P2POp and wait for completion."""\n    op = dist.P2POp(dist.irecv, tensor, peer)\n    op.wait()\n\n\ndef train_step_pipeline_afab(model, inputs, targets, device, dtype):\n    """Run one all-forward-all-backward pipeline-parallel training step.\n\n    Args:\n        model: a LlamaForCausalLM instance.\n        inputs: list of input-id microbatch tensors; together they form one batch.\n        targets: list of corresponding target-id microbatch tensors.\n        device: torch device.\n        dtype: torch dtype.\n    """\n    if dist.is_available() and dist.is_initialized():\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n    else:\n        world_size = 1\n        rank = 0\n\n    num_microbatches = len(inputs)\n    num_layers = len(model.layers)\n    hidden_size = model.config.hidden_size\n    partitions = _partition_layers(num_layers, world_size)\n    start_layer, end_layer = partitions[rank]\n\n    model.train()\n\n    # ------------------------------------------------------------------\n    # Forward phase: run all microbatches through this pipeline stage.\n    # ------------------------------------------------------------------\n    stage_inputs: List[Optional[torch.Tensor]] = []\n    stage_outputs: List[torch.Tensor] = []\n\n    for mb_idx in range(num_microbatches):\n        if rank == 0:\n            input_ids = inputs[mb_idx].to(device=device, dtype=torch.long)\n            stage_input = model.get_input_embeddings()(input_ids).to(device=device, dtype=dtype)\n            if not stage_input.requires_grad:\n                stage_input = stage_input.requires_grad_(True)\n            seq_len = input_ids.shape[1]\n            microbatch_size = input_ids.shape[0]\n        else:\n            microbatch_size = inputs[mb_idx].shape[0]\n            seq_len = inputs[mb_idx].shape[1]\n            stage_input = _recv_hidden(microbatch_size, seq_len, hidden_size, device, dtype)\n            _recv_tensor(stage_input, rank - 1)\n\n        position_ids = torch.arange(seq_len, device=device, dtype=torch.long).unsqueeze(0)\n        rotary_emb = _get_rotary_emb(model, stage_input, position_ids)\n        stage_output = _run_layers(model, start_layer, end_layer, stage_input, position_ids, rotary_emb)\n        if not stage_output.requires_grad:\n            stage_output = stage_output.requires_grad_(True)\n\n        stage_inputs.append(stage_input)\n        stage_outputs.append(stage_output)\n\n        if rank + 1 < world_size:\n            _send_tensor(stage_output.detach().to(device=device, dtype=dtype), rank + 1)\n\n    # ------------------------------------------------------------------\n    # Backward phase: run all microbatches in reverse order.\n    # ------------------------------------------------------------------\n    for mb_idx in reversed(range(num_microbatches)):\n        stage_input = stage_inputs[mb_idx]\n        stage_output = stage_outputs[mb_idx]\n\n        if rank == world_size - 1:\n            target = targets[mb_idx].to(device=device)\n            logits = model.get_output_embeddings()(stage_output).to(device=device, dtype=dtype)\n            loss = torch.nn.functional.cross_entropy(\n                logits.view(-1, logits.size(-1)),\n                target.view(-1),\n            )\n            loss = loss / num_microbatches\n\n            if world_size == 1:\n                loss.backward()\n            else:\n                grad_output = torch.autograd.grad(loss, stage_output)[0]\n                _send_tensor(grad_output.detach().to(device=device, dtype=dtype), rank - 1)\n        else:\n            microbatch_size = stage_output.shape[0]\n            seq_len = stage_output.shape[1]\n            grad_output = torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype)\n            _recv_tensor(grad_output, rank + 1)\n\n            if rank == 0:\n                stage_output.backward(grad_output)\n            else:\n                grad_input = torch.autograd.grad(\n                    stage_output,\n                    stage_input,\n                    grad_outputs=grad_output,\n                    retain_graph=(mb_idx != 0),\n                )[0]\n                _send_tensor(grad_input.detach().to(device=device, dtype=dtype), rank - 1)\n\n    return None\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
