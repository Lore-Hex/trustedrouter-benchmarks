tialized.  All microbatch forward passes\n    are run before any backward passes.  Communication between stages uses\n    ``torch.distributed.P2POp``.  No hooks are registered inside this function.\n    """\n    if not dist.is_available() or not dist.is_initialized():\n        world_size = 1\n        rank = 0\n    else:\n        world_size = dist.get_world_size()\n        rank = dist.get_rank()\n\n    num_microbatches = len(inputs)\n    num_layers = len(model.layers)\n    hidden_size = model.config.hidden_size\n    starts, ends = [], []\n    for s, e in _partition_layers(num_layers, world_size):\n        starts.append(s)\n        ends.append(e)\n    start, end = starts[rank], ends[rank]\n\n    model.train()\n\n    # ------------------------------------------------------------------\n    # Forward phase: run all microbatches through this stage.\n    # ------------------------------------------------------------------\n    activations: List[dict] = []\n    forward_outputs: List[Optional[torch.Tensor]] = []\n\n    for mb_idx in range(num_microbatches):\n        if rank == 0:\n            input_ids = _to_grad_tensor(inputs[mb_idx], device, torch.long)\n            embed_tokens = model.get_input_embeddings()\n            hidden_states = embed_tokens(input_ids).to(device=device, dtype=dtype)\n            if not hidden_states.requires_grad:\n                hidden_states = hidden_states.requires_grad_(True)\n            seq_len = input_ids.shape[1]\n            microbatch_size = input_ids.shape[0]\n        else:\n            microbatch_size = inputs[mb_idx].shape[0] if len(inputs) > 0 else 1\n            seq_len = inputs[mb_idx].shape[1] if len(inputs) > 0 else 1 if inputs else 1\n            hidden_states = _recv_hidden(microbatch_size, seq_len, hidden_size, device, dtype)\n            reqs = []\n            if rank + 1 < world_size:\n                recv_tensor = hidden_states\n            else:\n                recv_tensor = hidden_states\n            reqs.append(dist.P2POp(dist.irecv, recv_tensor, rank - 1))\n            for req in reqs:\n                req.wait()\n\n        position_ids = torch.arange(seq_len, device=device, dtype=torch.long).unsqueeze(0)\n        rotary_emb = _get_rotary_emb(model, hidden_states, position_ids, device)\n        hidden_states = _run_layers(model, start, end, hidden_states, position_ids, rotary_emb)\n        if not hidden_states.requires_grad:\n            hidden_states = hidden_states.requires_grad_(True)\n\n        forward_outputs.append(hidden_states)\n        activations.append({\n            "hidden_states": hidden_states,\n            "position_ids": position_ids,\n            "rotary_emb": rotary_emb,\n        })\n\n    # ------------------------------------------------------------------\n    # Backward phase: all microbatches in reverse order.\n    # ------------------------------------------------------------------\n    for mb_idx in reversed(range(num_microbatches)):\n        hidden_states = forward_outputs[mb_idx]\n        if rank == world_size - 1:\n            target = targets[mb_idx].to(device=device)\n            if target.dim() == 2:\n                target_flat = target.view(-1)\n            else:\n                target_flat = target.reshape(-1)\n            logits = model.get_output_embeddings()(hidden_states)\n            logits = logits.to(device=device, dtype=dtype)\n            loss = torch.nn.functional.cross_entropy(logits.view(-1, logits.size(-1)), target_flat)\n            loss = loss / num_microbatches\n            if world_size == 1:\n                loss.backward()\n            else:\n                grad_hidden = torch.autograd.grad(loss, hidden_states, retain_graph=(mb_idx != 0))[0]\n                send_tensor = grad_hidden.detach().to(device=device, dtype=dtype)\n                req = dist.P2POp(dist.isend, send_tensor, rank - 1)\n                req.wait()\n        else:\n            microbatch_size = hidden_states.shape[0]\n            seq_len = hidden_states.shape[1]\n            grad_output = torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype)\n            reqs = [dist.P2POp(dist.irecv, grad_output, rank + 1)]\n            for req in reqs:\n                req.wait()\n            grad_output = grad_output.to(device=device, dtype=dtype)\n            hidden_states.backward(grad_output)\n            if rank > 0:\n                input_hidden = activations[mb_idx]["hidden_states"]\n                grad_input = torch.autograd.grad(hidden_states, input_hidden, grad_outputs=grad_output, retain_graph=(mb_idx != 0))[0]\n                send_tensor = grad_input.detach().to(device=device, dtype=dtype)\n                req = dist.P2POp(dist.isend, send_tensor, rank - 1)\n                req.wait()\n\n    return None\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
