Sending keys: ['cat > /app/pipeline_parallel.py <<\'PY\'\n"""Pipeline parallel training for Hugging Face LLaMA models using PyTorch.\n\nThis module implements an all-forward-all-backward (AFAB) pipeline parallel\ntraining step for ``transformers.LlamaForCausalLM``.  The implementation is\nself-contained and uses ``torch.distributed`` point-to-point operations for\ninter-stage communication.\n"""\n\nfrom typing import List, Optional, Tuple\n\nimport torch\nimport torch.distributed as dist\nfrom torch.distributed import P2POp\n\n\ndef _partition_layers(num_layers: int, world_size: int) -> List[Tuple[int, int]]:\n    """Return ``(start, end)`` layer indices for each rank."""\n    base = num_layers // world_size\n    rem = num_layers % world_size\n    partitions: List[Tuple[int, int]] = []\n    start = 0\n    for rank in range(world_size):\n        count = base + (1 if rank < rem else 0)\n        end = start + count\n        partitions.append((start, end))\n        start = end\n    return partitions\n\n\ndef _to_grad_tensor(x: torch.Tensor, device: torch.device, dtype: torch.dtype) -> torch.Tensor:\n    """Move a tensor to device/dtype and make it a leaf requiring grad."""\n    x = x.to(device=device, dtype=dtype)\n    if not x.requires_grad:\n        x = x.requires_grad_(True)\n    return x\n\n\ndef _recv_hidden(microbatch_size: int, seq_len: int, hidden_size: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:\n    """Allocate a hidden-state tensor suitable for receiving from a peer."""\n    return torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype).requires_grad_(True)\n\n\ndef _layer_kwargs(layer, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]):\n    """Build forward kwargs compatible with several LlamaDecoderLayer versions."""\n    kwargs = {}\n    try:\n        import inspect\n\n        params = set(inspect.signature(layer.forward).parameters.keys())\n        if "position_ids" in params: