[?2004l     1	"""Pipeline parallel training for Hugging Face LLaMA models using PyTorch.
     2	
     3	This module implements an all-forward-all-backward (AFAB) pipeline parallel
     4	training step for ``transformers.LlamaForCausalLM``.  Communication between
     5	pipeline stages uses ``torch.distributed.P2POp``.
     6	"""
     7	
     8	from typing import List, Optional, Tuple
     9	
    10	import torch
    11	import torch.distributed as dist
    12	
    13	
    14	def _partition_layers(num_layers: int, world_size: int) -> List[Tuple[int, int]]:
    15	    """Return ``(start, end)`` layer indices for each rank in a roughly balanced way."""
    16	    base = num_layers // world_size
    17	    rem = num_layers % world_size
    18	    partitions: List[Tuple[int, int]] = []
    19	    start = 0
    20	    for rank in range(world_size):
    21	        count = base + (1 if rank < rem else 0)
    22	        end = start + count
    23	        partitions.append((start, end))
    24	        start = end
    25	    return partitions
    26	
    27	
    28	def _decoder_layer_kwargs(layer, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]) -> dict:
    29	    """Build kwargs for LlamaDecoderLayer across transformers versions."""
    30	    kwargs: dict = {}
    31	    try:
    32	        import inspect
    33	
    34	        params = set(inspect.signature(layer.forward).parameters.keys())
    35	        if "position_ids" in params:
    36	            kwargs["position_ids"] = position_ids
    37	        if "position_embeddings" in params and rotary_emb is not None:
    38	            kwargs["position_embeddings"] = rotary_emb
    39	    except Exception:
    40	        kwargs["position_ids"] = position_ids
    41	        if rotary_emb is not None:
    42	            kwargs["position_embeddings"] = rotary_emb
    43	    return kwargs
    44	
    45	
    46	def _get_rotary_emb(model, hidden_states: torch.Tensor, position_ids: torch.Tensor) -> Optional[Tuple[torch.Tensor, torch.Tensor]]:
    47	    """Return rotary embeddings from the model if available."""
    48	    model_ref = getattr(model, "model", model)
    49	    rotary_emb_mod = getattr(model_ref, "rotary_emb", None)
    50	    if rotary_emb_mod is None:
    51	        return None
    52	    try:
    53	        with torch.no_grad():
    54	            return rotary_emb_mod(hidden_states, position_ids)
    55	    except Exception:
    56	        return None
    57	
    58	
    59	def _run_layers(model, start: int, end: int, hidden_states: torch.Tensor, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]) -> torch.Tensor:
    60	    """Run ``model.layers[start:end]`` and return output hidden states."""
    61	    out = hidden_states
    62	    for layer in model.layers[start:end]:
    63	        kwargs = _decoder_layer_kwargs(layer, position_ids, rotary_emb)
    64	        layer_out = layer(out, **kwargs)
    65	        if isinstance(layer_out, (tuple, list)):
    66	            out = layer_out[0]
    67	        else:
    68	            out = layer_out
    69	    return out
    70	
    71	
    72	def _recv_hidden(microbatch_size: int, seq_len: int, hidden_size: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
    73	    """Allocate a non-leaf hidden-state tensor for receiving from a peer."""
    74	    return torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype).requires_grad_(True)
    75	
    76	
    77	def _send_tensor(tensor: torch.Tensor, peer: int) -> None:
    78	    """Send a tensor to ``peer`` using a P2POp and wait for completion."""
    79	    op = dist.P2POp(dist.isend, tensor, peer)
    80	    op.wait()
    81	
    82	
    83	def _recv_tensor(tensor: torch.Tensor, peer: int) -> None:
    84	    """Receive a tensor from ``peer`` using a P2POp and wait for completion."""
    85	    op = dist.P2POp(dist.irecv, tensor, peer)
    86	    op.wait()
    87	
    88	
    89	def train_step_pipeline_afab(model, inputs, targets, device, dtype):
    90	    """Run one all-forward-all-backward pipeline-parallel training step.
    91	
    92	    Args:
    93	        model: a LlamaForCausalLM instance.
    94	        inputs: list of input-id microbatch tensors; together they form one batch.
    95	        targets: list of corresponding target-id microbatch tensors.
    96	        device: torch device.
    97	        dtype: torch dtype.
    98	    """
    99	    if dist.is_available() and dist.is_initialized():
   100	        world_size = dist.get_world_size()
   101	        rank = dist.get_rank()
   102	    else:
   103	        world_size = 1
   104	        rank = 0
   105	
   106	    num_microbatches = len(inputs)
   107	    num_layers = len(model.layers)
   108	    hidden_size = model.config.hidden_size
   109	    partitions = _partition_layers(num_layers, world_size)
   110	    start_layer, end_layer = partitions[rank]
   111	
   112	    model.train()
   113	
   114	    # ------------------------------------------------------------------
   115	    # Forward phase: run all microbatches through this pipeline stage.
   116	    # ------------------------------------------------------------------
   117	    stage_inputs: List[Optional[torch.Tensor]] = []
   118	    stage_outputs: List[torch.Tensor] = []
   119	
   120	    for mb_idx in range(num_microbatches):
   121	        if rank == 0:
   122	            input_ids = inputs[mb_idx].to(device=device, dtype=torch.long)
   123	            stage_input = model.get_input_embeddings()(input_ids).to(device=device, dtype=dtype)
   124	            if not stage_input.requires_grad:
   125	                stage_input = stage_input.requires_grad_(True)
   126	            seq_len = input_ids.shape[1]
   127	            microbatch_size = input_ids.shape[0]
   128	        else:
   129	            microbatch_size = inputs[mb_idx].shape[0]
   130	            seq_len = inputs[mb_idx].shape[1]
   131	            stage_input = _recv_hidden(microbatch_size, seq_len, hidden_size, device, dtype)
   132	            _recv_tensor(stage_input, rank - 1)
   133	
   134	        position_ids = torch.arange(seq_len, device=device, dtype=torch.long).unsqueeze(0)
   135	        rotary_emb = _get_rotary_emb(model, stage_input, position_ids)
   136	        stage_output = _run_layers(model, start_layer, end_layer, stage_input, position_ids, rotary_emb)
   137	        if not stage_output.requires_grad:
   138	            stage_output = stage_output.requires_grad_(True)
   139	
   140	        stage_inputs.append(stage_input)
   141	        stage_outputs.append(stage_output)
   142	
   143	        if rank + 1 < world_size:
   144	            _send_tensor(stage_output.detach().to(device=device, dtype=dtype), rank + 1)
   145	
   146	    # ------------------------------------------------------------------
   147	    # Backward phase: run all microbatches in reverse order.
   148	    # ------------------------------------------------------------------
   149	    for mb_idx in reversed(range(num_microbatches)):
   150	        stage_input = stage_inputs[mb_idx]
   151	        stage_output = stage_outputs[mb_idx]
   152	
   153	        if rank == world_size - 1:
   154	            target = targets[mb_idx].to(device=device)
   155	            logits = model.get_output_embeddings()(stage_output).to(device=device, dtype=dtype)
   156	            loss = torch.nn.functional.cross_entropy(
   157	                logits.view(-1, logits.size(-1)),
   158	                target.view(-1),
   159	            )
   160	            loss = loss / num_microbatches
   161	
   162	            if world_size == 1:
   163	                loss.backward()
   164	            else:
   165	                grad_output = torch.autograd.grad(loss, stage_output)[0]
   166	                _send_tensor(grad_output.detach().to(device=device, dtype=dtype), rank - 1)
   167	        else:
   168	            microbatch_size = stage_output.shape[0]
   169	            seq_len = stage_output.shape[1]
   170	            grad_output = torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype)
   171	            _recv_tensor(grad_output, rank + 1)
   172	
   173	            if rank == 0:
   174	                stage_output.backward(grad_output)
