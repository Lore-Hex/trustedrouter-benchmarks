   208	def _send_tensor(tensor: torch.Tensor, peer: int) -> None:
   209	    """Send a tensor to ``peer`` using a P2POp and wait for completion."""
   210	    op = dist.P2POp(dist.isend, tensor, peer)
   211	    op.wait()
   212	
   213	
   214	def _recv_tensor(tensor: torch.Tensor, peer: int) -> None:
   215	    """Receive a tensor from ``peer`` using a P2POp and wait for completion."""
   216	    op = dist.P2POp(dist.irecv, tensor, peer)
   217	    op.wait()
