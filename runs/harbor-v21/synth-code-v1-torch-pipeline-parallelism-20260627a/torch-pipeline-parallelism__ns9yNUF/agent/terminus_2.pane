   190	def _run_layers(model, start: int, end: int, hidden_states: torch.Tensor, position_ids: torch.Tensor, rotary_emb: Optional[Tuple[torch.Tensor, torch.Tensor]]) -> torch.Tensor:
   191	    """Run ``model.layers[start:end]`` and return output hidden states."""
   192	    out = hidden_states
   193	    for layer in model.layers[start:end]:
   194	        kwargs = _decoder_layer_kwargs(layer, position_ids, rotary_emb)
   195	        layer_out = layer(out, **kwargs)
   196	        if isinstance(layer_out, (tuple, list)):
   197	            out = layer_out[0]
   198	        else:
   199	            out = layer_out
   200	    return out
   201	
   202	
   203	def _recv_hidden(microbatch_size: int, seq_len: int, hidden_size: int, device: torch.device, dtype: torch.dtype) -> torch.Tensor:
   204	    """Allocate a non-leaf hidden-state tensor for receiving from a peer."""
   205	    return torch.empty((microbatch_size, seq_len, hidden_size), device=device, dtype=dtype).requires_grad_(True)
   206	
