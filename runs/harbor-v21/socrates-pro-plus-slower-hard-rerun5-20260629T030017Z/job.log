Sending keys: ['python3 -c "\nimport struct\n# Dump .rodata from the binary\nwith open(\'orig\', \'rb\') as f:\n    # Read ELF header to find section headers\n    f.seek(0)\n    ident = f.read(16)\n    # 64-bit ELF\n    f.seek(40)  # e_shoff\n    e_shoff = struct.unpack(\'<Q\', f.read(8))[0]\n    f.seek(58)  # e_shentsize, e_shnum, e_shstrndx\n    e_shentsize = struct.unpack(\'<H\', f.read(2))[0]\n    e_shnum = struct.unpack(\'<H\', f.read(2))[0]\n    e_shstrndx = struct.unpack(\'<H\', f.read(2))[0]\n    \n    # Read section header string table\n    f.seek(e_shoff + e_shstrndx * e_shentsize)\n    shstr = f.read(e_shentsize)\n    str_off = struct.unpack(\'<Q\', shstr[24:32])[0]\n    str_size = struct.unpack(\'<Q\', shstr[32:40])[0]\n    f.seek(str_off)\n    shstrtab = f.read(str_size)\n    \n    # Find .rodata section\n    for i in range(e_shnum):\n        f.seek(e_shoff + i * e_shentsize)\n        sh = f.read(e_shentsize)\n        sh_name = struct.unpack(\'<I\', sh[0:4])[0]\n        name = shstrtab[sh_name:].split(b\'\\x00\')[0].decode()\n        if name == \'.rodata\':\n            ro_off = struct.unpack(\'<Q\', sh[24:32])[0]\n            ro_size = struct.unpack(\'<Q\', sh[32:40])[0]\n            f.seek(ro_off)\n            rodata = f.read(ro_size)\n            print(f\'.rodata at offset 0x{ro_off:x}, size {ro_size}\')\n            # Decode as floats (skip first 4 bytes which is the \\x01\\x00\\x02\\x00)\n            for j in range(0, len(rodata), 4):\n                if j + 4 <= len(rodata):\n                    val_f = struct.unpack(\'<f\', rodata[j:j+4])[0]\n                    val_i = struct.unpack(\'<I\', rodata[j:j+4])[0]\n                    print(f\'  0x{ro_off+j:x}: 0x{val_i:08x} float={val_f}\')\n            break\n"\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
