Sending keys: ["cat > find_params.py << 'PYEOF'\nimport math\n\nW, H = 2400, 1800\ncam = (0, -0.5, -5.0)\nvw = 2.0 * W / H  # 2.6667\nvh = 2.0\nvU = (vw, 0, 0)\nvV = (0, vh, 0)\nfl = (0, 0, 1.0)\nll = (cam[0] - vw/2 + fl[0], cam[1] - vh/2 + fl[1], cam[2] + fl[2])\n\n# Known sphere edges from original image\norig_edges = {810: (1178,1221), 830: (1114,1285), 850: (1084,1315), 870: (1063,1336), 890: (1048,1351), 910: (1036,1363), 950: (1021,1378), 1000: (1016,1383), 1050: (1025,1374), 1100: (1050,1349), 1150: (1103,1296)}\n\ndef sphere_edge_pixels(scy, scz, sr):\n    sc = (0, scy, scz)\n    result = {}\n    for y in orig_edges:\n        v = 1.0 - y / (H - 1)\n        # Binary search for left edge\n        lo, hi = 800, 1200\n        for _ in range(60):\n            x = (lo + hi) / 2\n            u = x / (W - 1)\n            tx = ll[0] + u * vw\n            ty = ll[1] + v * vh\n            tz = ll[2]\n            dx, dy, dz = tx - cam[0], ty - cam[1], tz - cam[2]\n            d = math.sqrt(dx*dx + dy*dy + dz*dz)\n            dx, dy, dz = dx/d, dy/d, dz/d\n            ocx, ocy,ocz = cam[0]-sc[0], cam[1]-sc[1], cam[2]-sc[2]\n            b = ocx*dx + ocy*dy + ocz*dz\n            c = ocx*ocx + ocy*ocy + ocz*ocz - sr*sr\n            h = b*b - c\n            if h < 0:\n                lo = x\n            else:\n                hi = x\n        left = (lo + hi) / 2\n        # Right edge\n        lo, hi = 1200, 1600\n        for _ in range(60):\n            x = (lo + hi) / 2\n            u = x / (W - 1)\n            tx = ll[0] + u * vw\n            ty = ll[1] + v * vh\n            tz = ll[2]\n            dx, dy, dz = tx - cam[0], ty - cam[1], tz - cam[2]\n            d = math.sqrt(dx*dx + dy*dy + dz*dz)\n            dx, dy, dz = dx/d, dy/d, dz/d\n            ocx, ocy, ocz = cam[0]-sc[0], cam[1]-sc[1], cam[2]-sc[2]\n            b = ocx*dx + ocy*dy + ocz*dz\n            c = ocx*ocx + ocy*ocy + ocz*ocz - sr*sr\n            h = b*b - c\n            if h < 0:\n                hi = x\n            else:\n                lo = x\n        right = (lo + hi) / 2\n        result[y] = (left, right)\n    return result\n\nbest_err = 1e9\nbest_params = None\nfor scy10 in range(-10, 10):\n    for scz10 in range(-10, 100):\n        for sr10 in range(5, 20):\n            scy = scy10 / 10.0\n            scz = scz10 / 10.0\n            sr = sr10 / 10.0\n            edges = sphere_edge_pixels(scy, scz, sr)\n            err = 0\n            valid = True\n            for y in orig_edges:\n                if y not in edges:\n                    valid = False\n                    break\n                ol, oor = orig_edges[y]\n                el, er = edges[y]\n                err += abs(el - ol) + abs(er - oor)\n            if valid and err < best_err:\n                best_err = err\n                best_params = (scy, scz, sr)\n                if err < 5:\n                    break\n\nprint(f'Best: scy={best_params[0]}, scz={best_params[1]}, sr={best_params[2]}, err={best_err}')\n# Show detail for best\nedges = sphere_edge_pixels(*best_params)\nfor y in sorted(edges):\n    ol, oor = orig_edges[y]\n    el, er = edges[y]\n    print(f'  Row {y}: orig=[{ol},{oor}] best=[{el:.0f},{er:.0f}]')\nPYEOF\npython3 find_params.py\n"] min_timeout_sec: 60.0 max_timeout_sec: 180.0
