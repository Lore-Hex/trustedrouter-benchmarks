Sending keys: ['cat > image.c << \'CEOF\'\n#include <stdio.h>\n#include <stdlib.h>\n#include <math.h>\n\ntypedef struct { float x, y, z; } V;\nV v(float x, float y, float z) { V r={x,y,z}; return r; }\nV vadd(V a, V b) { return v(a.x+b.x, a.y+b.y, a.z+b.z); }\nV vsub(V a, V b) { return v(a.x-b.x, a.y-b.y, a.z-b.z); }\nV vmul(V a, float t) { return v(a.x*t, a.y*t, a.z*t); }\nfloat vdot(V a, V b) { return a.x*b.x + a.y*b.y + a.z*b.z; }\nfloat vlen(V v) { return sqrtf(vdot(v,v)); }\nV vnorm(V a) { float l=vlen(a); return v(a.x/l, a.y/l, a.z/z); }\n\n// Scene parameters\nV cam = {0, 0, -5};\nV sph_center = {0, 0, 0};\nfloat sph_r = 1.0;\nfloat plane_y = -1.5;\nV light = {-1, 2, -1};\n\nfloat intersect_sphere(V ro, V rd, V sc, float sr) {\n    V oc = vsub(ro, sc);\n    float b = vdot(oc, rd);\n    float c = vdot(oc, oc) - sr*sr;\n    float h = b*b - c;\n    if (h < 0) return -1;\n    return -b - sqrtf(h);\n}\n\nfloat intersect_plane(V ro, V rd, float py) {\n    if (fabsf(rd.y) < 1e-6) return -1;\n    float t = (py - ro.y) / rd.y;\n    return t > 0 ? t : -1;\n}\n\nV trace(V ro, V rd) {\n    float ts = intersect_sphere(ro, rd, sph_center, sph_r);\n    float tp = intersect_plane(ro, rd, plane_y);\n    \n    float t;\n    int hit_sphere = 0, hit_plane = 0;\n    \n    if (ts > 0 && tp > 0) {\n        if (ts < tp) { t = ts; hit_sphere = 1; }\n        else { t = tp; hit_plane = 1; }\n    } else if (ts > 0) { t = ts; hit_sphere = 1; }\n    else if (tp > 0) { t = tp; hit_plane = 1; }\n    else {\n        // Sky\n        V n = vnorm(rd);\n        float a = 0.5 * (n.y + 1.0);\n        V col = vadd(vmul(v(1,1,1), 1.0-a), vmul(v(0.5, 0.7, 1.0), a));\n        return col;\n    }\n    \n    V pos = vadd(ro, vmul(rd, t));\n    V N, color;\n    \n    if (hit_sphere) {\n        N = vnorm(vsub(pos, sph_center));\n        color = v(0.2, 0.04, 0.04);\n    } else {\n        N = v(0, 1, 0);\n        int cx = (int)floorf(pos.x);\n        int cz = (int)floorf(pos.z);\n        float checker = ((cx