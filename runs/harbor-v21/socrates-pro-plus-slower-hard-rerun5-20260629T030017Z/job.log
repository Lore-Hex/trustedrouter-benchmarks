Sending keys: ["cat > compare.py << 'PYEOF'\nimport math\nimport sys\n\ndef read_ppm(filename):\n    with open(filename, 'r') as f:\n        magic = f.readline().strip()\n        dims = f.readline().strip().split()\n        w, h = int(dims[0]), int(dims[1])\n        maxval = int(f.readline().strip())\n        pixels = []\n        for line in f:\n            parts = line.strip().split()\n            if len(parts) == 3:\n                pixels.append(tuple(map(int, parts)))\n    return w, h, pixels\n\nprint('Reading image.ppm...')\nw1, h1, p1 = read_ppm('image.ppm')\nprint(f'  {w1}x{h1}, {len(p1)} pixels')\n\nprint('Reading reconstructed.ppm...')\nw2, h2, p2 = read_ppm('reconstructed.ppm')\nprint(f'  {w2}x{h2}, {len(p2)} pixels')\n\nassert w1 == w2 and h1 == h2\nassert len(p1) == len(p2)\n\n# Compute normalized L2 similarity\nsum_sq_diff = 0.0\nsum_sq_orig = 0.0\nmax_diff = 0\nfor i in range(len(p1)):\n    for c in range(3):\n        diff = p1[i][c] - p2[i][c]\n        sum_sq_diff += diff * diff\n        sum_sq_orig += p1[i][c] * p1[i][c]\n        if abs(diff) > max_diff:\n            max_diff = abs(diff)\n\nl2_dist = math.sqrt(sum_sq_diff)\nl2_orig = math.sqrt(sum_sq_orig)\nsimilarity = 1.0 - l2_dist / l2_orig if l2_orig > 0 else 1.0\n\nprint(f'L2 distance: {l2_dist}')\nprint(f'L2 norm of original: {l2_orig}')\nprint(f'Normalized L2 similarity: {similarity:.6f}')\nprint(f'Max pixel difference: {max_diff}')\n\n# Sample some pixels for visual comparison\nprint('\\nSample pixels (orig vs recon):')\nfor y, x in [(0,0), (0,1200), (450,1200), (900,1200), (1350,1200), (1799,2399)]:\n    idx = y * w1 + x\n    print(f'  ({y},{x}): orig={p1[idx]} recon={p2[idx]}')\nPYEOF\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
