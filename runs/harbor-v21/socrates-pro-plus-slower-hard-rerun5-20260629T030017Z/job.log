Sending keys: ['cat > sample.py << \'EOF\'\nimport sys\nimport numpy as np\n\nwidth = 2400\nheight = 1800\npixels = []\n\nwith open(\'image.ppm\', \'r\') as f:\n    # skip header\n    for _ in range(3):\n        f.readline()\n    # read all pixels into list of tuples\n    for line in f:\n        parts = line.strip().split()\n        if len(parts) != 3:\n            continue\n        r,g,b = map(int, parts)\n        pixels.append((r,g,b))\n\nprint(f"Total pixels: {len(pixels)}")\n# reshape to 2D array\nimg = np.array(pixels, dtype=np.uint8).reshape((height, width, 3))\n\n# sample rows\nfor y in [0, 450, 900, 1350, 1799]:\n    row = img[y]\n    avg = row.mean(axis=0)\n    mid = row[1200]\n    left = row[0]\n    right = row[-1]\n    print(f"Row {y}: avg={avg}, mid={mid}, left={left}, right={right}")\n\n# sample columns\nfor x in [0, 600, 1200, 1800, 2399]:\n    col = img[:, x]\n    avg = col.mean(axis=0)\n    top = col[0]\n    bottom = col[-1]\n    print(f"Col {x}: avg={avg}, top={top}, bottom={bottom}")\n\n# corners\ncorners = [(0,0), (0,2399), (1799,0), (1799,2399), (900,1200)]\nfor y,x in corners:\n    print(f"Corner/Center ({y},{x}): {img[y,x]}")\n\n# compute gradient: fit linear model for each channel vs row index\nimport numpy as np\nrows = np.arange(height)\nfor ch in range(3):\n    channel = img[:,:,ch]\n    avg_per_row = channel.mean(axis=1)\n    # linear regression\n    A = np.vstack([rows, np.ones(len(rows))]).T\n    m, c = np.linalg.lstsq(A, avg_per_row, rcond=None)[0]\n    print(f"Channel {ch}: slope={m:.4f}, intercept={c:.4f}")\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
