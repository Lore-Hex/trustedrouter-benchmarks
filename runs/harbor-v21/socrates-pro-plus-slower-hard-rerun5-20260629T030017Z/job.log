Sending keys: ['cat > image.c << \'CEOF\'\n#include <stdio.h>\n#include <math.h>\ntypedef struct{float x,y,z;}V;\nV mk(float x,float y,float z){V r;r.x=x;r.y=y;r.z=z;return r;}\nV ad(V a,V b){return mk(a.x+b.x,a.y+b.y,a.z+b.z);}\nV su(V a,V b){return mk(a.x-b.x,a.y-b.y,a.z-b.z);}\nV ml(V a,float t){return mk(a.x*t,a.y*t,a.z*t);}\nfloat dt(V a,V b){return a.x*b.x+a.y*b.y+a.z*b.z;}\nV nm(V v){float l=sqrtf(dt(v,v));return mk(v.x/l,v.y/l,v.z/l);}\n#define W 2400\n#define H 1800\nfloat sr=1.f,py=-1.5f;\nV ld;\nfloat hs(V ro,V sc,V rd){V oc=su(ro,sc);float b=dt(oc,rd),c=dt(oc,oc)-sr*sr,h=b*b-c;return h<0?-1:-b-sqrtf(h);}\nfloat hp(V ro,V rd){if(fabsf(rd.y)<1e-6f)return-1;float t=(py-ro.y)/rd.y;return t>0?t:-1;}\nV tr(V ro,V rd,V sc){\n    float ts=hs(ro,sc,rd),tp=hp(ro,rd),t;int h1=0,h2=0;\n    if(ts>0&&tp>0){if(ts<tp){t=ts;h1=1;}else{t=tp;h2=1;}}\n    else if(ts>0){t=ts;h1=1;}\n    else if(tp>0){t=tp;h2=1;}\n    else{V n=nm(rd);float a=.5f*(n.y+1.f);return ad(ml(mk(1,1,1),1.f-a),ml(mk(.5f,.7f,1.f),a));}\n    V pos=ad(ro,ml(rd,t)),N;\n    V color;\n    if(h1){N=nm(su(pos,sc));color=mk(1.f,.2f,.2f);}\n    else{N=mk(0,1,0);\n    double fx=floor((double)pos.x),fz=floor((double)pos.z);\n    int s=(int)(fx+fz)&1;\n    float ck=s?.4f:.9f;color=mk(ck,ck,ck);}\n    float diff=fmaxf(dt(N,ld),0.f);\n    V so=ad(pos,ml(N,.001f));\n    if(hs(so,sc,ld)>.001f)diff=0;\n    return ml(color,.2f+.8f*diff);\n}\nint main(){\n    ld=nm(mk(1.f,1.f,-1.f));\n    V cam={0,-.5f,-5.f};\n    V sc={0,0,0};\n    FILE*f=fopen("reconstructed.ppm","w");\n    fprintf(f,"P3\\n%d %d\\n255\\n",W,H);\n    float vw=2.f*W/H;\n    float vh=2.f;\n    V vU=mk(vw,0,0);\n    V vV=mk(0,vh,0);\n    V fl=mk(0,0,1.f);\n    V ll=ad(su(su(cam,ml(vU,.5f)),ml(vV,.5f)),fl);\n    for(int j=0;j<H;j++){\n        float v=1.f-(float)j/(H-1);\n        for(int i=0;i<W;i++){\n            float u=(float)i/(W-1);\n            V tgt=ad(ad(ll,ml(vU,u)),ml(vV,v));\n            V rd=nm(su(tgt,cam));\n            V c=tr(cam,rd,sc);\n            int r=(int)(fminf(c.x,1.f)*255.99f),g=(int)(fminf(c.y,1.f)*255.99f),b=(int)(fminf(c.z,1.f)*255.99f);\n            fprintf(f,"%d %d %d\\n",r,g,b);\n        }\n    }\n    fclose(f);return 0;\n}\nCEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
