Sending keys: ['cat > checker.py << \'PYEOF\'\nimport math\nW,H=2400,1800\ncam=(0,-0.5,-5.0)\nvw=2.0*W/H;vh=2.0\nll=(cam[0]-vw/2, cam[1]-vh/2, cam[2]+1.0)\npy=-1.5\n# For ground points, compute world x,z and check orig color\ndef getrow(fn,y):\n    f=open(fn);f.readline();f.readline();f.readline()\n    for _ in range(y*W):f.readline()\n    return [tuple(map(int,f.readline().split())) for _ in range(W)]\nfor y in [1000,1100,1200,1400,1600,1799]:\n    o=getrow(\'image.ppm\',y)\n    v=1.0-y/(H-1)\n    print(f\'Row {y}:\')\n    for x in [100,300,500,700,1700,1900,2100,2300]:\n        u=x/(W-1)\n        tx=ll[0]+u*vw; ty=ll[1]+v*vh; tz=ll[2]\n        dx,dy,dz=tx-cam[0],ty-cam[1],tz-cam[2]\n        d=math.sqrt(dx*dx+dy*dy+dz*dz)\n        dx,dy,dz=dx/d,dy/d,dz/d\n        if abs(dy)<1e-6: continue\n        t=(py-cam[1])/dy\n        if t<0: continue\n        wx=cam[0]+dx*t; wz=cam[2]+dz*t\n        fx=math.floor(wx); fz=math.floor(wz)\n        s=(int(fx)+int(fz))&1\n        col=o[x]\n        is_dark = col[0]<110  # 67 is dark, 152 is light\n        print(f\'  x={x}: wx={wx:.2f} wz={wz:.2f} fx={fx} fz={fz} s={s} orig={col} {"DARK" if is_dark else "LIGHT"}\')\nPYEOF\npython3 checker.py\n'] min_timeout_sec: 20.0 max_timeout_sec: 180.0
