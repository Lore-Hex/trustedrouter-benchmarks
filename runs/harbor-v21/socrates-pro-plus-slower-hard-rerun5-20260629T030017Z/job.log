as horizontal variation\nprint("\\n--- Horizontal variation within row 0 ---")\nwith open(\'image.ppm\', \'r\') as f:\n    row = get_row(f, 0)\n    unique = set(row)\n    print(f"Row 0 unique colors: {len(unique)}")\n    print(f"First 5: {row[:5]}")\n    print(f"Last 5: {row[-5:]}")\n    # check min/max for each channel\n    rs = [p[0] for p in row]\n    gs = [p[1] for p in row]\n    bs = [p[2] for p in row]\n    print(f"R range: {min(rs)}-{max(rs)}, G range: {min(gs)}-{max(gs)}, B range: {min(bs)}-{max(bs)}")\nPYEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
