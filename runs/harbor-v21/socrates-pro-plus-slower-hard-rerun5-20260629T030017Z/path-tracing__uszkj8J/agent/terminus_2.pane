[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { float x, y, z; } V;
[?2004l[?2004h> V v(float x, float y, float z) { V r={x,y,z}; return r; }
[?2004l[?2004h> V vadd(V a, V b) { return v(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> V vsub(V a, V b) { return v(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> V vmul(V a, float t) { return v(a.x*t, a.y*t, a.z*t); }
[?2004l[?2004h> float vdot(V a, V b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> float vlen(V v) { return sqrtf(vdot(v,v)); }
[?2004l[?2004h> V vnorm(V a) { float l=vlen(a); return v(a.x/l, a.y/l, a.z/z); }
[?2004l[?2004h> 
[?2004l[?2004h> // Scene parameters
[?2004l[?2004h> V cam = {0, 0, -5};
[?2004l[?2004h> V sph_center = {0, 0, 0};
[?2004l[?2004h> float sph_r = 1.0;
[?2004l[?2004h> float plane_y = -1.5;
[?2004l[?2004h> V light = {-1, 2, -1};
[?2004l[?2004h> 
[?2004l[?2004h> float intersect_sphere(V ro, V rd, V sc, float sr) {
[?2004l[?2004h>     V oc = vsub(ro, sc);
[?2004l[?2004h>     float b = vdot(oc, rd);
[?2004l[?2004h>     float c = vdot(oc, oc) - sr*sr;
[?2004l[?2004h>     float h = b*b - c;
[?2004l[?2004h>     if (h < 0) return -1;
[?2004l[?2004h>     return -b - sqrtf(h);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> float intersect_plane(V ro, V rd, float py) {
[?2004l[?2004h>     if (fabsf(rd.y) < 1e-6) return -1;
[?2004l[?2004h>     float t = (py - ro.y) / rd.y;
[?2004l[?2004h>     return t > 0 ? t : -1;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> V trace(V ro, V rd) {
[?2004l[?2004h>     float ts = intersect_sphere(ro, rd, sph_center, sph_r);
[?2004l[?2004h>     float tp = intersect_plane(ro, rd, plane_y);
[?2004l[?2004h>     
[?2004l[?2004h>     float t;
[?2004l[?2004h>     int hit_sphere = 0, hit_plane = 0;
[?2004l[?2004h>     
[?2004l[?2004h>     if (ts > 0 && tp > 0) {
[?2004l[?2004h>         if (ts < tp) { t = ts; hit_sphere = 1; }
[?2004l[?2004h>         else { t = tp; hit_plane = 1; }
[?2004l[?2004h>     } else if (ts > 0) { t = ts; hit_sphere = 1; }
[?2004l[?2004h>     else if (tp > 0) { t = tp; hit_plane = 1; }
[?2004l[?2004h>     else {
[?2004l[?2004h>         // Sky
[?2004l[?2004h>         V n = vnorm(rd);
[?2004l[?2004h>         float a = 0.5 * (n.y + 1.0);
[?2004l[?2004h>         V col = vadd(vmul(v(1,1,1), 1.0-a), vmul(v(0.5, 0.7, 1.0), a));
[?2004l[?2004h>         return col;
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     V pos = vadd(ro, vmul(rd, t));
[?2004l[?2004h>     V N, color;
[?2004l[?2004h>     
[?2004l[?2004h>     if (hit_sphere) {
[?2004l[?2004h>         N = vnorm(vsub(pos, sph_center));
[?2004l[?2004h>         color = v(0.2, 0.04, 0.04);
[?2004l[?2004h>     } else {
[?2004l[?2004h>         N = v(0, 1, 0);
[?2004l[?2004h>         int cx = (int)floorf(pos.x);
[?2004l[?2004h>         int cz = (int)floorf(pos.z);
[?2004l[?2004h>         float checker = ((cx + cz) & 1) ? 0.7 : 0.4;
[?2004l[?2004h>         color = v(checker, checker, checker);
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     // Lighting
[?2004l[?2004h>     V light_dir = vnorm(vsub(light, pos));
[?2004l[?2004h>     float diff = fmaxf(vdot(N, light_dir), 0.0);
[?2004l[?2004h>     
[?2004l[?2004h>     // Shadow
[?2004l[?2004h>     V shadow_orig = vadd(pos, vmul(N, 0.001));
[?2004l[?2004h>     float shadow_t = intersect_sphere(shadow_orig, light_dir, sph_center, sph_r);
[?2004l[?2004h>     float shadow_p = intersect_plane(shadow_orig, light_dir, plane_y);
[?2004l[?2004h>     int in_shadow = 0;
[?2004l[?2004h>     if (shadow_t > 0.01) in_shadow = 1;
[?2004l[?2004h>     if (shadow_p > 0.01 && shadow_p < vlen(vsub(light, pos))) in_shadow = 1;
[?2004l[?2004h>     
[?2004l[?2004h>     float ambient = 0.2;
[?2004l[?2004h>     float lighting = in_shadow ? ambient : (ambient + 0.8 * diff);
[?2004l[?2004h>     return vmul(color, lighting);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     int W = 2400, H = 1800;
[?2004l[?2004h>     FILE *f = fopen("reconstructed.ppm", "w");
[?2004l[?2004h>     fprintf(f, "P3\n%d %d\n255\n", W, H);
[?2004l[?2004h>     
[?2004l[?2004h>     float aspect = (float)W / H;
[?2004l[?2004h>     float fov = 2.0; // focal length related
[?2004l[?2004h>     
[?2004l[?2004h>     for (int y = 0; y < H; y++) {
[?2004l[?2004h>         for (int x = 0; x < W; x++) {
[?2004l[?2004h>             float u = (2.0 * (x + 0.5) / W - 1.0) * aspect;
[?2004l[?2004h>             float v_y = 1.0 - 2.0 * (y + 0.5) / H;
[?2004l[?2004h>             V rd = vnorm(v(u, v_y, fov));
[?2004l[?2004h>             V col = trace(cam, rd);
[?2004l[?2004h>             int r = (int)(fminf(col.x, 1.0) * 255.99);
[?2004l[?2004h>             int g = (int)(fminf(col.y, 1.0) * 255.99);
[?2004l[?2004h>             int b = (int)(fminf(col.z, 1.0) * 255.99);
[?2004l[?2004h>             fprintf(f, "%d %d %d\n", r, g, b);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(f);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
