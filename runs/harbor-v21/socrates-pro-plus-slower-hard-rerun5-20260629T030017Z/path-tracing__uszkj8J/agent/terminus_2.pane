[?2004hroot@c4c0775467a3:/app# cat > image.c << 'CEOF'
[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { float x, y, z; } V;
[?2004l[?2004h> V mk(float x, float y, float z) { V r; r.x=x; r.y=y; r.z=z; return r; }
[?2004l[?2004h> V add(V a, V b) { return mk(a.x+b.x, a.y+b.y, a.z+b.z); }
[?2004l[?2004h> V sub(V a, V b) { return mk(a.x-b.x, a.y-b.y, a.z-b.z); }
[?2004l[?2004h> V mul(V a, float t) { return mk(a.x*t, a.y*t, a.z*t); }
[?2004l[?2004h> float dot(V a, V b) { return a.x*b.x + a.y*b.y + a.z*b.z; }
[?2004l[?2004h> V norm(V v) { float l=sqrtf(dot(v,v)); return mk(v.x/l, v.y/l, v.z/l); }
[?2004l[?2004h> 
[?2004l[?2004h> // Scene
[?2004l[?2004h> V cam = {0, -0.5f, -5.0f};
[?2004l[?2004h> V sc  = {0, 0, 0};      // sphere center
[?2004l[?2004h> float sr = 1.0f;         // sphere radius
[?2004l[?2004h> float py = -1.5f;        // plane y
[?2004l[?2004h> V light = {1.0f, 1.0f, -1.0f};
[?2004l[?2004h> 
[?2004l[?2004h> float hit_sph(V ro, V rd) {
[?2004l[?2004h>     V oc = sub(ro, sc);
[?2004l[?2004h>     float b = dot(oc, rd);
[?2004l[?2004h>     float c = dot(oc, oc) - sr*sr;
[?2004l[?2004h>     float h = b*b - c;
[?2004l[?2004h>     if (h < 0) return -1;
[?2004l[?2004h>     return -b - sqrtf(h);
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> float hit_pln(V ro, V rd) {
[?2004l[?2004h>     if (fabsf(rd.y) < 1e-6f) return -1;
[?2004l[?2004h>     float t = (py - ro.y) / rd.y;
[?2004l[?2004h>     return t > 0 ? t : -1;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> V trace(V ro, V rd) {
[?2004l[?2004h>     float ts = hit_sph(ro, rd);
[?2004l[?2004h>     float tp = hit_pln(ro, rd);
[?2004l[?2004h>     float t;
[?2004l[?2004h>     int hs = 0, hp = 0;
[?2004l[?2004h>     if (ts > 0 && tp > 0) {
[?2004l[?2004h>         if (ts < tp) { t = ts; hs = 1; }
[?2004l[?2004h>         else { t = tp; hp = 1; }
[?2004l[?2004h>     } else if (ts > 0) { t = ts; hs = 1; }
[?2004l[?2004h>     else if (tp > 0) { t = tp; hp = 1; }
[?2004l[?2004h>     else {
[?2004l[?2004h>         V n = norm(rd);
[?2004l[?2004h>         float a = 0.5f * (n.y + 1.0f);
[?2004l[?2004h>         return add(mul(mk(1,1,1), 1.0f-a), mul(mk(0.5f, 0.7f, 1.0f), a));
[?2004l[?2004h>     }
[?2004l[?2004h>     V pos = add(ro, mul(rd, t));
[?2004l[?2004h>     V N; V color;
[?2004l[?2004h>     if (hs) {
[?2004l[?2004h>         N = norm(sub(pos, sc));
[?2004l[?2004h>         color = mk(1.0f, 0.2f, 0.2f);
[?2004l[?2004h>     } else {
[?2004l[?2004h>         N = mk(0, 1, 0);
[?2004l[?2004h>         int cx = (int)floorf(pos.x);
[?2004l[?2004h>         int cz = (int)floorf(pos.z);
[?2004l[?2004h>         float ck = ((cx + cz) & 1) ? 0.9f : 0.4f;
[?2004l[?2004h>         color = mk(ck, ck, ck);
[?2004l[?2004h>     }
[?2004l[?2004h>     // Light direction (point light)
[?2004l[?2004h>     V L = norm(sub(light, pos));
[?2004l[?2004h>     float diff = fmaxf(dot(N, L), 0.0f);
[?2004l[?2004h>     // Shadow
[?2004l[?2004h>     V so = add(pos, mul(N, 0.001f));
[?2004l[?2004h>     float sst = hit_sph(so, L);
[?2004l[?2004h>     if (sst > 0.01f) diff = 0.0f;
[?2004l[?2004h>     float lighting = 0.2f + 0.8f * diff;
[?2004l[?2004h>     return mul(color, lighting);
