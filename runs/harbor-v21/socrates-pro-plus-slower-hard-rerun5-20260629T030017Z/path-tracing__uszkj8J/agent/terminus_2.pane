[?2004hroot@c4c0775467a3:/app# cat > debug.py << 'PYEOF'
[?2004l[?2004h> import math
[?2004l[?2004h> # With viewport projection:
[?2004l[?2004h> # cam=(0,-0.5,-5), vU=(2.666,0,0), vV=(0,2,0), w=(0,0,1)
[?2004l[?2004h> # ll = cam - vU*0.5 - vV*0.5 + w = (-1.333, -1.5, -4)
[?2004l[?2004h> # target = ll + u*vU + v*vV
[?2004l[?2004h> # rd = norm(target - cam)
[?2004l[?2004h> 
[?2004l[?2004h> # For the sphere at origin, r=1:
[?2004l[?2004h> # The sphere edge is where discriminant=0
[?2004l[?2004h> # Let me find what pixel x corresponds to sphere edge at each row y
[?2004l[?2004h> 
[?2004l[?2004h> W,H=2400,1800
[?2004l[?2004h> cam=(0,-0.5,-5)
[?2004l[?2004h> vW=2.0*W/H
[?2004l[?2004h> ll=(-vW/2, -0.5-1, -5+1)  # = (-1.333, -1.5, -4)
[?2004l[?2004h> 
[?2004l[?2004h> for y in [800,810,820,830,840,850,860,870,880,890,900]:
[?2004l[?2004h>     v = 1.0 - y/(H-1)
[?2004l[?2004h>     # Find x where sphere edge is
[?2004l[?2004h>     # target = ll + u*vU + v*vV where vU=(vW,0,0), vV=(0,2,0)
[?2004l[?2004h>     # target = (ll[0]+u*vW, ll[1]+v*2, ll[2])
[?2004l[?2004h>     # rd = norm(target - cam)
[?2004l[?2004h>     # For sphere intersection at origin r=1:
[?2004l[?2004h>     # oc = cam - (0,0,0) = cam
[?2004l[?2004h>     # b = dot(oc, rd)
[?2004l[?2004h>     # c = dot(oc,oc) - 1
[?2004l[?2004h>     # h = b*b - c = 0 (tangent)
[?2004l[?2004h>     
[?2004l[?2004h>     # Let me just sweep x to find where sphere edge is
[?2004l[?2004h>     for x in range(1100, 1300):
[?2004l[?2004h>         u = x/(W-1)
[?2004l[?2004h>         tx = ll[0] + u*vW
[?2004l[?2004h>         ty = ll[1] + v*2
[?2004l[?2004h>         tz = ll[2]
[?2004l[?2004h>         dx,dy,dz = tx-cam[0], ty-cam[1], tz-cam[2]
[?2004l[?2004h>         l = math.sqrt(dx*dx+dy*dy+dz*dz)
[?2004l[?2004h>         dx,dy,dz = dx/l,dy/l,dz/l
[?2004l[?2004h>         # Sphere intersection
[?2004l[?2004h>         oc = cam
[?2004l[?2004h>         b = oc[0]*dx+oc[1]*dy+oc[2]*dz
[?2004l[?2004h>         c = oc[0]**2+oc[1]**2+oc[2]**2 - 1
[?2004l[?2004h>         h = b*b - c
[?2004l[?2004h>         if abs(h) < 0.01:
[?2004l[?2004h>             print(f'Row {y}: sphere edge at x={x} (h={h:.4f})')
[?2004l[?2004h>             break
[?2004l[?2004h> PYEOF
