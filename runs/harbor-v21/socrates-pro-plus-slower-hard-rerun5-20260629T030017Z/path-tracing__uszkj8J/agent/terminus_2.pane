[?2004l[?2004h>             fprintf(f,"%d %d %d\n",r,g,b);
[?2004l[?2004h>         }
[?2004l[?2004h>     }
[?2004l[?2004h>     fclose(f);return 0;
[?2004l[?2004h> }
