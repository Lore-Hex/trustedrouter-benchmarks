[?2004l[?2004h> 
[?2004l[?2004h> with open('image.ppm', 'r') as f:
[?2004l[?2004h>     # skip header
[?2004l[?2004h>     for _ in range(3):
[?2004l[?2004h>         f.readline()
[?2004l[?2004h>     # read all pixels into list of tuples
