[?2004hroot@c4c0775467a3:/app# cat > solve.py << 'PYEOF'
[?2004l[?2004h> import math
[?2004l[?2004h> # Using samples: N and diff (diff = max(dot(N, L), 0))
[?2004l[?2004h> # Lit samples (diff>0):
[?2004l[?2004h> # (860,1300): N=(0.501,0.697,-0.513) diff=0.397
[?2004l[?2004h> # (860,1320): N=(0.625,0.705,-0.336) diff=0.574
[?2004l[?2004h> # (1000,1383): N=(0.976,-0.035,-0.214) diff=0.422
[?2004l[?2004h> # Solve dot(N,L)=diff for L=(lx,ly,lz)
[?2004l[?2004h> import itertools
[?2004l[?2004h> A=[[0.501,0.697,-0.513],[0.625,0.705,-0.336],[0.976,-0.035,-0.214]]
[?2004l[?2004h> b=[0.397,0.574,0.422]
[?2004l[?2004h> # Solve 3x3 linear system
[?2004l[?2004h> def solve3(A,b):
[?2004l[?2004h>     import copy
