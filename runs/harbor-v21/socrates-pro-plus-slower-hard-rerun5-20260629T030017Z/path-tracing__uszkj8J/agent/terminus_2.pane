[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <math.h>
[?2004l[?2004h> 
[?2004l[?2004h> typedef struct { float x,y,z; } V;
[?2004l[?2004h> V mk(float x,float y,float z){V r;r.x=x;r.y=y;r.z=z;return r;}
[?2004l[?2004h> V add(V a,V b){return mk(a.x+b.x,a.y+b.y,a.z+b.z);}
[?2004l[?2004h> V sub(V a,V b){return mk(a.x-b.x,a.y-b.y,a.z-b.z);}
[?2004l[?2004h> V mul(V a,float t){return mk(a.x*t,a.y*t,a.z*t);}
[?2004l[?2004h> float dot(V a,V b){return a.x*b.x+a.y*b.y+a.z*b.z;}
[?2004l[?2004h> float len(V v){return sqrtf(dot(v,v));}
[?2004l[?2004h> V norm(V v){float l=len(v);return mk(v.x/l,v.y/l,v.z/l);}
[?2004l[?2004h> 
[?2004l[?2004h> #define W 2400
[?2004l[?2004h> #define H 1800
[?2004l[?2004h> 
[?2004l[?2004h> V cam={0.0f,-0.5f,-5.0f};
[?2004l[?2004h> V sc={0.0f,0.0f,0.0f};
[?2004l[?2004h> float sr=1.0f;
[?2004l[?2004h> float py=-1.5f;
[?2004l[?2004h> V ld;
[?2004l[?2004h> 
[?2004l[?2004h> float hit_s(V ro,V rd){
[?2004l[?2004h>     V oc=sub(ro,sc);
[?2004l[?2004h>     float b=dot(oc,rd);
[?2004l[?2004h>     float c=dot(oc,oc)-sr*sr;
[?2004l[?2004h>     float h=b*b-c;
[?2004l[?2004h>     if(h<0)return -1;
[?2004l[?2004h>     return -b-sqrtf(h);
[?2004l[?2004h> }
[?2004l[?2004h> float hit_p(V ro,V rd){
[?2004l[?2004h>     if(fabsf(rd.y)<1e-6f)return -1;
[?2004l[?2004h>     float t=(py-ro.y)/rd.y;
[?2004l[?2004h>     return t>0?t:-1;
[?2004l[?2004h> }
[?2004l[?2004h> V sky(V rd){
[?2004l[?2004h>     V n=norm(rd);
[?2004l[?2004h>     float a=0.5f*(n.y+1.0f);
[?2004l[?2004h>     return add(mul(mk(1,1,1),1.0f-a),mul(mk(0.5f,0.7f,1.0f),a));
[?2004l[?2004h> }
[?2004l[?2004h> V trace(V ro,V rd){
[?2004l[?2004h>     float ts=hit_s(ro,rd);
[?2004l[?2004h>     float tp=hit_p(ro,rd);
[?2004l[?2004h>     float t;int hs=0,hp=0;
[?2004l[?2004h>     if(ts>0&&tp>0){if(ts<tp){t=ts;hs=1;}else{t=tp;hp=1;}}
[?2004l[?2004h>     else if(ts>0){t=ts;hs=1;}
[?2004l[?2004h>     else if(tp>0){t=tp;hp=1;}
[?2004l[?2004h>     else return sky(rd);
[?2004l[?2004h>     V pos=add(ro,mul(rd,t));
[?2004l[?2004h>     V N;V color;
[?2004l[?2004h>     if(hs){N=norm(sub(pos,sc));color=mk(1.0f,0.2f,0.2f);}
[?2004l[?2004h>     else{N=mk(0,1,0);int cx=(int)floorf(pos.x);int cz=(int)floorf(pos.z);
[?2004l[?2004h>     float ck=((cx+cz)&1)?0.9f:0.4f;color=mk(ck,ck,ck);}
[?2004l[?2004h>     float diff=fmaxf(dot(N,ld),0.0f);
[?2004l[?2004h>     V so=add(pos,mul(N,0.001f));
[?2004l[?2004h>     if(hit_s(so,ld)>0.001f)diff=0;
[?2004l[?2004h>     float li=0.2f+0.8f*diff;
[?2004l[?2004h>     return mul(color,li);
[?2004l[?2004h> }
[?2004l[?2004h> int main(){
[?2004l[?2004h>     ld=norm(mk(1,1,-1));
[?2004l[?2004h>     FILE*f=fopen("reconstructed.ppm","w");
[?2004l[?2004h>     fprintf(f,"P3\n%d %d\n255\n",W,H);
[?2004l[?2004h>     float vw=2.0f*W/H;
[?2004l[?2004h>     float vh=2.0f;
[?2004l[?2004h>     V vU=mk(vw,0,0);
[?2004l[?2004h>     V vV=mk(0,vh,0);
[?2004l[?2004h>     V fl=mk(0,0,1.0f);
[?2004l[?2004h>     V ll=sub(sub(sub(cam,mul(vU,0.5f)),mul(vV,0.5f)),fl);
[?2004l[?2004h>     for(int j=0;j<H;j++){
[?2004l[?2004h>         float v=1.0f-j/(H-1.0f);
