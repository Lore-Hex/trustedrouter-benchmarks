[?2004l[?2004h> import math
[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def read_ppm(filename):
[?2004l[?2004h>     with open(filename, 'r') as f:
[?2004l[?2004h>         magic = f.readline().strip()
[?2004l[?2004h>         dims = f.readline().strip().split()
[?2004l[?2004h>         w, h = int(dims[0]), int(dims[1])
[?2004l[?2004h>         maxval = int(f.readline().strip())
[?2004l[?2004h>         pixels = []
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             parts = line.strip().split()
[?2004l[?2004h>             if len(parts) == 3:
[?2004l[?2004h>                 pixels.append(tuple(map(int, parts)))
[?2004l[?2004h>     return w, h, pixels
[?2004l[?2004h> 
[?2004l[?2004h> print('Reading image.ppm...')
[?2004l[?2004h> w1, h1, p1 = read_ppm('image.ppm')
[?2004l[?2004h> print(f'  {w1}x{h1}, {len(p1)} pixels')
[?2004l[?2004h> 
[?2004l[?2004h> print('Reading reconstructed.ppm...')
[?2004l[?2004h> w2, h2, p2 = read_ppm('reconstructed.ppm')
[?2004l[?2004h> print(f'  {w2}x{h2}, {len(p2)} pixels')
[?2004l[?2004h> 
[?2004l[?2004h> assert w1 == w2 and h1 == h2
[?2004l[?2004h> assert len(p1) == len(p2)
[?2004l[?2004h> 
[?2004l[?2004h> # Compute normalized L2 similarity
[?2004l[?2004h> sum_sq_diff = 0.0
[?2004l[?2004h> sum_sq_orig = 0.0
[?2004l[?2004h> max_diff = 0
[?2004l[?2004h> for i in range(len(p1)):
[?2004l[?2004h>     for c in range(3):
[?2004l[?2004h>         diff = p1[i][c] - p2[i][c]
[?2004l[?2004h>         sum_sq_diff += diff * diff
[?2004l[?2004h>         sum_sq_orig += p1[i][c] * p1[i][c]
[?2004l[?2004h>         if abs(diff) > max_diff:
[?2004l[?2004h>             max_diff = abs(diff)
[?2004l[?2004h> 
[?2004l[?2004h> l2_dist = math.sqrt(sum_sq_diff)
[?2004l[?2004h> l2_orig = math.sqrt(sum_sq_orig)
[?2004l[?2004h> similarity = 1.0 - l2_dist / l2_orig if l2_orig > 0 else 1.0
[?2004l[?2004h> 
[?2004l[?2004h> print(f'L2 distance: {l2_dist}')
[?2004l[?2004h> print(f'L2 norm of original: {l2_orig}')
[?2004l[?2004h> print(f'Normalized L2 similarity: {similarity:.6f}')
[?2004l[?2004h> print(f'Max pixel difference: {max_diff}')
[?2004l[?2004h> 
[?2004l[?2004h> # Sample some pixels for visual comparison
[?2004l[?2004h> print('\nSample pixels (orig vs recon):')
[?2004l[?2004h> for y, x in [(0,0), (0,1200), (450,1200), (900,1200), (1350,1200), (1799,2399)]:
[?2004l[?2004h>     idx = y * w1 + x
[?2004l[?2004h>     print(f'  ({y},{x}): orig={p1[idx]} recon={p2[idx]}')
