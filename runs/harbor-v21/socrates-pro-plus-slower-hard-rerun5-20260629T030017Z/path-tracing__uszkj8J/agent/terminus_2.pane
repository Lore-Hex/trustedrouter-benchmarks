[?2004l[?2004h>         if len(parts) != 3:
[?2004l[?2004h>             continue
[?2004l[?2004h>         r,g,b = map(int, parts)
[?2004l[?2004h>         pixels.append((r,g,b))
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Total pixels: {len(pixels)}")
[?2004l[?2004h> # reshape to 2D array
[?2004l[?2004h> img = np.array(pixels, dtype=np.uint8).reshape((height, width, 3))
[?2004l[?2004h> 
[?2004l[?2004h> # sample rows
[?2004l[?2004h> for y in [0, 450, 900, 1350, 1799]:
[?2004l[?2004h>     row = img[y]
[?2004l[?2004h>     avg = row.mean(axis=0)
[?2004l[?2004h>     mid = row[1200]
[?2004l[?2004h>     left = row[0]
[?2004l[?2004h>     right = row[-1]
[?2004l[?2004h>     print(f"Row {y}: avg={avg}, mid={mid}, left={left}, right={right}")
[?2004l[?2004h> 
[?2004l[?2004h> # sample columns
[?2004l[?2004h> for x in [0, 600, 1200, 1800, 2399]:
[?2004l[?2004h>     col = img[:, x]
[?2004l[?2004h>     avg = col.mean(axis=0)
[?2004l[?2004h>     top = col[0]
[?2004l[?2004h>     bottom = col[-1]
[?2004l[?2004h>     print(f"Col {x}: avg={avg}, top={top}, bottom={bottom}")
[?2004l[?2004h> 
[?2004l[?2004h> # corners
[?2004l[?2004h> corners = [(0,0), (0,2399), (1799,0), (1799,2399), (900,1200)]
[?2004l[?2004h> for y,x in corners:
[?2004l[?2004h>     print(f"Corner/Center ({y},{x}): {img[y,x]}")
[?2004l[?2004h> 
[?2004l[?2004h> # compute gradient: fit linear model for each channel vs row index
[?2004l[?2004h> import numpy as np
[?2004l[?2004h> rows = np.arange(height)
[?2004l[?2004h> for ch in range(3):
[?2004l[?2004h>     channel = img[:,:,ch]
[?2004l[?2004h>     avg_per_row = channel.mean(axis=1)
[?2004l[?2004h>     # linear regression
[?2004l[?2004h>     A = np.vstack([rows, np.ones(len(rows))]).T
[?2004l[?2004h>     m, c = np.linalg.lstsq(A, avg_per_row, rcond=None)[0]
[?2004l[?2004h>     print(f"Channel {ch}: slope={m:.4f}, intercept={c:.4f}")
