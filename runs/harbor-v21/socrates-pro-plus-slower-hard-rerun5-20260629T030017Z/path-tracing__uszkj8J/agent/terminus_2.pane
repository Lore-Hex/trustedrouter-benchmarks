[?2004l[?2004hroot@c4c0775467a3:/app# cat > checker.py << 'PYEOF'
[?2004l[?2004h> import math
[?2004l[?2004h> W,H=2400,1800
[?2004l[?2004h> cam=(0,-0.5,-5.0)
[?2004l[?2004h> vw=2.0*W/H;vh=2.0
[?2004l[?2004h> ll=(cam[0]-vw/2, cam[1]-vh/2, cam[2]+1.0)
[?2004l[?2004h> py=-1.5
[?2004l[?2004h> # For ground points, compute world x,z and check orig color
[?2004l[?2004h> def getrow(fn,y):
[?2004l[?2004h>     f=open(fn);f.readline();f.readline();f.readline()
[?2004l[?2004h>     for _ in range(y*W):f.readline()
[?2004l[?2004h>     return [tuple(map(int,f.readline().split())) for _ in range(W)]
[?2004l[?2004h> for y in [1000,1100,1200,1400,1600,1799]:
[?2004l[?2004h>     o=getrow('image.ppm',y)
[?2004l[?2004h>     v=1.0-y/(H-1)
[?2004l[?2004h>     print(f'Row {y}:')
[?2004l[?2004h>     for x in [100,300,500,700,1700,1900,2100,2300]:
[?2004l[?2004h>         u=x/(W-1)
[?2004l[?2004h>         tx=ll[0]+u*vw; ty=ll[1]+v*vh; tz=ll[2]
[?2004l[?2004h>         dx,dy,dz=tx-cam[0],ty-cam[1],tz-cam[2]
[?2004l[?2004h>         d=math.sqrt(dx*dx+dy*dy+dz*dz)
[?2004l[?2004h>         dx,dy,dz=dx/d,dy/d,dz/d
[?2004l[?2004h>         if abs(dy)<1e-6: continue
[?2004l[?2004h>         t=(py-cam[1])/dy
[?2004l[?2004h>         if t<0: continue
[?2004l[?2004h>         wx=cam[0]+dx*t; wz=cam[2]+dz*t
[?2004l[?2004h>         fx=math.floor(wx); fz=math.floor(wz)
[?2004l[?2004h>         s=(int(fx)+int(fz))&1
[?2004l[?2004h>         col=o[x]
[?2004l[?2004h>         is_dark = col[0]<110  # 67 is dark, 152 is light
[?2004l[?2004h>         print(f'  x={x}: wx={wx:.2f} wz={wz:.2f} fx={fx} fz={fz} s={s} orig={col} {"DARK" if is_dark else "LIGHT"}')
[?2004l[?2004h> PYEOF
