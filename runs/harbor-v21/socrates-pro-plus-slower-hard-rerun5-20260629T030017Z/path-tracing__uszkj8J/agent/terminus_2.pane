[?2004l[?2004h> import math
[?2004l[?2004h> W,H=2400,1800
[?2004l[?2004h> def getpixel(fn,y,x):
[?2004l[?2004h>     f=open(fn);f.readline();f.readline();f.readline()
[?2004l[?2004h>     for _ in range(y*W+x):f.readline()
[?2004l[?2004h>     return tuple(map(int,f.readline().split()))
[?2004l[?2004h> 
[?2004l[?2004h> cam=(0,-0.5,-5.0)
[?2004l[?2004h> sc=(0,-1.0,0.0)
[?2004l[?2004h> sr=1.0
[?2004l[?2004h> vw=2.0*W/H;vh=2.0
[?2004l[?2004h> ll=(cam[0]-vw/2,cam[1]-vh/2,cam[2]+1.0)
[?2004l[?2004h> 
[?2004l[?2004h> # Sample sphere pixels at various positions
[?2004l[?2004h> samples=[(860,1200),(860,1100),(860,1300),(860,1080),(860,1320),
[?2004l[?2004h>          (1000,1016),(1000,1100),(1000,1200),(1000,1300),(1000,1383),
[?2004l[?2004h>          (1150,1103),(1150,1200),(1150,1296)]
[?2004l[?2004h> 
[?2004l[?2004h> for y,x in samples:
[?2004l[?2004h>     v=1.0-y/(H-1)
[?2004l[?2004h>     u=x/(W-1)
[?2004l[?2004h>     tx=ll[0]+u*vw; ty=ll[1]+v*vh; tz=ll[2]
[?2004l[?2004h>     dx,dy,dz=tx-cam[0],ty-cam[1],tz-cam[2]
[?2004l[?2004h>     d=math.sqrt(dx*dx+dy*dy+dz*dz)
[?2004l[?2004h>     dx,dy,dz=dx/d,dy/d,dz/d
[?2004l[?2004h>     # Sphere intersection
[?2004l[?2004h>     oc=(cam[0]-sc[0],cam[1]-sc[1],cam[2]-sc[2])
[?2004l[?2004h>     b=oc[0]*dx+oc[1]*dy+oc[2]*dz
[?2004l[?2004h>     c_=oc[0]**2+oc[1]**2+oc[2]**2-sr**2
[?2004l[?2004h>     h=b*b-c_
[?2004l[?2004h>     if h<0: continue
[?2004l[?2004h>     t=-b-math.sqrt(h)
[?2004l[?2004h>     px=cam[0]+dx*t; py_=cam[1]+dy*t; pz=cam[2]+dz*t
[?2004l[?2004h>     nx=(px-sc[0])/sr; ny=(py_-sc[1])/sr; nz=(pz-sc[2])/sr
[?2004l[?2004h>     col=getpixel('image.ppm',y,x)
[?2004l[?2004h>     # What diff gives this color? col = (1.0, 0.2, 0.2) * (0.2+0.8*diff)
[?2004l[?2004h>     # From red channel: r/255 = 1.0 * (0.2+0.8*diff)
[?2004l[?2004h>     r_frac=col[0]/255.0
[?2004l[?2004h>     if r_frac > 0.201:
[?2004l[?2004h>         diff=(r_frac-0.2)/0.8
[?2004l[?2004h>     else:
[?2004l[?2004h>         diff=0.0
[?2004l[?2004h>     print(f'({y},{x}): pos=({px:.2f},{py_:.2f},{pz:.2f}) N=({nx:.3f},{ny:.3f},{nz:.3f}) col={col} diff={diff:.3f}')
