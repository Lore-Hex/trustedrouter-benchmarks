[?2004l[?2004h>                     js.append(j)
[?2004l[?2004h>             if len(js) < 2:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             V = np.stack(js, axis=0)
[?2004l[?2004h>             Vn = V / np.linalg.norm(V, axis=1, keepdims=True)
[?2004l[?2004h>             sim = Vn @ Vn.T
[?2004l[?2004h>             off = sim[np.triu_indices(len(js), k=1)]
[?2004l[?2004h>             if len(off) > 0 and off.min() > 0.99:
[?2004l[?2004h>                 out.append(np.mean(V, axis=0))
[?2004l[?2004h>         if len(out) >= target:
[?2004l[?2004h>             break
[?2004l[?2004h>     return out
