[?2004l[?2004h> def normalize_rows(M):
[?2004l[?2004h>     M = np.asarray(M, dtype=float)
[?2004l[?2004h>     n = np.linalg.norm(M, axis=1, keepdims=True)
[?2004l[?2004h>     n[n == 0] = 1.0
[?2004l[?2004h>     return M / n
[?2004l[?2004h> 
[?2004l[?2004h> def kmeans_unit(V, k, seed):
[?2004l[?2004h>     rng = np.random.default_rng(seed)
[?2004l[?2004h>     V = normalize_rows(V)
[?2004l[?2004h>     idx = [int(rng.integers(0, len(V)))]
[?2004l[?2004h>     dist2 = np.full(len(V), 1.0)
[?2004l[?2004h>     for _ in range(1, k):
[?2004l[?2004h>         s = np.abs(V @ V[idx[-1]])
[?2004l[?2004h>         d2 = np.clip(1.0 - s * s, 0.0, 1.0)
[?2004l[?2004h>         dist2 = np.minimum(dist2, d2)
[?2004l[?2004h>         total = float(dist2.sum())
[?2004l[?2004h>         if total <= 1e-12:
[?2004l[?2004h>             idx.append(int(rng.integers(0, len(V))))
[?2004l[?2004h>             continue
[?2004l[?2004h>         probs = dist2 / total
[?2004l[?2004h>         idx.append(int(rng.choice(len(V), p=probs)))
[?2004l[?2004h>     centers = V[idx].copy()
[?2004l[?2004h>     for _ in range(120):
[?2004l[?2004h>         sims = np.abs(V @ centers.T)
[?2004l[?2004h>         labels = sims.argmax(axis=1)
[?2004l[?2004h>         new_centers = np.zeros_like(centers)
[?2004l[?2004h>         for j in range(k):
[?2004l[?2004h>             members = V[labels == j]
[?2004l[?2004h>             if len(members) == 0:
[?2004l[?2004h>                 new_centers[j] = centers[j]
[?2004l[?2004h>                 continue
[?2004l[?2004h>             c = members.mean(axis=0)
[?2004l[?2004h>             cn = np.linalg.norm(c)
[?2004l[?2004h>             new_centers[j] = c / cn if cn > 0 else centers[j]
[?2004l[?2004h>         shift = np.linalg.norm(new_centers - centers)
[?2004l[?2004h>         centers = new_centers
[?2004l[?2004h>         if shift < 1e-7:
[?2004l[?2004h>             break
[?2004l[?2004h>     sims = np.abs(V @ centers.T)
[?2004l[?2004h>     labels = sims.argmax(axis=1)
[?2004l[?2004h>     counts = np.array([(labels == j).sum() for j in range(k)], dtype=int)
[?2004l[?2004h>     return centers, counts
