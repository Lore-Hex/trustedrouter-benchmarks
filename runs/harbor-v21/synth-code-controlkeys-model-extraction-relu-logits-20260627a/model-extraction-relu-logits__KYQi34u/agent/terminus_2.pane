[?2004l[?2004h> def refine_kink(x0, d, t0, half=0.04, iters=8):
[?2004l[?2004h>     t = float(t0)
[?2004l[?2004h>     for _ in range(iters):
[?2004l[?2004h>         tl = np.linspace(t - half, t - half * 0.25, 6)
[?2004l[?2004h>         tr = np.linspace(t + half * 0.25, t + half, 6)
[?2004l[?2004h>         yl = np.array([f(x0 + tt * d) for tt in tl])
[?2004l[?2004h>         yr = np.array([f(x0 + tt * d) for tt in tr])
[?2004l[?2004h>         al, bl = np.polyfit(tl, yl, 1)
[?2004l[?2004h>         ar, br = np.polyfit(tr, yr, 1)
[?2004l[?2004h>         if al == ar:
[?2004l[?2004h>             break
[?2004l[?2004h>         t_new = (br - bl) / (al - ar)
[?2004l[?2004h>         if not np.isfinite(t_new) or t_new <= t - half or t_new >= t + half:
[?2004l[?2004h>             break
[?2004l[?2004h>         t = float(t_new)
[?2004l[?2004h>     return t
[?2004l[?2004h> 
[?2004l[?2004h> def nearest_other_kink(x0, d, t, kinks, max_dist=0.5):
[?2004l[?2004h>     if not kinks:
[?2004l[?2004h>         return max_dist, max_dist
[?2004l[?2004h>     left = max_dist
[?2004l[?2004h>     right = max_dist
[?2004l[?2004h>     for kt in kinks:
[?2004l[?2004h>         if kt == t:
[?2004l[?2004h>             continue
[?2004l[?2004h>         dist = abs(kt - t)
[?2004l[?2004h>         if kt < t:
[?2004l[?2004h>             left = min(left, t - kt)
[?2004l[?2004h>         else:
[?2004lM, thr=0.998, min_count=2):
    vectors = [np.asarray(v, dtype=float) for v in vectors if np.linalg.norm(v) > 1e-9]
    reps = []
    sums = []
    counts = []
    for v in vectors:
        vn = v / np.linalg.norm(v)
        if not reps:
            reps.append(vn.copy()); sums.append(vn.copy()); counts.append(1); continue
        R = np.stack(reps, axis=0)
        b = int(np.argmax(np.abs(R @ vn)))
        if abs(float(R[b] @ vn)) > thr:
            counts[b] += 1
            sums[b] = sums[b] + vn
            reps[b] = sums[b] / np.linalg.norm(sums[b])
        else:
            reps.append(vn.copy()); sums.append(vn.copy()); counts.append(1)

    order = np.argsort(counts)[::-1]
    reps = [reps[i] for i in order]
    counts = [counts[i] for i in order]
    good = [(r, c) for r, c in zip(reps, counts) if c >= min_count]
    if len(good) < n:
        used = set(id(r) for r, _ in good)
        good.extend((r, c) for r, c in zip(reps, counts) if id(r) not in used)
    if len(good) < n:
        raise RuntimeError(f"Too few clusters: {len(good)}")
    rows = np.stack([r for r, _ in good[:n]], axis=0)
    return rows, np.array([c for _, c in good[:n]], dtype=int)

def main():
    candidates = collect(max_lines=120, target=600)
    print(f"Collected {len(candidates)} clean jump vectors")
    rows, counts = cluster(candidates, n=HIDDEN_DIM, thr=0.998, min_count=2)
    np.save("/app/stolen_A1.npy", rows)
    print("Saved /app/stolen_A1.npy with shape", rows.shape)
    print("Cluster counts:", counts.tolist())

if __name__ == "__main__":
    main()
