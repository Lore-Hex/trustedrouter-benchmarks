[?2004l[?2004h> def refine_centers(centers, V, rounds=6, core_thrs=(0.999, 0.998, 0.996, 0.994, 0.992, 0.990)):
[?2004l[?2004h>     centers = centers.copy()
[?2004l[?2004h>     V = normalize_rows(V)
[?2004l[?2004h>     for r in range(rounds):
[?2004l[?2004h>         thr = core_thrs[min(r, len(core_thrs) - 1)]
[?2004l[?2004h>         sims = np.abs(V @ centers.T)
[?2004l[?2004h>         labels = sims.argmax(axis=1)
[?2004l[?2004h>         for j in range(centers.shape[0]):
[?2004l[?2004h>             members = V[labels == j]
[?2004l[?2004h>             if len(members) == 0:
[?2004l[?2004h>                 continue
[?2004l[?2004h>             cs = np.abs(members @ centers[j])
[?2004l[?2004h>             core = members[cs >= thr] if len(members[cs >= thr]) >= 8 else members
[?2004l[?2004h>             c = core.mean(axis=0)
[?2004l[?2004h>             cn = np.linalg.norm(c)
[?2004l[?2004h>             if cn > 0:
[?2004l[?2004h>                 centers[j] = c / cn
[?2004l[?2004h>     sims = np.abs(V @ centers.T)
[?2004l[?2004h>     labels = sims.argmax(axis=1)
[?2004l[?2004h>     counts = np.array([(labels == j).sum() for j in range(centers.shape[0])], dtype=int)
[?2004l[?2004h>     return centers, counts
