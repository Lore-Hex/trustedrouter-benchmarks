[?2004l[?2004h> def extract_weights_for_neuron(neuron_idx, grads, neuron_indices, basis):
[?2004l[?2004h>     """Extract weight vector for a specific neuron by averaging aligned gradients."""
[?2004l[?2004h>     mask = [idx == neuron_idx for idx in neuron_indices]
[?2004l[?2004h>     selected = grads[mask]
