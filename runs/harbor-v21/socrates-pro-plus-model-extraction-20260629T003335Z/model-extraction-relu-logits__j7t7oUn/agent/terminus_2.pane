[?2004l[?2004h> def estimate_hidden_dim(num_samples=100, eps=1e-4, rank_tol=1e-3):
[?2004l[?2004h>     """Estimate number of hidden neurons by checking rank of Jacobians."""
[?2004l[?2004h>     grads = []
[?2004l[?2004h>     for _ in range(num_samples):
[?2004l[?2004h>         x = np.random.randn(10)
[?2004l[?2004h>         g = numerical_jacobian(forward.forward, x, eps)
[?2004l[?2004h>         grads.append(g)
[?2004l[?2004h>     grads = np.array(grads)
[?2004l[?2004h>     # Compute singular values to estimate rank
[?2004l[?2004h>     U, S, Vt = np.linalg.svd(grads, full_matrices=False)
[?2004l[?2004h>     rank = np.sum(S > rank_tol * S[0])
[?2004l[?2004h>     return rank, grads, Vt
[?2004l[?2004h> 
[?2004l[?2004h> def find_active_neurons(grads, Vt, hidden_dim, tol=0.1):
[?2004l[?2004h>     """Cluster gradients to find distinct neuron directions."""
