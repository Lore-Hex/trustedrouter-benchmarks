Sending keys: ['cat > /app/steal.py << \'EOF\'\nimport numpy as np\nimport forward\nimport sys\n\ndef numerical_jacobian(f, x, eps=1e-6):\n    """Compute Jacobian of scalar function f at x using finite differences."""\n    n = x.shape[0]\n    grad = np.zeros(n)\n    f0 = f(x)\n    for i in range(n):\n        x_plus = x.copy()\n        x_plus[i] += eps\n        grad[i] = (f(x_plus) - f0) / eps\n    return grad\n\ndef estimate_hidden_dim(num_samples=100, eps=1e-4, rank_tol=1e-3):\n    """Estimate number of hidden neurons by checking rank of Jacobians."""\n    grads = []\n    for _ in range(num_samples):\n        x = np.random.randn(10)\n        g = numerical_jacobian(forward.forward, x, eps)\n        grads.append(g)\n    grads = np.array(grads)\n    # Compute singular values to estimate rank\n    U, S, Vt = np.linalg.svd(grads, full_matrices=False)\n    rank = np.sum(S > rank_tol * S[0])\n    return rank, grads, Vt\n\ndef find_active_neurons(grads, Vt, hidden_dim, tol=0.1):\n    """Cluster gradients to find distinct neuron directions."""\n    # Use the first \'hidden_dim\' right singular vectors as basis\n    basis = Vt[:hidden_dim]  # shape (hidden_dim, 10)\n    # Project gradients onto basis\n    proj = grads @ basis.T  # (num_samples, hidden_dim)\n    # For each gradient, find which basis vector is most aligned\n    neuron_indices = []\n    for i in range(proj.shape[0]):\n        p = proj[i]\n        max_idx = np.argmax(np.abs(p))\n        neuron_indices.append(max_idx)\n    return neuron_indices\n\ndef extract_weights_for_neuron(neuron_idx, grads, neuron_indices, basis):\n    """Extract weight vector for a specific neuron by averaging aligned gradients."""\n    mask = [idx == neuron_idx for idx in neuron_indices]\n    selected = grads[mask]\n    if len(selected) == 0:\n        return None\n    # Average and project onto basis vector direction\n    avg = np.mean(selected, axis=0)\n    # The direction should be proportional to basis[neuron_idx]\n    # Since we only care up to scale, we can return normalized basis vector\n    weight = basis[neuron_idx]\n    # Normalize\n    weight = weight / np.linalg.norm(weight)\n    return weight\n\ndef main():\n    np.random.seed(42)\n    print("Estimating hidden dimension...")\n    hidden_dim, grads, Vt = estimate_hidden_dim(num_samples=500, eps=1e-5)\n    print(f"Estimated hidden dimension: {hidden_dim}")\n    \n    basis = Vt[:hidden_dim]\n    print("Finding active neurons for each gradient...")\n    neuron_indices = find_active_neurons(grads, Vt, hidden_dim)\n    \n    print("Extracting weights for each neuron...")\n    A1_extracted = []\n    for i in range(hidden_dim):\n        w = extract_weights_for_neuron(i, grads, neuron_indices, basis)\n        if w is not None:\n            A1_extracted.append(w)\n        else:\n            # If no gradient aligned with this basis vector, use the basis vector itself\n            A1_extracted.append(basis[i] / np.linalg.norm(basis[i]))\n    A1_extracted = np.array(A1_extracted)  # shape (hidden_dim, 10)\n    \n    print(f"Extracted A1 shape: {A1_extracted.shape}")\n    print("Saving to /app/stolen_A1.npy")\n    np.save("/app/stolen_A1.npy", A1_extracted)\n    print("Done.")\n\nif __name__ == "__main__":\n    main()\nEOF\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
