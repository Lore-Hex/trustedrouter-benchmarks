ta)\n        s2 = (fval(p+tm*d)-fval(p+tq*d))/(tm-tq)\n        if abs(s2-s1) > abs(sr-sl)*0.5 + 1e-12 and abs(s2-s1) > 1e-9:\n            tb = tm\n        else:\n            ta = tm\n    return 0.5*(ta+tb)\n\ndef neuron_normal_at_kink(p, d, t, h=1e-2):\n    # gradient difference across the kink gives direction of A1 row (the toggling neuron).\n    x_minus = p + (t-h)*d\n    x_plus  = p + (t+h)*d\n    g_m = grad(x_minus, eps=1e-4)\n    g_p = grad(x_plus, eps=1e-4)\n    diff = g_p - g_m\n    nrm = np.linalg.norm(diff)\n    if nrm < 1e-7:\n        return None\n    return diff/nrm\n\ndef main():\n    np.random.seed(0)\n    normals = []\n    n_lines = 400\n    for _ in range(n_lines):\n        p = np.random.randn(10)*1.0\n        d = np.random.randn(10); d/=np.linalg.norm(d)\n        kinks = find_kinks_on_line(p, d)\n        for t in kinks:\n            nrm = neuron_normal_at_kink(p, d, t)\n            if nrm is not None:\n                # canonical sign: make first nonzero comp positive\n                for c in nrm:\n                    if abs(c)>1e-8:\n                        if c<0: nrm = -nrm\n                        break\n                normals.append(nrm)\n        if len(normals) > 3000:\n            break\n    normals = np.array(normals)\n    print(f"Collected {len(normals)} kink normals")\n    # cluster by cosine similarity\n    reps = []\n    counts = []\n    for v in normals:\n        placed = False\n        for k in range(len(reps)):\n            if abs(np.dot(v, reps[k])) > 0.999:\n                # merge (align sign)\n                s = np.sign(np.dot(v, reps[k]))\n                reps[k] = (reps[k]*counts[k] + s*v)/(counts[k]+1)\n                reps[k] /= np.linalg.norm(reps[k])\n                counts[k]+=1\n                placed = True\n                break\n        if not placed:\n            reps.append(v.copy())\n            counts.append(1)\n    reps = np.array(reps)\n    counts = np.array(counts)\n    order = np.argsort(-counts)\n    reps = r