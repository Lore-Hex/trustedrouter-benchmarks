[?2004l   [?2004h> # => (R4_0 ^ f(L4_0 ^ K3)) ^ (R4_1 ^ f(L4_1 ^ K3)) = f_inv(L0_0 ^ f(R0p_0 ^ K0) ^ L4_0) ^ f_inv(L0_1 ^ f(R0p_1 ^ K0) ^ L4_1)
[?2004l[?2004h> 
[?2004l[?2004h> # This gives us LHS in terms of K3 only, RHS in terms of K0 only!
