import sys

def expand(k):
    return (k ^ (k << 16) ^ (k * 12345)) & 0xFFFFFFFF

def ROL2(v):
    return ((v << 2) | (v >> 6)) & 0xFF

def ROR2(v):
    return ((v >> 2) | (v << 6)) & 0xFF

def g_function(a, b, x):
    temp = (a + b + x) & 0xFF
    return ROL2(temp)

def f_function(input_val):
    x = [0, 0, 0, 0]
    val = input_val
    for i in range(4):
        x[i] = val & 0xFF
        val >>= 8
    y = [0, 0, 0, 0]
    y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)
    y[3] = g_function(x[3], y[2], 0)
    y[1] = g_function(x[1] ^ x[0], y[2], 0)
    y[0] = g_function(x[0], y[1], 1)
    output = 0
    for i in range(4):
        output |= y[i] << (8 * i)
    return output & 0xFFFFFFFF

def f_inverse(output_val):
    y = [0, 0, 0, 0]
    val = output_val
    for i in range(4):
        y[i] = val & 0xFF
        val >>= 8
    x3 = (ROR2(y[3]) - y[2]) & 0xFF
    d = (ROR2(y[1]) - y[2]) & 0xFF
    x0 = (ROR2(y[0]) - y[1] - 1) & 0xFF
    x1 = d ^ x0
    x3xorx2 = (ROR2(y[2]) - d - 1) & 0xFF
    x2 = x3 ^ x3xorx2
    return ((x3 << 24) | (x2 << 16) | (x1 << 8) | x0) & 0xFFFFFFFF

def getleft(x):
    return (x >> 32) & 0xFFFFFFFF

def getright(x):
    return x & 0xFFFFFFFF

def merge(left, right):
    return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)

def encrypt(pt, keys):
    L, R = getleft(pt), getright(pt)
    R ^= L
    for r in range(4):
        mixed = f_function(R ^ keys[r])
        L, R = R, L ^ mixed
    L ^= R
    return merge(R, L)

def decrypt(ct, keys):
    L = getright(ct)
    R = getleft(ct)
    L ^= R
    for r in range(3, -1, -1):
        temp = L
        L = R
        mixed = f_function(temp ^ keys[r])
        R = temp
        L ^= mixed
    R ^= L
    return merge(L, R)

# Read pairs
