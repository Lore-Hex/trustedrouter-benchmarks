[?2004l[?2004h> import sys
[?2004l[?2004h> 
[?2004l[?2004h> def expand(key):
[?2004l[?2004h>     return (key ^ (key << 16) ^ (key * 12345)) & 0xFFFFFFFF
[?2004l[?2004h> 
[?2004l[?2004h> def g_function(a, b, x):
[?2004l[?2004h>     temp = (a + b + x) & 0xFF
[?2004l[?2004h>     return ((temp << 2) | (temp >> 6)) & 0xFF
[?2004l[?2004h> 
[?2004l[?2004h> def f_function(input_val):
[?2004l[?2004h>     x = [0, 0, 0, 0]
[?2004l[?2004h>     val = input_val
[?2004l[?2004h>     for i in range(4):
[?2004l[?2004h>         x[i] = val & 0xFF
[?2004l[?2004h>         val >>= 8
[?2004l[?2004h>     y = [0, 0, 0, 0]
[?2004l[?2004h>     y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1)
[?2004l[?2004h>     y[3] = g_function(x[3], y[2], 0)
[?2004l[?2004h>     y[1] = g_function(x[1] ^ x[0], y[2], 0)
[?2004l[?2004h>     y[0] = g_function(x[0], y[1], 1)
[?2004l[?2004h>     output = 0
[?2004l[?2004h>     for i in range(4):
[?2004l[?2004h>         output |= y[i] << (8 * i)
[?2004l[?2004h>     return output & 0xFFFFFFFF
[?2004l[?2004h> 
[?2004l[?2004h> def getleft(x):
[?2004l[?2004h>     return (x >> 32) & 0xFFFFFFFF
[?2004l[?2004h> 
[?2004l[?2004h> def getright(x):
[?2004l[?2004h>     return x & 0xFFFFFFFF
[?2004l[?2004h> 
[?2004l[?2004h> def merge(left, right):
[?2004l[?2004h>     return ((left & 0xFFFFFFFF) << 32) | (right & 0xFFFFFFFF)
[?2004l[?2004h> 
[?2004l[?2004h> def encrypt(plaintext, keys):
[?2004l[?2004h>     left = getleft(plaintext)
[?2004l[?2004h>     right = getright(plaintext)
[?2004l[?2004h>     right ^= left
[?2004l[?2004h>     for r in range(4):
[?2004l[?2004h>         mixed = f_function(right ^ keys[r])
[?2004l[?2004h>         temp = right
[?2004l[?2004h>         right = left ^ mixed
[?2004l[?2004h>         left = temp
[?2004l[?2004h>     left ^= right
[?2004l[?2004h>     return merge(right, left)
[?2004l[?2004h> 
[?2004l[?2004h> # Read pairs
[?2004l[?2004h> pairs = []
[?2004l[?2004h> with open('/app/pairs.txt', 'r') as f:
[?2004l[?2004h>     for line in f:
[?2004l[?2004h>         parts = line.strip().split()
[?2004l[?2004h>         if len(parts) == 2:
[?2004l[?2004h>             pt = int(parts[0])
[?2004l[?2004h>             ct = int(parts[1])
[?2004l[?2004h>             pairs.append((pt, ct))
[?2004l[?2004h> 
[?2004l[?2004h> print(f"Read {len(pairs)} known pairs")
[?2004l[?2004h> 
[?2004l[?2004h> # Test various key structures
[?2004l[?2004h> # Structure 1: All keys are the same
[?2004l[?2004h> print("\n=== Testing all keys same ===")
[?2004l[?2004h> count = 0
[?2004l[?2004h> for seed in range(1<<20):
[?2004l[?2004h>     ek = expand(seed)
[?2004l[?2004h>     keys = [ek, ek, ek, ek]
[?2004l[?2004h>     ok = True
[?2004l[?2004h>     for pt, ct in pairs:
[?2004l[?2004h>         if encrypt(pt, keys) != ct:
[?2004l[?2004h>             ok = False
[?2004l[?2004h>             break
[?2004l[?2004h>     if ok:
[?2004l[?2004h>         print(f"FOUND: seed = 0x{seed:05X}")
[?2004l[?2004h>         break
[?2004l[?2004h>     count += 1
[?2004l[?2004h>     if count % 100000 == 0:
[?2004l[?2004h>         print(f"  Progress: {count}/{1<<20}")
[?2004l[?2004h> else:
[?2004l[?2004h>     print("  Not found (all keys same)")
[?2004l[?2004h> 
