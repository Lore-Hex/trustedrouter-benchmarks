[?2004l[?2004h> #include <stdio.h>
[?2004l[?2004h> #include <stdint.h>
[?2004l[?2004h> #include <stdlib.h>
[?2004l[?2004h> #include <string.h>
[?2004l[?2004h> 
[?2004l[?2004h> uint8_t g_function(uint8_t a, uint8_t b, uint8_t x) {
[?2004l[?2004h>     uint8_t temp = (a + b + x) & 0xFF;
[?2004l[?2004h>     return ((temp << 2) | (temp >> 6)) & 0xFF;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> uint32_t f_function(uint32_t input_val) {
[?2004l[?2004h>     uint8_t x[4], y[4];
[?2004l[?2004h>     uint32_t val = input_val;
[?2004l[?2004h>     for (int i = 0; i < 4; i++) {
[?2004l[?2004h>         x[i] = val & 0xFF;
[?2004l[?2004h>         val >>= 8;
[?2004l[?2004h>     }
[?2004l[?2004h>     y[2] = g_function(x[3] ^ x[2], x[1] ^ x[0], 1);
[?2004l[?2004h>     y[3] = g_function(x[3], y[2], 0);
[?2004l[?2004h>     y[1] = g_function(x[1] ^ x[0], y[2], 0);
[?2004l[?2004h>     y[0] = g_function(x[0], y[1], 1);
[?2004l[?2004h>     uint32_t output = 0;
[?2004l[?2004h>     for (int i = 0; i < 4; i++) {
[?2004l[?2004h>         output |= (uint32_t)y[i] << (8 * i);
[?2004l[?2004h>     }
[?2004l[?2004h>     return output;
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> int main() {
[?2004l[?2004h>     unsigned char *seen = calloc(1ULL << 28, 1); // 256MB - too large
[?2004l[?2004h>     // Actually let's just test a smaller sample
[?2004l[?2004h>     printf("Testing F function properties...\n");
[?2004l[?2004h>     
[?2004l[?2004h>     // Check if specific patterns hold
[?2004l[?2004h>     // For a Feistel-like cipher, we need to see if F can be linearized
[?2004l[?2004h>     printf("f(0) = 0x%08X\n", f_function(0));
[?2004l[?2004h>     printf("f(0xFFFFFFFF) = 0x%08X\n", f_function(0xFFFFFFFF));
[?2004l[?2004h>     printf("f(0x12345678) = 0x%08X\n", f_function(0x12345678));
[?2004l[?2004h>     
[?2004l[?2004h>     // Check if the expand function is invertible
[?2004l[?2004h>     printf("\nChecking expand function collisions...\n");
[?2004l[?2004h>     unsigned int *exp = calloc(1 << 20, sizeof(unsigned int));
[?2004l[?2004h>     for (int i = 0; i < (1<<20); i++) {
[?2004l[?2004h>         uint32_t e = i ^ (i << 16) ^ (i * 12345);
[?2004l[?2004h>         exp[i] = e;
[?2004l[?2004h>     }
[?2004l[?2004h>     // Check for collisions
[?2004l[?2004h>     for (int i = 0; i < (1<<20); i++) {
[?2004l[?2004h>         for (int j = i+1; j < (1<<20); j++) {
[?2004l[?2004h>             if (exp[i] == exp[j]) {
[?2004l[?2004h>                 printf("Collision: %d and %d both give 0x%08X\n", i, j, exp[i]);
[?2004l[?2004h>             }
[?2004l[?2004h>         }
[?2004l[?2004h>         if (i % 100000 == 0) printf("  Collision check: %d/%d\n", i, 1<<20);
[?2004l[?2004h>     }
[?2004l[?2004h>     printf("Collision check complete\n");
[?2004l[?2004h>     
[?2004l[?2004h>     free(exp);
[?2004l[?2004h>     return 0;
[?2004l[?2004h> }
[?2004l[?2004h> EOF
