python3 - <<'PY'
import json, random, chess
pairs=json.load(open('/app/re.json'))
keys=set()
for pat,_ in pairs:
    if pat.endswith(r' \d+ \d+$'):
        k=pat[1:-len(r' \d+ \d+$')]
        k=k.replace(r'\-','-')
        keys.add(k)
print('keys',len(keys))
rng=random.Random(20260629)
covered=0
total=0
examples=[]
for _ in range(500):
    b=chess.Board()
    for _ in range(80):
        moves=[m for m in b.legal_moves if not (m.promotion and m.promotion!=chess.QUEEN)]
        if not moves or b.is_game_over():
            break
        b.push(rng.choice(moves))
    if b.turn==chess.WHITE and not b.is_game_over():
        total+=1
        k=' '.join(b.fen().split(' ')[:4])
        if k in keys:
            covered+=1
        elif len(examples)<5:
            examples.append(b.fen())
print('total',total,'covered',covered,'rate',covered/total if total else None)
print('examples', examples)
