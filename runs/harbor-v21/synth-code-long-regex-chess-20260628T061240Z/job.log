ons) >= target:\n            return\n        b = chess.Board()\n        for _ in range(max_plies):\n            if b.turn == chess.WHITE:\n                add_position(b.fen())\n                if len(positions) >= target:\n                    return\n            moves = [m for m in b.legal_moves if not (m.promotion and m.promotion != chess.QUEEN)]\n            if not moves or b.is_game_over():\n                break\n            b.push(rng.choice(moves))\n\n# Required sample first.\nadd_position(sample)\n\n# Opera Game positions.\ngame = chess.pgn.read_game(io.StringIO(opera_pgn))\nboard = game.board()\nif board.turn == chess.WHITE:\n    add_position(board.fen())\nfor move in game.mainline_moves():\n    if board.turn == chess.WHITE:\n        add_position(board.fen())\n    board.push(move)\n\n# Broad coverage. Actual JSON size cap is enforced later.\ncollect_bfs(target=100000)\ncollect_random(target=100000)\n\nMAX_BYTES = 9500000\nMAX_PAIRS = 99000\npairs = []\nestimated = 2  # []\nfor k in order:\n    parts = k.split(\' \')\n    pat = \'^\' + \' \'.join(re.escape(x) for x in parts) + r\' \\d+ \\d+$\'\n    repl = \'\\\\n\'.join(positions[k])\n    pair_json = json.dumps([pat, repl], separators=(\',\', \':\'))\n    # JSON list separator comma is 1 byte.\n    if estimated + len(pair_json) + (1 if pairs else 0) > MAX_BYTES:\n        break\n    pairs.append((pat, repl))\n    estimated += len(pair_json) + (1 if len(pairs) > 1 else 0)\n    if len(pairs) >= MAX_PAIRS:\n        break\n\nwith open(\'/app/re.json\', \'w\') as f:\n    f.write(\'[\')\n    for i, (pat, repl) in enumerate(pairs):\n        if i:\n            f.write(\',\')\n        f.write(json.dumps([pat, repl], separators=(\',\', \':\')))\n    f.write(\']\')\n\nraw = open(\'/app/re.json\').read()\nprint(\'positions\', len(positions))\nprint(\'pairs\', len(pairs))\nprint(\'bytes\', len(raw))\nPY\npython3 /app/gen_re.py\n'] min_timeout_sec: 10.0 max_timeout_sec: 180.0
