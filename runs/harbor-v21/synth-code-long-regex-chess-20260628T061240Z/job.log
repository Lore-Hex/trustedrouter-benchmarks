Sending keys: ['cat > /app/gen_re.py <<\'PY\'\nimport json\nimport re\nimport io\nimport chess\nimport chess.pgn\n\nsample = "rnb1k1nr/p2p1ppp/3B4/1p1NPN1P/6P1/3P1Q2/P1P5/q4Kb1 w kq - 0 1"\n\npgn = """[Event "Opera Game"]\n[Site "Paris FRA"]\n[Date "1858.??.??"]\n[Round "?"]\n[White "Morphy, Paul"]\n[Black "Duke of Brunswick & Count Isouard"]\n[Result "1-0"]\n\n1. e4 e5 2. Nf3 d6 3. d4 Bg4 4. dxe5 Bxf3 5. Qxf3 dxe5 6. Bc4 Nf6 7. Qb3 Qe7 8. Nc3 c6 9. Bg5 b5 10. Nxb5 cxb5 11. Bxb5+ Nbd7 12. O-O-O Rd8 13. Rxd7 Rxd7 14. Rd1 Qe6 15. Bxd7+ Nxd7 16. Qb8+ Nxb8 17. Rd8# 1-0"""\n\npositions = [sample]\n\ngame = chess.pgn.read_game(io.StringIO(pgn))\nboard = game.board()\nif board.turn == chess.WHITE:\n    positions.append(board.fen())\n\nfor i, move in enumerate(game.mainline_moves(), 1):\n    if i % 2 == 1:\n        positions.append(board.fen())\n    board.push(move)\n\n# Deduplicate while preserving order.\nseen = set()\nunique = []\nfor fen in positions:\n    if fen not in seen:\n        seen.add(fen)\n        unique.append(fen)\n\npairs = []\nfor fen in unique:\n    b = chess.Board(fen)\n    next_fens = []\n    for move in b.legal_moves:\n        if move.promotion and move.promotion != chess.QUEEN:\n            continue\n        bb = b.copy()\n        bb.push(move)\n        next_fens.append(bb.fen())\n    if not next_fens:\n        continue\n\n    # Match first four FEN fields exactly; ignore move/halfmove counters.\n    board_part, side, castling, ep = fen.split(\' \')[:4]\n    pat = \'^\' + \' \'.join(re.escape(x) for x in [board_part, side, castling, ep]) + r\' \\d+ \\d+$\'\n    repl = \'\\\\n\'.join(next_fens)\n    pairs.append([pat, repl])\n\nwith open(\'/app/re.json\', \'w\') as f:\n    json.dump(pairs, f)\n\nprint(f"unique positions {len(unique)}")\nprint(f"pairs {len(pairs)}")\nprint(f"bytes {len(open(\'/app/re.json\').read())}")\nPY\npython3 /app/gen_re.py\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
