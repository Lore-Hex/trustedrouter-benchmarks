   rng = random.Random(20260628 + seed)\n    for _ in range(1000):\n        if len(positions) >= 100000:\n            break\n        bb = chess.Board()\n        maxply = rng.randint(10, 160)\n        for _ in range(maxply):\n            if bb.turn == chess.WHITE:\n                add(bb.fen())\n            moves = [m for m in bb.legal_moves if not (m.promotion and m.promotion != chess.QUEEN)]\n            if not moves or bb.is_game_over():\n                break\n            bb.push(rng.choice(moves))\n\nMAX_BYTES = 9900000\nMAX_PAIRS = 99000\npairs = []\nest = 2\nfor k in order:\n    pat = \'^\' + \' \'.join(re.escape(x) for x in k.split(\' \')) + r\' \\d+ \\d+$\'\n    repl = \'\\\\n\'.join(positions[k])\n    pj = json.dumps([pat, repl], separators=(\',\', \':\'))\n    extra = 1 if pairs else 0\n    if est + len(pj) + extra > MAX_BYTES:\n        break\n    pairs.append([pat, repl])\n    est += len(pj) + extra\n    if len(pairs) >= MAX_PAIRS:\n        break\n\n# Catch-all deletes any unmatched white-to-move input.\npairs.append([r\'^.* w .*$\', r\'\'])\n\nwith open(\'/app/re.json\', \'w\') as f:\n    f.write(\'[\')\n    for i, p in enumerate(pairs):\n        if i:\n            f.write(\',\')\n        f.write(json.dumps(p, separators=(\',\', \':\')))\n    f.write(\']\')\n\nraw = open(\'/app/re.json\').read()\nprint(\'positions\', len(positions), \'pairs\', len(pairs), \'bytes\', len(raw))\nPY\npython3 /app/gen_re.py\n'] min_timeout_sec: 60.0 max_timeout_sec: 180.0
