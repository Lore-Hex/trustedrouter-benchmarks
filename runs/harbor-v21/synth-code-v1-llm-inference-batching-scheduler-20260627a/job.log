Sending keys: ['cat > /app/task_file/scripts/optimizer.py <<\'PY\'\n#!/usr/bin/env python3\nimport json, os, math, collections\nsys_path = \'/app/task_file/scripts\'\nimport sys\nsys.path.insert(1, sys_path)\nfrom cost_model import CostModel, align, HEADS, HIDDEN\n\nGRAN = 64\nMAX_SHAPES = 8\nTHRESH = {\n    \'plan_b1.jsonl\': dict(cost=3.0e11, pad_ratio=0.055, p95_latency_ms=2.1e6, sequential_timecost=2.7e8),\n    \'plan_b2.jsonl\': dict(cost=4.8e10, pad_ratio=0.15, p95_latency_ms=2.1e5, sequential_timecost=3.2e7),\n}\n\ndef load(path):\n    return [json.loads(l) for l in open(path)]\n\ndef uniq_sorted(reqs):\n    seen = set()\n    out = []\n    for r in reqs:\n        s = align(r[\'prompt_len\'], GRAN)\n        if s not in seen:\n            seen.add(s)\n            out.append(s)\n    return sorted(out)\n\ndef choose_reps(u1, u2, k1, k2):\n    reps = []\n    for u, k in ((u1, k1), (u2, k2)):\n        if not u:\n            continue\n        if len(u) <= k:\n            reps.extend(u)\n        else:\n            step = len(u) / k\n            chosen = set()\n            for i in range(k):\n                idx = min(len(u)-1, int(round((i + 1) * step)) - 1)\n                chosen.add(u[idx])\n            chosen.add(u[-1])\n            reps.extend(sorted(chosen))\n    reps = sorted(set(reps))\n    return reps[:MAX_SHAPES] if len(reps) > MAX_SHAPES else reps\n\ndef assign_rep(s, reps):\n    for r in reps:\n        if r >= s:\n            return r\n    return reps[-1]\n\ndef build_plan(reqs, reps, batch_max_g=None, batch_max_size=None):\n    groups = collections.defaultdict(list)\n    for r in reqs:\n        s = align(r[\'prompt_len\'], GRAN)\n        rep = assign_rep(s, reps)\n        groups[rep].append(r)\n    recs = []\n    bid = 0\n    for rep in sorted(groups):\n        grp = sorted(groups[rep], key=lambda x: x[\'gen_len\'])\n        batches = []\n        cur = []\n        cur_max = 1\n        for r in grp:\n            g = r[\'gen_len\']\n            if cur and ((batch_max_g and max(cur_max, g) > batch_max_g) or (batch_max_size and len(cur) >= batch_max_size)):\n                batches.append(cur)\n                cur = [r]\n                cur_max = g\n            else:\n                cur.append(r)\n                cur_max = max(cur_max, g)\n        if cur:\n            batches.append(cur)\n        for b in batches:\n            bid += 1\n            batch_id = f"b-{bid:04d}"\n            for r in b:\n                recs.append({\n                    \'request_id\': r[\'request_id\'],\n                    \'batch_id\': batch_id,\n                    \'shape\': {\'seq_align\': rep, \'heads_align\': HEADS, \'hidden_align\': HIDDEN}\n                })\n    return recs\n\ndef write(path, recs):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, \'w\') as f:\n        for r in recs:\n            f.write(json.dumps(r) + \'\\n\')\n\ndef metrics_for(plan_path, req_path):\n    reqs = {r[\'request_id\']: r for r in load(req_path)}\n    plan = load(plan_path)\n    return CostModel(granularity=GRAN).plan_metrics(reqs, plan)\n\ndef validate(plan_path, req_path):\n    reqs = {r[\'request_id\']: r for r in load(req_path)}\n    plan = load(plan_path)\n    ids = [p[\'request_id\'] for p in plan]\n    shapes = collections.Counter(\n        (p[\'shape\'][\'seq_align\'], p[\'shape\'][\'heads_align\'], p[\'shape\'][\'hidden_align\'])\n        for p in plan\n    )\n    return {\n        \'all_included\': len(ids) == len(reqs) == len(set(ids)),\n        \'shapes_ok\': len(shapes) <= MAX_SHAPES and all(s[1] == 32 and s[2] == 4096 for s in shapes),\n        \'seq_ok\': all(align(reqs[p[\'request_id\']][\'prompt_len\'], GRAN) <= p[\'shape\'][\'seq_align\'] and p[\'shape\'][\'seq_align\'] % GRAN == 0 for p in plan)\n    }\n\ndef main():\n    root = \'/app/task_file\'\n    in1 = f\'{root}/input_data/requests_bucket_1.jsonl\'\n    in2 = f\'{root}/input_data/requests_bucket_2.jsonl\'\n    out1 = f\'{root}/output_data/plan_b1.jsonl\'\n    out2 = f\'{root}/output_data/plan_b2.jsonl\'\n    reqs1 = load(in1)\n    reqs2 = load(in2)\n    u1 = uniq_sorted(reqs1)\n    u2 = uniq_sorted(reqs2)\n\n    best = None\n    for k1 in range(1, 8):\n        k2 = MAX_SHAPES - k1\n        reps = choose_reps(u1, u2, k1, k2)\n        if len(reps) > MAX_SHAPES:\n            continue\n        for g1 in [32, 48, 64, 96, 128, 192, 256, 384, 512, 768, 1024]:\n            for s1 in [16, 24, 32, 48, 64, 96, 128, 192, 256, 400, 800]:\n                for g2 in [16, 24, 32, 48, 64, 96, 128, 192, 256, 384, 512]:\n                    for s2 in [16, 24, 32, 48, 64, 96, 128, 192, 256, 400]:\n                        p1 = build_plan(reqs1, reps, g1, s1)\n                        p2 = build_plan(reqs2, reps, g2, s2)\n                        shapes = set()\n                        for p in p1 + p2:\n                            sh = p[\'shape\']\n                            shapes.add((sh[\'seq_align\'], sh[\'heads_align\'], sh[\'hidden_align\']))\n                        if len(shapes) > MAX_SHAPES:\n                            continue\n                        write(out1, p1)\n                        write(out2, p2)\n                        m1 = metrics_for(out1, in1)\n                        m2 = metrics_for(out2, in2)\n                        if (m1[\'cost\'] <= THRESH[\'plan_b1.jsonl\'][\'cost\'] and m1[\'pad_ratio\'] <= THRESH[\'plan_b1.jsonl\'][\'pad_ratio\']\n                            and m1[\'p95_latency_ms\'] <= THRESH[\'plan_b1.jsonl\'][\'p95_latency_ms\'] and m1[\'sequential_timecost\'] <= THRESH[\'plan_b1.jsonl\'][\'sequential_timecost\']\n                            and m2[\'cost\'] <= THRESH[\'plan_b2.jsonl\'][\'cost\'] and m2[\'pad_ratio\'] <= THRESH[\'plan_b2.jsonl\'][\'pad_ratio\']\n                            and m2[\'p95_latency_ms\'] <= THRESH[\'plan_b2.jsonl\'][\'p95_latency_ms\'] and m2[\'sequential_timecost\'] <= THRESH[\'plan_b2.jsonl\'][\'sequential_timecost\']):\n                            score = m1[\'cost\'] + m2[\'cost\']\n                            if best is None or score < best[0]:\n                                best = (score, reps, g1, s1, g2, s2, dict(m1), dict(m2))\n    if best:\n        score, reps, g1, s1, g2, s2, m1, m2 = best\n        p1 = build_plan(reqs1, reps, g1, s1)\n        p2 = build_plan(reqs2, reps, g2, s2)\n        write(out1, p1)\n        write(out2, p2)\n        print(\'FOUND PASSING PLAN\')\n        print(\'reps\', reps, \'g1\', g1, \'s1\', s1, \'g2\', g2, \'s2\', s2)\n        print(\'b1\', {k: m1[k] for k in [\'cost\',\'pad_ratio\',\'p95_latency_ms\',\'sequential_timecost\']})\n        print(\'b2\', {k: m2[k] for k in [\'cost\',\'pad_ratio\',\'p95_latency_ms\',\'sequential_timecost\']})\n    else:\n        print(\'NO PASSING COMBINATION FOUND IN SEARCHED GRID\')\n        # write a reasonable default to inspect\n        reps = choose_reps(u1, u2, 5, 3)\n        p1 = build_plan(reqs1, reps, 128, 64)\n        p2 = build_plan(reqs2, reps, 64, 64)\n        write(out1, p1)\n        write(out2, p2)\n    for name, out, inp in [(\'plan_b1.jsonl\', out1, in1), (\'plan_b2.jsonl\', out2, in2)]:\n        m = metrics_for(out, inp)\n        v = validate(out, inp)\n        th = THRESH[name]\n        print(name)\n        print(\'  valid\', v)\n        print(\'  cost=%.6g pad_ratio=%.6f p95=%.6g seqtime=%.6g\' % (m[\'cost\'], m[\'pad_ratio\'], m[\'p95_latency_ms\'], m[\'sequential_timecost\']))\n        print(\'  pass\', all(m[k] <= th[k] for k in th))\n\nif __name__ == \'__main__\':\n    main()\nPY\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
