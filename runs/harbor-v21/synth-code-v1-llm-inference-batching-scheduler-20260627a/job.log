Sending keys: ["cat > /app/task_file/scripts/optimizer.py <<'PY'\n#!/usr/bin/env python3\nimport json, os, math, collections, sys\nsys.path.insert(1, '/app/task_file/scripts')\nfrom cost_model import CostModel, align, HEADS, HIDDEN, CostConsts\n\nGRAN=64\nMAX_SHAPES=8\nROOT='/app/task_file'\nIN1=f'{ROOT}/input_data/requests_bucket_1.jsonl'\nIN2=f'{ROOT}/input_data/requests_bucket_2.jsonl'\nOUT1=f'{ROOT}/output_data/plan_b1.jsonl'\nOUT2=f'{ROOT}/output_data/plan_b2.jsonl'\nTH={\n 'b1': {'cost':3.0e11,'pad_ratio':0.055,'p95_latency_ms':2.1e6,'sequential_timecost':2.7e8},\n 'b2': {'cost':4.8e10,'pad_ratio':0.15,'p95_latency_ms':2.1e5,'sequential_timecost':3.2e7},\n}\n\ndef load(p):\n    return [json.loads(l) for l in open(p)]\n\ndef uniq(reqs):\n    seen=set(); out=[]\n    for r in reqs:\n        s=align(r['prompt_len'],GRAN)\n        if s not in seen:\n            seen.add(s); out.append(s)\n    return sorted(out)\n\ndef quantile_reps(u,k):\n    if not u or k<=0: return []\n    if len(u)<=k: return u[:]\n    out=set()\n    for i in range(k):\n        q=(i+0.5)/k\n        idx=max(0,min(len(u)-1,int(q*(len(u)-1))))\n        out.add(u[idx])\n    out.add(u[-1])\n    return sorted(out)\n\ndef endpoint_reps(u,k):\n    if not u or k<=0: return []\n    if len(u)<=k: return u[:]\n    out=set()\n    for i in range(k):\n        idx=min(len(u)-1,int(round((i+1)*len(u)/k))-1)\n        out.add(u[idx])\n    return sorted(out)\n\ndef assign(s,reps):\n    for r in reps:\n        if r>=s: return r\n    return reps[-1]\n\ndef build(reqs,reps,gmax,bsize):\n    groups=collections.defaultdict(list)\n    for r in reqs:\n        groups[assign(align(r['prompt_len'],GRAN),reps)].append(r)\n    recs=[]; bid=0\n    for rep in sorted(groups):\n        grp=sorted(groups[rep], key=lambda x:x['gen_len'])\n        cur=[]; cmax=1\n        for r in grp:\n            g=r['gen_len']\n            if cur and ((gmax and max(cmax,g)>gmax) or (bsize and len(cur)>=bsize)):\n                bid+=1\n                b=f'b-{bid:04d}'\n                for x in cur:\n                    recs.append({'request_id':x['request_id'],'batch_id':b,'shape':{'seq_align':rep,'heads_align':HEADS,'hidden_align':HIDDEN}})\n                cur=[r]; cmax=g\n            else:\n                cur.append(r); cmax=max(cmax,g)\n        if cur:\n            bid+=1\n            b=f'b-{bid:04d}'\n            for x in cur:\n                recs.append({'request_id':x['request_id'],'batch_id':b,'shape':{'seq_align':rep,'heads_align':HEADS,'hidden_align':HIDDEN}})\n    return recs\n\ndef scalar_metrics(plan, req_map, cm):\n    # Faster scalar-only metric calculation matching CostModel.plan_metrics.\n    batches=collections.defaultdict(list)\n    shape_of={}\n    for p in plan:\n        batches[p['batch_id']].append(req_map[p['request_id']])\n        shape_of[p['batch_id']]=tuple(p['shape'][k] for k in ('seq_align','heads_align','hidden_align'))\n    c=CostConsts()\n    total_cost=0.0\n    pad_tokens=0\n    real_tokens=0\n    lat_by_batch={}\n    for bid, rs in batches.items():\n        S_max=max(align(r['prompt_len'],GRAN) for r in rs)\n        G_max=max(r['gen_len'] for r in rs)\n        cost_prefill=sum(c.Kp_attn*(align(r['prompt_len'],GRAN)**2)+c.Kp_mlp*(align(r['prompt_len'],GRAN)*HIDDEN) for r in rs)\n        a=S_max; n=G_max\n        sum_sq=n*(a*a)+a*n*(n-1)+(n*(n-1)*(2*n-1))//6\n        sum_lin=n*a+n*(n-1)/2\n        cost_decode=len(rs)*(c.Kd_attn*sum_sq+c.Kd_mlp*HIDDEN*sum_lin)\n        total_cost+=cost_prefill+cost_decode\n        pad_tokens+=sum(align(r['prompt_len'],GRAN)-r['prompt_len'] for r in rs)+sum(G_max-r['gen_len'] for r in rs)\n        real_tokens+=sum(r['prompt_len']+r['gen_len'] for r in rs)\n        lat_prefill=[c.Tp_attn*(align(r['prompt_len'],GRAN)**2)+c.Tp_mlp*(align(r['prompt_len'],GRAN)*HIDDEN) for r in rs]\n        lat_decode_per=c.Td_attn*sum_sq+c.Td_mlp*HIDDEN*sum_lin\n        lat_by_batch[bid]=[lp+lat_decode_per+c.Tbatch_overhead_ms for lp in lat_prefill]\n    unique_shapes=set(shape_of.values())\n    for s,h,hid in unique_shapes:\n        if s>0:\n            total_cost+=c.Kshape_attn*(s**2)+c.Kshape_mlp*(s*HIDDEN)\n    total_cost+=c.Kbatch_overhead_cost*len(batches)\n    shape_batches=collections.defaultdict(list)\n    for bid,shp in shape_of.items():\n        shape_batches[shp].append(bid)\n    all_lats=[]\n    for shp in sorted(shape_batches):\n        b_list=sorted(shape_batches[shp])\n        lats=lat_by_batch[b_list[0]]\n        if lats and c.Tshape_compile_ms>0:\n            lats=lats[:]  # avoid mutating shared list\n            lats[0]+=c.Tshape_compile_ms\n        for bid in b_list:\n            all_lats.extend(lat_by_batch[bid])\n    seq=0.0\n    for bid in sorted(lat_by_batch):\n        if lat_by_batch[bid]:\n            seq+=max(lat_by_batch[bid])\n    arr=sorted(all_lats)\n    p95=arr[max(0,min(len(arr)-1,int(math.ceil(0.95*len(arr)))-1))] if arr else 0.0\n    return {\n        'cost':total_cost,\n        'pad_ratio':pad_tokens/max(1,real_tokens),\n        'p95_latency_ms':p95,\n        'sequential_timecost':seq,\n    }\n\ndef ok(m,key):\n    return all(m[k]<=TH[key][k] for k in TH[key])\n\ndef validate(plan, req_map):\n    ids=[p['request_id'] for p in plan]\n    shapes=set((p['shape']['seq_align'],p['shape']['heads_align'],p['shape']['hidden_align']) for p in plan)\n    batch_shapes=collections.defaultdict(set)\n    for p in plan:\n        batch_shapes[p['batch_id']].add(p['shape']['seq_align'])\n    return {\n        'all_included': len(ids)==len(req_map)==len(set(ids)),\n        'shapes_ok': len(shapes)<=MAX_SHAPES and all(s[1]==32 and s[2]==4096 and s[0]%GRAN==0 for s in shapes),\n        'seq_ok': all(align(req_map[p['request_id']]['prompt_len'],GRAN)<=p['shape']['seq_align'] for p in plan),\n        'batch_shape_consistent': all(len(v)==1 for v in batch_shapes.values()),\n    }\n\ndef write(p, recs):\n    os.makedirs(os.path.dirname(p), exist_ok=True)\n    with open(p,'w') as f:\n        for r in recs:\n     