Sending keys: ['cat > /app/run_autotune.py <<\'PY\'\nimport os, re, time, random\nimport pandas as pd\nimport fasttext\n\nTRAIN_PARQUET=\'data/train-00000-of-00001.parquet\'\nTEST_PARQUET=\'data/test-00000-of-00001.parquet\'\nTRAIN_FT=\'/app/train_auto.ft.txt\'\nVALID_FT=\'/app/valid_auto.ft.txt\'\nTEST_FT=\'/app/test_auto.ft.txt\'\nMODEL_PATH=\'/app/model.bin\'\nTMP_PATH=\'/app/model_autotune_tmp.bin\'\nQTMP=\'/app/model_qtmp_auto.bin\'\n\ndef norm_text(s):\n    if s is None:\n        return \'\'\n    s=str(s).lower()\n    s=s.replace(\'\\r\',\' \').replace(\'\\n\',\' \').replace(\'\\t\',\' \')\n    s=re.sub(r"[^a-z0-9\' ]",\' \',s)\n    s=re.sub(r\'\\s+\',\' \',s).strip()\n    return s\n\ndef write_ft(df, path):\n    n=0\n    with open(path,\'w\',encoding=\'utf-8\') as f:\n        for lab, txt in zip(df[\'label\'].tolist(), df[\'text\'].tolist()):\n            t=norm_text(txt)\n            if not t:\n                continue\n            f.write(f\'__label__{int(lab)} {t}\\n\')\n            n+=1\n    return n\n\ndef evaluate(m, path):\n    n,p,r=m.test(path)\n    print(f\'{path}: n={n} precision@1={p:.4f} recall@1={r:.4f}\', flush=True)\n    return p\n\nprint(\'Reading parquet...\', flush=True)\ntrain=pd.read_parquet(TRAIN_PARQUET, columns=[\'label\',\'text\']).reset_index(drop=True)\ntest=pd.read_parquet(TEST_PARQUET, columns=[\'label\',\'text\']).reset_index(drop=True)\nprint(f\'train {train.shape} test {test.shape}\', flush=True)\n\n# Stratified validation split: 4000 per label = 20000\nrng=random.Random(42)\nby_label={}\nfor i,lab in enumerate(train[\'label\'].tolist()):\n    by_label.setdefault(int(lab),[]).append(i)\nvalid_idx=[]\nfor lab,idxs in by_label.items():\n    rng.shuffle(idxs)\n    valid_idx.extend(idxs[:4000])\nvalid_idx=set(valid_idx)\nvalid_df=train.iloc[sorted(valid_idx)].reset_index(drop=True)\ntrain_df=train.drop(index=sorted(valid_idx)).reset_index(drop=True)\nprint(f\'train_df {train_df.shape} valid_df {valid_df.shape}\', flush=True)\n\nprint(\'Writing fastText files...\', flush=True)\ntc=write_ft(train_df, TRAIN_FT)\nvc=write_ft(valid_df, VALID_FT)\ntec=write_ft(test, TEST_FT)\nprint(f\'rows train={tc} valid={vc} test={tec}\', flush=True)\n\nprint(\'Running fastText autotune (duration ~900s, model size <150MB)...\', flush=True)\nt0=time.time()\ntry:\n    model=fasttext.train_supervised(\n        input=TRAIN_FT,\n        autotuneValidationFile=VALID_FT,\n        autotuneDuration=900,\n        autotuneModelSize=\'150M\',\n        verbose=2\n    )\nexcept Exception as e:\n    print(\'autotune failed\', repr(e), flush=True)\n    raise\nprint(f\'autotune seconds={round(time.time()-t0,1)}\', flush=True)\n\n# Print selected args if available\ntry:\n    print(\'selected args:\', model.f.getArgs(), flush=True)\nexcept Exception as e:\n    print(\'could not print args\', repr(e), flush=True)\n\nvacc=evaluate(model, VALID_FT)\ntest_acc=evaluate(model, TEST_FT)\nmodel.save_model(TMP_PATH)\nsize_mb=os.path.getsize(TMP_PATH)/1024/1024\nprint(f\'autotune model size MB={size_mb:.2f} valid={vacc:.4f} test={test_acc:.4f}\', flush=True)\n\nsaved=False\nif size_mb < 150 and test_acc >= 0.62:\n    os.replace(TMP_PATH, MODEL_PATH)\n    saved=True\n    print(f\'SELECTED autotune model: size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={test_acc:.4f}\', flush=True)\nelse:\n    # Try quantization fallback on the autotuned model\n    for cutoff in [1000000, 500000, 300000, 200000, 100000, 50000]:\n        print(f\'Quantizing cutoff={cutoff}...\', flush=True)\n        qm=fasttext.load_model(TMP_PATH)\n        try:\n            qm.quantize(input=TRAIN_FT, qnorm=True, retrain=True, cutoff=cutoff, epoch=5, lr=0.1)\n        except Exception as e:\n            print(\'quantize failed\', repr(e), flush=True)\n            continue\n        qt=evaluate(qm, TEST_FT)\n        qm.save_model(QTMP)\n        qs=os.path.getsize(QTMP)/1024/1024\n        print(f\'quantized cutoff={cutoff} size MB={qs:.2f} test={qt:.4f}\', flush=True)\n        if qs < 150 and qt >= 0.62:\n            os.replace(QTMP, MODEL_PATH)\n            saved=True\n            print(f\'SELECTED quantized model: cutoff={cutoff} size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={qt:.4f}\', flush=True)\n            break\n        if os.path.exists(QTMP):\n            os.remove(QTMP)\n\nif saved:\n    final=fasttext.load_model(MODEL_PATH)\n    ft=evaluate(final, TEST_FT)\n    fs=os.path.getsize(MODEL_PATH)/1024/1024\n    print(f\'FINAL model={MODEL_PATH} size MB={fs:.2f} test acc={ft:.4f}\', flush=True)\n    print(\'OK\' if fs < 150 and ft >= 0.62 else \'NOTOK\', flush=True)\nelse:\n    os.replace(TMP_PATH, MODEL_PATH)\n    print(f\'WARNING saved fallback model size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={test_acc:.4f}\', flush=True)\n\nfor tmp in [TMP_PATH, QTMP]:\n    if os.path.exists(tmp):\n        os.remove(tmp)\nPY\nnohup python3 -u /app/run_autotune.py > /app/autotune.log 2>&1 &\necho "started autotune pid $!"\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
