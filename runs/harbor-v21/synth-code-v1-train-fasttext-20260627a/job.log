Sending keys: ['cat > /app/run_train3.py <<\'PY\'\nimport os, re, time\nimport pandas as pd\nimport fasttext\n\nTRAIN_PARQUET=\'data/train-00000-of-00001.parquet\'\nTEST_PARQUET=\'data/test-00000-of-00001.parquet\'\nTRAIN_FT=\'/app/train3.ft.txt\'\nTEST_FT=\'/app/test3.ft.txt\'\nMODEL_PATH=\'/app/model.bin\'\nFULL_PATH=\'/app/model_full3.bin\'\nQTMP=\'/app/model_qtmp3.bin\'\n\ndef norm_text(s):\n    if s is None:\n        return \'\'\n    s = str(s)\n    s = s.replace(\'\\r\', \' \').replace(\'\\n\', \' \').replace(\'\\t\', \' \')\n    s = re.sub(r\'\\s+\', \' \', s).strip()\n    return s\n\ndef write_ft(df, path):\n    n = 0\n    with open(path, \'w\', encoding=\'utf-8\') as f:\n        for lab, txt in zip(df[\'label\'].tolist(), df[\'text\'].tolist()):\n            t = norm_text(txt)\n            if not t:\n                continue\n            f.write(f\'__label__{int(lab)} {t}\\n\')\n            n += 1\n    return n\n\ndef evaluate(m, path):\n    n, p, r = m.test(path)\n    print(f\'{path}: n={n} precision@1={p:.4f} recall@1={r:.4f}\', flush=True)\n    return p\n\nprint(\'Reading parquet...\', flush=True)\ntrain = pd.read_parquet(TRAIN_PARQUET, columns=[\'label\',\'text\']).reset_index(drop=True)\ntest = pd.read_parquet(TEST_PARQUET, columns=[\'label\',\'text\']).reset_index(drop=True)\nprint(f\'train {train.shape} test {test.shape}\', flush=True)\n\nprint(\'Writing fastText files...\', flush=True)\ntrain_count = write_ft(train, TRAIN_FT)\ntest_count = write_ft(test, TEST_FT)\nprint(f\'rows train={train_count} test={test_count}\', flush=True)\n\nprint(\'Training model...\', flush=True)\nt0 = time.time()\nmodel = fasttext.train_supervised(\n    input=TRAIN_FT,\n    epoch=25,\n    lr=0.7,\n    wordNgrams=3,\n    dim=120,\n    minCount=2,\n    bucket=250000,\n    ws=5,\n    loss=\'softmax\',\n    thread=os.cpu_count() or 4,\n    verbose=2\n)\nprint(f\'train seconds={round(time.time()-t0,1)}\', flush=True)\n\ntest_acc = evaluate(model, TEST_FT)\nmodel.save_model(FULL_PATH)\nfull_size = os.path.getsize(FULL_PATH) / 1024 / 1024\nprint(f\'full size MB={full_size:.2f} test={test_acc:.4f}\', flush=True)\n\nsaved = False\nif full_size < 150 and test_acc >= 0.62:\n    os.replace(FULL_PATH, MODEL_PATH)\n    saved = True\n    print(f\'SELECTED full model: size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={test_acc:.4f}\', flush=True)\nelse:\n    for cutoff in [1000000, 500000, 300000, 200000, 100000, 50000]:\n        print(f\'Quantizing cutoff={cutoff}...\', flush=True)\n        qm = fasttext.load_model(FULL_PATH)\n        try:\n            qm.quantize(input=TRAIN_FT, qnorm=True, retrain=True, cutoff=cutoff, epoch=8, lr=0.3)\n        except Exception as e:\n            print(\'quantize failed\', repr(e), flush=True)\n            continue\n        qt = evaluate(qm, TEST_FT)\n        qm.save_model(QTMP)\n        qs = os.path.getsize(QTMP) / 1024 / 1024\n        print(f\'quantized cutoff={cutoff} size MB={qs:.2f} test={qt:.4f}\', flush=True)\n        if qs < 150 and qt >= 0.62:\n            os.replace(QTMP, MODEL_PATH)\n            saved = True\n            print(f\'SELECTED quantized model: cutoff={cutoff} size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={qt:.4f}\', flush=True)\n            break\n        if os.path.exists(QTMP):\n            os.remove(QTMP)\n\nif saved:\n    final = fasttext.load_model(MODEL_PATH)\n    final_test = evaluate(final, TEST_FT)\n    final_size = os.path.getsize(MODEL_PATH) / 1024 / 1024\n    print(f\'FINAL model={MODEL_PATH} size MB={final_size:.2f} test acc={final_test:.4f}\', flush=True)\n    print(\'OK\' if final_size < 150 and final_test >= 0.62 else \'NOTOK\', flush=True)\nelse:\n    os.replace(FULL_PATH, MODEL_PATH)\n    print(f\'WARNING saved fallback model size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={test_acc:.4f}\', flush=True)\n\nfor tmp in [FULL_PATH, QTMP]:\n    if os.path.exists(tmp):\n        os.remove(tmp)\nPY\nnohup python3 -u /app/run_train3.py > /app/train3.log 2