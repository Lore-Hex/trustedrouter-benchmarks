Sending keys: ["cat > /app/run_train.py <<'PY'\nimport os, re, time, random\nimport pandas as pd\nimport fasttext\n\nTRAIN_PARQUET='data/train-00000-of-00001.parquet'\nTEST_PARQUET='data/test-00000-of-00001.parquet'\nTRAIN_FT='/app/train.ft.txt'\nVALID_FT='/app/valid.ft.txt'\nTEST_FT='/app/test.ft.txt'\nMODEL_PATH='/app/model.bin'\nFULL_PATH='/app/model_full.bin'\nQTMP='/app/model_qtmp.bin'\n\ndef norm_text(s):\n    if s is None:\n        return ''\n    s=str(s).lower()\n    s=s.replace('\\r',' ').replace('\\n',' ').replace('\\t',' ')\n    s=re.sub(r'[^a-z0-9\\' ]',' ',s)\n    s=re.sub(r'\\s+',' ',s).strip()\n    return s\n\ndef write_ft(df, path):\n    n=0\n    with open(path,'w',encoding='utf-8') as f:\n        for lab, txt in zip(df['label'].tolist(), df['text'].tolist()):\n            t=norm_text(txt)\n            if not t:\n                continue\n            f.write(f'__label__{int(lab)} {t}\\n')\n            n+=1\n    return n\n\nprint('Reading train/test parquet...')\ntrain=pd.read_parquet(TRAIN_PARQUET, columns=['label','text']).reset_index(drop=True)\ntest=pd.read_parquet(TEST_PARQUET, columns=['label','text']).reset_index(drop=True)\nprint('train', train.shape, 'test', test.shape)\n\n# Random validation split (stratified-ish by random shuffle)\nrng=random.Random(42)\nidx=list(range(len(train)))\nrng.shuffle(idx)\nvalid_n=20000\nvalid_idx=set(idx[:valid_n])\nvalid_df=train.iloc[sorted(valid_idx)]\ntrain_df=train.drop(index=sorted(valid_idx)).reset_index(drop=True)\n\nprint('Writing fastText files...')\ntrain_count=write_ft(train_df, TRAIN_FT)\nvalid_count=write_ft(valid_df, VALID_FT)\ntest_count=write_ft(test, TEST_FT)\nprint(f'train ft rows={train_count}, valid ft rows={valid_count}, test ft rows={test_count}')\n\ndef evaluate(m, path):\n    n,p,r=m.test(path)\n    print(f'{path}: n={n} precision@1={p:.4f} recall@1={r:.4f}')\n    return p\n\nprint('Training full model...')\nt0=time.time()\nmodel=fasttext.train_supervised(\n    input=TRAIN_FT,\n    epoch=15,\n    lr=0.5,\n    wordNgrams=2,\n    dim=100,\n    minCount=3,\n    bucket=200000,\n    ws=5,\n    loss='softmax',\n    thread=os.cpu_count() or 4,\n    verbose=2\n)\nprint('train seconds', round(time.time()-t0,1))\nfull_valid=evaluate(model, VALID_FT)\nfull_test=evaluate(model, TEST_FT)\n\nmodel.save_model(FULL_PATH)\nfull_size=os.path.getsize(FULL_PATH)/1024/1024\nprint(f'full model size MB={full_size:.2f}')\n\nbest_model=model\nbest_acc=full_test\nbest_path=None\n\n# Try quantization candidates; keep first one that meets constraints, but prefer quantized if accurate enough.\nfor cutoff in [100000, 50000, 25000, 1000000]:\n    print(f'\\\\nQuantizing with cutoff={cutoff}...')\n    qm=fasttext.load_model(FULL_PATH)\n    try:\n        qm.quantize(input=TRAIN_FT, qnorm=True, retrain=True, cutoff=cutoff, epoch=5, lr=0.1)\n    except Exception as e:\n        print('quantize failed', repr(e))\n        continue\n    qv=evaluate(qm, VALID_FT)\n    qt=evaluate(qm, TEST_FT)\n    qm.save_model(QTMP)\n    qs=os.path.getsize(QTMP)/1024/1024\n    print(f'quantized cutoff={cutoff} size MB={qs:.2f} valid={qv:.4f} test={qt:.4f}')\n    if qs < 150 and qt >= 0.62:\n        os.replace(QTMP, MODEL_PATH)\n        print(f'SELECTED quantized model: cutoff={cutoff}, size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f}, test acc={qt:.4f}')\n        best_model=qm\n        best_acc=qt\n        best_path=MODEL_PATH\n        break\n    else:\n        if os.path.exists(QTMP):\n            os.remove(QTMP)\n\n# If quantization did not meet gate, use full model if it is small enough and accurate enough.\nif best_path is None:\n    if full_size < 150 and full_test >= 0.62:\n        os.replace(FULL_PATH, MODEL_PATH)\n        best_path=MODEL_PATH\n        print(f'SELECTED full model: size MB={full_size:.2f}, test acc={full_test:.4f}')\n    else:\n        # Fallback: save best available model even if it needs further attention.\n        os.replace(FULL_PATH, MODEL_PATH)\n        best_path=MODEL_PATH\n        print(f'WARNING: model saved but constraints may not be met: full size MB={full_size:.2f}, test acc={full_test:.4f}')\n\nif os.path.exists(FULL_PATH):\n    os.remove(FULL_PATH)\nif os.path.exists(QTMP):\n    os.remove(QTMP)\n\nprint('\\\\nFINAL CHECK')\nfinal_model=fasttext.load_model(MODEL_PATH)\nfinal_test=evaluate(final_model, TEST_FT)\nfinal_size=os.path.getsize(MODEL_PATH)/1024/1024\nprint(f'FINAL model={MODEL_PATH} size MB={final_size:.2f} test acc={final_test:.4f}')\nprint('OK' if final_size < 150 and final_test >= 0.62 else 'NOTOK')\nPY\npython3 /app/run_train.py 2>&1 | tail -120\n"] min_timeout_sec: 60.0 max_timeout_sec: 180.0
