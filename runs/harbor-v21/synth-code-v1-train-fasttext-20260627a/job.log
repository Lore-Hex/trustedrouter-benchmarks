Sending keys: ['cat > /app/run_manual_final.py <<\'PY\'\nimport os, time, subprocess, sys\nimport fasttext\n\nTRAIN_FT=\'/app/train.ft.txt\'\nTEST_FT=\'/app/test.ft.txt\'\nMODEL_PATH=\'/app/model.bin\'\nFULL_PATH=\'/app/model_full_manual2.bin\'\nLOG=\'/app/manual_final.log\'\n\ndef evaluate(m, path):\n    n,p,r=m.test(path)\n    print(f\'{path}: n={n} precision@1={p:.4f} recall@1={r:.4f}\', flush=True)\n    return p\n\nif not os.path.exists(TRAIN_FT) or not os.path.exists(TEST_FT):\n    raise FileNotFoundError(f\'missing fastText files {TRAIN_FT} or {TEST_FT}\')\n\nprint(f\'train file={TRAIN_FT} size={os.path.getsize(TRAIN_FT)/1024/1024:.1f}MB\', flush=True)\nprint(f\'test file={TEST_FT} size={os.path.getsize(TEST_FT)/1024/1024:.1f}MB\', flush=True)\n\nprint(\'Training manual model...\', flush=True)\nt0=time.time()\nmodel=fasttext.train_supervised(\n    input=TRAIN_FT,\n    epoch=30,\n    lr=0.5,\n    wordNgrams=2,\n    dim=150,\n    minCount=2,\n    bucket=300000,\n    ws=5,\n    loss=\'softmax\',\n    thread=os.cpu_count() or 4,\n    verbose=2\n)\nprint(f\'train seconds={round(time.time()-t0,1)}\', flush=True)\n\ntest_acc=evaluate(model, TEST_FT)\nmodel.save_model(FULL_PATH)\nfull_size=os.path.getsize(FULL_PATH)/1024/1024\nprint(f\'full size MB={full_size:.2f} test={test_acc:.4f}\', flush=True)\n\nsaved=False\nif full_size < 150 and test_acc >= 0.62:\n    os.replace(FULL_PATH, MODEL_PATH)\n    saved=True\n    print(f\'SELECTED full model: size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={test_acc:.4f}\', flush=True)\nelse:\n    print(\'Full model did not meet constraints; launching separate quantize subprocess\', flush=True)\n    qscript = r\'\'\'import os, fasttext\nFULL_PATH="/app/model_full_manual2.bin"\nMODEL_PATH="/app/model.bin"\nQTMP="/app/model_qtmp_manual2.bin"\nTRAIN_FT="/app/train.ft.txt"\nTEST_FT="/app/test.ft.txt"\n\ndef evaluate(m, path):\n    n,p,r=m.test(path)\n    print(f\'{path}: n={n} precision@1={p:.4f} recall@1={r:.4f}\', flush=True)\n    return p\n\nfor cutoff in [200000, 150000, 100000, 75000, 50000, 30000]:\n    print(f\'Quantizing cutoff={cutoff}...\', flush=True)\n    qm=fasttext.load_model(FULL_PATH)\n    try:\n        qm.quantize(input=TRAIN_FT, qnorm=True, retrain=True, cutoff=cutoff, epoch=8, lr=0.3)\n    except Exception as e:\n        print(\'quantize failed\', repr(e), flush=True)\n        continue\n    qt=evaluate(qm, TEST_FT)\n    qm.save_model(QTMP)\n    qs=os.path.getsize(QTMP)/1024/1024\n    print(f\'quantized cutoff={cutoff} size MB={qs:.2f} test={qt:.4f}\', flush=True)\n    if qs < 150 and qt >= 0.62:\n        os.replace(QTMP, MODEL_PATH)\n        print(f\'SELECTED quantized model: cutoff={cutoff} size MB={os.path.getsize(MODEL_PATH)/1024/1024:.2f} test={qt:.4f}\', flush=True)\n        break\n    if os.path.exists(QTMP):\n        os.remove(QTMP)\n\nif not os.path.exists(MODEL_PATH):\n    os.replace(FULL_PATH, MODEL_PATH)\n    print(\'WARNING saved fallback full model\', flush=True)\nif os.path.exists(FULL_PATH):\n    os.remove(FULL_PATH)\nif os.path.exists(QTMP):\n    os.remove(QTMP)\n\'\'\'\n    with open(\'/app/run_quantize_manual2.py\',\'w\') as f:\n        f.write(qscript)\n    ret=subprocess.run([sys.executable, \'-u\', \'/app/run_quantize_manual2.py\'])\n    print(\'quantize subprocess return\', ret.returncode, flush=True)\n    if os.path.exists(MODEL_PATH):\n        saved=True\n\nif saved and os.path.exists(MODEL_PATH):\n    print(\'Verifying final model...\', flush=True)\n    final=fasttext.load_model(MODEL_PATH)\n    ft=evaluate(final, TEST_FT)\n    fs=os.path.getsize(MODEL_PATH)/1024/1024\n    print(f\'FINAL model={MODEL_PATH} size MB={fs:.2f} test acc={ft:.4f}\', flush=True)\n    print(\'OK\' if fs < 150 and ft >= 0.62 else \'NOTOK\', flush=True)\nelse:\n    print(\'ERROR: no final model saved\', flush=True)\n\nif os.path.exists(FULL_PATH):\n    os.remove(FULL_PATH)\nPY\nnohup python3 -u /app/run_manual_final.py > /app/manual_final.log 2>&1 &\necho "started manual final pid $!"\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
