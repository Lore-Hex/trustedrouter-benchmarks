Sending keys: ['cat > /app/task_file/scripts/optimize_plans.py <<\'PY\'\n#!/usr/bin/env python3\nimport json, os, sys, collections, math\nfrom pathlib import Path\nsys.path.insert(0, str(Path(__file__).resolve().parent))\nfrom cost_model import CostModel, HEADS, HIDDEN, align\n\nROOT = Path(\'/app/task_file\')\nGRAN = 64\nSHAPES = [64, 128, 192, 256, 320, 448, 640, 2048]\nCM = CostModel(GRAN)\n\ndef load(path):\n    return [json.loads(l) for l in open(path)]\n\ndef save(path, recs):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, \'w\') as f:\n        for r in recs:\n            f.write(json.dumps(r) + \'\\n\')\n\ndef assign(reqs):\n    out = []\n    for r in reqs:\n        s = align(r[\'prompt_len\'], GRAN)\n        rep = SHAPES[-1]\n        for x in SHAPES:\n            if x >= s:\n                rep = x\n                break\n        rr = dict(r)\n        rr[\'shape_seq\'] = rep\n        out.append(rr)\n    return out\n\ndef decode_cost(s, g):\n    return CM.c.Kd_attn * CM._sum_sq_arith(s, g) + CM.c.Kd_mlp * HIDDEN * (g*s + g*(g-1)/2)\n\ndef decode_lat(s, g):\n    return CM.c.Td_attn * CM._sum_sq_arith(s, g) + CM.c.Td_mlp * HIDDEN * (g*s + g*(g-1)/2)\n\ndef prefill_lat(p):\n    return CM._prefill_lat(p)\n\ndef prefill_cost(p):\n    return CM._prefill_cost(p)\n\ndef seg_cost(rs, i, j):\n    sub = rs[i:j]\n    g = max(r[\'gen_len\'] for r in sub)\n    s = max(align(r[\'prompt_len\'], GRAN) for r in sub)\n    dc = decode_cost(s, g)\n    dl = decode_lat(s, g)\n    cost = sum(prefill_cost(r[\'prompt_len\']) for r in sub) + len(sub)*dc + CM.c.Kbatch_overhead_cost\n    pad = sum(align(r[\'prompt_len\'], GRAN)-r[\'prompt_len\'] for r in sub) + sum(g-r[\'gen_len\'] for r in sub)\n    max_lat = max(prefill_lat(r[\'prompt_len\']) for r in sub) + dl + CM.c.Tbatch_overhead_ms\n    return cost, pad, max_lat\n\ndef partition(rs, pad_penalty, max_batch=200, lat_weight=1.0):\n    rs = sorted(rs, key=lambda r: (r[\'gen_len\'], -align(r[\'prompt_len\'], GRAN)))\n    n = len(rs)\n    if not n:\n        return []\n    dp = [float(\'inf\')] * (n+1)\n    par = [-1] * (n+1)\n    dp[0] = 0.0\n    for j in range(1, n+1):\n        lo = max(0, j - max_batch)\n        for i in range(lo, j):\n            c, pad, lat = seg_cost(rs, i, j)\n            val = dp[i] + c + pad_penalty*pad + lat_weight*lat\n            if val < dp[j]:\n                dp[j] = val\n                par[j] = i\n    parts = []\n    j = n\n    while j > 0:\n        i = par[j]\n        parts.append((i, j))\n        j = i\n    parts.reverse()\n    return parts\n\ndef build_plan(reqs, pad_penalty, lat_weight=1.0):\n    assigned = assign(reqs)\n    by_shape = collections.defaultdict(list)\n    for r in assigned:\n        by_shape[r[\'shape_seq\']].append(r)\n    recs = []\n    bid = 0\n    for s in sorted(by_shape):\n        parts = partition(by_shape[s], pad_penalty, lat_weight=lat_weight)\n        for i, j in parts:\n            bid += 1\n            batch_id = f\'b{bid:04d}\'\n            for r in by_shape[s][i:j]:\n                recs.append({\'request_id\': r[\'request_id\'], \'batch_id\': batch_id,\n                              \'shape\': {\'seq_align\': s, \'heads_align\': HEADS, \'hidden_align\': HIDDEN}})\n    return recs\n\ndef metrics(reqs, plan):\n    rmap = {r[\'request_id\']: r for r in reqs}\n    return CostModel(GRAN).plan_metrics(rmap, plan)\n\ndef passes(m1, m2):\n    return (m1[\'sequential_timecost\'] < 2.7e8 and m2[\'sequential_timecost\'] < 3.2e7 and\n            m1[\'pad_ratio\'] < 0.055 and m2[\'pad_ratio\'] < 0.15 and\n            m1[\'cost\'] < 3.0e11 and m2[\'cost\'] < 4.8e10 and\n            m1[\'p95_latency_ms\'] < 2.1e6 and m2[\'p95_latency_ms\'] < 2.1e5)\n\ndef main():\n    b1 = load(str(ROOT/\'input_data\'/\'requests_bucket_1.jsonl\'))\n    b2 = load(str(ROOT/\'input_data\'/\'requests_bucket_2.jsonl\'))\n    best = None\n    penalties = [0, 1e2, 5e2, 1e3, 3e3, 6e3, 1e4, 2e4, 4e4, 8e4, 1.2e5, 1.6e5, 2.2e5, 3e5, 5e5, 8e5, 1.2e6, 2e6, 4e6, 1e7]\n    for pp in penalties:\n        for lw in [0.0, 0.3, 1.0, 3.0, 10.0]:\n            p1 = build_plan(b1, pp, lat_weight=lw)\n            p2 = build_plan(b2, pp, lat_weight=lw)\n            m1 = metrics(b1, p1)\n            m2 = metrics(b2, p2)\n            ok = passes(m1, m2)\n            score = m1[\'sequential_timecost\'] + m2[\'sequential_timecost\']\n            print(f\'pp={pp:g} lw={lw:g} batches={len(set(r["batch_id"] for r in p1))},{len(set(r["batch_id"] for r in p2))} seq={m1["sequential_timecost"]:.6e},{m2["sequential_timecost"]:.6e} pad={m1["pad_ratio"]:.4f},{m2["pad_ratio"]:.4f} cost={m1["cost"]:.6e},{m2["cost"]:.6e} ok={ok}\', file=sys.stderr)\n            if ok and (best is None or score < best[0]):\n                best = (score, p1, p2, pp, lw)\n    if best is None:\n        # Fallback: minimize threshold gap for sequential while respecting other thresholds.\n        for pp in penalties:\n            for lw in [0.0, 0.3, 1.0, 3.0, 10.0]:\n                p1 = build_plan(b1, pp, lat_weight=lw)\n                p2 = build_plan(b2, pp, lat_weight=lw)\n                m1 = metrics(b1, p1)\n                m2 = metrics(b2, p2)\n                if m1[\'pad_ratio\'] >= 0.055 or m2[\'pad_ratio\'] >= 0.15 or m1[\'cost\'] >= 3.0e11 or m2[\'cost\'] >= 4.8e10 or m1[\'p95_latency_ms\'] >= 2.1e6 or m2[\'p95_latency_ms\'] >= 2.1e5:\n                    continue\n                gap = max(0, m1[\'sequential_timecost\']-2.7e8) + max(0, m2[\'sequential_timecost\']-3.2e7)\n                if best is None or gap < best[0]:\n                    best = (gap, p1, p2, pp, lw)\n        if best is not None:\n            print(f\'WARNING: no fully passing; closest pp={best[3]} lw={best[4]} gap={best[0]:.6e}\', file=sys.stderr)\n    if best is not None:\n        save(str(ROOT/\'output_data\'/\'plan_b1.jsonl\'), best[1])\n        save(str(ROOT/\'output_data\'/\'plan_b2.jsonl\'), best[2])\n        print(f\'SAVED pp={best[3]} lw={best[4]} seq_score={best[0]:.6e}\', file=sys.stderr)\n    else:\n        print(\'NO VALID PLANS FOUND\', file=sys.stderr)\n        sys.exit(1)\n\nif __name__ == \'__main__\':\n    main()\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
