Sending keys: ["cat > /app/task_file/scripts/optimize_plans.py <<'PY'\n#!/usr/bin/env python3\nimport json, os, sys, math, collections, itertools\nfrom pathlib import Path\nsys.path.insert(0, str(Path(__file__).resolve().parent))\nfrom cost_model import CostModel, HEADS, HIDDEN, align\n\nROOT = Path('/app/task_file')\nGRAN = 64\nMAX_SHAPES = 8\nCM = CostModel(GRAN)\n\ndef load(path):\n    return [json.loads(l) for l in open(path)]\n\ndef save(path, recs):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, 'w') as f:\n        for r in recs:\n            f.write(json.dumps(r) + '\\n')\n\ndef shape_compile_cost(s):\n    return CM.c.Kshape_attn * (s ** 2) + CM.c.Kshape_mlp * (s * HIDDEN)\n\ndef choose_global_shapes(buckets, k=MAX_SHAPES, compile_weight=1e-4):\n    # all aligned prompt candidates across both buckets\n    cand = sorted({align(r['prompt_len'], GRAN) for reqs in buckets.values() for r in reqs})\n    maxs = cand[-1]\n    # weighted prompt padding only for shape selection; compile cost small tie-breaker\n    weights = collections.Counter()\n    for reqs in buckets.values():\n        for r in reqs:\n            weights[align(r['prompt_len'], GRAN)] += 1\n    n = len(cand)\n    # dp[j][kk] = (best_score, prev_j, prev_kk)\n    INF = float('inf')\n    dp = [[INF] * (k + 1) for _ in range(n + 1)]\n    par = [[None] * (k + 1) for _ in range(n + 1)]\n    dp[0][0] = 0.0\n    for i in range(n):\n        for kk in range(k + 1):\n            if dp[i][kk] == INF:\n                continue\n            # skip candidate i\n            if dp[i+1][kk] > dp[i][kk]:\n                dp[i+1][kk] = dp[i][kk]\n                par[i+1][kk] = (i, kk, False)\n            # take candidate i as a selected shape\n            if kk < k:\n                # requests with aligned seq in (prev_selected, cand[i]] are assigned to cand[i]\n                # prev_selected index is implicit via path; compute incremental padding using all buckets\n                # We need the previous selected candidate index. Reconstruct selected so far by backtracking would be slow;\n                # instead compute padding directly from selected set when finalizing.\n                score = dp[i][kk] + 0  # placeholder; we will use a different method below\n                # This DP is awkward for coverage ranges; use brute force over small candidate set instead.\n    # Candidate set is small enough (<=24+11=35); prune to important candidates and brute force up to 8.\n    # Pruning: keep all bucket1 unique high shapes because they are sparse and costly to overpad;\n    # plus a grid for low shapes where most requests live.\n    low_grid = list(range(64, 768, 64))\n    high_b1 = sorted(set(align(r['prompt_len'], GRAN) for r in buckets['1'] if align(r['prompt_len'], GRAN) >= 768))\n    high_b2 = sorted(set(align(r['prompt_len'], GRAN) for r in buckets['2'] if align(r['prompt_len'], GRAN) >= 768))\n    cand_pruned = sorted(set(low_grid + high_b1 + high_b2))\n    if maxs not in cand_pruned:\n        cand_pruned.append(maxs)\n    # Always include 64 and maxs for feasible coverage.\n    # Brute force combinations including maxs; limit to pruned candidates.\n    best = None\n    for kk in range(1, min(k, len(cand_pruned)) + 1):\n        for combo in itertools.combinations(cand_pruned, kk):\n            reps = sorted(combo)\n            if reps[0] != 64 or reps[-1] != maxs:\n                continue\n            pad = 0\n            for reqs in buckets.values():\n                for r in reqs:\n                    s = align(r['prompt_len'], GRAN)\n                    rep = maxs\n                    for x in reps:\n                        if x >= s:\n                            rep = x\n                            break\n                    pad += rep - r['prompt_len']\n            score = pad + compile_weight * sum(shape_compile_cost(s) for s in reps)\n            if best is None or score < best[0]:\n                best = (score, reps)\n    return best[1]\n\ndef assign_shape(reqs, reps):\n    out = []\n    reps = sorted(reps)\n    for r in reqs:\n        s = align(r['prompt_len'], GRAN)\n        rep = reps[-1]\n        for x in reps:\n            if x >= s:\n                rep = x\n                break\n        rr = dict(r)\n        rr['shape_seq'] = rep\n        out.append(rr)\n    return out\n\ndef build_plan(reqs, reps):\n    assigned = assign_shape(reqs, reps)\n    by_shape = collections.defaultdict(list)\n    for r in assigned:\n        by_shape[r['shape_seq']].append(r)\n    recs = []\n    bid = 0\n    for s in sorted(by_shape):\n        # group by exact gen_len to eliminate decode padding\n        by_gen = collections.defaultdict(list)\n        for r in by_shape[s]:\n            by_gen[r['gen_len']].append(r)\n        for g in sorted(by_gen):\n            bid += 1\n            batch_id = f'b{bid:04d}'\n            for r in by_gen[g]:\n                recs.append({\n                    'request_id': r['request_id'],\n                    'batch_id': batch_id,\n                    'shape': {'seq_align': s, 'heads_align': HEADS, 'hidden_align': HIDDEN}\n                })\n    return recs\n\ndef main():\n    b1 = load(str(ROOT / 'input_data' / 'requests_bucket_1.jsonl'))\n    b2 = load(str(ROOT / 'input_data' / 'requests_bucket_2.jsonl'))\n    reps = choose_global_shapes({'1': b1, '2': b2}, MAX_SHAPES)\n    plan1 = build_plan(b1, reps)\n    plan2 = build_plan(b2, reps)\n    save(str(ROOT / 'output_data' / 'plan_b1.jsonl'), plan1)\n    save(str(ROOT / 'output_data' / 'plan_b2.jsonl'), plan2)\n    print('global shapes:', reps)\n\nif __name__ == '__main__':\n    main()\nPY\npython3 /app/task_file/scripts/optimize_plans.py\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
