Sending keys: ["cat > /app/task_file/scripts/optimize_plans.py <<'PY'\n#!/usr/bin/env python3\nimport json, os, sys, math, collections\nfrom pathlib import Path\nsys.path.insert(0, str(Path(__file__).resolve().parent))\nfrom cost_model import CostModel, HEADS, HIDDEN, align\n\nROOT = Path('/app/task_file')\nGRAN = 64\nMAX_SHAPES = 8\nCM = CostModel(GRAN)\n\ndef load(path):\n    return [json.loads(l) for l in open(path)]\n\ndef save(path, recs):\n    os.makedirs(os.path.dirname(path), exist_ok=True)\n    with open(path, 'w') as f:\n        for r in recs:\n            f.write(json.dumps(r) + '\\n')\n\ndef shape_compile_cost(s):\n    return CM.c.Kshape_attn * (s ** 2) + CM.c.Kshape_mlp * (s * HIDDEN)\n\ndef prefill_cost(p):\n    return CM._prefill_cost(p)\n\ndef prefill_lat(p):\n    return CM._prefill_lat(p)\n\ndef decode_cost_for(s, g):\n    A = CM.c.Kd_attn\n    B = CM.c.Kd_mlp * HIDDEN\n    sum_sq = CM._sum_sq_arith(s, g)\n    sum_lin = g * s + g * (g - 1) / 2\n    return A * sum_sq + B * sum_lin\n\ndef decode_lat_for(s, g):\n    A = CM.c.Td_attn\n    B = CM.c.Td_mlp * HIDDEN\n    sum_sq = CM._sum_sq_arith(s, g)\n    sum_lin = g * s + g * (g - 1) / 2\n    return A * sum_sq + B * sum_lin\n\ndef choose_shapes(reqs, k):\n    uniq = sorted(set(align(r['prompt_len'], GRAN) for r in reqs))\n    weights = {s: 0 for s in uniq}\n    for r in reqs:\n        weights[align(r['prompt_len'], GRAN)] += 1\n    from itertools import combinations\n    best = None\n    for kk in range(1, min(k, len(uniq)) + 1):\n        for combo in combinations(uniq, kk):\n            reps = sorted(combo)\n            if reps[-1] != uniq[-1]:\n                continue\n            pad = 0\n            for r in reqs:\n                rep = reps[-1]\n                for x in reps:\n                    if x >= align(r['prompt_len'], GRAN):\n                        rep = x\n                        break\n                pad += rep - r['prompt_len']\n            score = pad + sum(shape_compile_cost(s) / 1e8 for s in reps)\n            if best is None or score < best[0]:\n                best = (score, reps)\n    if best is None:\n        return uniq[-1:]\n    return best[1]\n\ndef assign_shape(reqs, reps):\n    out = []\n    for r in reqs:\n        s = align(r['prompt_len'], GRAN)\n        rep = reps[-1]\n        for x in reps:\n            if x >= s:\n                rep = x\n                break\n        rr = dict(r)\n        rr['shape_seq'] = rep\n        out.append(rr)\n    return out\n\ndef partition_shape(reqs, pad_penalty=2e5, max_batch=200):\n    rs = sorted(reqs, key=lambda r: (r['gen_len'], r['prompt_len']))\n    n = len(rs)\n    if n == 0:\n        return []\n    pc = [prefill_cost(r['prompt_len']) for r in rs]\n    pl = [prefill_lat(r['prompt_len']) for r in rs]\n    ppad = [align(r['prompt_len'], GRAN) - r['prompt_len'] for r in rs]\n    def seg_cost(i, j):\n        sub = rs[i:j]\n        g = max(r['gen_len'] for r in sub)\n        s = max(align(r['prompt_len'], GRAN) for r in sub)\n        dc = decode_cost_for(s, g)\n        dl = decode_lat_for(s, g)\n        cost = sum(pc[i:j]) + len(sub) * dc + CM.c.Kbatch_overhead_cost\n        pad = sum(ppad[i:j]) + sum(g - r['gen_len'] for r in sub)\n        max_lat = max(pl[i:j]) + dl + CM.c.Tbatch_overhead_ms\n        return cost, pad, max_lat\n    dp = [float('inf')] * (n + 1)\n    par = [-1] * (n + 1)\n    dp[0] = 0.0\n    for j in range(1, n + 1):\n        for i in range(max(0, j - max_batch), j):\n            c, pad, lat = seg_cost(i, j)\n            val = dp[i] + c + pad_penalty * pad\n            if val < dp[j]:\n                dp[j] = val\n                par[j] = i\n    parts = []\n    j = n\n    while j > 0:\n        i = par[j]\n        parts.append((i, j))\n        j = i\n    parts.reverse()\n    return parts\n\ndef build_bucket(reqs, max_shapes):\n    reps = choose_shapes(reqs, max_shapes)\n    assigned = assign_shape(reqs, reps)\n    by_shape = collections.defaultdict(list)\n    for r in assigned:\n        by_shape[r['shape_seq']].append(r)\n    recs = []\n    bid = 0\n    for s in sorted(by_shape):\n        parts = partition_shape(by_shape[s])\n        for i, j in parts:\n            bid += 1\n            batch_id = f'b{bid:04d}'\n            for r in by_shape[s][i:j]:\n                recs.append({\n                    'request_id': r['request_id'],\n                    'batch_id': batch_id,\n                    'shape': {'seq_align': s, 'heads_align': HEADS, 'hidden_align': HIDDEN}\n                })\n    return recs\n\ndef main():\n    b1 = load(str(ROOT / 'input_data' / 'requests_bucket_1.jsonl'))\n    b2 = load(str(ROOT / 'input_data' / 'requests_bucket_2.jsonl'))\n    # split global shape budget; b1 dominates prompt range, b2 smaller\n    reps1 = choose_shapes(b1, 6)\n    reps2 = choose_shapes(b2, MAX_SHAPES - len(reps1))\n    plan1 = build_bucket_with_reps(b1, reps1)\n    plan2 = build_bucket_with_reps(b2, reps2)\n    save(str(ROOT / 'output_data' / 'plan_b1.jsonl'), plan1)\n    save(str(ROOT / 'output_data' / 'plan_b2.jsonl'), plan2)\n\ndef build_bucket_with_reps(reqs, reps):\n    assigned = assign_shape(reqs, reps)\n    by_shape = collections.defaultdict(list)\n    for r in assigned:\n        by_shape[r['shape_seq']].append(r)\n    recs = []\n    bid = 0\n    for s in sorted(by_shape):\n        parts = partition_shape(by_shape[s])\n        for i, j in parts:\n            bid += 1\n            batch_id = f'b{bid:04d}'\n            for r in by_shape[s][i:j]:\n                recs.append({\n                    'request_id': r['request_id'],\n                    'batch_id': batch_id,\n                    'shape': {'seq_align': s, 'heads_align': HEADS, 'hidden_align': HIDDEN}\n                })\n    return recs\n\nif __name__ == '__main__':\n    main()\nPY\npython3 /app/task_file/scripts/optimize_plans.py\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
