[?2004l[?2004h> import re,struct
[?2004l[?2004h> data=Path('mystery').read_bytes()
[?2004l[?2004h> files=['main2.txt','sphere_obj.txt','plane_obj.txt','sky_obj.txt','write_image_obj.txt']
[?2004l[?2004h> pat=re.compile(r'#\s+([0-9a-f]+) <([^>]+)>')
[?2004l[?2004h> def rd(addr,n=16):
[?2004l[?2004h>     off=addr-0x400000
[?2004l[?2004h>     if off<0 or off+n>len(data): return None
[?2004l[?2004h>     return data[off:off+n]
[?2004l[?2004h> for fn in files:
[?2004l[?2004h>     print('\\n===',fn)
[?2004l[?2004h>     seen=set()
[?2004l[?2004h>     for line in Path(fn).read_text().splitlines():
[?2004l[?2004h>         m=pat.search(line)
[?2004l[?2004h>         if not m: continue
[?2004l[?2004h>         addr=int(m.group(1),16)
[?2004l[?2004h>         if addr in seen: continue
[?2004l[?2004h>         seen.add(addr)
[?2004l[?2004h>         b=rd(addr)
[?2004l[?2004h>         if not b:
[?2004l[?2004h>             print(f'{addr:08x} OUT')
[?2004l[?2004h>             continue
[?2004l[?2004h>         fs=[struct.unpack('<f',b[j:j+4])[0] for j in range(0,16,4)]
[?2004l[?2004h>         txt=''.join(chr(x) if 32<=x<127 else '.' for x in b)
[?2004l[?2004h>         print(f'{addr:08x} {m.group(2)}: {txt} | '+' '.join(f'{f:.7g}' for f in fs))
