[?2004l[?2004h> from pathlib import Path
[?2004l[?2004h> import re,struct
[?2004l[?2004h> data=Path('mystery').read_bytes()
[?2004l[?2004h> cands=set()
[?2004l[?2004h> for i in range(0,len(data)-3,4):
[?2004l[?2004h>     b=data[i:i+4]
[?2004l[?2004h>     if b in (b'\x00\x00\x00\x00', b'\xff\xff\xff\xff'): continue
[?2004l[?2004h>     try: f=struct.unpack('<f',b)[0]
[?2004l[?2004h>     except Exception: continue
[?2004l[?2004h>     if 1e-5<=abs(f)<=1e5 and abs(f)<1000:
[?2004l[?2004h>         cands.add((i,f))
[?2004l[?2004h> for off,f in sorted(cands):
