[?2004l[?2004h>         row=data[i:i+16]
[?2004l[?2004h>         if not row: break
[?2004l[?2004h>         hexs=' '.join(f'{x:02x}' for x in row)
[?2004l[?2004h>         ascii=''.join(chr(x) if 32<=x<127 else '.' for x in row)
[?2004l[?2004h>         print(f'{i:08x}: {hexs:<48} {ascii}')
[?2004l[?2004h>         s=[]
[?2004l[?2004h>         for j in range(0,len(row)-3,4):
[?2004l[?2004h>             f=struct.unpack('<f',row[j:j+4])[0]
