Sending keys: ["cd /app && python3 - <<'PY'\nfrom pathlib import Path\nimport re,struct\ndata=Path('mystery').read_bytes()\nfiles=['main2.txt','sphere_obj.txt','plane_obj.txt','sky_obj.txt','write_image_obj.txt']\npat=re.compile(r'#\\s+([0-9a-f]+) <([^>]+)>')\ndef rd(addr,n=16):\n    off=addr-0x400000\n    if off<0 or off+n>len(data): return None\n    return data[off:off+n]\nfor fn in files:\n    print('\\\\n===',fn)\n    seen=set()\n    for line in Path(fn).read_text().splitlines():\n        m=pat.search(line)\n        if not m: continue\n        addr=int(m.group(1),16)\n        if addr in seen: continue\n        seen.add(addr)\n        b=rd(addr)\n        if not b:\n            print(f'{addr:08x} OUT')\n            continue\n        fs=[struct.unpack('<f',b[j:j+4])[0] for j in range(0,16,4)]\n        txt=''.join(chr(x) if 32<=x<127 else '.' for x in b)\n        print(f'{addr:08x} {m.group(2)}: {txt} | '+' '.join(f'{f:.7g}' for f in fs))\nPY\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
