[?2004l[?2004h> import feal
[?2004l[?2004h> 
[?2004l[?2004h> def attack(encrypt_fn):
[?2004l[?2004h>     # Differential characteristic through 3 rounds (probability 1):
[?2004l[?2004h>     # Δinput to f = 0x80808080 → Δf = 0x02000002 (deterministic)
[?2004l[?2004h>     # ΔPL = 0x02000002, ΔPR = 0x82808082
[?2004l[?2004h>     # ΔR0 = 0x80808080, ΔR1 = 0, ΔR2 = 0x80808080, ΔR3 = 0x02000002
[?2004l[?2004h>     # CL = R4, CR = L4 ^ R4, R3 = CL ^ CR
[?2004l[?2004h>     # ΔCL = ΔR4 = ΔR2 ^ Δf3 → Δf3 = ΔCL ^ 0x80808080
[?2004l[?2004h>     
[?2004l[?2004h>     delta_PL = 0x02000002
[?2004l[?2004h>     delta_PR = 0x82808082
[?2004l[?2004h>     XORDeltaR2 = 0x80808080
[?2004l[?2004h>     
[?2004l[?2004h>     # Pre-compute all derived key values (only 65536 possibilities)
[?2004l[?2004h>     all_k5 = [(seed * 1234567) & 0xFFFFFFFF for seed in range(65536)]
[?2004l[?2004h>     
[?2004l[?2004h>     # Generate multiple plaintext pairs
[?2004l[?2004h>     plaintexts = [
[?2004l[?2004h>         (0x12345678, 0x9ABCDEF0),
[?2004l[?2004h>         (0xDEADBEEF, 0xCAFEBABE),
[?2004l[?2004h>         (0xAAAAAAAA, 0x55555555),
[?2004l[?2004h>         (0x01010101, 0xFEFEFEFE),
[?2004l[?2004h>         (0x13572468, 0xABCDEF01),
[?2004l[?2004h>         (0x87654321, 0xFEDCBA98),
[?2004l[?2004h>         (0x0F0F0F0F, 0xF0F0F0F0),
[?2004l[?2004h>         (0x11112222, 0x33334444),
[?2004l[?2004h>     ]
[?2004l[?2004h>     
[?2004l[?2004h>     # Encrypt all pairs and compute R3 values and observed df3
[?2004l[?2004h>     pairs_data = []
[?2004l[?2004h>     for PL, PR in plaintexts:
[?2004l[?2004h>         P = feal.merge(PL, PR)
[?2004l[?2004h>         Ps = feal.merge(PL ^ delta_PL, PR ^ delta_PR)
[?2004l[?2004h>         C = encrypt_fn(P)
[?2004l[?2004h>         Cs = encrypt_fn(Ps)
[?2004l[?2004h>         CL, CR = feal.getleft(C), feal.getright(C)
[?2004l[?2004h>         CLs, CRs = feal.getleft(Cs), feal.getright(Cs)
[?2004l[?2004h>         R3 = CL ^ CR
[?2004l[?2004h>         R3s = CLs ^ CRs
[?2004l[?2004h>         df3_obs = (CL ^ CLs) ^ XORDeltaR2
[?2004l[?2004h>         pairs_data.append((R3, R3s, df3_obs))
[?2004l[?2004h>     
[?2004l[?2004h>     # Filter candidates using all pairs
[?2004l[?2004h>     candidates = list(all_k5)
[?2004l[?2004h>     for R3, R3s, df3_obs in pairs_data:
[?2004l[?2004h>         if len(candidates) == 1:
[?2004l[?2004h>             break
[?2004l[?2004h>         new_candidates = []
[?2004l[?2004h>         for k5 in candidates:
[?2004l[?2004h>             if feal.f_function(R3 ^ k5) ^ feal.f_function(R3s ^ k5) == df3_obs:
[?2004l[?2004h>                 new_candidates.append(k5)
[?2004l[?2004h>         candidates = new_candidates
[?2004l[?2004h>         if len(candidates) == 0:
[?2004l[?2004h>             break
[?2004l[?2004h>     
[?2004l[?2004h>     assert len(candidates) >= 1, "No candidates found!"
[?2004l[?2004h>     return candidates[0]
[?2004l[?2004h> ENDOFFILE
