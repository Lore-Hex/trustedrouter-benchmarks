[?2004l[?2004h> import feal
[?2004l[?2004h> 
[?2004l[?2004h> def attack(encrypt_fn):
[?2004l[?2004h>     # Differential: Δinput=0x80808080 → Δf=0x02000002 (deterministic)
[?2004l[?2004h>     # ΔPL=0x02000002, ΔPR=0x82808082 → ΔR3=0x02000002
[?2004l[?2004h>     # Δf3 = ΔCL ^ 0x80808080, R3 = CL ^ CR
[?2004l[?2004h>     
[?2004l[?2004h>     delta_PL = 0x02000002
[?2004l[?2004h>     delta_PR = 0x82808082
[?2004l[?2004h>     XORDeltaR2 = 0x80808080
[?2004l[?2004h>     
[?2004l[?2004h>     # Generate and encrypt multiple plaintext pairs
[?2004l[?2004h>     plaintexts = [
[?2004l[?2004h>         (0x12345678, 0x9ABCDEF0),
[?2004l[?2004h>         (0xDEADBEEF, 0xCAFEBABE),
[?2004l[?2004h>         (0xAAAAAAAA, 0x55555555),
[?2004l[?2004h>         (0x01010101, 0xFEFEFEFE),
[?2004l[?2004h>         (0x13572468, 0ABCDEF01),
[?2004l[?2004h>         (0x87654321, 0xFEDCBA98),
[?2004l[?2004h>         (0x0F0F0F0F, 0xF0F0F0F0),
[?2004l[?2004h>         (0x11112222, 0x33334444),
[?2004l[?2004h>     ]
[?2004l[?2004h>     
[?2004l[?2004h>     pairs = []
[?2004l[?2004h>     for PL, PR in plaintexts:
[?2004l[?2004h>         C = encrypt_fn(feal.merge(PL, PR))
[?2004l[?2004h>         Cs = encrypt_fn(feal.merge(PL ^ delta_PL, PR ^ delta_PR))
[?2004l[?2004h>         CL, CR = feal.getleft(C), feal.getright(C)
[?2004l[?2004h>         CLs, CRs = feal.getleft(Cs), feal.getright(Cs)
[?2004l[?2004h>         pairs.append((CL ^ CR, CLs ^ CRs, (CL ^ CLs) ^ XORDeltaR2))
[?2004l[?2004h>     
[?2004l[?2004h>     # Single pass: test all 65536 possible keys against all pairs
[?2004l[?2004h>     result = None
[?2004l[?2004h>     for seed in range(65536):
[?2004l[?2004h>         k5 = (seed * 1234567) & 0xFFFFFFFF
[?2004l[?2004h>         match = True
[?2004l[?2004h>         for R3, R3s, df3_obs in pairs:
[?2004l[?2004h>             if feal.f_function(R3 ^ k5) ^ feal.f_function(R3s ^ k5) != df3_obs:
[?2004l[?2004h>                 match = False
[?2004l[?2004h>                 break
[?2004l[?2004h>         if match:
[?2004l[?2004h>             if result is not None:
[?2004l[?2004h>                 # Multiple matches found, need more pairs - shouldn't happen with 8
[?2004l[?2004h>                 return result  # return first found (may need refinement)
[?2004l[?2004h>             result = k5
[?2004l[?2004h>     
[?2004l[?2004h>     assert result is not None, "No candidates found!"
[?2004l[?2004h>     return result
[?2004l[?2004h> ENDOFFILE
