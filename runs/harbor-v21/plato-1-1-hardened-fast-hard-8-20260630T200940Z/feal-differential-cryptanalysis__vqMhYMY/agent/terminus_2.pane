[?2004l[?2004h> import feal
[?2004l[?2004h> import random
[?2004l[?2004h> 
[?2004l[?2004h> def trace_both(plaintext, plaintext_star, keys):
[?2004l[?2004h>     """Trace encryption of both plaintexts and show round-by-round diffs"""
[?2004l[?2004h>     left = feal.getleft(plaintext)
[?2004l[?2004h>     right = feal.getright(plaintext)
[?2004l[?2004h>     left_s = feal.getleft(plaintext_star)
[?2004l[?2004h>     right_s = feal.getright(plaintext_star)
[?2004l[?2004h>     
[?2004l[?2004h>     left ^= keys[0]; right ^= keys[1]
[?2004l[?2004h>     left_s ^= keys[0]; right_s ^= keys[1]
[?2004l[?2004h>     
[?2004l[?2004h>     right ^= left; right_s ^= left_s
[?2004l[?2004h>     
[?2004l[?2004h>     L, R = left, right
[?2004l[?2004h>     Ls, Rs = left_s, right_s
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"  ΔL0={L^Ls:#010x} ΔR0={R^Rs:#010x}")
[?2004l[?2004h>     
[?2004l[?2004h>     for rnd in range(4):
[?2004l[?2004h>         fval = feal.f_function(R ^ keys[rnd+2])
[?2004l[?2004h>         fval_s = feal.f_function(Rs ^ keys[rnd+2])
[?2004l[?2004h>         print(f"  Round {rnd}: Δf={fval^fval_s:#010x}", end="")
[?2004l[?2004h>         newR = L ^ fval
[?2004l[?2004h>         newL = R
[?2004l[?2004h>         newRs = Ls ^ fval_s
[?2004l[?2004h>         newLs = Rs
[?2004l[?2004h>         L, R = newL, newR
[?2004l[?2004h>         Ls, Rs = newLs, newRs
[?2004l[?2004h>         print(f" ΔL{rnd+1}={L^Ls:#010x} ΔR{rnd+1}={R^Rs:#010x}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Post-mix
[?2004l[?2004h>     L ^= R; Ls ^= Rs
[?2004l[?2004h>     CL = feal.merge(R, L)
[?2004l[?2004h>     CLs = feal.merge(Rs, Ls)
[?2004l[?2004h>     return CL, CLs
[?2004l[?2004h> 
[?2004l[?2004h> random.seed(42)
[?2004l[?2004h> for trial in range(100):
[?2004l[?2004h>     feal.create_random_keys()
[?2004l[?2004h>     keys = list(feal.key)
[?2004l[?2004h>     
[?2004l[?2004h>     PL, PR = random.randint(0, 0xFFFFFFFF), random.randint(0, 0xFFFFFFFF)
[?2004l[?2004h>     delta_PL = 0x02000002
[?2004l[?2004h>     delta_PR = 0x82808082
[?2004l[?2004h>     P = feal.merge(PL, PR)
[?2004l[?2004h>     Ps = feal.merge(PL ^ delta_PL, PR ^ delta_PR)
[?2004l[?2004h>     
[?2004l[?2004h>     C, Cs = trace_both(P, Ps, keys)
[?2004l[?2004h>     CL, CR = feal.getleft(C), feal.getright(C)
[?2004l[?2004h>     CLs, CRs = feal.getleft(Cs), feal.getright(Cs)
[?2004l[?2004h>     dCL = CL ^ CLs
[?2004l[?2004h>     dR3 = (CL^CR) ^ (CLs^CRs)
[?2004l[?2004h>     print(f"Trial {trial}: ΔCL={dCL:#010x} ΔR3={dR3:#010x} key5={keys[5]:#010x}")
[?2004l[?2004h>     
[?2004l[?2004h>     if dR3 != 0x02000002:
[?2004l[?2004h>         print("  *** CHARACTERISTIC FAILED ***")
[?2004l[?2004h>         break
[?2004l[?2004h>     print()
