[?2004l[?2004h> def weighted_codon(aa, dna, random_choice=False):
[?2004l[?2004h>     cds=codons.get(aa, ['GCT'])
[?2004l[?2004h>     # choose codon that keeps recent 47nt + codon within 30-70 GC if possible
[?2004l[?2004h>     best=None; bestscore=-1e9
[?2004l[?2004h>     for c in cds:
[?2004l[?2004h>         test=dna+c
[?2004l[?2004h>         # evaluate window ending at end if possible
[?2004l[?2004h>         if len(test)>=50:
[?2004l[?2004h>             w=test[-50:]
[?2004l[?2004h>             g=sum(b in 'GC' for b in w)/50
[?2004l[?2004h>         else:
