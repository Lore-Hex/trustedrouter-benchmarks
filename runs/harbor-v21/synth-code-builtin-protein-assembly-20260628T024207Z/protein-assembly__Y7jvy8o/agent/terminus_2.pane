[?2004l[?2004h> import urllib.request, urllib.parse, json, re, time, os
[?2004l[?2004h> 
[?2004l[?2004h> def fetch(url, timeout=12, headers=None, max_bytes=None):
[?2004l[?2004h>     h={'User-Agent':'Mozilla/5.0','Accept':'application/json,text/html,*/*'}
