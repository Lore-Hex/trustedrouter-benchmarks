, pid, \'title\', meta[pid].get(\'title\',\'\'), \'mols\', meta[pid].get(\'molecules\',[])[:3], \'chains\', len(fas), \'hdr\', h, \'seqlen\', len(fas[0][\'seq\']) if fas else 0, \'seq\', s)\n    time.sleep(0.05)\n\nopen(\'/app/pdb_cache.json\',\'w\').write(json.dumps(cache,indent=1))\nopen(\'/app/pdb_meta.json\',\'w\').write(json.dumps(meta,indent=1))\nprint(\'Saved /app/pdb_cache.json and /app/pdb_meta.json\')\n\n# FPbase: fetch protein list and basic spectra\nfp=[]\ntry:\n    raw=fetch(\'https://www.fpbase.org/api/4.0/proteins/?format=json\')\n    fp=json.loads(raw)\n    open(\'/app/fpbase_proteins.json\',\'w\').write(json.dumps(fp,indent=1))\n    print(\'FPbase count\', len(fp) if isinstance(fp, list) else \'not-list\')\n    # Print proteins likely matching PDB ids or relevant names\n    for p in (fp if isinstance(fp, list) else []):\n        print(\'FPBASE\', p)\nexcept Exception as e:\n    print(\'FPbase list error\', type(e).__name__, e)\n    # try search endpoint variants\n    for q in [\'505\',\'610\',\'mCherry\',\'mRuby\',\'mNeonGreen\',\'EGFP\',\'sfGFP\',\'TagRFP\',\'mOrange\']:\n        try:\n            raw=fetch(f\'https://www.fpbase.org/api/4.0/proteins/?search={q}&format=json\')\n            d=json.loads(raw)\n            print(\'FPBASE_SEARCH\', q, type(d).__name__, len(d) if isinstance(d,list) else d)\n        except Exception as e2:\n            print(\'FPbase search error\', q, type(e2).__name__, e2)\nPY\npython3 /app/gather_info.py > /tmp/gather_output.txt 2>&1\nsed -n \'1,40p\' /tmp/gather_output.txt\n'] min_timeout_sec: 20.0 max_timeout_sec: 180.0
