Sending keys: ["cat > /app/verify_components.py <<'PY'\nimport urllib.request, urllib.parse, json, re, time, os\n\ndef fetch(url, timeout=12, headers=None, max_bytes=None):\n    h={'User-Agent':'Mozilla/5.0','Accept':'application/json,text/html,*/*'}\n    if headers: h.update(headers)\n    req=urllib.request.Request(url, headers=h)\n    with urllib.request.urlopen(req, timeout=timeout) as r:\n        data=r.read()\n    return data[:max_bytes] if max_bytes else data\n\nprint('=== FPBASE ENDPOINT PROBE ===')\nfor url in [\n 'https://www.fpbase.org/api/',\n 'https://www.fpbase.org/api/3/proteins/',\n 'https://www.fpbase.org/api/3.0/proteins/',\n 'https://www.fpbase.org/api/4.0/proteins/',\n 'https://www.fpbase.org/api/proteins/',\n 'https://fpbase.org/api/3/proteins/',\n 'https://fpbase.org/api/3.0/proteins/',\n 'https://fpbase.org/api/proteins/',\n]:\n    try:\n        d=fetch(url, max_bytes=300)\n        print('OK', url, 'len', len(d), d[:120])\n    except Exception as e:\n        print('ERR', url, type(e).__name__, e)\n\nprint('\\\\n=== FPBASE PROTEIN PAGE PROBE ===')\nfor slug in ['mCherry','TagRFP','TagRFP675','Clover','mNeonGreen','EGFP','sfGFP','mOrange','PSmOrange','mCherry2']:\n    try:\n        html=fetch(f'https://www.fpbase.org/protein/{slug}/', max_bytes=20000).decode('utf-8','replace')\n        # Extract title and some numeric peaks\n        title=re.search(r'<title>(.*?)</title>', html)\n        nums=re.findall(r'\\\\b(4\\d\\d|5\\d\\d|6\\d\\d|7\\d\\d)\\\\s*nm', html)\n        ex=re.findall(r'Excit(?:ation)?[: ]*([0-9.]+)', html, re.I)\n        em=re.findall(r'Emiss(?:ion)?[: ]*([0-9.]+)', html, re.I)\n        print('PAGE', slug, 'title', title.group(1) if title else '', 'nums', nums[:20], 'ex', ex[:5], 'em', em[:5])\n    except Exception as e:\n        print('PAGE', slug, type(e).__name__, e)\n\nprint('\\\\n=== PDB LIGANDS ===')\nids=[x.strip() for x in open('/app/pdb_ids.txt') if x.strip()]\nlig_data={}\nsmiles_target='Nc3nc(OCc1ccccc1)c2nc[nH]c2n3'\nfor pid in ids:\n    for endpoint in [f'https://www.ebi.ac.uk/pdbe/api/pdb/entry/ligands/{pid.lower()}', f'https://www.ebi.ac.uk/pdbe/api/pdb/entry/binding_sites/{pid.lower()}']:\n        try:\n            d=json.loads(fetch(endpoint))\n            txt=json.dumps(d)\n            match=smiles_target.replace(' ','') in txt.replace(' ','')\n            if match or '/BGC/' in txt or 'benzyl' in txt.lower() or 'guanine' in txt.lower():\n                print('INTEREST', pid, endpoint, 'match', match, 'prefix', txt[:500])\n            # Store compact ligand info\n            if 'ligands' in endpoint and d:\n                lig_data[pid]={}\n                for k,v in d.items():\n                    lig_data[pid][k]=v\n        except Exception as e:\n            pass\n    time.sleep(0.02)\nopen('/app/pdb_ligands.json','w').write(json.dumps(lig_data,indent=1))\n\n# Try RCSB chemical search for SMILES\nprint('\\\\n=== RCSB CHEMICAL SEARCH ===')\nfor url in [\n 'https://www.rcsb.org/api/v1/chemical/search?smiles='+urllib.parse.quote(smiles_target)+'&search-type=smiles',\n 'https://www.rcsb.org/api/v1/chemical/search?smiles='+urllib.parse.quote(smiles_target),\n]:\n    try:\n        d=fetch(url, max_bytes=2000)\n        print('OK', url, d[:500])\n    except Exception as e:\n        print('ERR', url, type(e).__name__, e)\n\nprint('\\\\n=== UNIPROT ERBB2 ===')\nfor uid in ['P04626','ERBB2']:\n    try:\n        d=fetch(f'https://rest.uniprot.org/uniprotkb/{uid}.fasta').decode()\n        print('FASTA', uid, 'len', len(d), d[:300])\n        open(f'/app/{uid}.fasta','w').write(d)\n        # Extract canonical sequence\n        seq=''.join(line.strip() for line in d.splitlines() if not line.startswith('>'))\n        print('SEQLEN', len(seq), 'SEQPREFIX', seq[:80])\n    except Exception as e:\n        print('ERR', uid, type(e).__name__, e)\n\n# Also search PDB API for ERBB2 to see available structures/binders\nprint('\\\\n=== RCSB ERBB2 STRUCTURES ===')\ntry:\n    q=urllib.parse.quote('ERBB2')\n    d=json.loads(fetch(f'https://www.rcsb.org/api/v1/structure/search?search_type=protein_sequence&query={q}&return_type=entry', max_bytes=1000))\n    print(json.dumps(d)[:500])\nexcept Exception as e:\n    print('ERR RCSB ERBB2', type(e).__name__, e)\nPY\npython3 /app/verify_components.py > /tmp/verify_output.txt 2>&1\nsed -n '1,60p' /tmp/verify_output.txt\necho '--- tail ---'\ntail -80 /tmp/verify_output.txt\n"] min_timeout_sec: 20.0 max_timeout_sec: 180.0
