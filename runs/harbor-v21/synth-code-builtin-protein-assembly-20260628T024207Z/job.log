Sending keys: ['cat > /app/gather_components.py <<\'PY\'\nimport urllib.request, urllib.parse, json, re, time, ssl, os\n\nctx=ssl.create_default_context()\n\ndef fetch(url, timeout=15, tries=3, max_bytes=None, headers=None):\n    h={\'User-Agent\':\'Mozilla/5.0\',\'Accept\':\'application/json,text/html,*/*\'}\n    if headers: h.update(headers)\n    last=None\n    for i in range(tries):\n        try:\n            req=urllib.request.Request(url, headers=h)\n            with urllib.request.urlopen(req, timeout=timeout, context=ctx) as r:\n                data=r.read()\n            return data[:max_bytes] if max_bytes else data\n        except Exception as e:\n            last=e\n            time.sleep(0.5*(i+1))\n    raise last\n\nprint(\'=== FPBASE FULL ===\')\nraw=fetch(\'https://www.fpbase.org/api/proteins/\', timeout=30, tries=5)\nfp=json.loads(raw)\nopen(\'/app/fpbase_full.json\',\'w\').write(json.dumps(fp,indent=1))\nprint(\'count\', len(fp))\nprint(\'first_keys\', list(fp[0].keys()) if fp else [])\n# Print schema sample\nif fp:\n    for k,v in fp[0].items():\n        print(\'schema\', k, type(v).__name__, repr(v)[:100])\n# Find numeric spectral fields recursively\nspectral_keys=set()\ndef collect_keys(obj, prefix=\'\'):\n    if isinstance(obj, dict):\n        for k,v in obj.items():\n            if re.search(r\'(excitation|emission|ex|em|peak)\', str(k), re.I) and isinstance(v,(int,float,str)):\n                spectral_keys.add(prefix+str(k))\n            collect_keys(v, prefix+str(k)+\'.\')\n    elif isinstance(obj, list):\n        for x in obj[:3]:\n            collect_keys(x, prefix)\nfor p in fp[:50]:\n    collect_keys(p)\nprint(\'spectral_keys_sample\', sorted(spectral_keys)[:50])\n\n# Print candidates that mention 505 or 610 or have likely spectral fields\ncnt=0\nfor p in fp:\n    s=json.dumps(p)\n    if re.search(r\'505|610\', s):\n        print(\'CANDIDATE\', p.get(\'name\'), p.get(\'slug\'), p.get(\'uuid\'), \'len\', len(p.get(\'seq\',\'\')), \'json\', s[:500])\n        cnt+=1\n        if cnt>=30: break\n\n# Try detail endpoints for common proteins and PDB-named candidates\nprint(\'\\\\n=== FPBASE DETAILS ===\')\nslugs=[\'mCherry\',\'mCherry2\',\'mScarlet\',\'mScarlet-I\',\'mRuby3\',\'TagRFP\',\'TagRFP675\',\'Clover\',\'mClover3\',\'mNeonGreen\',\'mGreenLantern\',\'sfGFP\',\'EGFP\',\'mOrange\',\'PSmOrange\',\'mKO\',\'mKO2\',\'mCherry3\',\'mApple\',\'mStrawberry\']\nfor slug in slugs:\n    for url in [f\'https://www.fpbase.org/api/proteins/{slug}/\', f\'https://fpbase.org/api/proteins/{slug}/\']:\n        try:\n            d=json.loads(fetch(url, timeout=8, tries=2, max_bytes=20000))\n            open(f\'/app/fpbase_detail_{slug}.json\',\'w\').write(json.dumps(d,indent=1))\n            print(\'OK\', slug, \'keys\', list(d.keys())[:20])\n            # print compact spectral-looking fields\n            def walk(o, prefix=\'\'):\n                if isinstance(o, dict):\n                    for k,v in o.items():\n                        if re.search(r\'(excitation|emission|ex|em|peak|wavelength)\', str(k), re.I):\n                            print(\'  FIELD\', prefix+str(k), repr(v)[:120])\n                        walk(v, prefix+str(k)+\'.\')\n                elif isinstance(o, list):\n                    for x in o[:5]:\n                        walk(x, prefix)\n            walk(d)\n            break\n        except Exception as e:\n            pass\n    time.sleep(0.05)\n\nprint(\'\\\\n=== PDB LIGANDS/BINDING SITES ===\')\nids=[x.strip() for x in open(\'/app/pdb_ids.txt\') if x.strip()]\nsmiles_target=\'Nc3nc(OCc1ccccc1)c2nc[nH]c2n3\'\nlig_data={}\nsite_data={}\nfor pid in ids:\n    for name,ep in [(\'ligands\',f\'https://www.ebi.ac.uk/pdbe/api/pdb/entry/ligands/{pid.lower()}\'), (\'binding_sites\',f\'https://www.ebi.ac.uk/pdbe/api/pdb/entry/binding_sites/{pid.lower()}\')]:\n        try:\n            d=json.loads(fetch(ep, timeout=10, tries=2))\n            txt=json.dumps(d).replace(\' \',\'\')\n            match=smiles_target.replace(\' \',\'\') in txt\n            low=txt.lower()\n            hints=[]\n            for kw in [\'benzyl\',\'guanine\',\'bg\',\'mtz\',\'methotrexate\',\'folate\',\'folic\',\'amp\',\'ampicillin\',\'ras\',\'cyclophilin\',\'snap\',\'chymotrypsin\',\'polymerase\']:\n                if kw in low:\n                    hints.append(kw)\n            if match or hints:\n                print(\'INTEREST\', pid, name, \'match\', match, \'hints\', hints, \'prefix\', txt[:500])\n            if name==\'ligands\' and d:\n                lig_data[pid]=d\n            elif name==\'binding_sites\' and d:\n                site_data[pid]=d\n        except Exception as e:\n            print(\'ERR\', pid, name, type(e).__name__, str(e)[:80])\n    time.sleep(0.02)\nopen(\'/app/pdb_ligands.json\',\'w\').write(json.dumps(lig_data,indent=1))\nopen(\'/app/pdb_binding_sites.json\',\'w\').write(json.dumps(site_data,indent=1))\n\nprint(\'\\\\n=== RCSB CHEMICAL SEARCH ===\')\nfor url in [\n \'https://www.rcsb.org/api/v1/chemical/search?smiles=\'+urllib.parse.quote(smiles_target),\n \'https://search.rcsb.org/rcsbsearch/v2/query?json=\'+urllib.parse.quote(json.dumps({"query":{"type":"terminal","service":"chemical","parameters":{"value_type":"smiles","value":smiles_target,"match_type":"graph-relaxed-stereochemistry"}},"return_type":"entry"})),\n]:\n    try:\n        d=fetch(url, timeout=12, tries=3, max_bytes=3000).decode(\'utf-8\',\'replace\')\n        print(\'OK\', url, d[:600])\n        open(\'/app/rcsb_smiles_search.txt\',\'w\').write(d)\n    except Exception as e:\n        print(\'ERR\', url, type(e).__name__, str(e)[:200])\n\nprint(\'\\\\n=== UNIPROT HER2 ===\')\ntry:\n    d=fetch(\'https://rest.uniprot.org/uniprotkb/P04626.fasta\', timeout=12, tries=3).decode()\n    open(\'/app/HER2.fasta\',\'w\').write(d)\n    seq=\'\'.join(line.strip() for line in d.splitlines() if not line.startswith(\'>\'))\n    print(\'HER2_SEQLEN\', len(seq), \'PREFIX\', seq[:100])\n    open(\'/app/her2_