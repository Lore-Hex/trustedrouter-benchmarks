Sending keys: ["cat > /app/build_gblock.py <<'PY'\nimport json, re, random, urllib.request, ssl\n\nctx=ssl.create_default_context()\n\ndef fetch_text(url):\n    req=urllib.request.Request(url, headers={'User-Agent':'Mozilla/5.0'})\n    return urllib.request.urlopen(req, timeout=20, context=ctx).read().decode('utf-8','replace')\n\ndef parse_fasta(text):\n    seqs=[]\n    h=None\n    for line in text.splitlines():\n        if line.startswith('>'):\n            h=line[1:]; seqs.append([h,''])\n        elif h is not None:\n            seqs[-1][1]+=line.strip()\n    return seqs\n\ndef rmM(s):\n    return s[1:] if s and s[0]=='M' else s\n\ndef clean_seq(s):\n    return re.sub(r'[^A-Za-z]', '', s)\n\n# Load cached data\nfp=json.load(open('/app/fpbase_full.json'))\nfpmap={p.get('slug'):p for p in fp}\ncache=json.load(open('/app/pdb_cache.json'))\n\n# Fetch live PDB FASTA to satisfy requirement exactly\nclover_pdb=parse_fasta(fetch_text('https://www.rcsb.org/fasta/entry/5WJ2/download'))[0][1]\nmcherry_pdb=parse_fasta(fetch_text('https://www.rcsb.org/fasta/entry/2H5Q/download'))[0][1]\nsnap_pdb=parse_fasta(fetch_text('https://www.rcsb.org/fasta/entry/3KZY/download'))[0][1]\n\n# Use FPbase canonical fluorescent protein sequences for Clover/mCherry, because PDB FASTA includes expression tags for 5WJ2.\nclover_fp=fpmap['clover']['seq']\nmcherry_fp=fpmap['mcherry']['seq']\nprint('Clover FP len', len(clover_fp), 'PDB len', len(clover_pdb), 'PDB prefix', clover_pdb[:30], 'FP prefix', clover_fp[:30])\nprint('mCherry FP len', len(mcherry_fp), 'PDB len', len(mcherry_pdb), 'PDB prefix', mcherry_pdb[:30], 'FP prefix', mcherry_fp[:30])\nprint('FPbase Clover ex/em', fpmap['clover']['states'][0]['ex_max'], fpmap['clover']['states'][0]['em_max'])\nprint('FPbase mCherry ex/em', fpmap['mcherry']['states'][0]['ex_max'], fpmap['mcherry']['states'][0]['em_max'])\n\n# DHFR from plasmid\ndhfr=clean_seq(open('/app/dhfr_protein.txt').read())\nprint('DHFR len', len(dhfr), dhfr[:30])\n\n# HER2 most common variant UniProt P04626\nher2=clean_seq(open('/app/her2_seq.txt').read())\n# Use extracellular domain IV (residues 480-652), contains trastuzumab epitope, compact enough.\nantibody_binder_raw=her2[479:652]\nprint('HER2 domain IV raw len', len(antibody_binder_raw), antibody_binder_raw[:30])\n\n# Remove N-terminal methionine from every subprotein\ncomponents=[\n    ('antibody_binder', rmM(antibody_binder_raw)),\n    ('donor_Clover', rmM(clover_fp)),\n    ('dhfr', rmM(dhfr)),\n    ('acceptor_mCherry', rmM(mcherry_fp)),\n    ('molecule_binder_SNAP', rmM(snap_pdb)),\n]\nprint('COMPONENTS')\nfor name,seq in components:\n    print(name, len(seq), seq[:30], 'startsM?', seq.startswith('M'))\n\ndef gs_linker(n):\n    return ''.join(['G','S'][i%2] for i in range(n))\n\nlinker=gs_linker(10)\nprint('LINKER', linker, len(linker))\n\n# Assemble with linkers only between subproteins\nprotein=components[0][1]\nfor i in range(1,len(components)):\n    protein += linker + components[i][1]\nprint('PROTEIN_LEN', len(protein), 'NT_LEN', len(protein)*3)\n\n# Codon optimization with GC window control\ncodons={\n 'A':['GCT','GCC','GCA','GCG'], 'R':['CGT','CGC','CGA','CGG','AGA','AGG'], 'N':['AAT','AAC'],\n 'D':['GAT','GAC'], 'C':['TGT','TGC'], 'Q':['CAA','CAG'], 'E':['GAA','GAG'], 'G':['GGT','GGC','GGA','GGG'],\n 'H':['CAT','CAC'], 'I':['ATT','ATC','ATA'], 'L':['TTA','TTG','CTT','CTC','CTA','CTG'], 'K':['AAA','AAG'],\n 'M':['ATG'], 'F':['TTT','TTC'], 'P':['CCT','CCC','CCA','CCG'], 'S':['TCT','TCC','TCA','TCG','AGT','AGC'],\n 'T':['ACT','ACC','ACA','ACG'], 'W':['TGG'], 'Y':['TAT','TAC'], 'V':['GTT','GTC','GTA','GTG']\n}\nweights={\n 'A':{'GCT':1.0,'GCC':1.1,'GCA':0.8,'GCG':1.2}, 'R':{'CGT':1.0,'CGC':1.1,'CGA':0.6,'CGG':0.7,'AGA':0.6,'AGG':0.6},\n 'N':{'AAT':1.0,'AAC':1.1}, 'D':{'GAT':1.0,'GAC':1.1}, 'C':{'TGT':1.0,'TGC':1.1}, 'Q':{'CAA':1.0,'CAG':1.1},\n 'E':{'GAA':1.0,'GAG':1.1}, 'G':{'GGT':1.0,'GGC':1.2,'GGA':0.8,'GGG':0.9}, 'H':{'CAT':1.0,'CAC':1.1},\n 'I':{'ATT':1.0,'ATC':1.1,'ATA':0.5}, 'L':{'TTA':0.5,'TTG':0.8,'CTT':1.0,'CTC':1.0,'CTA':0.5,'CTG':1.2},\n 'K':{'AAA':1.0,'AAG':1.1}, 'M':{'ATG':1.0}, 'F':{'TTT':1.0,'TTC':1.0}, 'P':{'CCT':1.0,'CCC':0.9,'CCA':0.9,'CCG':1.2},\n 'S':{'TCT':1.0,'TCC':1.0,'TCA':0.6,'TCG':0.7,'AGT':0.7,'AGC':1.1}, 'T':{'ACT':1.0,'ACC':1.1,'ACA':0.7,'ACG':0.8},\n 'W':{'TGG':1.0}, 'Y':{'TAT':1.0,'TAC':1.0}, 'V':{'GTT':1.0,'GTC':1.0,'GTA':0.6,'GTG':1.1}\n}\n\ndef gc_frac(c): return sum(b in 'GC' for b in c)/3\ndef window_gc_ok(seq):\n    for i in range(0, len(seq)-49):\n        w=seq[i:i+50]\n        g=sum(b in 'GC' for b in w)/50\n        if g<0.30 or g>0.70:\n            return False, i, g\n    return True, -1, 0.0\n\ndef weighted_codon(aa, dna, random_choice=False):\n    cds=codons.get(aa, ['GCT'])\n    # choose codon that keeps recent 47nt + codon within 30-70 GC if possible\n    best=None; bestscore=-1e9\n    for c in cds:\n        test=dna+c\n        # evaluate window ending at end if possible\n        if len(test)>=50:\n            w=test[-50:]\n            g=sum(b in 'GC' for b in w)/50\n        else:\n            g=(sum(b in 'GC' for b in test)/len(test)) if test else 0.5\n        penalty=0\n        if len(dna)+3>=50 and (g<0.30 or g>0.70):\n            penalty=100\n        # Also prefer moderate GC and respect weights\n        wt=weights.get(aa,{}).get(c,1.0)\n        score=wt - penalty - abs(g-0.50)*0.1\n        if random_choice:\n            # small randomization for retries\n            score += random.random()*0.2\n        if score>bestscore:\n            bestscore=score; best=c\n    return best\n\ndef optimize(protein, tries=50):\n    best=None\n    for t in range(tries):\n        dna=''\n        for aa in protein:\n            dna += weighted_codon(aa, dna, random_choice=(t>0))\n        ok,pos,g=window_gc_ok(dna)\n        if ok and len(dna)<=3000:\n            return dna\n        if best is None or (len(dna)<=3000 and not best[0]) or (best[0] and not ok and g closer):\n            best=(ok,dna,pos,g)\n    return best[1]\n\ndna=optimize(protein, tries=100)\nprint('DNA_LEN', len(dna))\nok,pos,g=window_gc_ok(dna)\nprint('GC_OK', ok, 'pos', pos, 'gc', g)\n\n# Validate translation\ngenetic={\n 'TTT':'F','TTC':'F','TTA':'L','TTG':'L','CTT':'L','CTC':'L','CTA':'L','CTG':'L','ATT':'I','ATC':'I','ATA':'I',\n 'ATG':'M','GTT':'V','GTC':'V','GTA':'V','GTG':'V','TCT':'S','TCC':'S','TCA':'S','TCG':'S','AGT':'S','AGC':'S',\n 'CCT':'P','CCC':'P','CCA':'P','CCG':'P','ACT':'T','ACC':'T','ACA':'T','ACG':'T','GCT':'A','GCC':'A','GCA':'A','GCG':'A',\n 'TAT':'Y','TAC':'Y','TAA':'*','TAG':'*','TGA':'*','CAT':'H','CAC':'H','CAA':'Q','CAG':'Q','AAT':'N','AAC':'N',\n 'AAA':'K','AAG':'K','GAT':'D','GAC':'D','GAA':'E','GAG':'E','TGT':'C','TGC':'C','TGG':'W','CGT':'R','CGC':'R',\n 'CGA':'R','CGG':'R','AGA':'R','AGG':'R','GGT':'G','GGC':'G','GGA':'G','GGG':'G'\n}\ntranslation=''.join(genetic.get(dna[i:i+3],'?') for i in range(0,len(dna),3))\nprint('TRANSLATION_MATCH', translation==protein)\nprint('NO_STOP', '*' not in translation)\nprint('NO_START_STOP', not dna.startswith('ATG') and not dna[-3:] in ['TAA','TAG','TGA'])\nprint('NO_TERMINAL_GS', not protein.startswith(linker) and not protein.endswith(linker))\nprint('TOTAL_GC', sum(b in 'GC' for b in dna)/len(dna))\n# Check linkers present between all components\njoined=linker.join([c[1] for c in components])\nprint('PROTEIN_ASSEMBLY_MATCH', protein==joined)\n\n# If valid, write output\nif ok and len(dna)<=3000 and translation==protein and '*' not in translation:\n    open('/app/gblock.txt','w').write(dna)\n    print('WROTE /app/gblock.txt')\nelse:\n    print('FAILED_VALIDATION')\nPY\npython3 /app/build_gblock.py\n"] min_timeout_sec: 1.0 max_timeout_sec: 180.0
